        for _ckpath in "/" "/login" "/admin"; do
            local _hdrs
            _hdrs=$(curl -s $_ins --max-time 6 -D - -o /dev/null \
                "${_sc}://${target}:${_po}${_ckpath}" 2>/dev/null || true)
            _cookies+=$(echo "$_hdrs" | grep -i "^Set-Cookie:" || true)
        done
        [[ -z "$_cookies" ]] && return 0
        echo "$_cookies" > "$_ck_dir/cookies_${_po}.txt"
        while IFS= read -r _ck; do
            [[ -z "$_ck" ]] && continue
            local _cn; _cn=$(echo "$_ck" | grep -oP 'Set-Cookie:\s*\K[^=;]+' | head -1 || true)
            # Flag Secure su HTTPS
            [[ "$_sc" == "https" ]] && ! echo "$_ck" | grep -qi "Secure" && \
                found LOW "Cookie '${_cn}' senza Secure su HTTPS (${_sc}:${_po})"
            # HttpOnly
            ! echo "$_ck" | grep -qi "HttpOnly" && \
                found LOW "Cookie '${_cn}' senza HttpOnly — accessibile via JS (${_sc}:${_po})"
            # SameSite
            ! echo "$_ck" | grep -qi "SameSite" && \
                found LOW "Cookie '${_cn}' senza SameSite — possibile CSRF (${_sc}:${_po})"
            # Valore base64 → decode
            local _cv; _cv=$(echo "$_ck" | grep -oP 'Set-Cookie:\s*[^=]+=\K[^;]+' | head -1 || true)
            if echo "$_cv" | grep -qP '^[A-Za-z0-9+/]{16,}={0,2}$'; then
                local _dec; _dec=$(echo "$_cv" | base64 -d 2>/dev/null || true)
                echo "$_dec" | grep -qP '[\x20-\x7E]{6,}' && \
                    found MEDIUM "Cookie '${_cn}' — valore base64 decodificato: ${_dec:0:80}"
            fi
        done <<< "$_cookies"
    }
    if [[ $DRY_RUN -eq 0 ]]; then
        _svc_found 80   "http.*80\|web.*80"  && { _cookie_analysis http  80;   ran_attack=1; }
