    if [[ $DRY_RUN -eq 0 ]]; then
        _svc_found 80   "http.*80\|web.*80"   && { _web_traversal http  80;   ran_attack=1; }
        _svc_found 443  "https\|ssl.*443"      && { _web_traversal https 443;  ran_attack=1; }
        _svc_found 8080 "http.*8080"           && { _web_traversal http  8080; ran_attack=1; }
