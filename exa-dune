# ============================================================
usage_mdns() {
    echo "Uso: exa-dune mdns <TARGET_NETWORK> [OPTIONS]"
    echo ""
    echo "  Enumera servizi mDNS/Bonjour e dispositivi Zeroconf sulla rete locale."
    echo "  Identifica stampanti, NAS, telecamere IP, Apple TV, smart speakers, ecc."
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE    Interfaccia di rete (default: auto)"
    echo "  --timeout N      Timeout ascolto in secondi (default: 10)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_mdns() {
    local target="" iface="" mdns_timeout=10
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)     iface="$2";         shift 2 ;;
            --timeout)   mdns_timeout="$2";  shift 2 ;;
            --output)    OUTDIR_BASE="$2";   shift 2 ;;
            --stealth)   STEALTH=1;          shift ;;
            --dry-run)   DRY_RUN=1;          shift ;;
            --help|-h)   usage_mdns; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_mdns; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && target="local"
    check_root
    setup_outdir "$target" "mdns"

    log "Target: $target | Output: $OUTDIR"

    # ── mDNS con avahi-browse ─────────────────────────────────
    section "mDNS Service Discovery (avahi-browse)"
    local avahi_out="$OUTDIR/avahi_browse.txt"
    local iface_flag=""
    [[ -n "$iface" ]] && iface_flag="--interface $iface"

    if command -v avahi-browse &>/dev/null; then
        run_cmd "avahi_browse" "avahi-browse --all --resolve --terminate $iface_flag 2>/dev/null | tee $avahi_out"
        if [[ -s "$avahi_out" ]]; then
            # Parse servizi trovati e registra findings
            while IFS= read -r line; do
                local stype shost sip sport
                # Estrai hostname/IP/port dalle righe address/port
                if echo "$line" | grep -q "hostname = \["; then
                    shost=$(echo "$line" | grep -oP "hostname = \[\K[^\]]+")
                fi
                if echo "$line" | grep -q "address = \["; then
                    sip=$(echo "$line" | grep -oP "address = \[\K[^\]]+")
                fi
                if echo "$line" | grep -q "port = \["; then
                    sport=$(echo "$line" | grep -oP "port = \[\K[^\]]+")
                fi
                if echo "$line" | grep -qE "^\+.*_[a-z]+\._tcp|^\+.*_[a-z]+\._udp"; then
                    stype=$(echo "$line" | awk '{print $NF}')
                    found "MEDIUM" "mDNS" "Servizio $stype su $line"
                fi
            done < "$avahi_out"
            ok "avahi-browse completato: $(wc -l < "$avahi_out") righe"
        fi
    else
        warn "avahi-browse non trovato — installa: apt install avahi-utils"
    fi

    # ── nmap mDNS (porta 5353 UDP) ────────────────────────────
    section "nmap mDNS/DNS-SD Scan"
    local nmap_mdns="$OUTDIR/nmap_mdns.txt"
    if [[ "$target" != "local" ]]; then
        run_cmd "nmap_mdns" "nmap -sU -p 5353 --script dns-service-discovery -oN $nmap_mdns $NMAP_TIMING $target 2>/dev/null"
        if [[ -s "$nmap_mdns" ]]; then
            while IFS= read -r line; do
                echo "$line" | grep -qE "^\|.*_[a-z]+\." || continue
                found "MEDIUM" "mDNS" "DNS-SD: $line"
            done < "$nmap_mdns"
        fi
    else
        warn "Usa un IP/CIDR come target per nmap mDNS (es: 192.168.1.0/24)"
    fi

    # ── nmap broadcast-mdns (passive) ────────────────────────
    section "mDNS Broadcast Discovery"
    local bcast_out="$OUTDIR/mdns_broadcast.txt"
    run_cmd "nmap_mdns_bcast" "nmap --script broadcast-dns-service-discovery $NMAP_TIMING 2>/dev/null | tee $bcast_out"
    if [[ -s "$bcast_out" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*_[a-z]+\." || continue
            found "LOW" "mDNS" "Broadcast: $line"
        done < "$bcast_out"
    fi

    ok "mDNS audit completato → $OUTDIR"
}

