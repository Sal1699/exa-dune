    # DNP3 (TCP/UDP 20000) — SCADA/ICS
    if _port_open 20000; then
        log "  ▶ [Fase 2/4] DNP3 :20000"
        if [[ $DRY_RUN -eq 0 ]]; then
            local _dnp3_dir="$OUTDIR_BASE/dnp3"
            mkdir -p "$_dnp3_dir"
            nmap -p 20000 --script dnp3-info \
                -oN "$_dnp3_dir/dnp3_info.txt" "$target" 2>/dev/null || true
            grep -qi "dnp3\|device\|vendor\|firmware" "$_dnp3_dir/dnp3_info.txt" 2>/dev/null && \
                found HIGH "DNP3:20000 — dispositivo SCADA/ICS rilevato"
        else
