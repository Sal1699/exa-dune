    # ── Moduli vendor-specifici (da contesto pre-scan) ───────
    if [[ -n "$detected_vendor" ]]; then
        _run_mod "CVE Scanner ($detected_vendor)" cam-cve "$target" --vendor "$detected_vendor" && ran_enum=1
    fi
    # cam-cve generico se è una camera ma vendor non identificato
    [[ $is_camera -eq 1 && -z "$detected_vendor" ]] && \
        _run_mod "CVE Scanner (camera)" cam-cve "$target" && ran_enum=1
    # cam-cve per VoIP gateway se vendor noto
    [[ $is_voip -eq 1 && -n "$detected_vendor" ]] && \
        _run_mod "CVE Scanner VoIP ($detected_vendor)" cam-cve "$target" --vendor "$detected_vendor" && ran_enum=1

    # ── nmap NSE scripts mirati post-discovery ─────────────────
    log "▶ [Fase 2/4] NSE scripts mirati in base ai servizi trovati..."
    if [[ $DRY_RUN -eq 0 ]]; then
        local _nse_dir="$OUTDIR_BASE/nse_targeted"
        mkdir -p "$_nse_dir"

        # HTTP
        local _http_nse_ports=""
        for _np in $open_tcp; do
            echo " 80 443 8000 8080 8443 " | grep -qw "$_np" && _http_nse_ports="${_http_nse_ports},${_np}"
        done
        _http_nse_ports="${_http_nse_ports#,}"
        if [[ -n "$_http_nse_ports" ]]; then
            log "  NSE HTTP ($_http_nse_ports)"
            nmap -p "$_http_nse_ports" \
                --script http-auth-finder,http-auth,http-default-accounts,\
http-methods,http-headers,http-robots.txt,http-server-header \
                $NMAP_TIMING -oN "$_nse_dir/http_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "valid credentials\|default.*credentials\|admin.*pass" \
                "$_nse_dir/http_nse.nmap" 2>/dev/null && \
                found CRITICAL "NSE — Credenziali HTTP di default trovate"
            grep -qi "TRACE\|^  PUT\|^  DELETE" \
                "$_nse_dir/http_nse.nmap" 2>/dev/null && \
                found HIGH "NSE — Metodi HTTP pericolosi abilitati (TRACE/PUT/DELETE)"
        fi

        # FTP
        _port_open 21 && {
            log "  NSE FTP"
            nmap -p 21 --script ftp-anon,ftp-bounce,ftp-syst \
                $NMAP_TIMING -oN "$_nse_dir/ftp_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "Anonymous.*allowed\|ftp-anon: Anonymous" \
                "$_nse_dir/ftp_nse.nmap" 2>/dev/null && \
                found CRITICAL "NSE — FTP accesso anonimo confermato"
        }

        # SSH
        { _port_open 22 || _port_open 2222 || _port_open 2200; } && {
            local _ssh_nse_p; _ssh_nse_p=$(for _sp in 22 2222 2200; do _port_open "$_sp" && echo "$_sp"; done | tr '\n' ',' | sed 's/,$//')
            log "  NSE SSH ($_ssh_nse_p)"
            nmap -p "$_ssh_nse_p" --script ssh2-enum-algos,ssh-hostkey,ssh-auth-methods \
                $NMAP_TIMING -oN "$_nse_dir/ssh_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "arcfour\|3des-cbc\|diffie-hellman-group1\|diffie-hellman-group14-sha1" \
                "$_nse_dir/ssh_nse.nmap" 2>/dev/null && \
                found MEDIUM "NSE — SSH: algoritmi crittografici deboli/obsoleti"
            grep -qi "password" "$_nse_dir/ssh_nse.nmap" 2>/dev/null && \
                found MEDIUM "NSE — SSH: autenticazione con password abilitata"
        }

        # SMB
        _port_open 445 && {
            log "  NSE SMB"
            nmap -p 445 \
                --script smb-vuln-ms17-010,smb-vuln-ms08-067,smb-security-mode,\
smb-system-info,smb2-security-mode \
                $NMAP_TIMING -oN "$_nse_dir/smb_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "VULNERABLE\|State: VULNERABLE" "$_nse_dir/smb_nse.nmap" 2>/dev/null && \
                found CRITICAL "NSE — SMB vulnerabile (EternalBlue MS17-010 / MS08-067)"
            grep -qi "Message signing enabled but not required" \
                "$_nse_dir/smb_nse.nmap" 2>/dev/null && \
                found MEDIUM "NSE — SMB: signing non obbligatorio (relay attack possibile)"
        }

        # SNMP
        { _port_open 161 || [[ -s "$prescan_dir/snmp_quick.txt" ]]; } && {
            log "  NSE SNMP"
            nmap -sU -p 161 --script snmp-brute,snmp-info,snmp-interfaces \
                $NMAP_TIMING -oN "$_nse_dir/snmp_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "valid credentials\|Account:" "$_nse_dir/snmp_nse.nmap" 2>/dev/null && \
                found HIGH "NSE — SNMP: community string trovata via brute"
        }

        # VNC
        _port_open 5900 && {
            log "  NSE VNC"
            nmap -p 5900 --script vnc-info,realvnc-auth-bypass \
                $NMAP_TIMING -oN "$_nse_dir/vnc_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "Authentication: None\|realvnc-auth-bypass.*Vulnerable" \
                "$_nse_dir/vnc_nse.nmap" 2>/dev/null && \
                found CRITICAL "NSE — VNC accessibile senza autenticazione"
        }

        # RTSP
        { _port_open 554 || _port_open 8554 || _port_open 10554 || _port_open 8899; } && {
            local _rtsp_nse_p; _rtsp_nse_p=$(for _rp in 554 8554 10554 8899; do _port_open "$_rp" && echo "$_rp"; done | tr '\n' ',' | sed 's/,$//')
            log "  NSE RTSP ($_rtsp_nse_p)"
            nmap -p "$_rtsp_nse_p" --script rtsp-url-brute,rtsp-methods \
                $NMAP_TIMING -oN "$_nse_dir/rtsp_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "200 OK\|DESCRIBE" "$_nse_dir/rtsp_nse.nmap" 2>/dev/null && \
                found MEDIUM "NSE — RTSP: stream accessibili rilevati"
        }

        # SIP
        { _port_open 5060 || _port_open 5061; } && {
            log "  NSE SIP"
            nmap -p 5060,5061 --script sip-enum-users,sip-methods \
                $NMAP_TIMING -oN "$_nse_dir/sip_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "200 OK\|user.*found\|extension" "$_nse_dir/sip_nse.nmap" 2>/dev/null && \
                found MEDIUM "NSE — SIP: utenti o estensioni enumerate"
        }

        # RDP
        _port_open 3389 && {
            log "  NSE RDP"
            nmap -p 3389 --script rdp-enum-encryption,rdp-vuln-ms12-020 \
                $NMAP_TIMING -oN "$_nse_dir/rdp_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "VULNERABLE\|encryption.*none\|NLA.*disabled" \
                "$_nse_dir/rdp_nse.nmap" 2>/dev/null && \
                found HIGH "NSE — RDP: cifratura debole o vulnerabilità MS12-020"
        }

        # MQTT
        { _port_open 1883 || _port_open 8883; } && {
            log "  NSE MQTT"
            nmap -p 1883,8883 --script mqtt-subscribe \
                $NMAP_TIMING -oN "$_nse_dir/mqtt_nse.nmap" "$target" 2>/dev/null || true
            grep -qi "CONNACK\|subscribe.*success" "$_nse_dir/mqtt_nse.nmap" 2>/dev/null && \
                found HIGH "NSE — MQTT: broker accessibile senza autenticazione"
        }

        local _nse_total; _nse_total=$(grep -c "VULNERABLE\|CRITICAL\|found\|valid cred" \
            "$_nse_dir"/*.nmap 2>/dev/null | grep -v ':0$' | wc -l || echo 0)
        log "NSE mirati completati — file in: $_nse_dir ($(_ls_count "$_nse_dir" "*.nmap") script)"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} NSE mirati: http/ftp/ssh/smb/snmp/vnc/rtsp/sip/rdp/mqtt scripts su porte trovate"
    fi

    # ── Banner grab su porte non gestite da moduli specifici ──
    # Lista porte coperte dai moduli sopra — tutto il resto è "unknown"
    local _known_ports=" 21 22 23 53 69 80 102 161 162 389 443 445 502 515 554 623 631 636 \
                         1883 1900 1935 2427 2944 3389 3478 4443 4840 5060 5061 5672 5683 5900 \
                         8000 8080 8200 8443 8554 9100 15672 20000 44818 47808 "
    local _unknown_ports=""
    for _p in $open_tcp; do
        echo "$_known_ports" | grep -qw "$_p" || _unknown_ports="$_unknown_ports $_p"
    done

    if [[ -n "${_unknown_ports// /}" ]]; then
        local _unk_dir="$OUTDIR_BASE/unknown_ports"
        [[ $DRY_RUN -eq 0 ]] && mkdir -p "$_unk_dir"
        log "Porte non gestite da moduli: $_unknown_ports — banner grab generico"

        for _p in $_unknown_ports; do
            log "  ▶ Banner grab porta $_p"
            if [[ $DRY_RUN -eq 0 ]]; then
                local _out_file="$_unk_dir/port_${_p}.txt"
                {
                    echo "=== PORT $_p — $(date) ==="

                    # 1. nmap -sV sulla porta specifica
                    echo "--- nmap -sV ---"
                    timeout 20 nmap -sV -p "$_p" --version-intensity 5 \
                        $NMAP_TIMING "$target" 2>/dev/null || true

                    # 2. Banner grab raw con nc (TCP)
                    echo "--- nc banner ---"
                    local _banner
                    _banner=$(echo -e "HEAD / HTTP/1.0\r\n\r\n" | \
                              timeout 5 nc -w 3 "$target" "$_p" 2>/dev/null | \
                              head -20 || true)
                    [[ -n "$_banner" ]] && echo "$_banner" || echo "(nessuna risposta)"

                    # 3. HTTP HEAD — molti device custom espongono HTTP su porte non standard
                    echo "--- HTTP HEAD ---"
                    local _http_resp
                    _http_resp=$(curl -sI --connect-timeout 3 --max-time 5 \
                                     "http://$target:$_p/" 2>/dev/null | head -15 || true)
                    if [[ -n "$_http_resp" ]]; then
                        echo "$_http_resp"
                        local _srv; _srv=$(echo "$_http_resp" | grep -i "^Server:" | head -1 || true)
                        [[ -n "$_srv" ]] && log "    HTTP:$_p → $_srv"
                    else
                        # 4. HTTPS HEAD se HTTP non risponde
                        local _https_resp
                        _https_resp=$(curl -skI --connect-timeout 3 --max-time 5 \
                                          "https://$target:$_p/" 2>/dev/null | head -15 || true)
                        if [[ -n "$_https_resp" ]]; then
                            echo "--- HTTPS HEAD ---"
                            echo "$_https_resp"
                            local _srv; _srv=$(echo "$_https_resp" | grep -i "^Server:" | head -1 || true)
                            [[ -n "$_srv" ]] && log "    HTTPS:$_p → $_srv"
                        fi
                    fi

                } > "$_out_file" 2>&1

                # Registra nel findings se abbiamo trovato qualcosa di utile
                local _svc_line
                _svc_line=$(grep -oP '\d+/tcp\s+open\s+\S+.*' "$_out_file" 2>/dev/null | head -1 || true)
                [[ -n "$_svc_line" ]] && \
                    found MEDIUM "Porta non standard aperta: $_p — $_svc_line" \
                    || found LOW "Porta non standard aperta: $_p (banner non identificato)"

                # CVE lookup via searchsploit sul banner/versione rilevata
                if command -v searchsploit &>/dev/null && [[ -n "$_svc_line" ]]; then
                    # Estrai nome servizio e versione: es. "8080/tcp open http Apache httpd 2.4.41"
                    local _svc_name; _svc_name=$(echo "$_svc_line" | \
                        grep -oP '(?<=open\s)\S+\s+\S+.*' | head -1 | \
                        sed 's/[[:space:]]\{2,\}/ /g' | cut -c1-60 || true)
                    if [[ -n "$_svc_name" ]]; then
                        local _ss_out; _ss_out=$(searchsploit --color=never -q \
                            "$_svc_name" 2>/dev/null | \
                            grep -vP '^\s*(-{5,}|Exploits:|ShellCodes:|No Results|^\s*$)' \
                            | head -5 || true)
                        if [[ -n "$_ss_out" ]]; then
                            found HIGH "Banner CVE — porta $_p ($_svc_name): CVE/exploit trovati"
                            echo "$_ss_out" | while IFS= read -r _ss_l; do
                                found MEDIUM "  searchsploit: $_ss_l"
                            done
                            echo "$_ss_out" >> "$_out_file"
                        fi
                    fi
                fi
            else
                echo -e "${CYAN}[DRY-RUN]${NC} banner grab porta $_p (nmap -sV + nc + curl)"
            fi
            ran_enum=1
        done
    fi

    # ── Fallback intelligente se nessuna porta trovata ───────
    if [[ $ran_enum -eq 0 ]]; then
        warn "Nessuna porta rilevata — fallback basato su pre-scan"
        local ran_fallback=0
        # Usa le porte a cui il pre-scan ha già risposto
        grep -qs "HTTP/.*:80"   "$prescan_dir/http_head.txt" 2>/dev/null && \
            _run_mod "Web HTTP :80 (da HEAD)"   web "$target" --port 80   --scheme http  && ran_fallback=1
        grep -qs "HTTP/.*:8080" "$prescan_dir/http_head.txt" 2>/dev/null && \
            _run_mod "Web HTTP :8080 (da HEAD)" web "$target" --port 8080 --scheme http  && ran_fallback=1
        grep -qs "HTTP/.*:443"  "$prescan_dir/http_head.txt" 2>/dev/null && \
            _run_mod "Web HTTPS :443 (da HEAD)" web "$target" --port 443  --scheme https && ran_fallback=1
        [[ -s "$prescan_dir/snmp_quick.txt" ]] && \
            _run_mod "SNMP (da quick probe)"    snmp "$target" && ran_fallback=1
        [[ $is_camera -eq 1 ]] && _run_mod "RTSP (vendor camera)"  rtsp  "$target" && ran_fallback=1
        [[ $is_camera -eq 1 ]] && _run_mod "ONVIF (vendor camera)" onvif "$target" && ran_fallback=1
        [[ $is_voip -eq 1 ]]   && _run_mod "SIP (vendor VoIP)"     sip   "$target" && ran_fallback=1
        # Se pre-scan non ha dato nulla di specifico → enumerazione minima garantita
        if [[ $ran_fallback -eq 0 ]]; then
            warn "Pre-scan senza dati specifici — enumerazione minima"
            _run_mod "Web HTTP :80" web  "$target" --port 80 --scheme http
            _run_mod "SIP/VoIP"     sip  "$target"
            _run_mod "SNMP"         snmp "$target"
            _run_mod "SSH :22"      ssh  "$target"
        fi
    fi

    # ── Device profile consolidato ───────────────────────────
    log "▶ [Fase 2/4] Generazione device profile..."
    if [[ $DRY_RUN -eq 0 ]]; then
        local _dp_file="$OUTDIR_BASE/device_profile.txt"
        {
            echo "╔══════════════════════════════════════════════════════════════╗"
            echo "║           DEVICE PROFILE — EXA-DUNE                         ║"
            echo "╚══════════════════════════════════════════════════════════════╝"
            echo ""
            echo "Target      : $target"
            echo "Data scan   : $(date)"
            echo "Output dir  : $OUTDIR_BASE"
            echo ""

            # Identità
            echo "── IDENTITÀ ──────────────────────────────────────────────────"
            [[ -n "$dns_hostname" ]] && echo "Hostname DNS : $dns_hostname"
            [[ -n "$detected_vendor" ]] && echo "Vendor       : $detected_vendor"
            [[ $is_camera -eq 1 ]] && echo "Tipo device  : IP Camera / NVR / DVR"
            [[ $is_voip -eq 1 ]]   && echo "Tipo device  : VoIP Gateway / PBX / SIP Phone"
            # MAC e vendor OUI
            if [[ -f "$prescan_dir/mac.txt" ]]; then
                local _pmac _pven
                _pmac=$(grep -oP '(?<=mac=)\S+' "$prescan_dir/mac.txt" 2>/dev/null | head -1 || true)
                _pven=$(grep -oP '(?<=vendor=).+' "$prescan_dir/mac.txt" 2>/dev/null | head -1 || true)
                [[ -n "$_pmac" ]] && echo "MAC          : $_pmac"
                [[ -n "$_pven" ]] && echo "MAC Vendor   : $_pven"
            fi
            # SSL cert CN/O
            if [[ -s "$prescan_dir/ssl_cert.txt" ]]; then
                echo "SSL CN/O     : $(grep -oP '(?<=CN\s=\s|O\s=\s)[^,/]+' \
                    "$prescan_dir/ssl_cert.txt" 2>/dev/null | head -3 | tr '\n' ' ' || true)"
            fi
            echo ""

            # Porte aperte
            echo "── PORTE ─────────────────────────────────────────────────────"
            echo "TCP aperte   :${open_tcp:- (nessuna)}"
            echo "UDP aperte   :${open_udp:- (nessuna)}"
            # Servizi nmap -sV se disponibili
            local _svc_nmap; _svc_nmap=$(find "$OUTDIR_BASE" -name "*.nmap" 2>/dev/null | \
                xargs grep -hE "^[0-9]+/tcp\s+open" 2>/dev/null | sort -u | head -20 || true)
            if [[ -n "$_svc_nmap" ]]; then
                echo ""
                echo "Servizi rilevati:"
                echo "$_svc_nmap" | while IFS= read -r _sl; do echo "  $_sl"; done
            fi
            echo ""

            # SNMP
            echo "── SNMP ──────────────────────────────────────────────────────"
            if [[ -s "$prescan_dir/snmp_quick.txt" ]]; then
                cat "$prescan_dir/snmp_quick.txt"
            else
                echo "(nessuna community risponde)"
            fi
            echo ""

            # Findings summary — conta per severità
            echo "── FINDINGS ──────────────────────────────────────────────────"
            local _all_f; _all_f=$(find "$OUTDIR_BASE" -name "findings.txt" \
                -exec cat {} \; 2>/dev/null | sort -u || true)
            local _n_crit _n_high _n_med _n_low
            _n_crit=$(echo "$_all_f" | grep -c "\[CRITICAL\]" 2>/dev/null || echo 0)
            _n_high=$(echo "$_all_f" | grep -c "\[HIGH\]"     2>/dev/null || echo 0)
            _n_med=$( echo "$_all_f" | grep -c "\[MEDIUM\]"   2>/dev/null || echo 0)
            _n_low=$( echo "$_all_f" | grep -c "\[LOW\]"      2>/dev/null || echo 0)
            echo "CRITICAL : $_n_crit"
            echo "HIGH     : $_n_high"
            echo "MEDIUM   : $_n_med"
            echo "LOW      : $_n_low"
            echo ""
            echo "Top findings (CRITICAL/HIGH):"
            echo "$_all_f" | grep -E "\[CRITICAL\]|\[HIGH\]" | head -20 | \
                while IFS= read -r _fl; do echo "  $_fl"; done || echo "  (nessuno)"
            echo ""

            # Credenziali trovate
            local _creds_file="$OUTDIR_BASE/.exa_creds.json"
            if [[ -s "$_creds_file" ]]; then
