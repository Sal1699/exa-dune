                          echo "set ConnectTimeout 8"
                          echo "check"
                          echo "back"
                      done <<< "$_found_mods"
                      echo "exit"; } > "$_msf_check_rc"
                    timeout 180 msfconsole -q -r "$_msf_check_rc" > /dev/null 2>&1 || true
