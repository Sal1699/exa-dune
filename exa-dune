usage_camcve() {
    echo "Uso: exa-dune cam-cve <TARGET> [OPTIONS]"
    echo ""
    echo "  Camera CVE Scanner — verifica vulnerabilità note su telecamere IP e device VoIP."
    echo "  Supporta: Hikvision, Dahua, Axis, Reolink, Uniview, Foscam, AudioCodes, Commend."
    echo ""
    echo "Opzioni:"
    echo "  --vendor VENDOR  hikvision|dahua|axis|reolink|audiocodes|commend|generic (default: auto)"
    echo "  --port PORT      HTTP port (default: 80)"
    echo "  --ssl            Usa HTTPS (443)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_camcve() {
    local target="" vendor="auto" port=80 use_ssl=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --vendor)    _req_arg "$1" "${2:-}"; vendor="$2";       shift 2 ;;
            --port)      _req_arg "$1" "${2:-}"; port="$2";         shift 2 ;;
            --ssl)       use_ssl=1;         shift ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_camcve; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_camcve; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_camcve; exit 1; }
    check_root
    setup_outdir "$target" "cam_cve"
    local scheme="http"; [[ $use_ssl -eq 1 ]] && { scheme="https"; port=443; }
    local base_url="${scheme}://${target}:${port}"
    local curl_opts="-s --max-time 8 -k"
    log "Target: $base_url | Vendor: $vendor | Output: $OUTDIR"

    # ── Auto-detect vendor da header/banner ──────────────────
    section "Camera Vendor Detection"
    local detect_out="$OUTDIR/cam_detect.txt"
    if [[ $DRY_RUN -eq 0 ]]; then
        local headers; headers=$(curl $curl_opts -I "$base_url/" 2>/dev/null || true)
        echo "$headers" > "$detect_out"
        if [[ "$vendor" == "auto" ]]; then
            echo "$headers" | grep -qi "hikvision\|dvr\|ipc\|hik" && vendor="hikvision"
            echo "$headers" | grep -qi "dahua\|dh-" && vendor="dahua"
            echo "$headers" | grep -qi "axis\|vapix" && vendor="axis"
            echo "$headers" | grep -qi "reolink" && vendor="reolink"
            echo "$headers" | grep -qi "uniview\|univideo" && vendor="uniview"
            echo "$headers" | grep -qi "audiocodes\|mp20\|mediant\|audiocos" && vendor="audiocodes"
            echo "$headers" | grep -qi "commend\|et962\|commander" && vendor="commend"
            # Se headers non bastano, controlla il body della homepage (es. Reolink mette brand solo nel <title>)
            if [[ "$vendor" == "auto" ]]; then
                local body_snip; body_snip=$(curl $curl_opts -m 6 "$base_url/" 2>/dev/null | head -c 4096 || true)
                echo "$body_snip" >> "$detect_out"
                echo "$body_snip" | grep -qi "hikvision\|DVR\|IPC.*hik" && vendor="hikvision"
                echo "$body_snip" | grep -qi "dahua" && vendor="dahua"
                echo "$body_snip" | grep -qi "axis\|vapix" && vendor="axis"
                echo "$body_snip" | grep -qi "reolink" && vendor="reolink"
                echo "$body_snip" | grep -qi "uniview\|univideo" && vendor="uniview"
                echo "$body_snip" | grep -qi "audiocodes\|mp20\|mediant" && vendor="audiocodes"
                echo "$body_snip" | grep -qi "commend\|et962" && vendor="commend"
            fi
            # Prova anche SNMP sysDescr per VoIP device
            if [[ "$vendor" == "auto" ]] && command -v snmpwalk &>/dev/null; then
                local snmp_desc; snmp_desc=$(snmpwalk -v2c -c public "$target" 1.3.6.1.2.1.1.1.0 2>/dev/null | head -1 || true)
                echo "$snmp_desc" | grep -qi "audiocodes\|mp20\|mediant" && vendor="audiocodes"
                echo "$snmp_desc" | grep -qi "commend\|et962" && vendor="commend"
            fi
            [[ "$vendor" == "auto" ]] && vendor="generic"
            ok "Vendor rilevato: $vendor"
        fi
    fi

    # ── CVE checks per vendor ─────────────────────────────────
    section "CVE Checks — $vendor"
    local cve_out="$OUTDIR/cam_cve_results.txt"

    _cam_check() {
        local cve="$1" desc="$2" url="$3" pattern="$4" severity="${5:-HIGH}"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} $cve — $desc — GET $url"
            return
        fi
        local resp; resp=$(curl $curl_opts "$url" 2>/dev/null || true)
        if [[ -n "$pattern" ]]; then
            if echo "$resp" | grep -qi "$pattern"; then
                found "$severity" "CAM-CVE" "$cve VULNERABLE: $desc ($url)"
                echo "[VULN] $cve $desc" | tee -a "$cve_out"
                echo "$resp" | head -5 >> "$cve_out"
            else
                echo "[SAFE] $cve $desc" >> "$cve_out"
                log "  $cve: non vulnerabile"
            fi
        else
            # Scarica body + codice in unica richiesta per evitare false positives
            local _raw _body _code
            _raw=$(curl $curl_opts -w "\n##HTTP_CODE##%{http_code}" "$url" 2>/dev/null || echo -e "\n##HTTP_CODE##000")
            _code=$(echo "$_raw" | grep -oP '(?<=##HTTP_CODE##)\d+$' || echo 000)
            _body=$(echo "$_raw" | sed '/##HTTP_CODE##/d')
            if [[ "$_code" == "200" ]] && ! echo "$_body" | grep -qi \
                "login first\|please login\|unauthorized\|password wrong\|access denied\|not authorized\|forbidden\|401\|authentication required"; then
                found "$severity" "CAM-CVE" "$cve POSSIBILMENTE VULNERABILE ($_code): $desc"
                echo "[WARN] $cve $_code $desc" | tee -a "$cve_out"
            else
                echo "[SAFE] $cve HTTP $_code $desc" >> "$cve_out"
            fi
        fi
    }

    case "$vendor" in
        hikvision)
            # CVE-2021-36260: Command injection via /SDK/webLanguage (unauthenticated)
            _cam_check "CVE-2021-36260" "Hikvision unauthenticated RCE via webLanguage" \
                "$base_url/SDK/webLanguage" "root\|passwd\|/bin" "CRITICAL"
            # CVE-2017-7921: Unauthenticated snapshot bypass
            _cam_check "CVE-2017-7921" "Hikvision unauthenticated snapshot bypass" \
                "$base_url/onvif-http/snapshot?auth=YWRtaW46MTEM" "JFIF\|Content-Type.*image" "HIGH"
            # CVE-2014-4880: Default credentials page exposure
            _cam_check "CVE-2014-4880" "Hikvision default credentials login page" \
                "$base_url/ISAPI/Security/userCheck" "statusValue\|userCheckResult\|<statusString>" "MEDIUM"
            # Information disclosure: device info without auth
            _cam_check "INFO-DISC" "Hikvision device info unauthenticated" \
