    log "Target: $target:$port/udp | Output: $OUTDIR"

    section "Nmap CoAP"
    run_cmd "nmap_coap" \
        "nmap -sU -p $port --script coap-resources \
         -oN \"$OUTDIR\"/nmap_coap.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_coap.txt" ]]; then
        grep -v "^#\|^$\|Nmap " "$OUTDIR/nmap_coap.txt" 2>/dev/null | head -20 \
            | tee "$OUTDIR/coap_nmap_summary.txt" || true
        grep -iE "open|resource" "$OUTDIR/nmap_coap.txt" 2>/dev/null && \
            found MEDIUM "CoAP:$port — servizio CoAP raggiungibile" || true
    fi

    section "CoAP Service Discovery (coap-client)"
    local coap_bin=""
    tool_ok coap-client   && coap_bin="coap-client"
    tool_ok coap-client-3 && coap_bin="coap-client-3"

    if [[ -n "$coap_bin" ]]; then
        # .well-known/core — resource discovery
        run_cmd "coap_discovery" \
            "$coap_bin -m get coap://$target:$port/.well-known/core 2>&1 \
             | tee \"$OUTDIR\"/coap_discovery.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/coap_discovery.txt" ]]; then
