_apply_retention() {
    # _apply_retention <target_dir>
    # Mantiene solo le ultime KEEP_RUNS run nella cartella per-target.
    local tdir="$1"
    local keep="${KEEP_RUNS:-5}"
    [[ "$keep" -le 0 ]] && return 0
    # Elenco dir timestamp ordinate dalla più vecchia alla più recente
    local dirs
    mapfile -t dirs < <(
        find "$tdir" -maxdepth 1 -mindepth 1 -type d -name '[0-9]*_[0-9]*' \
        | sort
    )
    local total="${#dirs[@]}"
    if (( total > keep )); then
        local to_delete=$(( total - keep ))
        for (( i=0; i<to_delete; i++ )); do
            rm -rf "${dirs[$i]}" 2>/dev/null && \
                log "Retention: rimossa run vecchia ${dirs[$i]}" || true
        done
    fi
}

