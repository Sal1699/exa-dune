usage_onvif() {
    echo "Uso: exa-dune onvif <TARGET> [OPTIONS]"
    echo ""
    echo "  ONVIF/gSOAP audit per telecamere IP e dispositivi IoT"
    echo "  Usa SOAP via curl — nessuna dipendenza extra richiesta"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta ONVIF (default: 8000, prova anche 8080, 80)"
    echo "  --userlist FILE    Lista utenti"
    echo "  --passlist FILE    Lista password"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_onvif() {
    local target="" port=8000
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)     _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --userlist) _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2"; shift 2 ;;
            --passlist) _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2"; shift 2 ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1;        shift ;;
            --help|-h)  usage_onvif; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_onvif; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_onvif; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "onvif"
    log "Target: $target | Porta ONVIF: $port | Output: $OUTDIR"

    local ul; ul=$(_wl_rtsp_users)
    local pl; pl=$(_wl_rtsp_pass)

    # Envelope SOAP generico per probe anonimo
    local soap_getinfo='<?xml version="1.0" encoding="UTF-8"?>
<s:Envelope xmlns:s="http://www.w3.org/2003/05/soap-envelope">
  <s:Body>
    <tds:GetDeviceInformation xmlns:tds="http://www.onvif.org/ver10/device/wsdl"/>
  </s:Body>
</s:Envelope>'

    local soap_getcaps='<?xml version="1.0" encoding="UTF-8"?>
<s:Envelope xmlns:s="http://www.w3.org/2003/05/soap-envelope">
  <s:Body>
    <tds:GetCapabilities xmlns:tds="http://www.onvif.org/ver10/device/wsdl">
      <tds:Category>All</tds:Category>
    </tds:GetCapabilities>
  </s:Body>
</s:Envelope>'

    local soap_getprofiles='<?xml version="1.0" encoding="UTF-8"?>
<s:Envelope xmlns:s="http://www.w3.org/2003/05/soap-envelope">
  <s:Body>
    <trt:GetProfiles xmlns:trt="http://www.onvif.org/ver10/media/wsdl"/>
  </s:Body>
</s:Envelope>'

    # Genera un SOAP envelope con WS-UsernameToken (digest)
    _onvif_auth_envelope() {
        local user="$1" pass="$2" soap_body="$3"
        ONVIF_USER="$user" ONVIF_PASS="$pass" ONVIF_SOAP_BODY="$soap_body" python3 - <<'PYEOF' 2>/dev/null
import hashlib, base64, datetime, os, random, string

user = os.environ['ONVIF_USER']
pwd  = os.environ['ONVIF_PASS']
soap_body = os.environ['ONVIF_SOAP_BODY']
# Nonce casuale
nonce_raw = ''.join(random.choices(string.ascii_letters + string.digits, k=16)).encode()
nonce_b64  = base64.b64encode(nonce_raw).decode()
created    = datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')
# WS-Security password digest = Base64(SHA1(nonce + created + password))
digest = base64.b64encode(
    hashlib.sha1(nonce_raw + created.encode() + pwd.encode()).digest()
).decode()

print(f'''<?xml version="1.0" encoding="UTF-8"?>
<s:Envelope xmlns:s="http://www.w3.org/2003/05/soap-envelope"
            xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"
            xmlns:wsu="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-utility-1.0.xsd">
  <s:Header>
    <wsse:Security>
      <wsse:UsernameToken>
        <wsse:Username>{user}</wsse:Username>
        <wsse:Password Type="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordDigest">{digest}</wsse:Password>
        <wsse:Nonce EncodingType="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-soap-message-security-1.0#Base64Binary">{nonce_b64}</wsse:Nonce>
        <wsu:Created>{created}</wsu:Created>
      </wsse:UsernameToken>
    </wsse:Security>
  </s:Header>
  <s:Body>
    {soap_body}
  </s:Body>
</s:Envelope>''')
PYEOF
    }

    _onvif_soap() {
        local onvif_url="$1" soap_env="$2" out_label="$3"
        local resp
        resp=$(curl -sk ${CURL_TIMEOUT:-10} -X POST "$onvif_url" \
               -H 'Content-Type: application/soap+xml; charset=utf-8' \
               -H 'SOAPAction: ""' \
               --data-binary "$soap_env" 2>/dev/null || true)
        echo "$resp" > "$OUTDIR/${out_label}.xml"
        echo "$resp"
    }

    for p in "$port" 8080 80; do
        check_port "$target" "$p" || continue
        local onvif_url="http://${target}:${p}/onvif/device_service"
        log "Tentativo ONVIF: $onvif_url"

        section "ONVIF GetDeviceInformation (anonimo)"
        if [[ $DRY_RUN -eq 0 ]]; then
            local info_resp
            info_resp=$(_onvif_soap "$onvif_url" "$soap_getinfo" "onvif_deviceinfo_anon")
            if echo "$info_resp" | grep -qi "Manufacturer\|Model\|FirmwareVersion\|SerialNumber"; then
                found HIGH "ONVIF:$p — GetDeviceInformation senza auth!"
                echo "$info_resp" | grep -oP '<[^>]+>[^<]{1,80}<\/[^>]+>' | grep -iE "Manufacturer|Model|Firmware|Serial|HardwareId" | \
                    while IFS= read -r line; do log "  $line"; done || true
            elif echo "$info_resp" | grep -qi "NotAuthorized\|Sender not Authorized\|Fault"; then
                log "  Auth richiesta — avvio brute force WS-Security"

                section "ONVIF WS-Security Brute Force"
                local body_getinfo='<tds:GetDeviceInformation xmlns:tds="http://www.onvif.org/ver10/device/wsdl"/>'
                local found_cred=""
                while IFS= read -r onvif_user; do
                    [[ -z "$onvif_user" ]] && continue
                    while IFS= read -r onvif_pass; do
                        [[ -z "$onvif_pass" ]] && continue
                        local auth_env
                        auth_env=$(_onvif_auth_envelope "$onvif_user" "$onvif_pass" "$body_getinfo")
                        [[ -z "$auth_env" ]] && continue
                        local auth_resp
                        auth_resp=$(_onvif_soap "$onvif_url" "$auth_env" "onvif_auth_test" 2>/dev/null)
                        if echo "$auth_resp" | grep -qi "Manufacturer\|Model\|GetDeviceInformationResponse"; then
                            found CRITICAL "ONVIF:$p — credenziale valida: ${onvif_user}:${onvif_pass}"
                            echo "${onvif_user}:${onvif_pass}" > "$OUTDIR/onvif_creds.txt"
                            found_cred="${onvif_user}:${onvif_pass}"
                            break 2
                        fi
                    done < "$pl"
                done < "$ul"

                if [[ -n "$found_cred" ]]; then
                    local fc_user="${found_cred%%:*}" fc_pass="${found_cred#*:}"
                    section "ONVIF GetCapabilities + GetProfiles"
                    local body_caps='<tds:GetCapabilities xmlns:tds="http://www.onvif.org/ver10/device/wsdl"><tds:Category>All</tds:Category></tds:GetCapabilities>'
                    local caps_env; caps_env=$(_onvif_auth_envelope "$fc_user" "$fc_pass" "$body_caps")
                    _onvif_soap "$onvif_url" "$caps_env" "onvif_caps" > /dev/null
                    local body_prof='<trt:GetProfiles xmlns:trt="http://www.onvif.org/ver10/media/wsdl"/>'
                    local prof_env; prof_env=$(_onvif_auth_envelope "$fc_user" "$fc_pass" "$body_prof")
                    local prof_resp; prof_resp=$(_onvif_soap "${onvif_url/device_service/media_service}" "$prof_env" "onvif_profiles")
                    # Estrai StreamUri
                    local body_stream='<trt:GetStreamUri xmlns:trt="http://www.onvif.org/ver10/media/wsdl"><trt:StreamSetup><tt:Stream xmlns:tt="http://www.onvif.org/ver10/schema">RTP-Unicast</tt:Stream><tt:Transport xmlns:tt="http://www.onvif.org/ver10/schema"><tt:Protocol>RTSP</tt:Protocol></tt:Transport></trt:StreamSetup><trt:ProfileToken>Profile_1</trt:ProfileToken></trt:GetStreamUri>'
                    local stream_env; stream_env=$(_onvif_auth_envelope "$fc_user" "$fc_pass" "$body_stream")
                    local stream_resp; stream_resp=$(_onvif_soap "${onvif_url/device_service/media_service}" "$stream_env" "onvif_stream")
                    local rtsp_uri; rtsp_uri=$(echo "$stream_resp" | grep -oP 'rtsp://[^<"]+' | head -1 || true)
                    [[ -n "$rtsp_uri" ]] && found HIGH "ONVIF:$p — RTSP stream URI: $rtsp_uri"
                fi
            else
                log "  Risposta ONVIF non riconosciuta (porta $p potrebbe non essere ONVIF)"
                echo "$info_resp" | head -5 >> "$OUTDIR/onvif_raw_${p}.txt"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} ONVIF SOAP GetDeviceInformation → $onvif_url"
            echo -e "${CYAN}[DRY-RUN]${NC} ONVIF WS-Security brute force con $ul / $pl"
        fi
        break  # Usa solo il primo porto raggiungibile
    done

    local onvif_script="$EXA_SCRIPTS_DIR/python/onvif_brute.py"
    if [[ -f "$onvif_script" ]]; then
        section "ONVIF Default Credentials (onvif_brute.py)"
        run_cmd "onvif_brute" "python3 \"$onvif_script\" $target --port $port 2>&1 | tee \"$OUTDIR\"/onvif_brute.txt"
    fi

    ok "ONVIF audit completato → $OUTDIR"
}

# ============================================================
#  FUNZIONALITÀ 1 — exa-dune update
# ============================================================
usage_update() {
    echo "Uso: exa-dune update [OPTIONS]"
    echo ""
    echo "  Aggiorna exa-dune all'ultima versione."
    echo "  Se è presente un repo git locale esegue 'git pull' (rileva remote/branch automaticamente)."
    echo "  Altrimenti scarica direttamente da GitHub (https://raw.githubusercontent.com/Sal1699/exa-dune/main/exa-dune)."
    echo "  Verifica che il file scaricato sia un bash script valido prima di installarlo."
    echo ""
    echo "Opzioni:"
    echo "  --force, -f    Reinstalla anche se la versione è già aggiornata"
    echo "  --dry-run      Mostra cosa verrebbe fatto senza eseguire"
}

cmd_update() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)   DRY_RUN=1; shift ;;
            --force|-f)  force=1;   shift ;;
            --help|-h)   usage_update; exit 0 ;;
            *) err "Opzione sconosciuta: $1"; usage_update; exit 1 ;;
        esac
    done

    banner
    section "Update exa-dune"

    local version_before="$VERSION"
    log "Versione corrente: $version_before"

    local RAW_URL="https://raw.githubusercontent.com/Sal1699/exa-dune/main/exa-dune"
    local INSTALL_PATH="/usr/local/bin/exa-dune"
    local TMP_FILE="/tmp/exa-dune-update-$$"

    # ── Cerca un repo git locale ──────────────────────────────────────────
    local script_dir; script_dir=$(dirname "$SCRIPT_PATH")
    local repo_dir=""
    local search_dir="$script_dir"
    for _ in 1 2 3 4 5; do
        if [[ -d "$search_dir/.git" ]]; then
            repo_dir="$search_dir"
            break
        fi
        search_dir=$(dirname "$search_dir")
        [[ "$search_dir" == "/" ]] && break
    done

    if [[ -n "$repo_dir" ]]; then
        log "Repository git trovato: $repo_dir"

        if [[ "$DRY_RUN" -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} git -C $repo_dir fetch && git pull"
            echo -e "${CYAN}[DRY-RUN]${NC} cp $repo_dir/exa-dune $INSTALL_PATH && chmod +x $INSTALL_PATH"
            return 0
        fi

        # Determina remote e branch correnti (non hardcodare origin/main)
        local git_remote git_branch
        git_remote=$(git -C "$repo_dir" remote 2>/dev/null | head -1)
        git_branch=$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
        [[ -z "$git_remote" ]] && git_remote="origin"
        log "Remote: $git_remote  Branch: $git_branch"

        # Fetch + check se ci sono aggiornamenti
        git -C "$repo_dir" fetch "$git_remote" "$git_branch" 2>&1 | while IFS= read -r l; do log "$l"; done || true

        local local_hash remote_hash
        local_hash=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null || echo "")
        remote_hash=$(git -C "$repo_dir" rev-parse "${git_remote}/${git_branch}" 2>/dev/null || echo "")

        if [[ "$local_hash" == "$remote_hash" && $force -eq 0 ]]; then
            ok "exa-dune è già all'ultima versione ($version_before) — usa --force per reinstallare"
            return 0
        fi

        local git_output
        git_output=$(git -C "$repo_dir" pull "$git_remote" "$git_branch" 2>&1) || {
            err "git pull fallito: $git_output"
            warn "Tentativo fallback con download diretto..."
            # Fallback a download diretto
            git_remote=""
            repo_dir=""
        }
        [[ -n "$repo_dir" ]] && log "$git_output"
    fi

    # ── Download diretto da GitHub (usato se no repo o pull fallito) ──────
    if [[ -z "$repo_dir" ]]; then
        log "Download diretto da GitHub: $RAW_URL"

        if [[ "$DRY_RUN" -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} curl -fsSL $RAW_URL -o $INSTALL_PATH && chmod +x $INSTALL_PATH"
            return 0
        fi

        curl -fsSL --retry 3 --retry-delay 2 "$RAW_URL" -o "$TMP_FILE" || {
            err "Download fallito da: $RAW_URL"
            rm -f "$TMP_FILE"
            exit 1
        }

        # Verifica che il file scaricato sia uno script bash valido
        if ! head -1 "$TMP_FILE" | grep -q "^#!.*bash"; then
            err "File scaricato non valido (non è uno script bash) — aggiornamento annullato"
            rm -f "$TMP_FILE"
            exit 1
        fi

        local version_after
        version_after=$(grep -m1 '^VERSION=' "$TMP_FILE" | cut -d'"' -f2 || echo "sconosciuta")

        if [[ "$version_after" == "$version_before" && $force -eq 0 ]]; then
            ok "exa-dune è già all'ultima versione ($version_before) — usa --force per reinstallare"
            rm -f "$TMP_FILE"
            return 0
        fi

        cp "$TMP_FILE" "$INSTALL_PATH"
        chmod +x "$INSTALL_PATH"
        rm -f "$TMP_FILE"
        ok "Aggiornamento completato: $version_before → $version_after"
        ok "Script installato in: $INSTALL_PATH"
        return 0
    fi

    # ── Copia da repo git aggiornato ──────────────────────────────────────
    local updated_script=""
    if [[ -f "$repo_dir/exa-dune" ]]; then
        updated_script="$repo_dir/exa-dune"
    else
        updated_script=$(find "$repo_dir" -maxdepth 2 -name "exa-dune" -not -path "*/.git/*" 2>/dev/null | head -1)
    fi

    if [[ -z "$updated_script" ]]; then
        err "File exa-dune non trovato nel repo dopo il pull"
        exit 1
    fi

    local version_after
    version_after=$(grep -m1 '^VERSION=' "$updated_script" | cut -d'"' -f2 || echo "sconosciuta")
    cp "$updated_script" "$INSTALL_PATH"
    chmod +x "$INSTALL_PATH"
    ok "Aggiornamento completato: $version_before → $version_after"
    ok "Script installato in: $INSTALL_PATH"

    if [[ -d "$repo_dir/scripts" ]]; then
        log "Aggiornamento script ausiliari..."
        _install_scripts
    fi
}

