cmd_opcua() {
    local target="" port=4840
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_opcua; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_opcua; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_opcua; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "opcua"
    log "Target: $target:$port | Output: $OUTDIR"

    section "OPC-UA — nmap scan :$port"
    run_cmd "nmap_opcua" \
        "nmap -p $port -sV --script opcua-info \
         -oN \"$OUTDIR/nmap_opcua.nmap\" $target 2>/dev/null"
    if [[ $DRY_RUN -eq 0 ]]; then
        if grep -qi "opc\|opc.ua\|open" "$OUTDIR/nmap_opcua.nmap" 2>/dev/null; then
            found MEDIUM "OPC-UA:$port — server identificato via nmap"
        fi
    fi

    section "OPC-UA — Banner probe :$port"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" "$port"; then
            # OPC-UA TCP transport: HEL message
            local _hel_msg
            _hel_msg=$(printf 'HEL\x00\x00\x00\x00\x00\xf0\x00\x00\x00\xf0\x00\x00\x00\xf0\x00\x00\x00\x00\x00\x00\x00' | \
                timeout 6 nc -w 5 "$target" "$port" 2>/dev/null | xxd | head -5 || true)
            echo "$_hel_msg" > "$OUTDIR/opcua_banner.txt"
            if [[ -n "$_hel_msg" ]]; then
                found HIGH "OPC-UA:$port — server risponde al HEL message"
                # Controlla se risponde con ACK (0x41 43 4b = "ACK")
                echo "$_hel_msg" | grep -qi "ACK\|4143 4b" && \
                    found CRITICAL "OPC-UA:$port — handshake riuscito (anonymous access possibile)"
            fi
        else
            warn "Porta $port chiusa — OPC-UA non raggiungibile"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} OPC-UA HEL message probe su $target:$port"
    fi

    section "OPC-UA — Python opcua client (se disponibile)"
    if [[ $DRY_RUN -eq 0 ]]; then
        if python3 -c "import opcua" 2>/dev/null; then
            EXA_OPCUA_TARGET="opc.tcp://${target}:${port}" python3 - <<'PYEOF' 2>/dev/null \
                > "$OUTDIR/opcua_nodes.txt" || true
import os, sys
try:
    from opcua import Client
    url = os.environ.get('EXA_OPCUA_TARGET', 'opc.tcp://localhost:4840')
    c = Client(url)
    c.connect()
    root = c.get_root_node()
    print(f"Connected: {url}")
    print(f"Root node: {root}")
    children = root.get_children()
    for ch in children[:20]:
        print(f"  {ch}")
    c.disconnect()
    print("Anonymous access: SUCCESS")
except Exception as e:
    print(f"Connection failed: {e}")
PYEOF
            grep -qi "Anonymous access: SUCCESS" "$OUTDIR/opcua_nodes.txt" 2>/dev/null && \
                found CRITICAL "OPC-UA:$port — accesso anonymous riuscito (opcua python client)"
        else
            log "python3-opcua non disponibile — installa: pip3 install opcua"
        fi
    fi

    ok "OPC-UA audit completato → $OUTDIR"
}

