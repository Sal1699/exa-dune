_cleanup_sigint()   {
    warn "Interrotto (SIGINT). Cleanup..."
    [[ -n "$_log_file" ]] && echo "[SIGINT] $(date)" >> "$_log_file" 2>/dev/null || true
    _cleanup_tmpfiles
    if [[ -n "$_ACTIVE_TMUX_SESSION" ]]; then
        warn "Sessione tmux attiva: $_ACTIVE_TMUX_SESSION — usa 'tmux attach -t $_ACTIVE_TMUX_SESSION' per riprendere"
