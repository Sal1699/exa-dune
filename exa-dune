            printf "  %-10s %s\n" "onvif"   "ONVIF/gSOAP IP camera audit (curl SOAP, WS-Security brute)"
            printf "  %-10s %s\n" "js"      "JavaScript analysis        (endpoint/secret extraction)"
            printf "  %-10s %s\n" "dns"     "DNS enumeration            (dig, dnsrecon, host, nmap)"
            printf "  %-10s %s\n" "ipmi"    "IPMI/BMC audit             (nmap, ipmitool)"
            printf "  %-10s %s\n" "coap"    "CoAP IoT protocol audit    (nmap, coap-client)"
            printf "  %-10s %s\n" "mdns"    "mDNS/Bonjour service discovery  (avahi-browse, nmap dns-sd)"
