        fi
    fi

    ok "Telnet audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: mqtt
# ============================================================
usage_mqtt() {
    echo "Uso: exa-dune mqtt <TARGET> [OPTIONS]"
    echo ""
    echo "  MQTT broker audit — accesso anonimo, topic enumeration"
    echo "  Wraps: nmap mqtt NSE, mosquitto_sub"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 1883; controlla anche 8883)"
    echo "  --topics FILE      File topic aggiuntivi da testare"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_mqtt() {
    local target="" port=1883 topics_file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";        shift 2 ;;
            --topics)    topics_file="$2"; shift 2 ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_mqtt; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_mqtt; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_mqtt; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "mqtt"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap MQTT Scan (1883, 8883)"
    run_cmd "nmap_mqtt" \
        "nmap -p 1883,8883 --script mqtt-subscribe \
         -oN "$OUTDIR"/nmap_mqtt.txt $target 2>&1"

    if ! tool_ok mosquitto_sub; then
        warn "mosquitto_sub non trovato (apt install mosquitto-clients) — test broker saltato"
        ok "MQTT audit parziale (solo nmap) → $OUTDIR"
        return
    fi

    section "Test Accesso Anonimo"
    for p in 1883 8883; do
        local extra=""; [[ $p -eq 8883 ]] && extra="--insecure"
        run_cmd "mqtt_anon_$p" \
            "timeout 5 mosquitto_sub -h $target -p $p -t '#' $extra -v 2>&1 \
             | head -30 | tee "$OUTDIR"/mqtt_anon_${p}.txt"
        if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/mqtt_anon_${p}.txt" ]]; then
            if ! grep -qiE "error|refused|not authorized|Connection Refused" "$OUTDIR/mqtt_anon_${p}.txt"; then
                found HIGH "MQTT:${p} — broker accessibile in modo anonimo"
            fi
        fi
    done

    section "Topic Enumeration"
    local topic_list=(
        "#"
        "\$SYS/#"
        "home/#" "sensor/#" "device/#" "status/#"
        "command/#" "telemetry/#" "config/#"
        "update/#" "alarm/#" "camera/#"
        "gateway/#" "bridge/#" "network/#"
    )
    [[ -f "$topics_file" ]] && mapfile -t extra_topics < "$topics_file" && \
        topic_list+=("${extra_topics[@]}")

    if [[ $DRY_RUN -eq 0 ]]; then
        for topic in "${topic_list[@]}"; do
            local result
            result=$(timeout 3 mosquitto_sub -h "$target" -p "$port" -t "$topic" -v 2>&1 | head -5 || true)
            if [[ -n "$result" ]] && ! echo "$result" | grep -qiE "error|refused|not authorized"; then
                { echo "=== Topic: $topic ==="; echo "$result"; } >> "$OUTDIR/mqtt_topics.txt"
            fi
        done
        [[ -s "$OUTDIR/mqtt_topics.txt" ]] && found HIGH "MQTT — topic attivi trovati (vedi mqtt_topics.txt)"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} MQTT topic enum: ${#topic_list[@]} topics su $target:$port"
    fi

    section "MQTT Publish Test (write access)"
    if [[ $DRY_RUN -eq 0 ]] && tool_ok mosquitto_pub; then
        for p in 1883 8883; do
            check_port "$target" "$p" || continue
            local extra=""; [[ $p -eq 8883 ]] && extra="--insecure"
            local pub_resp
            pub_resp=$(timeout 5 mosquitto_pub -h "$target" -p "$p" \
                -t "exa-dune-test/probe" -m "exa_probe_$(date +%s)" \
                $extra 2>&1 || true)
            if ! echo "$pub_resp" | grep -qiE "error|refused|not authorized|Connection"; then
                found CRITICAL "MQTT:${p} — PUBLISH anonimo riuscito su topic 'exa-dune-test/probe'"
                echo "MQTT:$p write access confermato" >> "$OUTDIR/mqtt_write.txt"
            fi
        done
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} MQTT publish test su $target:1883,8883"
    else
        warn "mosquitto_pub non trovato — publish test saltato"
    fi

    section "MQTT Retained Messages (credenziali/config)"
    if [[ $DRY_RUN -eq 0 ]] && tool_ok mosquitto_sub; then
        local retained
        retained=$(timeout 8 mosquitto_sub -h "$target" -p "$port" \
            -t '#' -v --retained-only 2>/dev/null | head -30 || true)
        if [[ -n "$retained" ]]; then
            echo "$retained" > "$OUTDIR/mqtt_retained.txt"
            found MEDIUM "MQTT:$port — messaggi retained ricevuti (vedi mqtt_retained.txt)"
            # Cerca pattern di credenziali
            echo "$retained" | grep -iE "pass|password|key|secret|token|api" | \
                while IFS= read -r line; do found HIGH "MQTT retained — possibile credenziale: $line"; done || true
        fi
    fi

    section "MQTT Credential Brute Force"
    if [[ $DRY_RUN -eq 0 ]] && tool_ok mosquitto_sub; then
        local mqtt_creds=(
            "admin:admin" "mqtt:mqtt" "user:user"
            "guest:guest" "admin:password" "test:test"
            "mqttuser:mqttpass" "iot:iot" "device:device"
            "root:root" "admin:1234" "admin:12345"
        )
        for cred in "${mqtt_creds[@]}"; do
            local u="${cred%%:*}" p="${cred##*:}"
            local resp
            resp=$(timeout 4 mosquitto_sub -h "$target" -p "$port" \
                -u "$u" -P "$p" -t 'exa-probe' 2>&1 || true)
            if ! echo "$resp" | grep -qiE "error|refused|not authorized|bad user"; then
                found HIGH "MQTT:$port — credenziali valide: ${u}:${p}"
                echo "${u}:${p}" >> "$OUTDIR/mqtt_creds.txt"
                break
            fi
        done
    fi

    ok "MQTT audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: modbus
# ============================================================
usage_modbus() {
    echo "Uso: exa-dune modbus <TARGET> [OPTIONS]"
    echo ""
    echo "  Modbus/ICS audit (Modbus TCP, BACnet/IP, EtherNet/IP)"
    echo "  Wraps: nmap ICS/SCADA NSE, raw TCP probes"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta Modbus (default: 502)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_modbus() {
    local target="" port=502
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    port="$2";        shift 2 ;;
            --output)  OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;        shift ;;
            --help|-h) usage_modbus; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_modbus; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_modbus; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "modbus"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap ICS/SCADA Scan"
    run_cmd "nmap_ics_tcp" \
        "nmap -p 502,44818,2404,102 \
         --script modbus-discover,enip-info \
         -oN "$OUTDIR"/nmap_ics_tcp.txt $target 2>&1"
    run_cmd "nmap_bacnet" \
        "nmap -sU -p 47808 --script bacnet-info \
         -oN "$OUTDIR"/nmap_bacnet.txt $target 2>&1"

    if [[ $DRY_RUN -eq 0 ]]; then
        grep -q "^502/tcp.*open"   "$OUTDIR/nmap_ics_tcp.txt" 2>/dev/null && \
            found CRITICAL "ICS:502 — Modbus TCP esposto (nessuna autenticazione nativa)"
        grep -q "^44818/tcp.*open" "$OUTDIR/nmap_ics_tcp.txt" 2>/dev/null && \
            found HIGH "ICS:44818 — EtherNet/IP esposto"
    fi

    section "Modbus Unit ID Enumeration (1-10)"
    if [[ $DRY_RUN -eq 0 ]]; then
        for uid in $(seq 1 10); do
            local uid_hex; uid_hex=$(printf '%02x' "$uid")
            # FC43 Device Identification con unit ID variabile
            local id_resp
            id_resp=$(printf "\\x00\\x01\\x00\\x00\\x00\\x05\\x${uid_hex}\\x2b\\x0e\\x01\\x00" \
                | nc -w 2 "$target" "$port" 2>/dev/null | strings 2>/dev/null | head -3 || true)
            if [[ -n "$id_resp" ]]; then
                echo "Unit ID $uid: $id_resp" | tee -a "$OUTDIR/modbus_units.txt"
                found INFO "Modbus — Unit ID $uid risponde: $id_resp"
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Modbus unit ID 1-10 enum su $target:$port"
    fi

    section "Modbus Raw Probes (FC1/FC2/FC3/FC43)"
    # FC1 — Read Coils 0-9
    run_cmd "modbus_fc1" \
        "printf '\\x00\\x01\\x00\\x00\\x00\\x06\\x01\\x01\\x00\\x00\\x00\\x0a' \
         | nc -w 3 $target $port 2>/dev/null | xxd 2>/dev/null \
         | tee \"$OUTDIR\"/modbus_fc1.txt"
    # FC2 — Read Discrete Inputs 0-9
    run_cmd "modbus_fc2" \
        "printf '\\x00\\x01\\x00\\x00\\x00\\x06\\x01\\x02\\x00\\x00\\x00\\x0a' \
         | nc -w 3 $target $port 2>/dev/null | xxd 2>/dev/null \
         | tee \"$OUTDIR\"/modbus_fc2.txt"
    # FC3 — Read Holding Registers 0-9
    run_cmd "modbus_fc3" \
        "printf '\\x00\\x01\\x00\\x00\\x00\\x06\\x01\\x03\\x00\\x00\\x00\\x0a' \
         | nc -w 3 $target $port 2>/dev/null | xxd 2>/dev/null \
         | tee \"$OUTDIR\"/modbus_fc3.txt"
    # FC4 — Read Input Registers 0-9
    run_cmd "modbus_fc4" \
        "printf '\\x00\\x01\\x00\\x00\\x00\\x06\\x01\\x04\\x00\\x00\\x00\\x0a' \
         | nc -w 3 $target $port 2>/dev/null | xxd 2>/dev/null \
         | tee \"$OUTDIR\"/modbus_fc4.txt"
    # FC43 — Device Identification
    run_cmd "modbus_fc43" \
        "printf '\\x00\\x01\\x00\\x00\\x00\\x05\\x01\\x2b\\x0e\\x01\\x00' \
         | nc -w 3 $target $port 2>/dev/null | strings 2>/dev/null \
         | tee \"$OUTDIR\"/modbus_fc43.txt"
    if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/modbus_fc43.txt" ]]; then
        found INFO "Modbus FC43 — device identificabile via Device Identification"
    fi

    section "Modbus Write Test (FC5 Coil / FC6 Register — WARNING: modificativo)"
    log "ATTENZIONE: FC5/FC6 scrivono sul dispositivo — abilitare solo in ambienti controllati"
    # FC5 — Write Single Coil (coil 0 → ON = 0xFF00)
    # Solo se il target risponde ai read (evita falsi positivi)
    if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/modbus_fc1.txt" ]]; then
        if grep -q "[0-9a-f][0-9a-f] " "$OUTDIR/modbus_fc1.txt" 2>/dev/null; then
            warn "FC5 Write Coil SALTATO (usa --write-test per abilitare in ambienti controllati)"
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} Modbus FC5 Write Single Coil / FC6 Write Register (disabilitato in live)"
    fi
    # Segnala comunque se FC3 restituisce dati (write sarebbe possibile)
    if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/modbus_fc3.txt" ]]; then
        local fc3_data; fc3_data=$(grep -c "[0-9a-f]" "$OUTDIR/modbus_fc3.txt" 2>/dev/null || echo 0)
        [[ $fc3_data -gt 2 ]] && \
            found HIGH "Modbus FC3 — registri leggibili senza autenticazione: scrittura probabilmente possibile"
    fi

    ok "Modbus/ICS audit completato → $OUTDIR"
}

