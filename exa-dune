    [[ -z "$target" ]] && { err "TARGET mancante"; usage_dns; exit 1; }
    validate_target "$target"
    # Se non specificato il dominio, usa il target come dominio
    [[ -z "$domain" ]] && domain="$target"
    setup_outdir "$target" "dns"
    log "Target DNS: $target | Dominio: $domain | Output: $OUTDIR"

    section "Nmap DNS Scripts"
    run_cmd "nmap_dns" \
        "nmap -p 53 --script dns-zone-transfer,dns-brute,dns-recursion,dns-service-discovery \
         --script-args dns-zone-transfer.domain=$domain \
         -oN \"$OUTDIR\"/nmap_dns.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_dns.txt" ]]; then
        grep -iE "zone transfer|dns-zone-transfer" "$OUTDIR/nmap_dns.txt" 2>/dev/null | \
            grep -iv "failed\|ERROR\|could not" | \
            while IFS= read -r line; do found HIGH "DNS — $line"; done || true
    fi

    section "Zone Transfer (dig axfr)"
    if require_tool dig; then
        run_cmd "dig_axfr" \
            "dig @$target AXFR $domain 2>&1 | tee \"$OUTDIR\"/dig_axfr.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/dig_axfr.txt" ]]; then
            if grep -q "Transfer failed\|connection timed out\|communications error" \
                   "$OUTDIR/dig_axfr.txt" 2>/dev/null; then
                log "Zone transfer non consentito"
            elif grep -qE "^[^;].*IN\s+(A|AAAA|CNAME|MX|NS)" "$OUTDIR/dig_axfr.txt" 2>/dev/null; then
                found CRITICAL "DNS — Zone Transfer RIUSCITO su $domain"
            fi
        fi
        # SOA, NS, MX base records
        run_cmd "dig_base" \
            "dig @$target $domain ANY +noall +answer 2>&1 | tee \"$OUTDIR\"/dig_any.txt"
    fi

    section "Reverse Lookup"
    if require_tool host; then
        run_cmd "host_rev" \
            "host $target 2>&1 | tee \"$OUTDIR\"/host_reverse.txt"
    fi

    section "DNS Recon"
    if require_tool dnsrecon; then
        run_cmd "dnsrecon_std" \
            "dnsrecon -d $domain -n $target -t std,axfr,brt \
             -j \"$OUTDIR\"/dnsrecon.json 2>&1 | tee \"$OUTDIR\"/dnsrecon.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/dnsrecon.json" ]]; then
            grep -iE '"type".*"A"|axfr' "$OUTDIR/dnsrecon.json" 2>/dev/null | head -20 \
                >> "$OUTDIR/dns_hosts.txt" || true
        fi
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "Subdomain Brute Force"
        local wl="${wordlist:-$(_wl_dns)}"
        if [[ -n "$wl" && -f "$wl" ]]; then
            if require_tool dnsrecon; then
                run_cmd "dnsrecon_brute" \
                    "dnsrecon -d $domain -n $target -t brt -D $wl \
                     -j \"$OUTDIR\"/dnsrecon_brute.json 2>&1 | tee \"$OUTDIR\"/dnsrecon_brute.txt"
            else
                # Fallback manuale con dig
                if [[ $DRY_RUN -eq 0 ]]; then
                    log "Subdomain brute force manuale (dig)..."
                    while IFS= read -r sub; do
                        [[ -z "$sub" ]] && continue
                        local fqdn="${sub}.${domain}"
                        local res; res=$(dig @"$target" "$fqdn" A +short 2>/dev/null | head -1 || true)
                        if [[ -n "$res" ]]; then
                            echo "$fqdn → $res" >> "$OUTDIR/subdomains.txt"
                            found INFO "DNS — subdomain trovato: $fqdn → $res"
                        fi
                    done < "$wl"
                fi
            fi
        else
            warn "Wordlist subdomain non trovata — brute force saltato"
        fi
    fi

    ok "DNS audit completato → $OUTDIR"
}

