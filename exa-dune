cmd_sqli() {
    local target="" port=80 scheme="http" custom_url=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --scheme)  _req_arg "$1" "${2:-}"; scheme="$2";      shift 2 ;;
