# ============================================================
usage_coap() {
    echo "Uso: exa-dune coap <TARGET> [OPTIONS]"
    echo ""
    echo "  CoAP IoT protocol audit — OBSERVE, DTLS bypass, resource injection"
    echo "  Wraps: nmap coap NSE, coap-client (libcoap)"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta UDP (default: 5683)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_coap() {
    local target="" port=5683
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;        shift ;;
            --help|-h) usage_coap; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_coap; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_coap; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "coap"
    log "Target: $target:$port/udp | Output: $OUTDIR"

    section "Nmap CoAP"
    run_cmd "nmap_coap" \
        "nmap -sU -p $port --script coap-resources \
         -oN \"$OUTDIR\"/nmap_coap.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_coap.txt" ]]; then
        grep -v "^#\|^$\|Nmap " "$OUTDIR/nmap_coap.txt" 2>/dev/null | head -20 \
            | tee "$OUTDIR/coap_nmap_summary.txt" || true
        grep -iE "open|resource" "$OUTDIR/nmap_coap.txt" 2>/dev/null && \
            found MEDIUM "CoAP:$port — servizio CoAP raggiungibile" || true
    fi

    section "DTLS Bypass Check (porta 5684)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local dtls_resp
        dtls_resp=$(printf '\x40\x01\x00\x01\xbb\x2f\x00\x00' \
            | nc -u -w 3 "$target" 5684 2>/dev/null | strings | head -3 || true)
        if [[ -n "$dtls_resp" ]]; then
            found HIGH "CoAP — porta DTLS 5684 risponde a traffico non-DTLS (possibile bypass DTLS)"
            echo "$dtls_resp" >> "$OUTDIR/coap_dtls_bypass.txt"
        else
            log "CoAP DTLS port 5684: nessuna risposta non-DTLS"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} CoAP DTLS bypass check $target:5684"
    fi

    section "CoAP Service Discovery (coap-client)"
    local coap_bin=""
    tool_ok coap-client   && coap_bin="coap-client"
    tool_ok coap-client-3 && coap_bin="coap-client-3"

    local discovered_resources=()

    if [[ -n "$coap_bin" ]]; then
        # .well-known/core — resource discovery completo
        run_cmd "coap_discovery" \
            "$coap_bin -m get coap://$target:$port/.well-known/core 2>&1 \
             | tee \"$OUTDIR\"/coap_discovery.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/coap_discovery.txt" ]]; then
            if grep -q "</" "$OUTDIR/coap_discovery.txt" 2>/dev/null; then
                found HIGH "CoAP:$port — .well-known/core accessibile (no auth)"
                # Parsa risorse con metodi supportati
                while IFS= read -r resource; do
                    discovered_resources+=("$resource")
                    local res_out="$OUTDIR/coap_res_${resource//\//_}.txt"
                    "$coap_bin" -m get "coap://$target:$port/$resource" \
                        > "$res_out" 2>&1 || true
                    if [[ -s "$res_out" ]]; then
                        local methods=""
                        # Cerca indicatori di metodi nell'output
                        grep -qi "if=\|rt=\|obs" "$OUTDIR/coap_discovery.txt" 2>/dev/null && methods="GET/OBS"
                        found INFO "CoAP:$port — risorsa: /$resource [$methods]"
                    fi
                done < <(grep -oP '(?<=<)[^>]+(?=>)' "$OUTDIR/coap_discovery.txt" 2>/dev/null || true)
            fi
        fi

        # Test GET su path comuni (auth resources, config, status)
        for res in "" "version" "config" "status" "info" "settings" \
                   "actuators" "sensors" "auth" "login" "admin"; do
            run_cmd "coap_get_${res:-root}" \
                "$coap_bin -m get coap://$target:$port/$res 2>&1 \
                 | tee \"$OUTDIR\"/coap_get_${res:-root}.txt" || true
            if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/coap_get_${res:-root}.txt" ]]; then
                case "$res" in
                    auth|login|admin)
                        found MEDIUM "CoAP:$port — risorsa sensibile accessibile: /$res"
                        ;;
                    config)
                        found HIGH "CoAP:$port — risorsa /config leggibile senza auth"
                        ;;
                esac
            fi
        done

        # CoAP OBSERVE attack (registra per notifiche senza auth)
        section "CoAP OBSERVE Attack"
        if [[ $DRY_RUN -eq 0 ]]; then
            for obs_res in "sensors" "status" "actuators"; do
                local obs_out="$OUTDIR/coap_observe_${obs_res}.txt"
                timeout 8 "$coap_bin" -m get -s 5 \
                    "coap://$target:$port/$obs_res" > "$obs_out" 2>&1 || true
                if [[ -s "$obs_out" ]]; then
                    local obs_lines; obs_lines=$(wc -l < "$obs_out" 2>/dev/null || echo 0)
                    if [[ $obs_lines -gt 1 ]]; then
                        found HIGH "CoAP:$port — OBSERVE su /$obs_res: $obs_lines aggiornamenti ricevuti (no auth)"
                    fi
                fi
            done
        else
            echo -e "${CYAN}[DRY-RUN]${NC} CoAP OBSERVE attack $target:$port"
        fi

        # Resource injection test (PUT/POST su risorse trovate)
        section "CoAP Resource Injection (PUT/POST)"
        if [[ $DRY_RUN -eq 0 && ${#discovered_resources[@]} -gt 0 ]]; then
            for resource in "${discovered_resources[@]:0:5}"; do
                local put_resp
                put_resp=$(timeout 5 "$coap_bin" -m put \
                    "coap://$target:$port/$resource" \
                    -e "exa-dune-probe-$(date +%s)" 2>&1 || true)
                if echo "$put_resp" | grep -qiE "2\.[0-4]|Changed|Created"; then
                    found CRITICAL "CoAP:$port — PUT su /$resource riuscito SENZA AUTH (injection possibile)"
                    echo "PUT /$resource OK" >> "$OUTDIR/coap_injection.txt"
                fi
            done
        else
            echo -e "${CYAN}[DRY-RUN]${NC} CoAP resource injection test $target:$port"
        fi

    else
        warn "coap-client non trovato — usa nmap results (apt install libcoap2-bin)"
    fi

    local coap_script="$EXA_SCRIPTS_DIR/python/coap_scan.py"
    if [[ -f "$coap_script" ]]; then
        section "CoAP Discovery (custom scanner)"
        run_cmd "coap_scan" "python3 \"$coap_script\" $target --port $port --action discover 2>&1 | tee \"$OUTDIR\"/coap_scan.txt"
    fi

    ok "CoAP audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: mdns
# ============================================================
usage_mdns() {
    echo "Uso: exa-dune mdns <TARGET_NETWORK> [OPTIONS]"
    echo ""
    echo "  Enumera servizi mDNS/Bonjour e dispositivi Zeroconf sulla rete locale."
    echo "  Identifica stampanti, NAS, telecamere IP, Apple TV, smart speakers, ecc."
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE    Interfaccia di rete (default: auto)"
    echo "  --timeout N      Timeout ascolto in secondi (default: 10)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_mdns() {
    local target="" iface="" mdns_timeout=10
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)     _req_arg "$1" "${2:-}"; iface="$2";         shift 2 ;;
            --timeout)   _req_arg "$1" "${2:-}"; mdns_timeout="$2";  shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";   shift 2 ;;
            --stealth)   STEALTH=1;          shift ;;
            --dry-run)   DRY_RUN=1;          shift ;;
            --help|-h)   usage_mdns; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_mdns; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && target="local"
    check_root
    setup_outdir "$target" "mdns"

    log "Target: $target | Output: $OUTDIR"

    # ── mDNS con avahi-browse ─────────────────────────────────
    section "mDNS Service Discovery (avahi-browse)"
    local avahi_out="$OUTDIR/avahi_browse.txt"
    local iface_flag=""
    [[ -n "$iface" ]] && iface_flag="--interface $iface"

    if command -v avahi-browse &>/dev/null; then
        run_cmd "avahi_browse" "avahi-browse --all --resolve --terminate $iface_flag 2>/dev/null | tee $avahi_out"
        if [[ -s "$avahi_out" ]]; then
            # Parse servizi trovati e registra findings
            while IFS= read -r line; do
                local stype shost sip sport
                # Estrai hostname/IP/port dalle righe address/port
                if echo "$line" | grep -q "hostname = \["; then
                    shost=$(echo "$line" | grep -oP "hostname = \[\K[^\]]+")
                fi
                if echo "$line" | grep -q "address = \["; then
                    sip=$(echo "$line" | grep -oP "address = \[\K[^\]]+")
                fi
                if echo "$line" | grep -q "port = \["; then
                    sport=$(echo "$line" | grep -oP "port = \[\K[^\]]+")
                fi
                if echo "$line" | grep -qE "^\+.*_[a-z]+\._tcp|^\+.*_[a-z]+\._udp"; then
                    stype=$(echo "$line" | awk '{print $NF}')
                    found "MEDIUM" "mDNS" "Servizio $stype su $line"
                fi
            done < "$avahi_out"
            ok "avahi-browse completato: $(wc -l < "$avahi_out") righe"
        fi
    else
        warn "avahi-browse non trovato — installa: apt install avahi-utils"
    fi

    # ── nmap mDNS (porta 5353 UDP) ────────────────────────────
    section "nmap mDNS/DNS-SD Scan"
    local nmap_mdns="$OUTDIR/nmap_mdns.txt"
    if [[ "$target" != "local" ]]; then
        run_cmd "nmap_mdns" "nmap -sU -p 5353 --script dns-service-discovery -oN \"$nmap_mdns\" $NMAP_TIMING $target 2>/dev/null"
        if [[ -s "$nmap_mdns" ]]; then
            while IFS= read -r line; do
                echo "$line" | grep -qE "^\|.*_[a-z]+\." || continue
                found "MEDIUM" "mDNS" "DNS-SD: $line"
            done < "$nmap_mdns"
        fi
    else
        warn "Usa un IP/CIDR come target per nmap mDNS (es: 192.168.1.0/24)"
    fi

    # ── nmap broadcast-mdns (passive) ────────────────────────
    section "mDNS Broadcast Discovery"
    local bcast_out="$OUTDIR/mdns_broadcast.txt"
    run_cmd "nmap_mdns_bcast" "nmap --script broadcast-dns-service-discovery $NMAP_TIMING 2>/dev/null | tee $bcast_out"
    if [[ -s "$bcast_out" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*_[a-z]+\." || continue
            found "LOW" "mDNS" "Broadcast: $line"
        done < "$bcast_out"
    fi

    ok "mDNS audit completato → $OUTDIR"
}

