    # S7comm / Profinet (TCP 102) — PLC Siemens
    if _port_open 102; then
        log "  ▶ [Fase 2/4] S7comm/Profinet :102"
        if [[ $DRY_RUN -eq 0 ]]; then
            local _s7_dir="$OUTDIR_BASE/s7comm"
            mkdir -p "$_s7_dir"
            nmap -p 102 --script s7-info \
                -oN "$_s7_dir/s7_info.txt" "$target" 2>/dev/null || true
            if grep -qi "S7\|Siemens\|PLC\|CPU\|Module" "$_s7_dir/s7_info.txt" 2>/dev/null; then
                found HIGH "S7comm:102 — PLC Siemens identificato (Profinet/S7)"
                grep -oP 'Module.*|System.*|Plant.*|Hardware.*|Firmware.*' \
                    "$_s7_dir/s7_info.txt" 2>/dev/null | head -5 | \
                    while IFS= read -r _l; do found MEDIUM "S7comm:102 — $_l"; done || true
