            *)               target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_telnet; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "telnet"
    log "Target: $target | Porte: $ports_str | Output: $OUTDIR"

    IFS=',' read -ra ports <<< "$ports_str"

    section "Banner Grab"
    if [[ $DRY_RUN -eq 0 ]]; then
        for p in "${ports[@]}"; do
            local banner
            banner=$(nc -w 3 "$target" "$p" </dev/null 2>&1 | head -5)
