        for res in "" "version" "config" "status" "info" "settings" "actuators" "sensors"; do
            run_cmd "coap_get_$res" \
                "$coap_bin -m get coap://$target:$port/$res 2>&1 \
                 | tee \"$OUTDIR\"/coap_get_${res:-root}.txt" || true
        done
    else
