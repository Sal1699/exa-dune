            echo "══════════════════════════════════════════════════════════════"
            echo "Generato: $(date) | exa-dune v${VERSION}"
        } > "$_dp_file" 2>/dev/null || true

        ok "Device profile salvato: $_dp_file"
        # Stampa a schermo un riassunto compatto
        echo ""
        echo -e "${BOLD}${CYAN}┌─ DEVICE PROFILE ──────────────────────────────────────────┐${NC}"
        printf "${CYAN}│${NC} %-58s ${CYAN}│${NC}\n" "Target  : $target"
        [[ -n "$detected_vendor" ]] && printf "${CYAN}│${NC} %-58s ${CYAN}│${NC}\n" "Vendor  : $detected_vendor"
        printf "${CYAN}│${NC} %-58s ${CYAN}│${NC}\n" "TCP     : ${open_tcp:-(nessuna)}"
        printf "${CYAN}│${NC} %-58s ${CYAN}│${NC}\n" "Findings: CRIT=$_n_crit HIGH=$_n_high MED=$_n_med LOW=$_n_low"
        echo -e "${BOLD}${CYAN}└───────────────────────────────────────────────────────────┘${NC}"
        echo ""
    else
