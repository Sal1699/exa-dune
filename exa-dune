         --script ldap-rootdse,ldap-brute,ldap-novell-getpass,ldap-search \
         -oN \"$OUTDIR\"/nmap_ldap.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_ldap.txt" ]]; then
        grep -iE "namingContext|rootDomainNaming|defaultNamingContext|ldap" \
            "$OUTDIR/nmap_ldap.txt" 2>/dev/null | head -10 | tee "$OUTDIR/ldap_rootdse.txt" || true
        # Auto-estrai base DN se non fornito
        if [[ -z "$base_dn" ]]; then
            base_dn=$(grep -oP '(?<=defaultNamingContext: )DC=[^\s]+' "$OUTDIR/nmap_ldap.txt" 2>/dev/null | head -1 || true)
            [[ -n "$base_dn" ]] && log "Base DN rilevato: $base_dn"
        fi
    fi

    section "LDAP Null Binding (ldapsearch)"
    if require_tool ldapsearch; then
        local ldap_opts="-x -H ldap://$target:$port"
        [[ "$port" == "636" ]] && ldap_opts="-x -H ldaps://$target:$port"
        # rootDSE
        run_cmd "ldap_rootdse" \
            "ldapsearch $ldap_opts -s base -b '' '(objectclass=*)' 2>&1 \
             | tee \"$OUTDIR\"/ldapsearch_rootdse.txt"
        if [[ $DRY_RUN -eq 0 && -n "$base_dn" ]]; then
            # Null bind enumeration
            run_cmd "ldap_null_users" \
                "ldapsearch $ldap_opts -b '$base_dn' '(objectclass=person)' \
                 cn sAMAccountName mail 2>&1 | head -100 | tee \"$OUTDIR\"/ldap_users.txt"
            run_cmd "ldap_null_groups" \
                "ldapsearch $ldap_opts -b '$base_dn' '(objectclass=group)' \
                 cn member 2>&1 | head -100 | tee \"$OUTDIR\"/ldap_groups.txt"
            # Check se null binding ha restituito risultati
            if [[ -f "$OUTDIR/ldap_users.txt" ]] && \
               grep -q "^dn:" "$OUTDIR/ldap_users.txt" 2>/dev/null; then
                found HIGH "LDAP:$port — Null Binding consentito (enumerazione senza credenziali)"
                local nusers; nusers=$(grep -c "^dn:" "$OUTDIR/ldap_users.txt" 2>/dev/null || echo 0)
                found MEDIUM "LDAP:$port — $nusers oggetti person enumerati via null bind"
            fi
        elif [[ $DRY_RUN -eq 0 ]]; then
            warn "Base DN non rilevato — enumeration limitata"
        fi
    else
        warn "ldapsearch non trovato — (apt install ldap-utils)"
    fi

    ok "LDAP audit completato → $OUTDIR"
}

