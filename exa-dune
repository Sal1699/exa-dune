        "nmap -p $port --script vnc-info,vnc-brute,realvnc-auth-bypass \
         -oN \"$OUTDIR\"/nmap_vnc.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_vnc.txt" ]]; then
        grep -iE "SecurityType:|Protocol version:|None|no auth|bypass" "$OUTDIR/nmap_vnc.txt" 2>/dev/null \
            | tee "$OUTDIR/vnc_summary.txt" || true
        grep -i "None\|no auth\|bypass" "$OUTDIR/nmap_vnc.txt" 2>/dev/null && \
            found CRITICAL "VNC:$port — autenticazione ASSENTE (None auth)" || true
    fi

    section "Banner (nc)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local banner; banner=$(nc -w 3 "$target" "$port" </dev/null 2>&1 | head -3 || true)
        [[ -n "$banner" ]] && echo "$banner" | tee "$OUTDIR/vnc_banner.txt"
        echo "$banner" | grep -oP 'RFB \d+\.\d+' 2>/dev/null | \
            while IFS= read -r ver; do found INFO "VNC:$port — versione: $ver"; done || true
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Banner grab VNC $target:$port"
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "VNC Password Brute Force"
        check_port "$target" "$port" || { warn "Porta $port chiusa"; return; }
        if require_tool hydra; then
            local pl; pl=$(_wl_pass)
            run_cmd "hydra_vnc" \
                "hydra -P \"$pl\" -s $port -t $threads -f -w 4 -W 2 \
                 -o \"$OUTDIR/hydra_vnc.txt\" $target vnc 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_vnc.txt" ]]; then
                grep -i "password:" "$OUTDIR/hydra_vnc.txt" 2>/dev/null | \
                    while IFS= read -r line; do found HIGH "VNC:$port — $line"; done || true
            fi
        fi
    fi

    ok "VNC audit completato → $OUTDIR"
}

