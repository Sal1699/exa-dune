usage_rtmp() {
    echo "Uso: exa-dune rtmp <TARGET> [OPTIONS]"
    echo ""
    echo "  RTMP stream probing — DVR, telecamere IP, media server (porta 1935)."
    echo "  Enumera app/stream, verifica accesso anonimo, cattura metadati."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta RTMP (default: 1935)"
    echo "  --apps LIST      App da provare (default: embedded list)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_rtmp() {
    local target="" port=1935 custom_apps=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";         shift 2 ;;
            --apps)      _req_arg "$1" "${2:-}"; custom_apps="$2";  shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_rtmp; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_rtmp; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_rtmp; exit 1; }
    check_root
    setup_outdir "$target" "rtmp"
    log "Target: $target:$port | Output: $OUTDIR"

    # Wordlist app/stream RTMP comuni (DVR, NVR, telecamere IP)
    local _rtmp_apps
    if [[ -n "$custom_apps" && -f "$custom_apps" ]]; then
        _rtmp_apps="$custom_apps"
    else
        local _rtmp_tmp; _rtmp_tmp=$(mktemp)
        cat > "$_rtmp_tmp" <<'WL'
live
stream
live/stream
hls
rtmp
video
cam
camera
cam0
cam1
live/cam
dvr
nvr
record
ch1
ch2
channel1
channel2
bcs/channel0_main.bcs
bcs/channel0_sub.bcs
WL
        _rtmp_apps="$_rtmp_tmp"
    fi

    # ── nmap RTMP port check ──────────────────────────────────
    section "RTMP Port Scan"
    local nmap_rtmp="$OUTDIR/nmap_rtmp.txt"
    run_cmd "nmap_rtmp" "nmap -p $port -sV $NMAP_TIMING $target 2>/dev/null | tee $nmap_rtmp"
    if grep -qE "$port/tcp.*open" "$nmap_rtmp" 2>/dev/null; then
        found "MEDIUM" "RTMP" "RTMP porta $port aperta su $target"
    fi

    # ── ffprobe RTMP metadata probe ───────────────────────────
    section "RTMP Metadata Probe (ffprobe)"
    local ffprobe_out="$OUTDIR/rtmp_meta.txt"
    if command -v ffprobe &>/dev/null; then
        local _found_rtmp=0
        while IFS= read -r app; do
            [[ -z "$app" || "$app" == "#"* ]] && continue
            local rtmp_url="rtmp://${target}:${port}/${app}"
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} ffprobe $rtmp_url" 
                continue
            fi
            local meta
            meta=$(timeout ${CMD_TIMEOUT:-8} ffprobe -v quiet -print_format json \
                -show_streams "$rtmp_url" 2>/dev/null || true)
            # Verifica che ci siano stream reali (codec_type presente) — {} vuoto = errore I/O
            if echo "$meta" | grep -q '"codec_type"'; then
                echo "[FOUND] $rtmp_url"
                echo "$meta" >> "$ffprobe_out"
                found "HIGH" "RTMP" "Stream RTMP accessibile senza auth: $rtmp_url"
                _found_rtmp=1
            fi
        done < "$_rtmp_apps"
        [[ $_found_rtmp -eq 0 && $DRY_RUN -eq 0 ]] && log "Nessun stream RTMP accessibile"
    else
        warn "ffprobe non trovato — installa: apt install ffmpeg"
    fi

    # ── rtmpdump handshake probe ──────────────────────────────
    section "RTMP Handshake / Server Info (rtmpdump)"
    local rtmpdump_out="$OUTDIR/rtmpdump_probe.txt"
    if command -v rtmpdump &>/dev/null; then
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} rtmpdump -r rtmp://${target}:${port}/live --stop 1" 
        else
            # Solo handshake — stop subito dopo
            timeout 10 rtmpdump -r "rtmp://${target}:${port}/live" \
                --stop 1 -o /dev/null 2>&1 | head -20 | tee "$rtmpdump_out" || true
            if grep -qi "connected\|rtmp\|server" "$rtmpdump_out" 2>/dev/null; then
                found "MEDIUM" "RTMP" "Server RTMP risponde: $(head -2 "$rtmpdump_out")"
            fi
        fi
    else
        warn "rtmpdump non trovato — installa: apt install rtmpdump"
    fi

    [[ -n "$_rtmp_tmp" ]] && rm -f "$_rtmp_tmp" 2>/dev/null || true
    ok "RTMP audit completato → $OUTDIR"
}

