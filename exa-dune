    # ── RTSP anonymous access ─────────────────────────────────────
    if { _port_open 554 || _port_open 8554 || echo "$all_findings" | grep -qi "rtsp"; }; then
        log "  ▶ RTSP anonymous access test"
        ran_attack=1
        local _rtsp_port=554; _port_open 8554 && _rtsp_port=8554
        local _rtsp_paths=("/" "/live" "/stream" "/video1" "/live/ch0"
