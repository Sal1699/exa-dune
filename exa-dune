    fi

    echo ""
    echo -e "${BOLD}${GREEN}══════════════════════════════════════════${NC}"
    echo -e "${BOLD}${GREEN}  ASSESSMENT COMPLETATO${NC}"
    echo -e "${BOLD}${GREEN}══════════════════════════════════════════${NC}"
    printf "  %-20s %s\n" "Target:"       "$target"
    printf "  %-20s %s\n" "Durata:"       "$_dur_fmt"
    printf "  %-20s %s\n" "Output dir:"   "$OUTDIR_BASE"
    printf "  %-20s %s\n" "Findings totali:" "$_f4_total (C:$_f4_crit H:$_f4_high M:$_f4_med L:$_f4_low)"
    printf "  %-20s %s\n" "Credenziali:"  "$_f4_creds trovate"
    echo -e "${BOLD}${GREEN}══════════════════════════════════════════${NC}"
    echo ""
}

# ============================================================
#  REPORT HELPERS — CVSS lookup, ATT&CK, OWASP IoT
# ============================================================
_cvss_lookup() {
    local cve_id="$1"
    [[ "$cve_id" != CVE-* ]] && { echo "N/A"; return; }
    local url="https://services.nvd.nist.gov/rest/json/cves/2.0?cveId=${cve_id}"
    local result
    result=$(timeout 8 curl -s "$url" 2>/dev/null || echo "")
    if [[ -n "$result" ]]; then
        echo "$result" | python3 -c "
import json,sys
d=json.load(sys.stdin)
try:
    m=d['vulnerabilities'][0]['cve']['metrics']
    if 'cvssMetricV31' in m:
        s=m['cvssMetricV31'][0]['cvssData']
    elif 'cvssMetricV30' in m:
        s=m['cvssMetricV30'][0]['cvssData']
    elif 'cvssMetricV2' in m:
        s=m['cvssMetricV2'][0]['cvssData']
    else:
        print('N/A'); exit()
    print(str(s.get('baseScore','N/A'))+' ('+s.get('baseSeverity','?')+')')
except: print('N/A')
" 2>/dev/null || echo "N/A"
    else
        echo "N/A"
    fi
}

_attck_map() {
    local finding_text="$1"
    local technique=""
    case "${finding_text,,}" in
        *"brute"*|*"password"*|*"credential"*) technique="T1110 — Brute Force" ;;
        *"default"*"cred"*|*"default"*"pass"*)  technique="T1078.001 — Default Accounts" ;;
        *"telnet"*)         technique="T1021.004 — Remote Services: Telnet" ;;
        *"ssh"*)            technique="T1021.004 — Remote Services: SSH" ;;
        *"snmp"*)           technique="T1602.001 — SNMP MIB Dump" ;;
        *"ftp"*)            technique="T1021.004 — Remote Services: FTP" ;;
        *"upnp"*)           technique="T1590.005 — Network Topology (UPnP)" ;;
        *"firmware"*)       technique="T1195.002 — Compromise Software Supply Chain" ;;
        *"cve"*)            technique="T1190 — Exploit Public-Facing Application" ;;
        *"bypass"*|*"evasion"*) technique="T1562 — Impair Defenses" ;;
        *"arp"*|*"mitm"*)   technique="T1557.002 — ARP Cache Poisoning" ;;
        *"mqtt"*)           technique="T1071.001 — App Layer Protocol" ;;
        *"scan"*|*"port"*)  technique="T1046 — Network Service Discovery" ;;
        *"smb"*)            technique="T1021.002 — Remote Services: SMB" ;;
        *"rdp"*)            technique="T1021.001 — Remote Services: RDP" ;;
        *"ldap"*)           technique="T1087.002 — Domain Account Discovery" ;;
        *"dns"*)            technique="T1071.004 — Application Layer Protocol: DNS" ;;
        *"sip"*|*"voip"*)   technique="T1071.001 — Application Layer Protocol: VoIP" ;;
        *"log4"*|*"jndi"*)  technique="T1190 — Exploit Public-Facing App (Log4Shell)" ;;
        *"sql"*"inject"*)   technique="T1190 — Exploit Public-Facing App (SQLi)" ;;
        *"xss"*|*"xxe"*|*"ssrf"*) technique="T1190 — Exploit Public-Facing Application" ;;
        *) technique="T1590 — Gather Victim Network Information" ;;
    esac
    echo "$technique"
}

_owasp_iot_map() {
    local finding_text="$1"
    case "${finding_text,,}" in
        *"default"*"pass"*|*"weak"*"pass"*|*"brute"*) echo "I1 — Weak/Guessable Passwords" ;;
        *"telnet"*|*"ftp"*|*"http"*"plain"*)           echo "I2 — Insecure Network Services" ;;
        *"tls"*|*"ssl"*|*"cert"*|*"https"*)            echo "I3 — Insecure Ecosystem Interfaces" ;;
        *"update"*|*"firmware"*|*"version"*)            echo "I4 — Lack of Secure Update Mechanism" ;;
        *"credential"*"store"*|*"hardcoded"*)           echo "I5 — Use of Insecure/Outdated Components" ;;
        *"privacy"*|*"data"*"leak"*)                    echo "I6 — Insufficient Privacy Protection" ;;
        *"encrypt"*|*"plain"*"text"*)                   echo "I7 — Insecure Data Transfer/Storage" ;;
        *"snmp"*|*"upnp"*|*"manage"*)                  echo "I8 — Lack of Device Management" ;;
        *"hardcoded"*|*"backdoor"*)                     echo "I9 — Insecure Default Settings" ;;
        *"physical"*|*"uart"*|*"jtag"*)                echo "I10 — Lack of Physical Hardening" ;;
        *) echo "I8 — Lack of Device Management" ;;
    esac
}

# ============================================================
#  SUBCOMMAND: report
# ============================================================
usage_report() {
    echo "Uso: exa-dune report <OUTDIR> [OPTIONS]"
    echo ""
    echo "  Genera report da risultati in OUTDIR"
    echo ""
    echo "Opzioni:"
    echo "  --html             Genera report HTML con severity colorata"
    echo "  --pdf              Genera report PDF (richiede wkhtmltopdf o chromium)"
    echo "  --dry-run"
}

cmd_report() {
    local outdir="" do_html=0 do_pdf=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --html)    do_html=1;  shift ;;
            --pdf)     do_pdf=1; do_html=1; shift ;;
            --dry-run) DRY_RUN=1; shift ;;
            --help|-h) usage_report; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_report; exit 1 ;;
            *)         outdir="$1"; shift ;;
        esac
    done
    [[ -z "$outdir" ]] && { err "Directory non specificata"; usage_report; exit 1; }
    [[ ! -d "$outdir" && $DRY_RUN -eq 0 ]] && { err "Directory non trovata: $outdir"; usage_report; exit 1; }
    outdir="${outdir%/}"

    local report_file="$outdir/REPORT_$(date +%Y%m%d_%H%M%S).txt"
    # Extract IP or hostname from directory name (e.g. exa-dune-10-0-0-1-20250101)
    local target; target=$(basename "$outdir" | grep -oP '(\d{1,3}-){3}\d{1,3}' | head -1 | tr '-' '.' 2>/dev/null || true)
    [[ -z "$target" ]] && target=$(basename "$outdir")

    # Helper: print section header
    _section() { printf '\n── %-47s\n' "$1" | tr ' ' '─' | head -c 51; echo; }

    {
        echo "═══════════════════════════════════════════════════"
        echo "  EXA-DUNE — Report di Assessment"
        echo "  Target : $target"
        echo "  Outdir : $outdir"
        echo "  Data   : $(date)"
        echo "═══════════════════════════════════════════════════"

        # ── FINDINGS aggregati da tutti i sottomoduli ────────
        _section "FINDINGS"
        local has_findings=0
        # Findings in root (da run singolo) e in ogni subdir (da auto)
        while IFS= read -r -d '' ffile; do
            local module; module=$(basename "$(dirname "$ffile")")
            [[ "$module" == "$(basename "$outdir")" ]] && module="root"
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                printf "  [%-10s] %s\n" "$module" "$line"
                has_findings=1
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        [[ $has_findings -eq 0 ]] && echo "  (nessun finding registrato)"

        # ── CREDENZIALI ──────────────────────────────────────
        _section "CREDENZIALI"
        local has_creds=0
        # Da hydra output
        while IFS= read -r -d '' hfile; do
            local module; module=$(basename "$(dirname "$hfile")")
            [[ "$module" == "$(basename "$outdir")" ]] && module="root"
            while IFS= read -r line; do
                [[ "$line" == *"login:"* ]] || continue
                printf "  [%-10s] %s\n" "$module" "$line"
                has_creds=1
            done < "$hfile"
        done < <(find "$outdir" -name "hydra_*.txt" -print0 2>/dev/null | sort -z)
        [[ $has_creds -eq 0 ]] && echo "  (nessuna credenziale trovata)"

        # ── CAMBIO CREDENZIALI ───────────────────────────────
        _section "CAMBIO CREDENZIALI (post brute-force)"
        local cc_file="$outdir/cred_changes.txt"
        if [[ -s "$cc_file" ]]; then
            cat "$cc_file"
        else
            echo "  (nessun cambio credenziale eseguito)"
        fi

        # ── PORTE APERTE ─────────────────────────────────────
        _section "PORTE APERTE"
        local nmap_file
        nmap_file=$(find "$outdir" -maxdepth 2 \
            \( -name "nmap_fast.nmap" -o -name "nmap_full.nmap" \) 2>/dev/null | head -1)
        if [[ -n "$nmap_file" ]]; then
            grep -E "^[0-9]+/tcp.*open" "$nmap_file" 2>/dev/null | head -40 || true
        else
            # Fallback a gnmap
            nmap_file=$(find "$outdir" -maxdepth 2 -name "*.gnmap" 2>/dev/null | head -1)
            [[ -n "$nmap_file" ]] && grep -oP '[0-9]+/open/[^/]+/[^/]+/[^/]+/[^/]+' \
                "$nmap_file" 2>/dev/null | head -40 || echo "  (nessun file nmap trovato)"
        fi

        # ── SNMP ─────────────────────────────────────────────
        _section "SNMP"
        local snmp_out=0
        while IFS= read -r -d '' f; do
            cat "$f" 2>/dev/null && snmp_out=1
        done < <(find "$outdir" -name "snmp_found.txt" -print0 2>/dev/null)
        [[ $snmp_out -eq 0 ]] && echo "  (nessuna community SNMP trovata)"

        # ── NIKTO ────────────────────────────────────────────
        _section "NIKTO"
        local nikto_out=0
        while IFS= read -r -d '' f; do
            local module; module=$(basename "$(dirname "$f")")
            while IFS= read -r line; do
                [[ "$line" =~ (OSVDB|CVE|\+\ ) ]] || continue
                printf "  [%-10s] %s\n" "$module" "$line"
                nikto_out=1
            done < "$f"
        done < <(find "$outdir" -name "nikto.txt" -print0 2>/dev/null)
        [[ $nikto_out -eq 0 ]] && echo "  (nessun finding nikto)"

        # ── GOBUSTER ─────────────────────────────────────────
        _section "GOBUSTER"
        local gob_out=0
        while IFS= read -r -d '' f; do
            local module; module=$(basename "$(dirname "$f")")
            local count=0
            while IFS= read -r line; do
                [[ -z "$line" || "$line" == "="* ]] && continue
                ((count++)) || true; [[ $count -gt 20 ]] && break
                printf "  [%-10s] %s\n" "$module" "$line"
                gob_out=1
            done < "$f"
        done < <(find "$outdir" -name "gobuster.txt" -print0 2>/dev/null)
        [[ $gob_out -eq 0 ]] && echo "  (nessun path trovato)"

        # ── SIP EXTENSIONS ───────────────────────────────────
        _section "SIP EXTENSIONS"
        local sip_out=0
        while IFS= read -r -d '' f; do
            cat "$f" 2>/dev/null && sip_out=1
        done < <(find "$outdir" -name "sip_extensions.txt" -print0 2>/dev/null)
        [[ $sip_out -eq 0 ]] && echo "  (nessuna extension SIP trovata)"

        # ── MODULI COMPLETATI ─────────────────────────────────
        _section "MODULI"
        find "$outdir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | while IFS= read -r d; do
            local mod; mod=$(basename "$d")
            local log_lines; log_lines=$(find "$d" -name "*.log" -o -name "*.txt" 2>/dev/null | wc -l)
            printf "  %-15s → %d file output\n" "$mod" "$log_lines"
        done

        # ── ATTCK + OWASP MAPPING ─────────────────────────────
        _section "MITRE ATT&CK + OWASP IoT MAPPING"
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                local _attck; _attck=$(_attck_map "$line")
                local _owasp; _owasp=$(_owasp_iot_map "$line")
                printf "  %-50s | ATT&CK: %-40s | OWASP: %s\n" \
                    "${line:0:48}" "$_attck" "$_owasp"
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)

        # ── CVE ENRICHMENT ────────────────────────────────────
        _section "CVE ENRICHMENT (NVD)"
        local _cve_found=0
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                local _cve_id; _cve_id=$(echo "$line" | grep -oP 'CVE-[0-9]{4}-[0-9]+' | head -1 || true)
                [[ -z "$_cve_id" ]] && continue
                local _score; _score=$(_cvss_lookup "$_cve_id")
                printf "  %-20s CVSS: %s\n" "$_cve_id" "$_score"
                _cve_found=1
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        [[ $_cve_found -eq 0 ]] && echo "  (nessun CVE rilevato)"

        # ── IEC 62443 COMPLIANCE ──────────────────────────────
        _section "IEC 62443 — Industrial Cybersecurity Compliance"
        echo "SL-1 (Basic):"
        local _has_telnet _has_snmp_v1 _has_https _has_def_creds
        _has_telnet=$(find "$outdir" -name "findings.txt" -exec grep -li "telnet" {} \; 2>/dev/null | head -1)
        _has_snmp_v1=$(find "$outdir" -name "findings.txt" -exec grep -li "snmp" {} \; 2>/dev/null | head -1)
        _has_https=$(find "$outdir" -name "findings.txt" -exec grep -li "https\|tls\|ssl" {} \; 2>/dev/null | head -1)
        _has_def_creds=$(find "$outdir" -name "findings.txt" -exec grep -li "default\|credential\|brute" {} \; 2>/dev/null | head -1)
        [[ -n "$_has_telnet" ]]   && echo "  ✗ FAIL — Telnet trovato (req. 4.3.3.5.2: no unencrypted protocols)" \
                                 || echo "  ✓ PASS — Telnet non rilevato"
        [[ -n "$_has_snmp_v1" ]]  && echo "  ✗ FAIL — SNMP trovato (req. 4.3.3.3.3: secure protocols)" \
                                 || echo "  ✓ PASS — SNMP v1/v2c non rilevato"
        [[ -n "$_has_https" ]]    && echo "  ✓ PASS — HTTPS/TLS disponibile" \
                                 || echo "  ✗ FAIL — HTTPS/TLS non rilevato"
        echo "SL-2 (Medium):"
        [[ -n "$_has_def_creds" ]] && echo "  ✗ FAIL — Credenziali di default trovate (req. 4.3.3.7.2)" \
                                  || echo "  ✓ PASS — Nessuna credenziale di default rilevata"

        # ── EXECUTIVE SUMMARY ─────────────────────────────────
        _section "EXECUTIVE SUMMARY — Valutazione per il Cliente"
        # Conta findings
        local _es_crit=0 _es_high=0 _es_med=0 _es_low=0 _es_creds=0 _es_ports=0
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                case "$line" in
                    \[CRITICAL\]*) ((_es_crit++)) || true ;;
                    \[HIGH\]*)     ((_es_high++))  || true ;;
                    \[MEDIUM\]*)   ((_es_med++))   || true ;;
                    \[LOW\]*)      ((_es_low++))   || true ;;
                esac
                echo "$line" | grep -qi "login:\|password\|credential\|cred" && ((_es_creds++)) || true
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        local _nmap_f_es; _nmap_f_es=$(find "$outdir" -maxdepth 2 \
            \( -name "nmap_fast.nmap" -o -name "nmap_full.nmap" \) 2>/dev/null | head -1)
        [[ -n "$_nmap_f_es" ]] && _es_ports=$(grep -cE "^[0-9]+/tcp.*open" "$_nmap_f_es" 2>/dev/null || echo 0)
        local _es_cves; _es_cves=$(find "$outdir" -name "findings.txt" -exec grep -hoP 'CVE-[0-9]{4}-[0-9]+' {} \; 2>/dev/null | sort -u | wc -l)

        local _risk_lvl="BASSO"
        [[ $_es_low -gt 0 ]]  && _risk_lvl="BASSO"
        [[ $_es_med -gt 0 ]]  && _risk_lvl="MEDIO"
        [[ $_es_high -gt 0 ]] && _risk_lvl="ALTO"
        [[ $_es_crit -gt 0 || ( $_es_high -gt 0 && $_es_creds -gt 0 ) ]] && _risk_lvl="CRITICO"

        echo ""
        echo "══════════════════════════════════════════════════"
        echo "  EXECUTIVE SUMMARY — Valutazione per il Cliente"
        echo "══════════════════════════════════════════════════"
        echo "Livello di rischio globale: $_risk_lvl"
        echo ""
        echo "Punti critici:"
        printf "  • %d credenziali trovate (accesso confermato)\n" "$_es_creds"
        printf "  • %d porte ad alto rischio esposte\n" "$_es_ports"
        printf "  • %d CVE confermati\n" "$_es_cves"
        echo ""
        echo "Raccomandazioni prioritarie:"
        echo "  1. Cambiare immediatamente le credenziali di default"
        echo "  2. Aggiornare il firmware all'ultima versione"
        echo "  3. Disabilitare i servizi non necessari (Telnet, SNMP v1/v2)"
        echo "══════════════════════════════════════════════════"

        echo ""
        echo "═══════════════════════════════════════════════════"
        echo "  Fine report — $(date)"
        echo "═══════════════════════════════════════════════════"
    } | tee "$report_file" 2>/dev/null

    echo ""
    ok "Report salvato: $report_file"

    if [[ $do_html -eq 1 ]]; then
        local html_file="${report_file%.txt}.html"

        # Conta findings per severity
        local n_critical=0 n_high=0 n_medium=0 n_low=0 n_info=0
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                # Filtra righe rumore nmap/raw (iniziano con |, #, spazio+|)
                echo "$line" | grep -qP '^\s*[\|#]' && continue
                case "$line" in
                    \[CRITICAL\]*) ((n_critical++)) || true ;;
                    \[HIGH\]*)     ((n_high++))     || true ;;
                    \[MEDIUM\]*)   ((n_medium++))   || true ;;
                    \[LOW\]*)      ((n_low++))      || true ;;
                    *)             ((n_info++))     || true ;;
                esac
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        local n_total=$(( n_critical + n_high + n_medium + n_low + n_info ))
        local max_n=$(( n_total > 0 ? n_total : 1 ))

        # Porte aperte da nmap
        local nmap_file
        nmap_file=$(find "$outdir" -maxdepth 2 \( -name "nmap_fast.nmap" -o -name "nmap_full.nmap" \) 2>/dev/null | head -1)

        {
        cat << 'HTMLEOF'
