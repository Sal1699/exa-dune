                "$base_url/cgi-bin/api.cgi?cmd=Logout&rs=xxxx" "value\|code" "LOW"
            ;;
        audiocodes)
            # ── AudioCodes MP20x ─────────────────────────────────────────────
            # CVE-2019-9955: XSS in pagina di management web (GET /Forms/*)
            _cam_check "CVE-2019-9955" "AudioCodes XSS in web management /Forms/login_security_1.htm" \
                "$base_url/Forms/login_security_1.htm" "login\|security\|html\|form" "HIGH"
            _cam_check "CVE-2019-9955-form" "AudioCodes XSS via /Forms/ (pattern generico)" \
                "$base_url/Forms/" "title\|form\|input\|script" "HIGH"
            # CVE-2016-4960: Directory traversal via path nel firmware upgrade
            _cam_check "CVE-2016-4960" "AudioCodes directory traversal via firmware upgrade path" \
                "$base_url/Forms/firmware_upgrade_1.htm" "upgrade\|firmware\|upload\|path" "HIGH"
            # Default credentials check via web management
            _cam_check "DEFAULT-CREDS-LOGIN" "AudioCodes default credentials page esposta" \
                "$base_url/Forms/login_security_1.htm" "login\|LoginForm\|password" "MEDIUM"
            # Pagina di management senza auth
            _cam_check "MGMT-NOAUTH" "AudioCodes management page senza autenticazione" \
                "$base_url/Forms/" "AudioCodes\|Management\|System" "HIGH"
            # SNMP community "public" espone configurazione SIP
            if [[ $DRY_RUN -eq 0 ]] && command -v snmpwalk &>/dev/null; then
                log "AudioCodes: verifica SNMP community 'public' per config SIP..."
                local snmp_sip; snmp_sip=$(snmpwalk -v2c -c public -t 3 "$target" \
                    1.3.6.1.4.1.5003 2>/dev/null | head -10 || true)
                if [[ -n "$snmp_sip" ]]; then
                    found HIGH "AudioCodes SNMP 'public' espone config SIP (OID 1.3.6.1.4.1.5003): $(echo "$snmp_sip" | head -2)"
                    echo "[SNMP-SIP] $snmp_sip" | head -10 >> "$cve_out"
                else
                    log "  SNMP OID AudioCodes non raggiungibile o community non 'public'"
                fi
            elif [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} snmpwalk -v2c -c public $target 1.3.6.1.4.1.5003 (AudioCodes SIP OID)"
            fi
            # Default creds brute force indicativo (solo check rapido)
            # Baseline senza credenziali per evitare falsi positivi su form-based auth
            local _ac_noauth_code; _ac_noauth_code=$(curl $curl_opts -o /dev/null -w "%{http_code}" \
                "$base_url/Forms/login_security_1.htm" 2>/dev/null || echo 000)
            for cred_pair in "admin:admin" "Admin:Admin" "root:1234" "user:user"; do
                local ac_user; ac_user="${cred_pair%%:*}"
                local ac_pass; ac_pass="${cred_pair##*:}"
                if [[ $DRY_RUN -eq 0 ]]; then
                    local ac_body ac_code
                    ac_body=$(curl $curl_opts -u "${ac_user}:${ac_pass}" \
                        "$base_url/Forms/login_security_1.htm" 2>/dev/null || true)
                    ac_code=$(curl $curl_opts -o /dev/null -w "%{http_code}" \
                        -u "${ac_user}:${ac_pass}" "$base_url/Forms/login_security_1.htm" 2>/dev/null || echo 000)
                    # Autentica solo se: codice cambia da non-auth OPPURE body indica accesso (no login form)
                    if { [[ "$ac_code" == "200" && "$_ac_noauth_code" != "200" ]] || \
                         { [[ "$ac_code" == "200" ]] && echo "$ac_body" | grep -qi \
                           "logout\|management\|dashboard\|system status\|configuration" && \
                           ! echo "$ac_body" | grep -qi "LoginForm\|login_security\|<input.*password"; }; }; then
                        found CRITICAL "AudioCodes credenziali default trovate: ${ac_user}:${ac_pass} (HTTP $ac_code)"
                        echo "[DEFAULT-CRED] $ac_user:$ac_pass" >> "$cve_out"
                    fi
                else
                    echo -e "${CYAN}[DRY-RUN]${NC} Provo credenziali AudioCodes: ${cred_pair} su $base_url"
                fi
            done
            ;;
        commend)
            # ── Commend ET962-BF5xx ──────────────────────────────────────────
            # Default credentials check
            # Baseline senza credenziali — evita false positive su form-based auth (200 sempre)
            local _ce_noauth_code; _ce_noauth_code=$(curl $curl_opts -o /dev/null -w "%{http_code}" \
                "$base_url/" 2>/dev/null || echo 000)
            for cred_pair in "admin:admin" "Admin:Admin" "user:user" "root:root"; do
                local ce_user; ce_user="${cred_pair%%:*}"
                local ce_pass; ce_pass="${cred_pair##*:}"
                if [[ $DRY_RUN -eq 0 ]]; then
                    local ce_body ce_code
                    ce_body=$(curl $curl_opts -u "${ce_user}:${ce_pass}" "$base_url/" 2>/dev/null || true)
                    ce_code=$(curl $curl_opts -o /dev/null -w "%{http_code}" \
                        -u "${ce_user}:${ce_pass}" "$base_url/" 2>/dev/null || echo 000)
                    # Credenziali valide: codice Basic Auth cambia (401→200) O body indica pannello admin
                    if { [[ "$ce_code" == "200" && "$_ce_noauth_code" == "401" ]] || \
                         { [[ "$ce_code" == "200" ]] && echo "$ce_body" | grep -qi \
                           "logout\|dashboard\|configuration\|system\|status" && \
                           ! echo "$ce_body" | grep -qi "login\|password\|unauthorized"; }; }; then
                        found CRITICAL "Commend ET962 credenziali default: ${ce_user}:${ce_pass} (HTTP $ce_code)"
                        echo "[DEFAULT-CRED] $ce_user:$ce_pass" >> "$cve_out"
                    fi
                else
                    echo -e "${CYAN}[DRY-RUN]${NC} Provo credenziali Commend ET962: ${cred_pair} su $base_url"
                fi
            done
            # Web management su porta 80: /cgi-bin/ paths
            _cam_check "COMMEND-CGI" "Commend ET962 CGI directory esposta" \
                "$base_url/cgi-bin/" "cgi\|bin\|Index\|directory" "HIGH"
            _cam_check "COMMEND-CGI-STATUS" "Commend ET962 CGI status endpoint" \
                "$base_url/cgi-bin/status.cgi" "status\|system\|version" "MEDIUM"
            _cam_check "COMMEND-CGI-CONFIG" "Commend ET962 CGI config endpoint" \
                "$base_url/cgi-bin/config.cgi" "config\|admin\|password" "HIGH"
            # RTSP stream su porta 554 spesso senza auth
            if [[ $DRY_RUN -eq 0 ]]; then
                log "Commend ET962: verifica RTSP su porta 554 senza autenticazione..."
                local rtsp_check; rtsp_check=$(curl -s --max-time 5 \
                    "rtsp://${target}:554/" 2>/dev/null || \
                    nc -z -w 3 "$target" 554 2>/dev/null && echo "porta aperta" || true)
                if echo "$rtsp_check" | grep -qi "porta aperta\|RTSP\|200 OK"; then
                    found HIGH "Commend ET962 RTSP porta 554 raggiungibile (possibile stream senza auth)"
                    echo "[RTSP-OPEN] porta 554 aperta" >> "$cve_out"
                fi
            else
                echo -e "${CYAN}[DRY-RUN]${NC} Verifica RTSP Commend ET962: rtsp://${target}:554/"
            fi
            # SIP registration senza autenticazione
            if [[ $DRY_RUN -eq 0 ]] && command -v svmap &>/dev/null; then
                log "Commend ET962: verifica SIP registration senza autenticazione..."
                local sip_check_out="$OUTDIR/commend_sip_check.txt"
                timeout 15 svmap --transport=udp "$target" -p 5060 2>/dev/null | tee "$sip_check_out" || true
                if grep -qi "200\|SIP\|registration" "$sip_check_out" 2>/dev/null; then
                    found HIGH "Commend ET962 SIP service risponde — verifica auth su porta 5060"
                fi
            elif [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} svmap --transport=udp $target -p 5060 (Commend SIP check)"
            fi
            ;;
        generic|*)
            # Generic camera checks (work across multiple vendors)
            _cam_check "GENERIC-SNAPSHOT" "Unauthenticated snapshot" \
                "$base_url/cgi-bin/snapshot.cgi" "JFIF\|Content-Type.*image" "HIGH"
            _cam_check "GENERIC-CONFIG" "Config backup unauthenticated" \
                "$base_url/cgi-bin/config.cgi" "admin\|password\|ssid" "HIGH"
            _cam_check "GENERIC-RTSP" "RTSP credential in web response" \
                "$base_url/cgi-bin/hi3510/param.cgi?cmd=getrtspurl" "rtsp://\|\"password\"\|\"credential\"\|\"passwd\"" "HIGH"
            _cam_check "GENERIC-EXEC" "Exec CGI endpoint" \
                "$base_url/cgi-bin/exec.cgi" "" "MEDIUM"
            _cam_check "GENERIC-DEBUG" "Debug endpoint exposed" \
                "$base_url/cgi-bin/debug.cgi" "" "MEDIUM"
            _cam_check "ONVIF-INFO" "ONVIF device info unauthenticated" \
                "${scheme}://${target}:8000" "onvif\|soap\|device" "MEDIUM"
            ;;
    esac

    local cam_batch_script="$EXA_SCRIPTS_DIR/python/cam_cve_batch.py"
    if [[ -f "$cam_batch_script" ]]; then
        section "Camera CVE Batch Check (cam_cve_batch.py)"
        run_cmd "cam_cve_batch_py" "python3 \"$cam_batch_script\" $target --vendor ${vendor:-auto} 2>&1 | tee \"$OUTDIR\"/cam_cve_batch.txt"
    fi

    ok "Camera CVE scan completato → $OUTDIR (vendor: $vendor)"
}

# ============================================================
#  SUBCOMMAND: sip-fuzz
# ============================================================
usage_sipfuzz() {
    echo "Uso: exa-dune sip-fuzz <TARGET> [OPTIONS]"
    echo ""
    echo "  SIP Fuzzing — invia messaggi SIP malformati e stress test."
    echo "  Usa sipsak per OPTIONS flood, header fuzzing, tracerouting SIP."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta SIP (default: 5060)"
    echo "  --method M       Metodo SIP: OPTIONS|INVITE|REGISTER (default: OPTIONS)"
    echo "  --count N        Numero di messaggi (default: 50)"
    echo "  --sleep MS       Delay tra messaggi in ms (default: 100)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_sipfuzz() {
    local target="" port=5060 method="OPTIONS" count=50 sleep_ms=100
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";      shift 2 ;;
            --method)    _req_arg "$1" "${2:-}"; method="$2";    shift 2 ;;
            --count)     _req_arg "$1" "${2:-}"; count="$2";     shift 2 ;;
            --sleep)     _req_arg "$1" "${2:-}"; sleep_ms="$2";  shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --stealth)   STEALTH=1;      shift ;;
            --dry-run)   DRY_RUN=1;      shift ;;
            --help|-h)   usage_sipfuzz; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_sipfuzz; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_sipfuzz; exit 1; }
    check_root
    setup_outdir "$target" "sip_fuzz"
    log "Target: $target:$port | Metodo: $method | Output: $OUTDIR"

    # ── sipsak: SIP Swiss Army Knife ─────────────────────────
    section "SIP $method Probe (sipsak)"
    local sipsak_out="$OUTDIR/sipsak_probe.txt"
    if command -v sipsak &>/dev/null; then
        # Single OPTIONS probe con verbose
        run_cmd "sipsak_probe" "sipsak -v -s sip:probe@${target}:${port} 2>&1 | tee $sipsak_out"
        if [[ -s "$sipsak_out" ]]; then
            # Server banner e Allow
            local server_hdr; server_hdr=$(grep -i "^Server:" "$sipsak_out" 2>/dev/null | head -1 || true)
            local allow_hdr; allow_hdr=$(grep -i "^Allow:" "$sipsak_out" 2>/dev/null | head -1 || true)
            [[ -n "$server_hdr" ]] && found "INFO" "SIP-FUZZ" "Server: $server_hdr"
            [[ -n "$allow_hdr" ]] && found "INFO" "SIP-FUZZ" "Metodi SIP permessi: $allow_hdr"
            if grep -q "200\|OK" "$sipsak_out" 2>/dev/null; then
                found "MEDIUM" "SIP-FUZZ" "Server SIP risponde a $method senza auth"
            fi
        fi
    else
        warn "sipsak non trovato — installa: apt install sipsak"
    fi

    # ── sipsak: SIP Trace/Traceroute ─────────────────────────
    section "SIP Trace (sipsak -T)"
    local trace_out="$OUTDIR/sipsak_trace.txt"
    if command -v sipsak &>/dev/null && [[ $DRY_RUN -eq 0 ]]; then
        timeout 20 sipsak -T -s "sip:trace@${target}:${port}" 2>&1 | tee "$trace_out" || true
        if grep -qi "hop\|Via\|200\|486" "$trace_out" 2>/dev/null; then
            found "INFO" "SIP-FUZZ" "SIP trace: $(wc -l < "$trace_out") hop(s) rilevati"
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} sipsak -T -s sip:trace@${target}:${port}" 
    fi

    # ── sipsak: INVITE flood (stress test) ───────────────────
    if [[ "$method" == "INVITE" ]]; then
        section "SIP INVITE Stress Test"
        local flood_out="$OUTDIR/sipsak_flood.txt"
        if command -v sipsak &>/dev/null; then
            run_cmd "sipsak_flood" "sipsak -f $count -s sip:stress@${target}:${port} 2>&1 | tee $flood_out"
            if grep -qi "flood\|request sent\|reply" "$flood_out" 2>/dev/null; then
                found "HIGH" "SIP-FUZZ" "INVITE stress test: server $target risponde — possibile DoS"
            fi
        fi
    fi

    # ── SIP nmap fuzzer NSE ───────────────────────────────────
    section "SIP Header Analysis (nmap sip-methods)"
    local nmap_sip="$OUTDIR/nmap_sip_methods.txt"
    run_cmd "nmap_sip" "nmap -sU -p $port --script sip-methods,sip-enum-users $NMAP_TIMING $target 2>/dev/null | tee $nmap_sip"
    if [[ -s "$nmap_sip" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*Method|^\|.*Extension" || continue
            found "INFO" "SIP-FUZZ" "$line"
        done < "$nmap_sip"
    fi

    ok "SIP fuzzing completato → $OUTDIR"
}

