# Helper: parse porte 'filtered' da un file gnmap
_fw_filtered() {
    grep "Ports:" "$1" 2>/dev/null | \
        grep -oP '[0-9]+/filtered(?!/\!)' | cut -d/ -f1 | sort -n || true
}
# Helper: parse porte 'open' da un file gnmap
_fw_open() {
    grep "Ports:" "$1" 2>/dev/null | \
        grep -oP '[0-9]+/open' | cut -d/ -f1 | sort -n || true
}
# Helper: parse porte 'unfiltered' da un file gnmap
_fw_unfiltered() {
    grep "Ports:" "$1" 2>/dev/null | \
        grep -oP '[0-9]+/unfiltered' | cut -d/ -f1 | sort -n || true
}
# Helper: porta in lista? (newline-separated)
_fw_in_list() {
    local port="$1" list="$2"
    echo "$list" | grep -q "^${port}$"
}
# Helper: MAC → IPv6 link-local (EUI-64)
_mac_to_link_local() {
    local mac="$1"
    IFS=':' read -ra o <<< "$mac"
    local f; f=$(printf '%02x' $(( 16#${o[0]} ^ 0x02 )) )
    printf 'fe80::%s%s:%sff:fe%s:%s%s\n' \
        "$f" "${o[1]}" "${o[2]}" "${o[3]}" "${o[4]}" "${o[5]}"
}

cmd_fw() {
    local target="" ports_str="22,23,80,443,445,5060,8080,8443,8554,21,25,53,554,2323"
    local tech_str="all" sip_port=5060 upnp_port="" probe_port=14444
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ports)      ports_str="$2";    shift 2 ;;
            --tech)       tech_str="$2";     shift 2 ;;
