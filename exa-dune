    # ── Rate limiting detection ───────────────────────────────────
    # Rileva HTTP 429/503 o backoff progressivo prima del brute-force
    _ratelimit_check() {
        local _sc="$1" _po="$2"
        local _ins=""; [[ "$_sc" == "https" ]] && _ins="-k"
        local _blocked=0 _delays=()
        for _i in 1 2 3; do
            local _t0; _t0=$(date +%s%3N 2>/dev/null || date +%s)
            local _code
            _code=$(curl -s $_ins -o /dev/null -w "%{http_code}" \
                --user "exa_rl_probe_$$:wrongpass_$$" --max-time 4 \
                "${_sc}://${target}:${_po}/" 2>/dev/null || echo "000")
            local _t1; _t1=$(date +%s%3N 2>/dev/null || date +%s)
            _delays+=("$(( _t1 - _t0 ))")
            [[ "$_code" == "429" || "$_code" == "503" || "$_code" == "429" ]] && _blocked=1 && break
        done
        if [[ $_blocked -eq 1 ]]; then
            warn "  Rate limiting su ${_sc}:${_po} (HTTP 429/503) — brute-force rallentato"
            HYDRA_RATE_OPTS="-t 1 -W 5 -w 8"
            return 0
        fi
        # Backoff progressivo: l'ultimo tentativo è 3x più lento del primo
        if [[ ${#_delays[@]} -ge 3 && ${_delays[-1]} -gt $(( ${_delays[0]} * 3 )) && ${_delays[-1]} -gt 2000 ]]; then
            warn "  Backoff progressivo rilevato su ${_sc}:${_po} — brute-force rallentato"
            HYDRA_RATE_OPTS="-t 1 -W 3"
            return 0
        fi
        HYDRA_RATE_OPTS=""
        return 1
