EXA_DB="/root/pentest/exa-dune.db"

_db_init() {
    [[ "$DRY_RUN" -eq 1 ]] && return
    command -v sqlite3 &>/dev/null || { warn "sqlite3 non disponibile — storia assessment disabilitata"; return 1; }
    mkdir -p "$(dirname "$EXA_DB")"
    sqlite3 "$EXA_DB" << 'DBEOF' 2>/dev/null
CREATE TABLE IF NOT EXISTS assessments (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    target TEXT,
    module TEXT,
    timestamp TEXT,
    outdir TEXT,
    findings_count INTEGER DEFAULT 0,
    critical_count INTEGER DEFAULT 0,
    high_count INTEGER DEFAULT 0
);
CREATE TABLE IF NOT EXISTS findings (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    assessment_id INTEGER,
    severity TEXT,
    message TEXT,
    timestamp TEXT
);
DBEOF
    return 0
}

_db_insert_assessment() {
    [[ "$DRY_RUN" -eq 1 ]] && return
    command -v python3 &>/dev/null || return 1
    local target="$1" module="${2:-}" outdir="${3:-}"
    local ts; ts=$(date -u +%Y-%m-%dT%H:%M:%S)
    export V_TARGET="$target" V_MODULE="$module" V_OUTDIR="$outdir" V_TS="$ts"
    _EXA_DB_ASSESSMENT_ID=$(python3 - <<'PYEOF'
import sqlite3, os
db = os.environ['EXA_DB']
conn = sqlite3.connect(db)
cur = conn.execute(
    "INSERT INTO assessments (target,module,timestamp,outdir) VALUES (?,?,?,?)",
    (os.environ['V_TARGET'], os.environ['V_MODULE'], os.environ['V_TS'], os.environ['V_OUTDIR'])
)
conn.commit()
print(cur.lastrowid)
conn.close()
PYEOF
2>/dev/null || echo "")
    export _EXA_DB_ASSESSMENT_ID
    unset V_TARGET V_MODULE V_OUTDIR V_TS
}

_db_update_assessment() {
    [[ "$DRY_RUN" -eq 1 ]] && return
    command -v sqlite3 &>/dev/null || return 1
    local id="${_EXA_DB_ASSESSMENT_ID:-}"
    [[ -z "$id" ]] && return
    local outdir="$1"
    local n_total=0 n_crit=0 n_high=0
    if [[ -n "$outdir" ]]; then
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                case "$line" in
                    \[CRITICAL\]*) ((n_crit++)) || true; ((n_total++)) || true ;;
                    \[HIGH\]*)     ((n_high++)) || true; ((n_total++)) || true ;;
                    \[MEDIUM\]*|\[LOW\]*) ((n_total++)) || true ;;
                esac
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null)
    fi
    export V_ID="$id" V_NTOTAL="$n_total" V_NCRIT="$n_crit" V_NHIGH="$n_high"
    python3 - <<'PYEOF' 2>/dev/null || true
import sqlite3, os
db = os.environ['EXA_DB']
conn = sqlite3.connect(db)
conn.execute(
    "UPDATE assessments SET findings_count=?, critical_count=?, high_count=? WHERE id=?",
    (int(os.environ['V_NTOTAL']), int(os.environ['V_NCRIT']), int(os.environ['V_NHIGH']), int(os.environ['V_ID']))
)
conn.commit()
conn.close()
PYEOF
    unset V_ID V_NTOTAL V_NCRIT V_NHIGH
}

_db_insert_finding() {
    [[ "$DRY_RUN" -eq 1 ]] && return
    command -v python3 &>/dev/null || return 1
    local sev="$1" msg="$2"
    local id="${_EXA_DB_ASSESSMENT_ID:-0}"
    local ts; ts=$(date -u +%Y-%m-%dT%H:%M:%S)
    export V_ID="$id" V_SEV="$sev" V_MSG="$msg" V_TS="$ts"
    python3 - <<'PYEOF' 2>/dev/null || true
import sqlite3, os
db = os.environ['EXA_DB']
conn = sqlite3.connect(db)
conn.execute(
    "INSERT INTO findings (assessment_id,severity,message,timestamp) VALUES (?,?,?,?)",
    (int(os.environ['V_ID']), os.environ['V_SEV'], os.environ['V_MSG'], os.environ['V_TS'])
)
conn.commit()
conn.close()
PYEOF
    unset V_ID V_SEV V_MSG V_TS
}

usage_history() {
    echo "Uso: exa-dune history [OPTIONS]"
    echo ""
    echo "  Mostra lo storico degli assessment dal database SQLite."
    echo ""
    echo "Opzioni:"
    echo "  --target TARGET    Filtra per target"
    echo "  --last N           Mostra ultimi N assessment"
    echo "  --findings ID      Mostra finding dell'assessment con ID specificato"
}

cmd_history() {
    local filter_target="" last_n="" findings_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)   _req_arg "--target" "${2:-}"; filter_target="$2"; shift 2 ;;
            --last)     _req_arg "--last" "${2:-}"; last_n="$2"; shift 2 ;;
            --findings) _req_arg "--findings" "${2:-}"; findings_id="$2"; shift 2 ;;
            --help|-h)  usage_history; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_history; exit 1 ;;
            *)          shift ;;
        esac
    done

    # FIX 6 — validazione numerica
    if [[ -n "$last_n" ]]; then
        [[ "$last_n" =~ ^[0-9]+$ ]] || { err "--last richiede un numero intero positivo"; exit 1; }
    fi
    if [[ -n "$findings_id" ]]; then
        [[ "$findings_id" =~ ^[0-9]+$ ]] || { err "--findings richiede un ID numerico"; exit 1; }
    fi

    command -v python3 &>/dev/null || { err "python3 non disponibile"; exit 1; }
    _db_init

    if [[ ! -f "$EXA_DB" ]]; then
        log "Database non ancora creato: $EXA_DB"
        log "Verrà creato automaticamente alla prossima esecuzione di un modulo."
        return 0
    fi

    banner
    section "Storico Assessment (${EXA_DB})"

    # Temp script helper per query parametrizzate (evita heredoc in subshell)
    local _py_tmp; _py_tmp=$(mktemp /tmp/exa_hist_XXXXXX.py)
    # shellcheck disable=SC2064
    trap "rm -f '$_py_tmp'" RETURN

    if [[ -n "$findings_id" ]]; then
        # Mostra header assessment — FIX 1d parametri bind
        cat > "$_py_tmp" << 'PYEOF'
import sqlite3, os
db = os.environ['EXA_DB']
conn = sqlite3.connect(db)
row = conn.execute(
    "SELECT target,module,timestamp,outdir FROM assessments WHERE id=?",
    (int(os.environ['V_FID']),)
).fetchone()
conn.close()
if row:
    print('|'.join(str(c) if c is not None else '' for c in row))
PYEOF
        local rec
        export V_FID="$findings_id"
        rec=$(python3 "$_py_tmp" 2>/dev/null || echo "")
        unset V_FID
        if [[ -z "$rec" ]]; then
            err "Assessment ID $findings_id non trovato"
            rm -f "$_py_tmp"
            exit 1
        fi
        local a_target a_module a_ts a_outdir
        IFS='|' read -r a_target a_module a_ts a_outdir <<< "$rec"
        log "Assessment #$findings_id — Target: $a_target  Modulo: $a_module  Data: $a_ts"
        log "Output: $a_outdir"
        echo ""
        printf "  %-10s %-12s %s\n" "SEVERITY" "TIMESTAMP" "MESSAGGIO"
        printf "  %-10s %-12s %s\n" "─────────" "───────────" "──────────────────────────────────"
        cat > "$_py_tmp" << 'PYEOF'
import sqlite3, os
db = os.environ['EXA_DB']
conn = sqlite3.connect(db)
for row in conn.execute(
    "SELECT severity, timestamp, message FROM findings WHERE assessment_id=? ORDER BY id",
    (int(os.environ['V_FID']),)
):
    print('|'.join(str(c) if c is not None else '' for c in row))
conn.close()
PYEOF
        export V_FID="$findings_id"
        local findings_rows
        findings_rows=$(python3 "$_py_tmp" 2>/dev/null || true)
        unset V_FID
        while IFS='|' read -r sev ts msg; do
            local color
            case "$sev" in
                CRITICAL) color='\033[1;31m' ;;
                HIGH)     color='\033[0;31m' ;;
                MEDIUM)   color='\033[1;33m' ;;
                LOW)      color='\033[0;36m' ;;
                *)        color='\033[0;32m' ;;
            esac
            printf "  ${color}%-10s${NC} %-20s %s\n" "$sev" "$ts" "$msg"
        done <<< "$findings_rows"
        rm -f "$_py_tmp"
        return 0
    fi

    # Query principale — FIX 1d parametri bind
    printf "  %-5s %-18s %-12s %-22s %-8s %-8s %-8s %s\n" \
        "ID" "TARGET" "MODULO" "DATA" "FINDING" "CRIT" "HIGH" "OUTDIR"
    printf "  %s\n" "─────────────────────────────────────────────────────────────────────────────────────"

    cat > "$_py_tmp" << 'PYEOF'
import sqlite3, os
db = os.environ['EXA_DB']
ft = os.environ.get('V_FILTER_TARGET', '')
ln = os.environ.get('V_LAST_N', '')
conn = sqlite3.connect(db)
if ft:
    q = "SELECT id,target,module,timestamp,findings_count,critical_count,high_count,outdir FROM assessments WHERE target=? ORDER BY id DESC"
    params = [ft]
else:
    q = "SELECT id,target,module,timestamp,findings_count,critical_count,high_count,outdir FROM assessments ORDER BY id DESC"
    params = []
if ln:
    q += " LIMIT ?"
    params.append(int(ln))
for row in conn.execute(q, params):
    print('|'.join(str(c) if c is not None else '' for c in row))
conn.close()
PYEOF
    export V_FILTER_TARGET="${filter_target}" V_LAST_N="${last_n}"
    local assess_rows
    assess_rows=$(python3 "$_py_tmp" 2>/dev/null || true)
    unset V_FILTER_TARGET V_LAST_N
    while IFS='|' read -r id tgt mod ts fc cc hc od; do
        local color='\033[0;32m'
        [[ "${cc:-0}" -gt 0 ]] && color='\033[1;31m'
        [[ "${cc:-0}" -eq 0 && "${hc:-0}" -gt 0 ]] && color='\033[0;31m'
        printf "  ${color}%-5s${NC} %-18s %-12s %-22s %-8s %-8s %-8s %s\n" \
            "${id}" "${tgt:0:18}" "${mod:0:12}" "${ts:0:22}" "${fc:-0}" "${cc:-0}" "${hc:-0}" "${od:0:40}"
    done <<< "$assess_rows"

    cat > "$_py_tmp" << 'PYEOF'
import sqlite3, os
db = os.environ['EXA_DB']
ft = os.environ.get('V_FILTER_TARGET', '')
conn = sqlite3.connect(db)
if ft:
    row = conn.execute("SELECT COUNT(*) FROM assessments WHERE target=?", (ft,)).fetchone()
else:
    row = conn.execute("SELECT COUNT(*) FROM assessments").fetchone()
print(row[0] if row else 0)
conn.close()
PYEOF
    echo ""
    export V_FILTER_TARGET="${filter_target}"
    local total
    total=$(python3 "$_py_tmp" 2>/dev/null || echo 0)
    unset V_FILTER_TARGET
    rm -f "$_py_tmp"
    log "Totale assessment in archivio: $total"
}

# ============================================================
#  MODULO: printer — IPP / JetDirect / PJL
# ============================================================
usage_printer() {
    echo "Uso: exa-dune printer TARGET [OPTIONS]"
    echo ""
    echo "  Audit stampanti di rete: PJL (porta 9100), IPP (631), LPD (515)."
    echo "  Testa accesso non autenticato, dump filesystem, model/firmware info."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta JetDirect (default: 9100)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_printer() {
    local target="" port=9100
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_printer; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_printer; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_printer; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "printer"
    log "Target: $target | Output: $OUTDIR"

    section "Printer — JetDirect PJL :$port"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" "$port"; then
            local _pjl_cmds=(
                $'\x1b%-12345X@PJL\r\n@PJL INFO ID\r\n\x1b%-12345X'
                $'\x1b%-12345X@PJL\r\n@PJL INFO STATUS\r\n\x1b%-12345X'
                $'\x1b%-12345X@PJL\r\n@PJL INFO FILESYS\r\n\x1b%-12345X'
                $'\x1b%-12345X@PJL\r\n@PJL FSDIRLIST NAME="0:/" ENTRY=1 COUNT=99\r\n\x1b%-12345X'
            )
            local _pjl_labels=("info_id" "status" "filesys" "fsdirlist")
            local _i=0
            for _cmd in "${_pjl_cmds[@]}"; do
                local _label="${_pjl_labels[$_i]}"
                local _out
                _out=$(printf '%s' "$_cmd" | timeout 6 nc -w 5 "$target" "$port" 2>/dev/null || true)
                echo "$_out" > "$OUTDIR/pjl_${_label}.txt"
                if [[ -n "$_out" ]]; then
                    if echo "$_out" | grep -qi "HP\|Lexmark\|Brother\|Canon\|Epson\|Xerox\|Konica\|OKI\|Ricoh\|Samsung\|@PJL\|READY\|ONLINE"; then
                        found HIGH "Printer PJL:$port — risposta a PJL $_label"
                        local _model; _model=$(echo "$_out" | grep -oiP '(?<=ID=)\S[^\r\n]+' | head -1 || true)
                        [[ -n "$_model" ]] && found HIGH "Printer modello: $_model"
                    fi
                    if echo "$_out" | grep -qi '0:/\|1:/\|NAME='; then
                        found CRITICAL "Printer PJL:$port — filesystem esposto via FSDIRLIST"
                    fi
                fi
                ((_i++)) || true
            done
            # Tenta lettura /etc/passwd via PJL FSQUERY
            local _pjl_read
            _pjl_read=$(printf '\x1b%%-12345X@PJL\r\n@PJL FSQUERY NAME="0:/etc/passwd"\r\n\x1b%%-12345X' | \
                timeout 6 nc -w 5 "$target" "$port" 2>/dev/null || true)
            echo "$_pjl_read" > "$OUTDIR/pjl_fsquery_passwd.txt"
            echo "$_pjl_read" | grep -qi "FILEERR\|FILESIZE\|root:" && \
                found CRITICAL "Printer PJL:$port — lettura file system (FSQUERY)"
        else
            warn "Porta $port chiusa — JetDirect non raggiungibile"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} PJL probe su $target:$port (INFO ID/STATUS/FILESYS/FSDIRLIST)"
    fi

    section "Printer — IPP :631"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" 631; then
            # IPP Get-Printer-Attributes via HTTP POST
            local _ipp_payload
            _ipp_payload=$(printf '\x01\x01\x00\x0b\x00\x00\x00\x01\x01\x47\x00\x12attributes-charset\x05utf-8\x48\x00\x1battributes-natural-language\x05en-us\x45\x00\x0bprinter-uri\x15ipp://localhost/ipp/\x03')
            local _ipp_resp
            _ipp_resp=$(printf '%s' "$_ipp_payload" | \
                curl -s --max-time 8 -X POST \
                    -H "Content-Type: application/ipp" \
                    --data-binary @- \
                    "http://$target:631/ipp" 2>/dev/null || true)
            echo "$_ipp_resp" > "$OUTDIR/ipp_attrs.bin"
            if [[ -n "$_ipp_resp" ]]; then
                found MEDIUM "Printer IPP:631 — servizio attivo"
                # Prova anche l'interfaccia web CUPS
                local _cups
                _cups=$(curl -s --max-time 5 "http://$target:631/" 2>/dev/null | grep -oiP '<title>[^<]+' | head -1 || true)
                [[ -n "$_cups" ]] && found MEDIUM "Printer CUPS:631 — web UI: $_cups"
            fi
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} IPP Get-Printer-Attributes su $target:631"
    fi

    section "Printer — LPD :515"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" 515; then
            local _lpd_resp
            _lpd_resp=$(printf '\x01\n' | timeout 5 nc -w 4 "$target" 515 2>/dev/null | xxd | head -3 || true)
            [[ -n "$_lpd_resp" ]] && found MEDIUM "Printer LPD:515 — servizio attivo (LPR/LPD)"
            echo "$_lpd_resp" > "$OUTDIR/lpd_probe.txt"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} LPD probe su $target:515"
    fi

    section "Printer — nmap NSE"
    run_cmd "nmap_printer" \
        "nmap -p $port,631,515 --script printer-info,pjl-ready-message,ipp-tags \
         -oN \"$OUTDIR/nmap_printer.nmap\" $target 2>/dev/null"
    [[ $DRY_RUN -eq 0 ]] && grep -qi "printer\|PJL\|model\|status" \
        "$OUTDIR/nmap_printer.nmap" 2>/dev/null && \
        found MEDIUM "Printer NSE — informazioni dispositivo rilevate"

    ok "Printer audit completato → $OUTDIR"
}

# ============================================================
#  MODULO: amqp — RabbitMQ / AMQP
# ============================================================
usage_amqp() {
    echo "Uso: exa-dune amqp TARGET [OPTIONS]"
    echo ""
    echo "  Audit RabbitMQ/AMQP: test accesso anonimo, default creds,"
    echo "  Management API (15672), vhost/queue/user enumeration."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta AMQP (default: 5672)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_amqp() {
    local target="" port=5672
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_amqp; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_amqp; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_amqp; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "amqp"
    log "Target: $target:$port | Output: $OUTDIR"

    section "AMQP Banner Grab :$port"
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" "$port"; then
            # AMQP handshake: invia "AMQP\x00\x00\x09\x01" (protocol header AMQP 0-9-1)
            local _amqp_banner
            _amqp_banner=$(printf 'AMQP\x00\x00\x09\x01' | timeout 6 nc -w 5 "$target" "$port" 2>/dev/null | strings | head -10 || true)
            echo "$_amqp_banner" > "$OUTDIR/amqp_banner.txt"
            if [[ -n "$_amqp_banner" ]]; then
                found HIGH "AMQP:$port — servizio risponde (broker identificato)"
                local _ver; _ver=$(echo "$_amqp_banner" | grep -oiP 'RabbitMQ\s[\d.]+|AMQP[\s\d.]+' | head -1 || true)
                [[ -n "$_ver" ]] && found HIGH "AMQP:$port — versione: $_ver"
            fi
        else
            warn "Porta $port chiusa — AMQP non raggiungibile"
            ok "AMQP audit completato → $OUTDIR"; return
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} AMQP handshake probe su $target:$port"
    fi

    section "AMQP Management API :15672"
    local _mgmt_ok=0
    local _default_creds=("guest:guest" "admin:admin" "rabbitmq:rabbitmq" "admin:password" "user:user")
    if [[ $DRY_RUN -eq 0 ]]; then
        if check_port "$target" 15672; then
            found MEDIUM "RabbitMQ Management UI:15672 — porta aperta"
            for _cred in "${_default_creds[@]}"; do
                local _u="${_cred%%:*}" _p="${_cred##*:}"
                local _code
