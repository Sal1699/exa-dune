                _rresp=$(timeout 5 bash -c \
                    "printf 'DESCRIBE rtsp://${target}:${_rtsp_port}${_rp} RTSP/1.0\r\nCSeq: 1\r\n\r\n' \
                     | nc -q 2 ${target} ${_rtsp_port} 2>/dev/null" || true)
