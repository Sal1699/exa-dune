                    "http://$target:15672/api/overview" 2>/dev/null || echo "000")
                if [[ "$_code" == "200" ]]; then
                    found CRITICAL "RabbitMQ:15672 — accesso con ${_u}:${_p}"
                    _mgmt_ok=1
                    # Dump overview, vhosts, queues, users
                    for _api_ep in "overview" "vhosts" "queues" "users" "connections" "exchanges"; do
                        curl -s --user "${_u}:${_p}" --max-time 8 \
                            "http://$target:15672/api/$_api_ep" 2>/dev/null | \
                            python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps(d,indent=2))" \
                            2>/dev/null > "$OUTDIR/mgmt_${_api_ep}.json" || true
                    done
                    break
                fi
            done
            if [[ $_mgmt_ok -eq 0 ]]; then
                # Prova brute force hydra sulla management UI
                if tool_ok hydra; then
                    local _ul; _ul=$(_wl_users)
                    local _pl; _pl=$(_wl_pass)
                    run_cmd "hydra_amqp" \
                        "hydra -L \"$_ul\" -P \"$_pl\" -s 15672 -t 4 -f -w 4 -W 2 \
                         -o \"$OUTDIR/hydra_amqp_mgmt.txt\" $target http-get /api/overview 2>&1"
                    grep -i "login:" "$OUTDIR/hydra_amqp_mgmt.txt" 2>/dev/null | \
                        while IFS= read -r _l; do found HIGH "RabbitMQ:15672 brute-force — $_l"; done || true
                fi
            fi
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} RabbitMQ Management API probe $target:15672 (default creds + hydra)"
    fi

    section "AMQP Erlang Port Mapper :25672"
    if [[ $DRY_RUN -eq 0 ]] && check_port "$target" 25672; then
        local _erl_banner
        _erl_banner=$(timeout 5 nc -w 4 "$target" 25672 </dev/null 2>/dev/null | strings | head -5 || true)
        echo "$_erl_banner" > "$OUTDIR/erlang_banner.txt"
        [[ -n "$_erl_banner" ]] && found HIGH "RabbitMQ Erlang dist:25672 — porta esposta (clustering attack possibile)"
    fi

    ok "AMQP audit completato → $OUTDIR"
}

