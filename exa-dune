cmd_bacnet() {
    local target="" port=47808
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";         shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_bacnet; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_bacnet; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_bacnet; exit 1; }
    check_root
    setup_outdir "$target" "bacnet"
    log "Target: $target:$port | Output: $OUTDIR"

    # ── nmap BACnet NSE scripts ───────────────────────────────
    section "BACnet/IP — nmap bacnet-info"
    local nmap_bacnet="$OUTDIR/nmap_bacnet.txt"
    run_cmd "nmap_bacnet" "nmap -sU -p $port --script bacnet-info -oN \"$nmap_bacnet\" $NMAP_TIMING $target 2>/dev/null"
    if [[ -s "$nmap_bacnet" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*(" || continue
            found "HIGH" "BACnet" "$line"
        done < "$nmap_bacnet"
        ok "nmap BACnet completato"
    fi

    # ── BACnet Who-Is broadcast via Python3 ──────────────────
    section "BACnet Who-Is Broadcast"
    local whois_out="$OUTDIR/bacnet_whois.txt"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} BACnet Who-Is su $target:$port"
    else
        BACNET_TARGET="$target" BACNET_PORT_ENV="$port" \
        python3 - <<'PYEOF' > "$whois_out" 2>&1 || true
import socket, struct, time, os

BACNET_PORT = int(os.environ['BACNET_PORT_ENV'])
bacnet_target = os.environ['BACNET_TARGET']

# BACnet Who-Is NPDU + APDU (broadcast)
# BVLL Type=0x81 Function=0x0b (original-unicast-npdu) + NPDU + APDU
whois = bytes([
    0x81, 0x0b,          # BVLL: BACnet/IP, Original-Unicast-NPDU
    0x00, 0x09,          # BVLL Length: 9 bytes
    0x01, 0x00,          # NPDU version=1, control=0
    0x10, 0x08,          # APDU: unconfirmed-req, Who-Is
    0x00, 0x00, 0xff, 0xff, 0xff  # Range: all devices
])
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.settimeout(5)
    s.sendto(whois, (bacnet_target, BACNET_PORT))
    s.sendto(whois, ("255.255.255.255", BACNET_PORT))
    print(f"[BACnet] Who-Is broadcast inviato a {BACNET_PORT}/UDP")
    deadline = time.time() + 5
    while time.time() < deadline:
        try:
            data, addr = s.recvfrom(1024)
            print(f"[BACnet] I-Am risposta da {addr[0]}: {data.hex()}")
        except socket.timeout:
            break
        except: break
    s.close()
except Exception as e:
    print(f"[BACnet] Errore: {e}")
PYEOF
        if grep -q "I-Am risposta" "$whois_out" 2>/dev/null; then
            while IFS= read -r line; do
                echo "$line" | grep -q "I-Am risposta" && found "HIGH" "BACnet" "Dispositivo BACnet: $line"
            done < "$whois_out"
        else
            log "Nessuna risposta BACnet I-Am ricevuta"
        fi
    fi

    # ── nmap scan BACnet port ────────────────────────────────
    section "BACnet Port Scan"
    local bacnet_tcp="$OUTDIR/nmap_bacnet_tcp.txt"
    run_cmd "nmap_bacnet_tcp" "nmap -p $port -sV --script bacnet-info $NMAP_TIMING $target 2>/dev/null | tee \"$bacnet_tcp\""

    ok "BACnet audit completato → $OUTDIR"
}

