                # Enumera ogni risorsa trovata
                grep -oP '(?<=<)[^>]+(?=>)' "$OUTDIR/coap_discovery.txt" 2>/dev/null | \
                while IFS= read -r resource; do
                    local res_out="$OUTDIR/coap_res_${resource//\//_}.txt"
