            nmap -p 445 --script \
                "smb-vuln-ms17-010,smb-vuln-ms08-067,smb-security-mode,smb2-security-mode,smb-vuln-cve-2020-0796" \
                -oN "$OUTDIR_BASE/smb/vuln_scan.txt" "$target" 2>/dev/null || true
            if grep -qi "VULNERABLE\|CVE-2017-0144\|CVE-2020-0796" "$OUTDIR_BASE/smb/vuln_scan.txt" 2>/dev/null; then
                found CRITICAL "SMB:445 — vulnerabilità critica (MS17-010/EternalBlue o SMBGhost)"
            fi
