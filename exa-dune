    echo "  EtherNet/IP — Common Industrial Protocol (CIP) su TCP/UDP 44818."
    echo "  Enumera controller PLC, Identity, I/O modules (Allen-Bradley, Rockwell, ecc.)"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta EtherNet/IP (default: 44818)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_enip() {
    local target="" port=44818
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";         shift 2 ;;
            --output)    OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_enip; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_enip; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_enip; exit 1; }
    check_root
    setup_outdir "$target" "enip"
    log "Target: $target:$port | Output: $OUTDIR"

    # ── nmap EtherNet/IP NSE scripts ─────────────────────────
    section "EtherNet/IP — nmap enip-info"
    local nmap_enip="$OUTDIR/nmap_enip.txt"
    run_cmd "nmap_enip" "nmap -p $port -sV --script enip-info -oN $nmap_enip $NMAP_TIMING $target 2>/dev/null"
    if [[ -s "$nmap_enip" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "^\|.*(Product|Vendor|Serial|Revision|Identity)" || continue
            found "HIGH" "EtherNet/IP" "$line"
        done < "$nmap_enip"
        grep -qE "$port/tcp.*open" "$nmap_enip" 2>/dev/null && \
            found "HIGH" "EtherNet/IP" "EtherNet/IP porta $port aperta — PLC/ICS esposto"
    fi

    # ── UDP CIP List Identity broadcast ──────────────────────
    section "CIP List Identity (UDP broadcast)"
    local cip_out="$OUTDIR/cip_list_identity.txt"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} CIP List Identity broadcast su $target:$port" 
    else
        python3 - <<PYEOF > "$cip_out" 2>&1 || true
import socket, struct, time

ENIP_PORT = $port
# EtherNet/IP ListIdentity request
LIST_IDENTITY = bytes([
    0x65, 0x00,  # Command: ListIdentity (0x0065)
    0x00, 0x00,  # Length: 0
    0x00, 0x00, 0x00, 0x00,  # Session Handle
    0x00, 0x00, 0x00, 0x00,  # Status
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  # Sender Context
    0x00, 0x00, 0x00, 0x00   # Options
])
try:
    # UDP broadcast
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    s.settimeout(5)
    s.sendto(LIST_IDENTITY, ("$target", ENIP_PORT))
    s.sendto(LIST_IDENTITY, ("255.255.255.255", ENIP_PORT))
    print(f"[EtherNet/IP] ListIdentity broadcast inviato a {ENIP_PORT}/UDP")
    deadline = time.time() + 5
    while time.time() < deadline:
        try:
            data, addr = s.recvfrom(1024)
            print(f"[EtherNet/IP] Risposta da {addr[0]}: {data.hex()}")
            # Parse Identity Response
            if len(data) >= 28:
                vendor_id  = struct.unpack_from('<H', data, 28)[0] if len(data) > 30 else 0
                device_type = struct.unpack_from('<H', data, 30)[0] if len(data) > 32 else 0
                print(f"  Vendor ID:   {vendor_id:#06x}")
                print(f"  Device Type: {device_type:#06x}")
        except socket.timeout:
            break
        except: break
    s.close()
    # TCP ListServices
    try:
        ts = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        ts.settimeout(5)
        ts.connect(("$target", ENIP_PORT))
        ts.send(LIST_IDENTITY)
        resp = ts.recv(1024)
        if resp:
            print(f"[EtherNet/IP] TCP risposta ({len(resp)} bytes): {resp[:64].hex()}")
        ts.close()
    except Exception as e:
        print(f"[EtherNet/IP] TCP: {e}")
except Exception as e:
    print(f"[EtherNet/IP] Errore: {e}")
PYEOF
        if grep -q "EtherNet/IP.*Risposta" "$cip_out" 2>/dev/null; then
            while IFS= read -r line; do
                echo "$line" | grep -q "Risposta" && found "HIGH" "EtherNet/IP" "Dispositivo CIP risponde: $line"
            done < "$cip_out"
        else
            log "Nessuna risposta EtherNet/IP (dispositivo non presente o filtrato)"
        fi
    fi

    # ── nmap UDP EtherNet/IP ──────────────────────────────────
    section "EtherNet/IP UDP Scan"
    local nmap_enip_udp="$OUTDIR/nmap_enip_udp.txt"
    run_cmd "nmap_enip_udp" "nmap -sU -p $port --script enip-info $NMAP_TIMING $target 2>/dev/null | tee $nmap_enip_udp"
    [[ -s "$nmap_enip_udp" ]] && grep -qE "^\|" "$nmap_enip_udp" && \
        found "HIGH" "EtherNet/IP" "EtherNet/IP UDP: $(grep '^\|' "$nmap_enip_udp" | head -1)"

    ok "EtherNet/IP audit completato → $OUTDIR"
}

