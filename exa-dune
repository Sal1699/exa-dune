}

cmd_ipmi() {
    local target="" port=623
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)     _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --userlist) _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2"; shift 2 ;;
            --passlist) _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2"; shift 2 ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1;        shift ;;
            --help|-h)  usage_ipmi; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_ipmi; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_ipmi; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "ipmi"
    log "Target: $target:$port/udp | Output: $OUTDIR"

    section "Nmap IPMI Version + Cipher"
    run_cmd "nmap_ipmi" \
        "nmap -sU -p $port --script ipmi-version,ipmi-brute,ipmi-cipher-zero \
         -oN \"$OUTDIR\"/nmap_ipmi.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_ipmi.txt" ]]; then
        grep -iE "cipher.*0|IPMI-2|Authentication|Supported" "$OUTDIR/nmap_ipmi.txt" 2>/dev/null \
            | tee "$OUTDIR/ipmi_summary.txt" || true
        grep -i "cipher.*0" "$OUTDIR/nmap_ipmi.txt" 2>/dev/null && \
            found CRITICAL "IPMI:$port — Cipher 0 abilitato (auth bypass possibile)" || true
    fi

    section "IPMI Version (ipmitool)"
    if require_tool ipmitool; then
        run_cmd "ipmitool_ver" \
            "ipmitool -I lanplus -H $target -p $port -U '' -P '' mc info 2>&1 \
             | tee \"$OUTDIR\"/ipmitool_info.txt"

        section "IPMI Hash Dump (Cipher 0)"
        run_cmd "ipmitool_hash" \
            "ipmitool -I lanplus -H $target -p $port -C 0 -U admin -P '' mc info 2>&1 \
             | tee \"$OUTDIR\"/ipmitool_cipher0.txt"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/ipmitool_cipher0.txt" ]]; then
            grep -i "Device ID\|Firmware\|Manufacturer" "$OUTDIR/ipmitool_cipher0.txt" 2>/dev/null && \
                found CRITICAL "IPMI:$port — accesso con Cipher 0 riuscito (auth bypass)" || true
        fi

        section "IPMI Default Credentials"
        local ul; ul=$(_wl_users)
        local pl; pl=$(_wl_pass)
        if [[ $DRY_RUN -eq 0 ]]; then
            while IFS= read -r user; do
                [[ -z "$user" ]] && continue
                while IFS= read -r pass; do
                    [[ -z "$pass" ]] && continue
                    local result
                    result=$(ipmitool -I lanplus -H "$target" -p "$port" \
                             -U "$user" -P "$pass" chassis status 2>&1 | head -2 || true)
                    if echo "$result" | grep -q "System Power"; then
                        found CRITICAL "IPMI:$port — credenziali valide: ${user}:${pass}"
                        break 2
                    fi
                done < "$pl"
            done < "$ul"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} IPMI default creds test su $target:$port"
        fi
    else
        warn "ipmitool non trovato — (apt install ipmitool)"
    fi

    ok "IPMI audit completato → $OUTDIR"
}

