usage_install() {
    echo "Uso: exa-dune install [--wordlists] [--dry-run]"
    echo ""
    echo "  Installa automaticamente tutti i tool richiesti da exa-dune."
    echo "  Deve essere eseguito come root."
    echo ""
    echo "Opzioni:"
    echo "  --wordlists    Scarica anche le wordlist aggiuntive da GitHub"
    echo "  --dry-run      Mostra cosa verrebbe installato senza installare"
}

_install_scripts() {
    local scripts_dir="$EXA_SCRIPTS_DIR"
    local repo_scripts_dir
    repo_scripts_dir="$(dirname "$SCRIPT_PATH")/scripts"

    mkdir -p "$scripts_dir/python" "$scripts_dir/js" "$scripts_dir/sh"

    if [[ -d "$repo_scripts_dir" ]]; then
        log "Installazione script da repo locale..."
        cp -r "$repo_scripts_dir/python/"*.py "$scripts_dir/python/" 2>/dev/null || true
        cp -r "$repo_scripts_dir/js/"*.js      "$scripts_dir/js/"     2>/dev/null || true
        cp -r "$repo_scripts_dir/sh/"*.sh      "$scripts_dir/sh/"     2>/dev/null || true
        chmod +x "$scripts_dir/sh/"*.sh     2>/dev/null || true
        chmod +x "$scripts_dir/python/"*.py 2>/dev/null || true
    else
        log "Download script da GitHub..."
        local base_url="https://raw.githubusercontent.com/Sal1699/exa-dune/main/scripts"
        local py_scripts=(sip_enum.py onvif_brute.py modbus_rw.py coap_scan.py rtsp_fingerprint.py mqtt_audit.py upnp_exploit.py cam_cve_batch.py http_iot_fuzz.py sip_pcap_creds.py)
        local js_scripts=(websocket_audit.js xss_generator.js)
        local sh_scripts=(voip_capture.sh net_recon.sh)

        for f in "${py_scripts[@]}"; do
            printf "  Download %-40s " "$f..."
            curl -sfL --max-time 30 "$base_url/python/$f" -o "$scripts_dir/python/$f" 2>/dev/null \
                && echo "OK" || echo "FAIL"
        done
        for f in "${js_scripts[@]}"; do
            printf "  Download %-40s " "$f..."
            curl -sfL --max-time 30 "$base_url/js/$f" -o "$scripts_dir/js/$f" 2>/dev/null \
                && echo "OK" || echo "FAIL"
        done
        for f in "${sh_scripts[@]}"; do
            printf "  Download %-40s " "$f..."
            curl -sfL --max-time 30 "$base_url/sh/$f" -o "$scripts_dir/sh/$f" 2>/dev/null \
                && echo "OK" || { echo "FAIL"; continue; }
            chmod +x "$scripts_dir/sh/$f"
        done
    fi

    ok "Script installati in: $scripts_dir"

    # Installa dipendenze Python
    log "Verifica dipendenze Python..."
    python3 -c "import paho.mqtt.client" 2>/dev/null \
        && ok "paho-mqtt OK" \
        || { pip3 install paho-mqtt -q 2>/dev/null && ok "paho-mqtt installato" || warn "paho-mqtt non installato"; }
    python3 -c "import scapy" 2>/dev/null \
        && ok "scapy OK" \
        || warn "scapy non trovato (sip_pcap_creds.py limitato)"

    # Node.js check per script JS
    if command -v node &>/dev/null; then
        ok "Node.js: $(node --version)"
        node -e "require('ws')" 2>/dev/null \
            && ok "ws OK" \
            || { npm install -g ws 2>/dev/null && ok "ws installato" || warn "ws npm package non installato (websocket_audit.js limitato)"; }
    else
        warn "Node.js non trovato — script JS disabilitati. Installa: apt install nodejs"
    fi
}

cmd_install() {
    local do_wordlists=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --wordlists) do_wordlists=1; shift ;;
            --dry-run)   DRY_RUN=1;      shift ;;
            --help|-h)   usage_install; exit 0 ;;
            *) shift ;;
        esac
    done

    check_root
    banner

    echo -e "${BOLD}=== exa-dune v${VERSION} — Installazione Tool ===${NC}"
    echo ""

    # ── Pacchetti apt ──────────────────────────────────────────────────────────
    # formato: "nome_comando:pacchetto_apt"
    local APT_TOOLS=(
        "nmap:nmap"
        "hydra:hydra"
        "nikto:nikto"
        "gobuster:gobuster"
        "ffuf:ffuf"
        "curl:curl"
        "wget:wget"
        "git:git"
        "python3:python3"
        "pip3:python3-pip"
        "nc:netcat-openbsd"
        "openssl:openssl"
        "dig:dnsutils"
        "host:bind9-host"
        "dnsrecon:dnsrecon"
        "sslscan:sslscan"
        "enum4linux:enum4linux"
        "smbclient:smbclient"
        "snmpwalk:snmp"
        "snmpget:snmp"
        "ipmitool:ipmitool"
        "mosquitto_sub:mosquitto-clients"
        "atftp:atftp"
        "redis-cli:redis-tools"
        "ldapsearch:ldap-utils"
        "arp-scan:arp-scan"
        "ffmpeg:ffmpeg"
        "cvlc:vlc"
        "tmux:tmux"
        "weasyprint:weasyprint"
        "searchsploit:exploitdb"
        "testssl:testssl.sh"
        "svmap:sipvicious"
        "nuclei:nuclei"
        "sipsak:sipsak"
        "rtmpdump:rtmpdump"
        "avahi-browse:avahi-utils"
        "bettercap:bettercap"
        "responder:responder"
        "ike-scan:ike-scan"
        "masscan:masscan"
        "hashcat:hashcat"
        "john:john"
        "binwalk:binwalk"
        "hping3:hping3"
        "netexec:netexec"
        "voiphopper:voiphopper"
        "nxc:netexec"
    )

    # ── Pacchetti pip3 (fallback se apt non disponibile) ──────────────────────
    local PIP_TOOLS=(
        "weasyprint:weasyprint"
        "svmap:sipvicious"
        "wafw00f:wafw00f"
        "sippts:sippts"
    )

    echo -e "${BOLD}[1/3] Controllo tool apt...${NC}"
    local apt_missing=()
    local apt_present=()
    for entry in "${APT_TOOLS[@]}"; do
        local cmd="${entry%%:*}"
        local pkg="${entry##*:}"
        if tool_ok "$cmd"; then
            apt_present+=("$cmd")
        else
            apt_missing+=("$pkg")
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "  ${YELLOW}[MANCANTE]${NC} $cmd → apt install $pkg"
            fi
        fi
    done
    echo "  Presenti: ${#apt_present[@]} | Mancanti: ${#apt_missing[@]}"

    if [[ ${#apt_missing[@]} -gt 0 ]]; then
        if [[ $DRY_RUN -eq 0 ]]; then
            log "Aggiornamento lista pacchetti..."
            apt-get update -qq 2>/dev/null || warn "apt update fallito — continuo comunque"
            log "Installazione pacchetti: ${apt_missing[*]}"
            # Installa rimuovendo duplicati
            local unique_pkgs
            unique_pkgs=$(echo "${apt_missing[@]}" | tr ' ' '\n' | sort -u | tr '\n' ' ')
            DEBIAN_FRONTEND=noninteractive apt-get install -y -qq $unique_pkgs 2>/dev/null \
                && ok "Pacchetti apt installati" \
                || warn "Alcuni pacchetti apt non disponibili — controlla manualmente"
        fi
    else
        ok "Tutti i tool apt già presenti"
    fi

    echo ""
    echo -e "${BOLD}[2/3] Controllo tool pip3...${NC}"
    local pip_installed=0
    for entry in "${PIP_TOOLS[@]}"; do
        local cmd="${entry%%:*}"
        local pkg="${entry##*:}"
        if ! tool_ok "$cmd"; then
            if [[ $DRY_RUN -eq 0 ]]; then
                log "  pip3 install $pkg"
                pip3 install -q "$pkg" 2>/dev/null && ok "  $pkg installato" || warn "  $pkg fallito (pip3)"
            else
                echo -e "  ${YELLOW}[MANCANTE]${NC} $cmd → pip3 install $pkg"
            fi
            ((pip_installed++)) || true
        fi
    done
    [[ $pip_installed -eq 0 ]] && ok "Tutti i tool pip3 già presenti"

    echo ""
    echo -e "${BOLD}[3/3] Verifica installazione...${NC}"
    local all_ok=1
    local status_lines=()
    for entry in "${APT_TOOLS[@]}"; do
        local cmd="${entry%%:*}"
        if tool_ok "$cmd"; then
            status_lines+=("  ${GREEN}✓${NC} $cmd")
        else
            status_lines+=("  ${RED}✗${NC} $cmd")
            all_ok=0
        fi
    done
    # Stampa in colonne
    local i=0
    for line in "${status_lines[@]}"; do
        echo -e "$line"
    done

    if [[ $all_ok -eq 1 ]]; then
        ok "Tutti i tool exa-dune sono pronti."
    else
        warn "Alcuni tool non installati. Funzionalità limitate — i moduli salteranno i passi che richiedono tool mancanti."
    fi

    # ── Wordlist aggiuntive da GitHub ─────────────────────────────────────────
    if [[ $do_wordlists -eq 1 ]]; then
        echo ""
        echo -e "${BOLD}[BONUS] Download wordlist aggiuntive da GitHub...${NC}"
        if [[ $DRY_RUN -eq 0 ]]; then
            _download_wordlists
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Verrebbe eseguito: _download_wordlists → $EXA_WL_DIR"
        fi
    else
        echo ""
        log "Suggerimento: esegui 'exa-dune install --wordlists' per scaricare wordlist aggiuntive da GitHub (SecLists + IoT)."
    fi

    echo ""
    echo ""
    echo -e "${BOLD}[SETUP] Cartella report Desktop...${NC}"
    _init_reports_dir

    echo ""
    echo -e "${BOLD}[SETUP] Installazione tool PDF (HTML→PDF)...${NC}"
    if [[ $DRY_RUN -eq 0 ]]; then
        local pdf_tool; pdf_tool=$(_ensure_pdf_tool 2>/dev/null)
        if [[ -n "$pdf_tool" ]]; then
            ok "Tool PDF disponibile: $pdf_tool"
        else
            warn "Nessun tool PDF trovato — i report PDF non saranno generabili"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Verifica/installazione weasyprint"
    fi

    echo ""
    echo -e "${BOLD}[4/4] Installazione script ausiliari...${NC}"
    if [[ $DRY_RUN -eq 0 ]]; then
        _install_scripts
    else
        echo -e "${CYAN}[DRY-RUN]${NC} _install_scripts → $EXA_SCRIPTS_DIR"
    fi

    ok "exa-dune v${VERSION} pronto. Usa: exa-dune help"
}

