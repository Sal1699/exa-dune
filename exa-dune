#!/bin/bash
# ============================================================
#  EXA-DUNE — Generic Network Assessment Tool
#  Wraps: nmap · hydra · nikto · gobuster · sipvicious
#         enum4linux · smbclient · snmpwalk · mosquitto_sub
#         searchsploit · arp-scan · curl · atftp · nc
#         testssl.sh · sslscan · dnsrecon · ldapsearch · ipmitool · ffuf
#
#  Uso:  exa-dune <subcommand> <TARGET> [OPTIONS]
#        exa-dune help [subcommand]
#
#  Subcommands:
#    scan    — Port scan + recon (nmap, arp-scan, searchsploit)
#    web     — Web audit (nikto, gobuster, curl, nmap http NSE)
#    sip     — SIP enum (svmap, svwar, svcrack, nmap sip NSE)
#    smb     — SMB enum (enum4linux, smbclient, nmap smb NSE)
#    creds   — Credential brute force (hydra multiprotocol)
#    snmp    — SNMP audit (snmpwalk, nmap snmp NSE)
#    ftp     — FTP audit (nmap, anon test, hydra)
#    ssh     — SSH audit + brute force (hydra)
#    telnet  — Telnet banner + brute force (hydra)
#    mqtt    — MQTT broker audit (mosquitto_sub, nmap)
#    modbus  — Modbus/ICS audit (nmap, raw probes)
#    upnp    — UPnP/SSDP audit (nmap, curl SOAP)
#    ssl     — TLS/SSL full audit (testssl.sh, sslscan, openssl, nmap)
#    tftp    — TFTP file enumeration (atftp, nmap tftp-enum NSE)
#    rtsp    — RTSP stream audit (nmap, curl)
#    js      — JavaScript analysis (endpoint/secret extraction)
#    dns     — DNS enumeration (dig, dnsrecon, host)
#    ipmi    — IPMI/BMC audit (nmap, ipmitool)
#    coap    — CoAP IoT protocol audit (nmap, coap-client)
#    vnc     — VNC audit (nmap vnc NSE, hydra)
#    rdp     — RDP enumeration + brute force (nmap, hydra)
#    ldap    — LDAP enumeration (ldapsearch, nmap ldap NSE)
#    post    — Post-exploitation + reverse shell (multi-vector)
#    fw      — Firewall embedded analysis + bypass (ACK/FIN/frag/src-port/IPv6/UPnP/SIP-ALG)
#    nuclei  — Nuclei CVE/template scanner (IoT, CVEs, panels, logins)
#    mitm    — MITM framework (bettercap: ARP spoof, sniff, BLE)
#    poison  — LLMNR/MDNS poisoning + hash crack (responder, hashcat/john)
#    pivot   — HTTP tunneling + SOCKS5 proxy (chisel)
#    vpn     — IPsec/IKE VPN enumeration (ike-scan)
#    auto    — Auto-profile full assessment (tmux orchestration)
#    report  — Generate text report from output dir
# ============================================================

set -euo pipefail

VERSION="3.2.0"
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

# ── Colori ──────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── Logging ─────────────────────────────────────────────────
_log_file=""
_write_log() { [[ "${DRY_RUN:-0}" -eq 0 && -n "$_log_file" ]] && echo -e "$*" >> "$_log_file" || true; }
log()   { local m="[$(date +%H:%M:%S)] $*"; echo -e "$m"; _write_log "$m"; }
ok()    { local m="${GREEN}[OK]${NC} $*";    echo -e "$m"; _write_log "[OK] $*"; }
warn()  { local m="${YELLOW}[!]${NC} $*";    echo -e "$m"; _write_log "[!] $*"; }
err()   { local m="${RED}[ERR]${NC} $*";     echo -e "$m" >&2; _write_log "[ERR] $*"; }
# found [CRITICAL|HIGH|MEDIUM|LOW|INFO] "messaggio"
found() {
    local sev="INFO" msg
    case "$1" in
        CRITICAL|HIGH|MEDIUM|LOW|INFO) sev="$1"; shift ;;
    esac
    msg="$*"
    local color
    case "$sev" in
        CRITICAL) color='\033[1;37;41m' ;;  # bianco su sfondo rosso
        HIGH)     color='\033[1;31m'    ;;  # rosso bold
        MEDIUM)   color='\033[1;33m'    ;;  # giallo bold
        LOW)      color='\033[0;36m'    ;;  # cyan
        *)        color="$GREEN"        ;;  # verde (INFO)
    esac
    echo -e "${color}[FOUND:${sev}]${NC} ${msg}"
    _write_log "[FOUND:${sev}] ${msg}"
    if [[ "${DRY_RUN:-0}" -eq 0 ]]; then
        local findings_dir="${OUTDIR_BASE:-${OUTDIR:-}}"
        [[ -n "$findings_dir" ]] && echo "[${sev}] ${msg}" >> "$findings_dir/findings.txt" || true
        # JSON output se abilitato
        if [[ "${JSON_OUTPUT:-0}" -eq 1 && -n "$findings_dir" ]]; then
            _json_append_finding "$sev" "$msg" "$findings_dir"
        fi
        # SQLite: registra finding nel DB storico
        _db_insert_finding "$sev" "$msg" 2>/dev/null || true
    fi
    [[ "$sev" == "HIGH" || "$sev" == "CRITICAL" ]] && \
        _telegram_notify "$msg" "$sev" || true
}

# ── Telegram notifications ───────────────────────────────────────────────────
_telegram_notify() {
    # Send message to Telegram if configured
    local msg="$1" level="${2:-INFO}"
    local token="${TELEGRAM_TOKEN:-${EXA_TELEGRAM_TOKEN:-}}"
    local chat_id="${TELEGRAM_CHAT_ID:-${EXA_TELEGRAM_CHAT_ID:-}}"
    [[ -z "$token" || -z "$chat_id" ]] && return 0
    local emoji="ℹ️"
    case "$level" in CRITICAL) emoji="🔴" ;; HIGH) emoji="🟠" ;; MEDIUM) emoji="🟡" ;; LOW) emoji="🔵" ;; OK) emoji="✅" ;; esac
    local full_msg="${emoji} *exa-dune* — ${level}: ${msg}"
    curl -s -m 5 "https://api.telegram.org/bot${token}/sendMessage" \
        -d "chat_id=${chat_id}" \
        -d "parse_mode=Markdown" \
        --data-urlencode "text=${full_msg}" >/dev/null 2>&1 || true
}

# ── JSON output helpers ───────────────────────────────────────────────────────
_json_escape() {
    # Escape stringa per JSON (sostituisce " \ e caratteri di controllo)
    local s="$*"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    echo "$s"
}

_json_append_finding() {
    local sev="$1" msg="$2" dir="$3"
    local ts; ts=$(date -u +%Y-%m-%dT%H:%M:%S)
    local target_val; target_val=$(basename "$dir" | grep -oP '(\d{1,3}[-.]){3}\d{1,3}' | head -1 | tr '-' '.' 2>/dev/null || echo "unknown")
    local json_file="$dir/findings.json"
    local escaped_msg; escaped_msg=$(_json_escape "$msg")
    local escaped_target; escaped_target=$(_json_escape "$target_val")
    local lock_file="${json_file}.lock"
    # flock garantisce atomicità in esecuzione parallela (cmd_auto/tmux)
    (
        flock -x 200
        if [[ ! -f "$json_file" ]]; then
            # Prima scrittura: crea file JSON valido in un'unica operazione atomica
            printf '{"findings":[\n  {"severity":"%s","message":"%s","timestamp":"%s","target":"%s"}\n]}\n' \
                "$sev" "$escaped_msg" "$ts" "$escaped_target" > "$json_file"
        else
            # Append: rimuovi la chiusura ]}, aggiungi nuovo entry, richiudi
            local tmp; tmp=$(mktemp "${json_file}.tmp.XXXXXX")
            # Cleanup automatico del tmp se la subshell esce in modo anomalo
            trap "rm -f \"$tmp\"" EXIT
            if grep -q '^\]}' "$json_file" 2>/dev/null; then
                head -n -1 "$json_file" > "$tmp"
            else
                # File senza chiusura (es. scrittura interrotta): copia as-is
                cp "$json_file" "$tmp"
            fi
            printf '  ,{"severity":"%s","message":"%s","timestamp":"%s","target":"%s"}\n' \
                "$sev" "$escaped_msg" "$ts" "$escaped_target" >> "$tmp"
            printf ']}\n' >> "$tmp"
            mv "$tmp" "$json_file"
        fi
    ) 200>"$lock_file" 2>/dev/null || true
}

_json_write_summary() {
    local dir="${1:-${OUTDIR_BASE:-${OUTDIR:-}}}"
    local module="${2:-unknown}"
    [[ -z "$dir" || "${DRY_RUN:-0}" -eq 1 ]] && return
    local ts; ts=$(date -u +%Y-%m-%dT%H:%M:%S)
    local target_val; target_val=$(basename "$dir" | grep -oP '(\d{1,3}[-.]){3}\d{1,3}' | head -1 | tr '-' '.' 2>/dev/null || echo "unknown")

    # Raccogli porte aperte da nmap
    local ports_json=""
    local nmap_f; nmap_f=$(find "$dir" -maxdepth 2 -name "nmap_fast.nmap" 2>/dev/null | head -1)
    if [[ -n "$nmap_f" ]]; then
        local ports_list; ports_list=$(grep -E "^[0-9]+/tcp.*open" "$nmap_f" 2>/dev/null | awk '{print $1}' | tr '\n' ',' | sed 's/,$//' || true)
        if [[ -n "$ports_list" ]]; then
            # Converti "80/tcp,443/tcp" in array JSON
            local IFS=','
            local pa="" first=1
            for p in $ports_list; do
                local ep; ep=$(_json_escape "$p")
                [[ $first -eq 1 ]] && pa="\"${ep}\"" && first=0 || pa="${pa},\"${ep}\""
            done
            ports_json="[$pa]"
        fi
    fi
    [[ -z "$ports_json" ]] && ports_json="[]"

    # Raccogli findings dal file JSON se esiste
    local findings_json="[]"
    if [[ -f "$dir/findings.json" ]]; then
        findings_json=$(EXA_FINDINGS_FILE="$dir/findings.json" python3 -c "
import json,os
try:
    d=json.load(open(os.environ['EXA_FINDINGS_FILE']))
    print(json.dumps(d.get('findings',[])))
except:
    print('[]')
" 2>/dev/null || echo "[]")
    fi

    # Usa Python per costruire il JSON finale: evita command injection da
    # $(…) o backtick nel testo dei finding quando espanso in un heredoc bash.
    export EXA_SUM_TARGET="$target_val" EXA_SUM_MODULE="$module" \
           EXA_SUM_TS="$ts" EXA_SUM_VER="$VERSION" \
           EXA_SUM_FINDINGS="$findings_json" EXA_SUM_PORTS="$ports_json" \
           EXA_SUM_OUT="$dir/summary.json"
    python3 - <<'PYEOF' 2>/dev/null || true
import json, os
d = {
    "target":             os.environ["EXA_SUM_TARGET"],
    "module":             os.environ["EXA_SUM_MODULE"],
    "timestamp":          os.environ["EXA_SUM_TS"],
    "exa_dune_version":   os.environ["EXA_SUM_VER"],
    "findings":           json.loads(os.environ.get("EXA_SUM_FINDINGS", "[]")),
    "ports_open":         json.loads(os.environ.get("EXA_SUM_PORTS",   "[]")),
}
with open(os.environ["EXA_SUM_OUT"], "w") as fh:
    json.dump(d, fh, indent=2)
PYEOF
    unset EXA_SUM_TARGET EXA_SUM_MODULE EXA_SUM_TS EXA_SUM_VER \
          EXA_SUM_FINDINGS EXA_SUM_PORTS EXA_SUM_OUT
    ok "Summary JSON: $dir/summary.json"
}
section(){ echo -e "\n${BOLD}${CYAN}━━ $* ━━${NC}"; [[ -n "$_log_file" ]] && echo "━━ $* ━━" >> "$_log_file" || true; }
# _req_arg OPTION VALUE — verifica che VALUE non sia vuoto
_req_arg() { [[ -z "${2:-}" ]] && { err "$1 richiede un argomento"; exit 1; } || true; }

banner() {
    echo -e "${BOLD}${CYAN}"
    echo "╔══════════════════════════════════════════════╗"
    printf "║  %-44s║\n" "  EXA-DUNE v${VERSION}"
    printf "║  %-44s║\n" "  Generic Network Assessment Tool"
    echo "╚══════════════════════════════════════════════╝"
    echo -e "${NC}"
}

