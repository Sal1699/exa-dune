# ── Helpers ──────────────────────────────────────────────────
check_root() { [[ $EUID -eq 0 ]] || { err "Richiede root (sudo)."; exit 1; }; }

validate_target() {
    local t="$1"
    # IP singolo
    [[ "$t" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] && return 0
    # CIDR (192.168.1.0/24 o 10.0.0.0/8)
    [[ "$t" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/([0-9]|[1-2][0-9]|3[0-2])$ ]] && return 0
    # Hostname (inclusi sottodomini)
    [[ "$t" =~ ^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9\-]+)*(\.[a-zA-Z]{2,})+$ ]] && return 0
    # Hostname semplice senza TLD (es. "router", "camera1")
    [[ "$t" =~ ^[a-zA-Z0-9][a-zA-Z0-9\-]{0,62}$ ]] && return 0
    err "Target non valido: $t (usa IP, CIDR, o hostname)"
    exit 1
}

validate_port() {
    local p="$1"
    [[ "$p" =~ ^[0-9]+$ ]] && [[ $p -ge 1 && $p -le 65535 ]] && return 0
    err "Porta non valida: $p (range 1-65535)"
    exit 1
}

validate_timeout() {
    local t="$1"
    [[ "$t" =~ ^[0-9]+$ ]] && [[ $t -ge 1 && $t -le 1440 ]] && return 0
    err "Timeout non valido: $t (usa un numero intero di minuti, max 1440)"
    exit 1
}

setup_outdir() {
    # Imposta globali: OUTDIR, OUTDIR_BASE, _log_file
    local target="$1" sub="${2:-}"
    local ts; ts=$(date +%Y%m%d_%H%M%S)

    if [[ -z "$OUTDIR_BASE" ]]; then
        # Struttura per-target: <base>/<target>/<timestamp>
        local _base_root="${EXA_OUTPUT_DIR:-/root/pentest}"
        local _target_dir="${_base_root}/${target}"
        OUTDIR_BASE="${_target_dir}/${ts}"
        _EXA_TARGET_DIR="$_target_dir"   # usato per symlink e retention
    else
        _EXA_TARGET_DIR=""               # --output manuale: non tocchiamo struttura
    fi

    if [[ -n "$sub" ]]; then
        OUTDIR="${OUTDIR_BASE}/${sub}"
    else
        OUTDIR="${OUTDIR_BASE}"
    fi

    if [[ "$DRY_RUN" -eq 0 ]]; then
        mkdir -p "$OUTDIR" "$OUTDIR_BASE" || { err "Impossibile creare directory output: $OUTDIR_BASE (permessi insufficienti?)"; exit 1; }

        # Symlink latest → timestamp corrente
        if [[ -n "${_EXA_TARGET_DIR:-}" ]]; then
            ln -sfn "$ts" "${_EXA_TARGET_DIR}/latest" 2>/dev/null || true
            # Retention: rimuovi run vecchie oltre KEEP_RUNS
            _apply_retention "$_EXA_TARGET_DIR"
        fi

        # Log sempre nella root di sessione, non nella subdir del modulo
        _log_file="$OUTDIR_BASE/exa-dune.log"
        [[ -n "$sub" ]] && echo "--- Modulo: $sub START $(date) ---" >> "$_log_file" || true
        # SQLite: inizializza DB e registra assessment
        _db_init 2>/dev/null || true
        _db_insert_assessment "$target" "${sub:-global}" "$OUTDIR_BASE" 2>/dev/null || true
        # Credential store
        _cred_store_init 2>/dev/null || true
    else
        _log_file=""
    fi
}

run_cmd() {
    # run_cmd WINDOW_NAME COMMAND  — esegue o stampa in dry-run
    local name="$1" cmd="$2"
    if [[ "${DRY_RUN:-0}" -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} [$name] $cmd"
        return
    fi
    local _max_t=""
    if [[ "${TIMEOUT:-0}" -gt 0 ]]; then
        _max_t="${TIMEOUT}m"
    elif [[ "$cmd" == *hydra* ]]; then
        # Hydra senza timeout globale: max ${HYDRA_TIMEOUT:-5} minuti per singola sessione
        _max_t="${HYDRA_TIMEOUT:-5}m"
    fi
    if [[ -n "$_max_t" ]]; then
        timeout "$_max_t" bash -c "$cmd" || true
    else
        bash -c "$cmd" || true
    fi
}

run_in_tmux() {
    local session="$1" window="$2" cmd="$3"
    if [[ "${DRY_RUN:-0}" -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} [tmux:$window] $cmd"; return
    fi
    if [[ "${TIMEOUT:-0}" -gt 0 ]]; then
        cmd="timeout ${TIMEOUT}m bash -c $(printf '%q' "$cmd")"
    fi
    tmux new-window -t "$session" -n "$window" 2>/dev/null || true
    tmux send-keys -t "$session:$window" "$cmd" Enter
}

tool_ok() { command -v "$1" &>/dev/null; }

require_tool() {
    tool_ok "$1" || { warn "Tool non trovato: $1 — step saltato. Installa: apt install $1"; return 1; }
    return 0
}

check_port() {
    nc -z -w 2 "$1" "$2" &>/dev/null
}

_ensure_pdf_tool() {
    # Restituisce il nome del tool HTML→PDF disponibile, installando se necessario.
    # Priorità: weasyprint (preinstallato su Kali) → wkhtmltopdf → chromium → apt install
    if tool_ok weasyprint;          then echo "weasyprint";   return 0; fi
    if tool_ok wkhtmltopdf;         then echo "wkhtmltopdf";  return 0; fi
    if tool_ok chromium-headless-shell; then echo "chromium-headless-shell"; return 0; fi
    if tool_ok chromium;            then echo "chromium";     return 0; fi
    if tool_ok google-chrome-stable; then echo "google-chrome-stable"; return 0; fi
    warn "Nessun tool PDF trovato — installazione automatica weasyprint..."
    if apt-get install -y weasyprint 2>/dev/null && tool_ok weasyprint; then
        ok "weasyprint installato."; echo "weasyprint"; return 0
    fi
    warn "apt fallito — provo pip3..."
    if pip3 install weasyprint 2>/dev/null && tool_ok weasyprint; then
        echo "weasyprint"; return 0
    fi
    err "Nessun tool PDF disponibile. Installa: apt install weasyprint"
    return 1
}

_ensure_media_tools() {
    # Installa automaticamente ffmpeg e vlc se assenti (richiede root).
    # Chiamata all'inizio di cmd_rtsp e da qualunque modulo che cattura media.
    local missing=()
    tool_ok ffmpeg || missing+=(ffmpeg)
    tool_ok cvlc   || missing+=(vlc)
    [[ ${#missing[@]} -eq 0 ]] && return 0
    warn "Media tools mancanti: ${missing[*]} — installazione automatica..."
    if [[ $EUID -eq 0 ]]; then
        DEBIAN_FRONTEND=noninteractive apt-get install -y -qq "${missing[@]}" 2>/dev/null \
            && ok "Installati: ${missing[*]}" \
            || warn "Installazione fallita — riprova: apt install ${missing[*]}"
    else
        warn "Non in root: installa manualmente → sudo apt install ${missing[*]}"
    fi
    return 0
}

