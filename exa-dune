            _h248_banner=$(printf '\x00\x00\x00\x01' | timeout 5 nc -q 2 "$target" 2944 2>/dev/null | xxd 2>/dev/null | head -5 || true)
            if [[ -n "$_h248_banner" ]]; then
                echo "$_h248_banner" > "$_h248_dir/banner.txt"
