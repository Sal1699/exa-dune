usage_rdp() {
    echo "Uso: exa-dune rdp <TARGET> [OPTIONS]"
    echo ""
    echo "  RDP audit — encryption, NLA, CredSSP, BlueKeep, brute force"
    echo "  Wraps: nmap rdp NSE, openssl, hydra, rdesktop/xfreerdp"
    echo ""
    echo "Opzioni:"
    echo "  --port PORT        Porta (default: 3389)"
    echo "  --no-bruteforce"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --threads N        Thread hydra (default: 4)"
    echo "  --check-nla        Test NLA e CredSSP downgrade"
    echo "  --screenshot       Tenta cattura schermata login (rdesktop/xfreerdp)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_rdp() {
    local target="" port=3389 do_brute=1 threads=4
    local do_check_nla=0 do_screenshot=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)          _req_arg "$1" "${2:-}"; port="$2";        shift 2 ;;
            --no-bruteforce) do_brute=0;       shift ;;
            --userlist)      _req_arg "$1" "${2:-}"; CUSTOM_USERS="$2"; shift 2 ;;
            --passlist)      _req_arg "$1" "${2:-}"; CUSTOM_PASS="$2"; shift 2 ;;
            --threads)       _req_arg "$1" "${2:-}"; threads="$2";     shift 2 ;;
            --check-nla)     do_check_nla=1;   shift ;;
            --screenshot)    do_screenshot=1;  shift ;;
            --output)        _req_arg "$1" "${2:-}"; OUTDIR_BASE="$2"; shift 2 ;;
            --dry-run)       DRY_RUN=1;        shift ;;
            --help|-h)       usage_rdp; exit 0 ;;
            -*)              err "Opzione sconosciuta: $1"; usage_rdp; exit 1 ;;
            *)               target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_rdp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "rdp"
    log "Target: $target:$port | Output: $OUTDIR"

    section "Nmap RDP Scripts"
    run_cmd "nmap_rdp" \
        "nmap -p $port \
         --script rdp-enum-encryption,rdp-vuln-ms12-020 \
         -oN \"$OUTDIR\"/nmap_rdp.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_rdp.txt" ]]; then
        grep -iE "encryption|NLA|security layer|VULNERABLE|MS12" "$OUTDIR/nmap_rdp.txt" 2>/dev/null \
            | tee "$OUTDIR/rdp_summary.txt" || true
        grep -i "VULNERABLE\|MS12-020" "$OUTDIR/nmap_rdp.txt" 2>/dev/null && \
            found CRITICAL "RDP:$port — VULNERABILE MS12-020 (DoS/possibile RCE)" || true
        grep -iE "security.*none|encryption.*none" "$OUTDIR/nmap_rdp.txt" 2>/dev/null && \
            found HIGH "RDP:$port — RDP Security (no NLA, traffico non cifrato)" || true
        # Rileva encryption level debole
        if grep -qiE "rc4.*40|rc4.*56|encryption.*low" "$OUTDIR/nmap_rdp.txt" 2>/dev/null; then
            found HIGH "RDP:$port — encryption debole rilevata (RC4 40/56-bit)"
        fi
    fi

    section "NLA Detection + CredSSP Downgrade Test"
    if [[ $do_check_nla -eq 1 || $DRY_RUN -eq 1 ]]; then
        if [[ $DRY_RUN -eq 0 ]]; then
            if tool_ok openssl; then
                local ssl_resp
                ssl_resp=$(echo "QUIT" | timeout 8 openssl s_client \
                    -connect "${target}:${port}" 2>&1 | head -20 || true)
                echo "$ssl_resp" > "$OUTDIR/rdp_ssl_probe.txt"
                if echo "$ssl_resp" | grep -qiE "TLSv1\.[23]|Protocol"; then
                    found INFO "RDP:$port — TLS supportato (CredSSP probabilmente attivo)"
                fi
                if echo "$ssl_resp" | grep -qiE "TLSv1\.0|SSLv3"; then
                    found HIGH "RDP:$port — TLS 1.0 o SSLv3 in uso (downgrade possibile)"
                fi
            fi
            # Check NLA dal nmap output
            if [[ -f "$OUTDIR/nmap_rdp.txt" ]]; then
                if grep -qi "HYBRID\|NLA\|Network Level" "$OUTDIR/nmap_rdp.txt" 2>/dev/null; then
                    log "RDP:$port — NLA/Hybrid auth rilevata"
                else
                    found HIGH "RDP:$port — NLA non richiesto: connessione possibile senza credenziali AD"
                fi
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} RDP NLA/CredSSP check $target:$port"
        fi
    fi

    section "BlueKeep / DejaBlue Banner Check (CVE-2019-0708)"
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/nmap_rdp.txt" ]]; then
        # Controlla versione OS da nmap per range vulnerabile
        local os_ver
        os_ver=$(grep -iE "Windows [0-9]|Windows XP|Windows 7|Windows 2008|Windows 2003" \
            "$OUTDIR/nmap_rdp.txt" 2>/dev/null | head -1 || true)
        if [[ -n "$os_ver" ]]; then
            found INFO "RDP:$port — OS rilevato: $os_ver"
            if echo "$os_ver" | grep -qiE "Windows XP|Windows 7|Windows 2008|Windows 2003|Windows Vista"; then
                found HIGH "RDP:$port — OS potenzialmente vulnerabile a BlueKeep CVE-2019-0708: $os_ver"
            fi
        fi
        # Check NSE bluekeep se disponibile
        run_cmd "nmap_bluekeep" \
            "nmap -p $port --script rdp-vuln-ms12-020 \
             -oN \"$OUTDIR\"/nmap_bluekeep.txt $target 2>&1 || true"
    else
        echo -e "${CYAN}[DRY-RUN]${NC} BlueKeep banner check $target:$port"
    fi

    section "Screenshot Login (rdesktop/xfreerdp)"
    if [[ $do_screenshot -eq 1 ]]; then
        if [[ $DRY_RUN -eq 0 ]]; then
            if tool_ok xfreerdp; then
                timeout 10 xfreerdp /v:"${target}:${port}" /u:"" /p:"" \
                    /cert-ignore /auth-only 2>/dev/null | head -5 || true
                log "xfreerdp screenshot attempt eseguito (output in log)"
            elif tool_ok rdesktop; then
                timeout 10 rdesktop -u "" -p "" "${target}:${port}" \
                    2>/dev/null | head -5 || true
                log "rdesktop screenshot attempt eseguito"
            else
                warn "xfreerdp/rdesktop non trovati — screenshot saltato"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} RDP screenshot login $target:$port"
        fi
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "RDP Brute Force"
        check_port "$target" "$port" || { warn "Porta $port chiusa"; return; }
        if require_tool hydra; then
            local ul; ul=$(_wl_users); local pl; pl=$(_wl_pass)
            run_cmd "hydra_rdp" \
                "hydra -L \"$ul\" -P \"$pl\" -s $port -t $threads -f -w 4 -W 2 \
                 -o \"$OUTDIR/hydra_rdp.txt\" $target rdp 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_rdp.txt" ]]; then
                grep -i "login:" "$OUTDIR/hydra_rdp.txt" 2>/dev/null | \
                    while IFS= read -r line; do
                        found HIGH "RDP:$port — $line"
                        local hu hp
                        hu=$(echo "$line" | grep -oP 'login:\s*\K\S+' || true)
                        hp=$(echo "$line" | grep -oP 'password:\s*\K\S+' || true)
                        [[ -n "$hu" && -n "$hp" ]] && \
                            _cred_store_add rdp "$target" "$port" "$hu" "$hp" "rdp:hydra"
                    done || true
            fi
        fi
    fi

    ok "RDP audit completato → $OUTDIR"
}

