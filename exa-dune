        for _pair in "${_pairs[@]}"; do
            local _u="${_pair%%:*}" _p="${_pair##*:}"
            local _code
            _code=$(curl -s $_ins -o /dev/null -w "%{http_code}" \
                    --user "${_u}:${_p}" --max-time 4 \
                    "${_scheme}://${target}:${_port}/" 2>/dev/null || echo "000")
