            --dry-run) DRY_RUN=1;              shift ;;
            --stealth) STEALTH=1;              shift ;;
            --help|-h) usage_sqli; exit 0 ;;
            -*)        err "Opzione sconosciuta: $1"; usage_sqli; exit 1 ;;
            *)         target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_sqli; exit 1; }
    validate_target "$target"
    check_root
    setup_outdir "$target" "sqli"
    log "Target: ${scheme}://${target}:${port} | Output: $OUTDIR"

    if ! tool_ok sqlmap; then
        warn "sqlmap non trovato — installa: apt install sqlmap"
        ok "SQLi audit saltato"; return
    fi

    local base_url="${scheme}://${target}:${port}"
    local _sqlmap_opts="--batch --level=2 --risk=2 --timeout=30 --output-dir=\"$OUTDIR\""
    [[ $STEALTH -eq 1 ]] && _sqlmap_opts="$_sqlmap_opts --delay=2 --safe-freq=5"
    local insecure=""; [[ "$scheme" == "https" ]] && insecure="--ignore-ssl-errors"

    # Raccoglie URL da testare
    local -a _urls=()
    if [[ -n "$custom_url" ]]; then
        _urls+=("$custom_url")
    else
        _urls+=("${base_url}/?id=1" "${base_url}/?q=test" "${base_url}/?search=a")
        # Leggi URL da gobuster se disponibile
        local _gob_file
        _gob_file=$(find "$OUTDIR_BASE" -name "gobuster*.txt" 2>/dev/null | head -1 || true)
        if [[ -n "$_gob_file" ]]; then
            while IFS= read -r _line; do
                local _path; _path=$(echo "$_line" | grep -oP '^/\S+' | head -1 || true)
                [[ -n "$_path" ]] && _urls+=("${base_url}${_path}?id=1")
            done < "$_gob_file"
        fi
    fi

    section "SQLi — sqlmap su ${#_urls[@]} URL"
    local _sqli_found=0
    for _url in "${_urls[@]:0:10}"; do
        log "  Test SQLi: $_url"
        if [[ $DRY_RUN -eq 0 ]]; then
            # shellcheck disable=SC2086
            local _sm_out
            _sm_out=$(timeout 120 sqlmap -u "$_url" $insecure $DEBUG_OPTS \
                --batch --level=2 --risk=2 --timeout=20 \
                --output-dir="$OUTDIR/sqlmap" 2>&1 | tail -20 || true)
            echo "=== $_url ===" >> "$OUTDIR/sqlmap_summary.txt"
            echo "$_sm_out"     >> "$OUTDIR/sqlmap_summary.txt"
            if echo "$_sm_out" | grep -qi "is vulnerable\|sql injection\|parameter.*injectable\|sqlmap identified"; then
                found CRITICAL "SQLi confermata — URL: $_url"
                _sqli_found=1
                # Enumera DB
                timeout 120 sqlmap -u "$_url" $insecure \
                    --batch --dbs --output-dir="$OUTDIR/sqlmap" 2>&1 \
                    >> "$OUTDIR/sqlmap_dbs.txt" || true
                grep -qi "available databases" "$OUTDIR/sqlmap_dbs.txt" 2>/dev/null && \
                    found CRITICAL "SQLi — database enumeration riuscita: $(grep -oP '\[\*\] \K\S+' "$OUTDIR/sqlmap_dbs.txt" 2>/dev/null | head -5 | tr '\n' ' ' || true)"
            fi
        else
            echo -e "${CYAN}[DRY-RUN]${NC} sqlmap -u $_url --batch --level=2 --risk=2"
        fi
    done
    [[ $_sqli_found -eq 0 && $DRY_RUN -eq 0 ]] && log "Nessuna SQL injection rilevata"

    ok "SQLi audit completato → $OUTDIR"
}

