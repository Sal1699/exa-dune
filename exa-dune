        local nikto_out=0
        while IFS= read -r -d '' f; do
            local module; module=$(basename "$(dirname "$f")")
            while IFS= read -r line; do
                [[ "$line" =~ (OSVDB|CVE|\+\ ) ]] || continue
                printf "  [%-10s] %s\n" "$module" "$line"
                nikto_out=1
            done < "$f"
        done < <(find "$outdir" -name "nikto.txt" -print0 2>/dev/null)
        [[ $nikto_out -eq 0 ]] && echo "  (nessun finding nikto)"

        # ── GOBUSTER ─────────────────────────────────────────
        _section "GOBUSTER"
        local gob_out=0
        while IFS= read -r -d '' f; do
            local module; module=$(basename "$(dirname "$f")")
            local count=0
            while IFS= read -r line; do
                [[ -z "$line" || "$line" == "="* ]] && continue
                ((count++)) || true; [[ $count -gt 20 ]] && break
                printf "  [%-10s] %s\n" "$module" "$line"
                gob_out=1
            done < "$f"
        done < <(find "$outdir" -name "gobuster.txt" -print0 2>/dev/null)
        [[ $gob_out -eq 0 ]] && echo "  (nessun path trovato)"

