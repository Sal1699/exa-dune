    [[ -z "$target" ]] && { err "TARGET mancante"; usage_ftp; exit 1; }
    validate_target "$target"
    setup_outdir "$target" "ftp"
    log "Target: $target | Output: $OUTDIR"

    section "Nmap FTP NSE Scripts"
    run_cmd "nmap_ftp" \
        "nmap -p 21,2121 \
         --script ftp-anon,ftp-bounce,ftp-syst,ftp-proftpd-backdoor,ftp-vsftpd-backdoor \
         -oN "$OUTDIR"/nmap_ftp.txt $target 2>&1"
    if [[ $DRY_RUN -eq 0 ]] && grep -q "Anonymous FTP login allowed" "$OUTDIR/nmap_ftp.txt" 2>/dev/null; then
        found HIGH "FTP:21 — accesso anonimo consentito"
    fi

    section "Banner Grab + Accesso Anonimo"
    if [[ $DRY_RUN -eq 0 ]]; then
        for p in 21 2121; do
            check_port "$target" "$p" || continue
            local banner; banner=$(nc -w 3 "$target" "$p" </dev/null 2>&1 | head -3)
            [[ -n "$banner" ]] && echo "FTP:${p} | $banner" | tee -a "$OUTDIR/ftp_banner.txt"
            local anon
            anon=$(curl -s --max-time 10 "ftp://${target}:${p}/" \
                   --user "anonymous:pentest@scan.local" 2>&1 | head -20)
            if [[ -n "$anon" ]] && ! echo "$anon" | grep -qiE "530|Login.*failed|denied|refused"; then
                found HIGH "FTP:${p} — accesso anonimo riuscito"
                echo "$anon" > "$OUTDIR/ftp_anon_${p}.txt"
            fi
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} FTP banner + anon access test su $target:21,2121"
    fi

    section "FTP Write Permission Test (anonimo)"
    if [[ $DRY_RUN -eq 0 ]]; then
        for p in 21 2121; do
            check_port "$target" "$p" || continue
            # Prova STOR come anonimo
            local stor_resp
            stor_resp=$(curl -s --max-time 10 \
                "ftp://${target}:${p}/.exa_write_test" \
                --user "anonymous:pentest@test.local" \
                --upload-file /dev/null 2>&1 || true)
            if echo "$stor_resp" | grep -qiE "226|Transfer complete|200"; then
                found CRITICAL "FTP:${p} — SCRITTURA ANONIMA: upload riuscito"
                curl -s --max-time 5 --user "anonymous:pentest@test.local" \
                    "ftp://${target}:${p}/" --quote "DELE .exa_write_test" &>/dev/null || true
            fi
        done
    fi

    section "FTP Directory Traversal"
    if [[ $DRY_RUN -eq 0 ]]; then
        for p in 21 2121; do
            check_port "$target" "$p" || continue
            for traverse in "../etc/passwd" "../../etc/passwd" "/etc/passwd" \
                            "../etc/shadow" "/proc/version"; do
                local trav_resp
                trav_resp=$(curl -s --max-time 8 \
                    "ftp://${target}:${p}/${traverse}" \
                    --user "anonymous:pentest@test.local" 2>/dev/null | head -3 || true)
                if echo "$trav_resp" | grep -qE "root:|bin:|daemon:|Linux version"; then
                    found CRITICAL "FTP:${p} — directory traversal: ${traverse} esposto"
                    echo "FTP traversal: ftp://${target}:${p}/${traverse}" >> "$OUTDIR/ftp_traversal.txt"
                fi
            done
        done
    else
        echo -e "${CYAN}[DRY-RUN]${NC} FTP directory traversal probe su $target"
    fi

    section "FTP Bounce Scan"
    if [[ $DRY_RUN -eq 0 ]]; then
        run_cmd "nmap_ftp_bounce" \
            "nmap -p 80,443,8080,8443,22 -b anonymous:pentest@${target}:${port} \
             $target 2>&1 | tee \"$OUTDIR\"/ftp_bounce.txt"
        if grep -q "open" "$OUTDIR/ftp_bounce.txt" 2>/dev/null; then
            found HIGH "FTP:$port — FTP bounce scan funziona (FTP server usabile come proxy di scansione)"
        fi
    else
        echo -e "${CYAN}[DRY-RUN]${NC} FTP bounce scan via $target:$port"
    fi

    if [[ $do_brute -eq 1 ]]; then
        section "FTP Brute Force (hydra)"
        if require_tool hydra; then
            local ul; ul=$(_wl_users); local pl; pl=$(_wl_pass)
            run_cmd "hydra_ftp" \
                "hydra -L $ul -P $pl -s $port -t $threads -f \
                 -o \"$OUTDIR\"/hydra_ftp.txt $target ftp 2>&1"
            if [[ $DRY_RUN -eq 0 && -f "$OUTDIR/hydra_ftp.txt" ]]; then
                grep -i "login:" "$OUTDIR/hydra_ftp.txt" 2>/dev/null \
                    | while IFS= read -r line; do found HIGH "FTP:${port} — $line"; done || true
            fi
        fi
    fi

    ok "FTP audit completato → $OUTDIR"
}

