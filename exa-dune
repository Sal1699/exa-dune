#  MODULO: log4shell — CVE-2021-44228 Detection
# ============================================================
usage_log4shell() {
    echo "Uso: exa-dune log4shell TARGET [OPTIONS]"
    echo ""
    echo "  Rileva CVE-2021-44228 (Log4Shell) su target HTTP/HTTPS."
