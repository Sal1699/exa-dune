# ============================================================
usage_wsd() {
    echo "Uso: exa-dune wsd <TARGET> [OPTIONS]"
    echo ""
    echo "  WS-Discovery — rileva dispositivi su rete locale (telecamere ONVIF,"
    echo "  stampanti, NAS, smart TV) tramite multicast WSD (porta UDP 3702)."
    echo ""
    echo "Opzioni:"
    echo "  --port PORT      Porta WSD (default: 3702)"
    echo "  --timeout N      Timeout ascolto multicast in secondi (default: 5)"
    echo "  --output DIR"
    echo "  --dry-run"
}

cmd_wsd() {
    local target="" port=3702 wsd_timeout=5
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)      port="$2";         shift 2 ;;
            --timeout)   wsd_timeout="$2";  shift 2 ;;
            --output)    OUTDIR_BASE="$2";  shift 2 ;;
            --stealth)   STEALTH=1;         shift ;;
            --dry-run)   DRY_RUN=1;         shift ;;
            --help|-h)   usage_wsd; exit 0 ;;
            -*)          err "Opzione sconosciuta: $1"; usage_wsd; exit 1 ;;
            *)           target="$1"; shift ;;
        esac
    done
    [[ -z "$target" ]] && { err "TARGET mancante"; usage_wsd; exit 1; }
    check_root
    setup_outdir "$target" "wsd"
    log "Target: $target | Output: $OUTDIR"

    # ── WS-Discovery via nmap ────────────────────────────────
    section "WS-Discovery (nmap broadcast)"
    local wsd_nmap="$OUTDIR/wsd_nmap.txt"
    run_cmd "nmap_wsd" "nmap -sU -p $port --script broadcast-wsd-discover $NMAP_TIMING $target 2>/dev/null | tee $wsd_nmap"
    if [[ -s "$wsd_nmap" ]]; then
        while IFS= read -r line; do
            echo "$line" | grep -qE "Types:|Address:|XAddrs:" || continue
            found "MEDIUM" "WSD" "WS-Discovery: $line"
        done < "$wsd_nmap"
        ok "nmap WSD completato"
    fi

    # ── WS-Discovery via Python3 multicast ───────────────────
    section "WS-Discovery UDP Multicast (239.255.255.250:3702)"
    local wsd_out="$OUTDIR/wsd_multicast.txt"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} WS-Discovery multicast probe su $target:$port"
    else
        python3 - <<PYEOF > "$wsd_out" 2>&1 || true
import socket, uuid, time, sys

WSD_MCAST = "239.255.255.250"
WSD_PORT  = $port
PROBE_MSG = '''<?xml version="1.0" encoding="utf-8"?>
<soap:Envelope xmlns:soap="http://www.w3.org/2003/05/soap-envelope"
               xmlns:wsa="http://schemas.xmlsoap.org/ws/2004/08/addressing"
               xmlns:wsd="http://schemas.xmlsoap.org/ws/2005/04/discovery">
  <soap:Header>
    <wsa:To>urn:schemas-xmlsoap-org:ws:2005:04:discovery</wsa:To>
    <wsa:Action>http://schemas.xmlsoap.org/ws/2005/04/discovery/Probe</wsa:Action>
    <wsa:MessageID>urn:uuid:__UUID__</wsa:MessageID>
  </soap:Header>
  <soap:Body>
    <wsd:Probe>
      <wsd:Types>wsdp:Device</wsd:Types>
    </wsd:Probe>
  </soap:Body>
</soap:Envelope>'''

msg = PROBE_MSG.replace("__UUID__", str(uuid.uuid4())).encode()
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
    s.setsockopt(socket.IPPROTO_IP, socket.IP_MULTICAST_TTL, 4)
    s.settimeout($wsd_timeout)
    # Probe su target specifico e multicast
    for dest in ["$target", WSD_MCAST]:
        try: s.sendto(msg, (dest, WSD_PORT))
        except: pass
    print(f"[WSD] Probe inviato a {WSD_MCAST}:{WSD_PORT} e $target:{WSD_PORT}")
    print(f"[WSD] Ascolto risposte per {$wsd_timeout}s...")
    deadline = time.time() + $wsd_timeout
    while time.time() < deadline:
        try:
            data, addr = s.recvfrom(65535)
            print(f"[WSD] Risposta da {addr[0]}:{addr[1]}")
            print(data.decode(errors='replace'))
            print("---")
        except socket.timeout:
            break
        except: break
    s.close()
except Exception as e:
    print(f"[WSD] Errore: {e}", file=sys.stderr)
PYEOF
        if [[ -s "$wsd_out" ]]; then
            # Estrai Types, XAddrs dai ProbeMatches
            local found_wsd=0
            while IFS= read -r line; do
                if echo "$line" | grep -qE "Risposta da|Types|XAddrs|Scopes"; then
                    echo "$line" | grep -q "Risposta da" && {
                        local dev_ip; dev_ip=$(echo "$line" | grep -oP '[\d.]+(?=:)')
                        found "MEDIUM" "WSD" "Dispositivo WSD rilevato: $dev_ip"
                        found_wsd=1
                    }
                fi
            done < "$wsd_out"
            [[ $found_wsd -eq 0 ]] && log "Nessun dispositivo WSD risposto"
        fi
    fi

    # ── SSDP (UPnP discovery su 1900) ────────────────────────
    section "SSDP M-SEARCH (1900/UDP)"
    local ssdp_out="$OUTDIR/ssdp_discover.txt"
    if [[ $DRY_RUN -eq 1 ]]; then
        echo -e "${CYAN}[DRY-RUN]${NC} SSDP M-SEARCH su $target"
    else
        python3 - <<PYEOF > "$ssdp_out" 2>&1 || true
import socket, time

SSDP_MCAST = "239.255.255.250"
SSDP_PORT  = 1900
MSEARCH = (
    "M-SEARCH * HTTP/1.1\r\n"
    "HOST: 239.255.255.250:1900\r\n"
    "MAN: \"ssdp:discover\"\r\n"
    "MX: 3\r\n"
    "ST: ssdp:all\r\n\r\n"
)
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.settimeout(5)
    s.sendto(MSEARCH.encode(), (SSDP_MCAST, SSDP_PORT))
    s.sendto(MSEARCH.encode(), ("$target", SSDP_PORT))
    print(f"[SSDP] M-SEARCH inviato")
    deadline = time.time() + 5
    seen = set()
    while time.time() < deadline:
        try:
            data, addr = s.recvfrom(65535)
            if addr[0] not in seen:
                seen.add(addr[0])
                print(f"[SSDP] {addr[0]}: {data.decode(errors='replace')[:200]}")
        except socket.timeout:
            break
        except: break
    s.close()
except Exception as e:
    print(f"[SSDP] Errore: {e}")
PYEOF
        if [[ -s "$ssdp_out" ]]; then
            while IFS= read -r line; do
                echo "$line" | grep -q "^\[SSDP\].*\." && {
                    local ssdp_ip; ssdp_ip=$(echo "$line" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+' | head -1)
                    [[ -n "$ssdp_ip" ]] && found "LOW" "SSDP" "Dispositivo SSDP: $ssdp_ip → $line"
                }
            done < "$ssdp_out"
        fi
    fi

    ok "WS-Discovery/SSDP audit completato → $OUTDIR"
}

